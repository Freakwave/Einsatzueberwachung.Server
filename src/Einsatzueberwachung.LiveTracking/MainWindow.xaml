<Window x:Class="Einsatzueberwachung.LiveTracking.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Einsatzueberwachung.LiveTracking"
        mc:Ignorable="d"
        Title="Einsatzüberwachung – GPS Live Tracking" Height="700" Width="900"
        Closing="Window_Closing">
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>
    <DockPanel>
        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Margin="0,0,5,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGpsConnected}" Value="True">
                                        <Setter Property="Fill" Value="LimeGreen"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="GPS" Margin="0,0,15,0"/>
                    <Ellipse Width="10" Height="10" Margin="0,0,5,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsServerConnected}" Value="True">
                                        <Setter Property="Fill" Value="LimeGreen"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="Server" Margin="0,0,15,0"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Margin="5,0"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Margin="5,0">
                    <Run Text="Gesendet: "/>
                    <Run Text="{Binding TotalLocationsSent, Mode=OneWay}"/>
                    <Run Text=" | Fehler: "/>
                    <Run Text="{Binding TotalLocationsFailed, Mode=OneWay}"/>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!-- Main Content -->
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <!-- Connection Panel -->
            <GroupBox Grid.Row="0" Header="Server-Verbindung" Margin="0,0,0,10" Padding="10">
                <StackPanel>
                    <TextBlock Text="Einsatzüberwachung Server" FontWeight="Bold" Margin="0,0,0,5"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="{Binding ServerConnectButtonText}"
                                Command="{Binding ConnectServerCommand}"
                                Padding="15,5" Margin="5,0,0,0"/>
                        <TextBox Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalContentAlignment="Center" Padding="5,3"/>
                    </DockPanel>
                </StackPanel>
            </GroupBox>

            <!-- Main Device Info -->
            <GroupBox Grid.Row="1" Header="Hauptgerät (GPS)" Margin="0,0,0,10" Padding="10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Position: " FontWeight="Bold"/>
                        <TextBlock Text="{Binding MainDeviceCoords}" Margin="0,0,20,0"/>
                        <TextBlock Text="Lat,Lon (dezimal): " FontWeight="Bold"/>
                        <TextBlock Text="{Binding MainDeviceDecimalLonLat}" Margin="0,0,20,0"/>
                        <TextBlock Text="UTM: " FontWeight="Bold"/>
                        <TextBlock Text="{Binding CurrentUtmString}" Margin="0,0,20,0"/>
                        <TextBlock Text="Fix: " FontWeight="Bold"/>
                        <TextBlock Text="{Binding CurrentPvtData.FixType, FallbackValue='--'}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="{Binding SimulationButtonText}"
                                Command="{Binding ToggleSimulationCommand}"
                                Padding="15,4" Margin="0,0,10,0"/>
                        <TextBlock VerticalAlignment="Center" Foreground="Gray"
                                   FontStyle="Italic"
                                   Text="Simuliert 3 Hundehalsbänder um Stadtpark Gelsenkirchen"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Dog Collar List -->
            <GroupBox Grid.Row="2" Header="Erkannte Hundehalsbänder" Margin="0,0,0,10" Padding="5">
                <DataGrid ItemsSource="{Binding DogTracks}" AutoGenerateColumns="False" 
                          IsReadOnly="True" HeadersVisibility="Column"
                          CanUserSortColumns="True" GridLinesVisibility="Horizontal"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding DogName}" Width="120"/>
                        <DataGridTextColumn Header="ID" Binding="{Binding CollarId}" Width="50"/>
                        <DataGridTextColumn Header="Lat,Lon (dezimal)" Binding="{Binding DecimalLonLat}" Width="170"/>
                        <DataGridTextColumn Header="Position (UTM)" Binding="{Binding UtmString}" Width="180"/>
                        <DataGridTextColumn Header="Höhe" Binding="{Binding Altitude, StringFormat={}{0:F0}m}" Width="60"/>
                        <DataGridTextColumn Header="Batt" Binding="{Binding BatteryLevel}" Width="40"/>
                        <DataGridTextColumn Header="GPS" Binding="{Binding GpsStrength}" Width="40"/>
                        <DataGridTextColumn Header="Funk" Binding="{Binding CommStrength}" Width="40"/>
                        <DataGridTextColumn Header="Gesendet" Binding="{Binding TotalPointsSent}" Width="70"/>
                        <DataGridTextColumn Header="Letztes Update" Binding="{Binding LastUpdate, StringFormat={}{0:HH:mm:ss}}" Width="100"/>
                        <DataGridTemplateColumn Header="Status" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Ellipse Width="12" Height="12" HorizontalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="Orange"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LastSendSuccess}" Value="True">
                                                        <Setter Property="Fill" Value="LimeGreen"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding LastSendSuccess}" Value="False">
                                                        <Setter Property="Fill" Value="Red"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch" 
                          VerticalAlignment="Center" Background="Transparent"/>

            <!-- Log -->
            <GroupBox Grid.Row="4" Header="Protokoll" Padding="5">
                <ListBox ItemsSource="{Binding LogMessages}" FontFamily="Consolas" FontSize="11"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
