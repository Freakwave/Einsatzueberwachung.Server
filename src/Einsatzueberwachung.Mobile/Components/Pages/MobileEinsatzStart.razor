@page "/einsatz"
@rendermode InteractiveServer

@inject Einsatzueberwachung.Mobile.Services.MobileApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>Einsatz anlegen</PageTitle>

<section class="mobile-card">
    <h1><i class="bi bi-alarm me-2"></i>Einsatz anlegen</h1>
    <p class="subline">Vereinfachte Mobile-Eingabe fuer einen neuen Einsatz</p>

    <EditForm Model="_einsatz" OnValidSubmit="OnSubmitAsync">
        <DataAnnotationsValidator />

        <div class="mobile-field">
            <label for="einsatztyp">Einsatzart</label>
            <InputSelect id="einsatztyp" class="form-select" @bind-Value="_einsatz.IstEinsatz">
                <option value="true">Einsatz</option>
                <option value="false">Uebung</option>
            </InputSelect>
        </div>

        <div class="mobile-field">
            <label for="einsatzort">Einsatzort</label>
            <InputText id="einsatzort" class="form-control" @bind-Value="_einsatz.Einsatzort" />
        </div>

        <div class="mobile-field">
            <label for="einsatzleiter">Einsatzleiter</label>
            <InputText id="einsatzleiter" class="form-control" @bind-Value="_einsatz.Einsatzleiter" />
        </div>

        <div class="mobile-field">
            <label for="fuehrungsassistent">Fuehrungsassistent</label>
            <InputText id="fuehrungsassistent" class="form-control" @bind-Value="_einsatz.Fuehrungsassistent" />
        </div>

        <div class="mobile-field">
            <label for="alarmzeit">Alarmzeit (HH:mm)</label>
            <input id="alarmzeit" type="time" step="60" class="form-control"
                   value="@_alarmTime"
                   @onchange="e => _alarmTime = e.Value?.ToString() ?? string.Empty" />
        </div>

        <div class="mobile-field">
            <label for="alarmiert">Alarmiert durch (Melder)</label>
            <InputText id="alarmiert" class="form-control" @bind-Value="_einsatz.Alarmiert" placeholder="z.B. Polizei, Leitstelle" />
        </div>

        <div class="mobile-field">
            <label for="bemerkung">Bemerkung</label>
            <InputTextArea id="bemerkung" class="form-control" @bind-Value="_bemerkung" />
        </div>

        <button class="btn btn-primary mobile-btn" type="submit" disabled="@_isSubmitting">
            @(_isSubmitting ? "Wird gestartet..." : "Einsatz starten")
        </button>
    </EditForm>

    @if (!string.IsNullOrWhiteSpace(_status))
    {
        <p class="status-line">@_status</p>
    }
</section>

@code {
    private static readonly string[] AlarmDateFormats =
    {
        "dd.MM.yyyy HH:mm",
        "dd.MM.yyyy HH:mm:ss",
        "yyyy-MM-dd HH:mm",
        "yyyy-MM-ddTHH:mm",
        "yyyy-MM-ddTHH:mm:ss"
    };

    private static readonly string[] AlarmTimeFormats =
    {
        "H:mm",
        "HH:mm",
        "H:mm:ss",
        "HH:mm:ss"
    };

    private readonly Einsatzueberwachung.Domain.Models.EinsatzData _einsatz = new()
    {
        IstEinsatz = true,
        EinsatzDatum = DateTime.Now
    };

    private string _alarmTime = DateTime.Now.ToString("HH:mm");

    private string _bemerkung = string.Empty;
    private string _status = string.Empty;
    private bool _isSubmitting;

    private async Task OnSubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_einsatz.Einsatzort) || string.IsNullOrWhiteSpace(_einsatz.Einsatzleiter))
        {
            _status = "Einsatzort und Einsatzleiter sind erforderlich.";
            return;
        }

        if (!TryPrepareAlarmTime())
        {
            _status = "Alarmzeit ungueltig. Bitte HH:mm oder dd.MM.yyyy HH:mm verwenden.";
            return;
        }

        _isSubmitting = true;
        _status = "Einsatz wird gestartet...";

        var success = await ApiClient.StartEinsatzAsync(_einsatz, _bemerkung);

        _isSubmitting = false;

        if (!success)
        {
            _status = "Fehler beim Starten des Einsatzes.";
            return;
        }

        _status = "Einsatz wurde gestartet.";
        await Task.Delay(600);
        Navigation.NavigateTo("teams", forceLoad: true);
    }

    private bool TryPrepareAlarmTime()
    {
        if (string.IsNullOrWhiteSpace(_alarmTime))
        {
            var now = DateTime.Now;
            _einsatz.AlarmierungsZeit = now;
            return true;
        }

        if (DateTime.TryParseExact(_alarmTime.Trim(), AlarmTimeFormats, System.Globalization.CultureInfo.GetCultureInfo("de-DE"), System.Globalization.DateTimeStyles.None, out var parsed)
            || DateTime.TryParse(_alarmTime.Trim(), System.Globalization.CultureInfo.GetCultureInfo("de-DE"), System.Globalization.DateTimeStyles.None, out parsed))
        {
            var now = DateTime.Now;
            parsed = new DateTime(now.Year, now.Month, now.Day, parsed.Hour, parsed.Minute, 0);
            if (parsed > now.AddMinutes(1))
            {
                parsed = parsed.AddDays(-1);
            }

            _einsatz.AlarmierungsZeit = parsed;
            return true;
        }

        return false;
    }
}
