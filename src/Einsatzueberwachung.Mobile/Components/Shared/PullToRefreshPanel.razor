@using Microsoft.AspNetCore.Components.Web

<div class="ptr-wrapper"
     @ontouchstart="OnTouchStart"
     @ontouchmove="OnTouchMove"
     @ontouchend="OnTouchEnd">
    @if (_pullDistance > 0)
    {
        <div class="ptr-indicator small text-muted mb-2">
            @(_pullDistance >= Threshold ? "Loslassen zum Aktualisieren" : "Nach unten ziehen zum Aktualisieren")
        </div>
    }

    @ChildContent
</div>

@code {
    private const double Threshold = 80;
    private double _startY;
    private double _pullDistance;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public EventCallback OnRefresh { get; set; }

    private void OnTouchStart(TouchEventArgs args)
    {
        if (args.Touches.Length == 0)
        {
            return;
        }

        _startY = args.Touches[0].ClientY;
        _pullDistance = 0;
    }

    private void OnTouchMove(TouchEventArgs args)
    {
        if (args.Touches.Length == 0)
        {
            return;
        }

        var currentY = args.Touches[0].ClientY;
        var delta = currentY - _startY;
        _pullDistance = delta > 0 ? Math.Min(delta, 140) : 0;
    }

    private async Task OnTouchEnd(TouchEventArgs _)
    {
        var shouldRefresh = _pullDistance >= Threshold;
        _pullDistance = 0;

        if (shouldRefresh && OnRefresh.HasDelegate)
        {
            await OnRefresh.InvokeAsync();
        }
    }
}
