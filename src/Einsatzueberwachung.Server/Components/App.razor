<!DOCTYPE html>
<html lang="de" data-bs-theme="light">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <script>
        (function () {
            const storageKey = "einsatz.theme";
            const legacyStorageKey = "theme";
            const browserPrefsKey = "browser-prefs";
            const themeMap = {
                nrw: { primary: "#A72920", secondary: "#404040" },
                ruhr: { primary: "#005D9E", secondary: "#FFED00" }
            };

            const parseDark = (value) => {
                const normalizedValue = (value ?? "").toString().trim().toLowerCase();
                return normalizedValue === "dark"
                    || normalizedValue === "true"
                    || normalizedValue === "1"
                    || normalizedValue === "yes"
                    || normalizedValue === "on";
            };

            const normalizePreset = (value) => {
                const normalizedValue = (value ?? "").toString().trim().toLowerCase();
                return normalizedValue === "ruhr" ? "ruhr" : "nrw";
            };

            const normalizeIntensity = (value) => {
                const normalizedValue = (value ?? "").toString().trim().toLowerCase();
                if (normalizedValue === "dezent") {
                    return "dezent";
                }

                if (normalizedValue === "lebhaft") {
                    return "lebhaft";
                }

                return "ausgewogen";
            };

            const setAttributeOnRoots = (name, value) => {
                document.documentElement.setAttribute(name, value);
                if (document.body) {
                    document.body.setAttribute(name, value);
                }
            };

            const setStyleOnRoots = (name, value) => {
                document.documentElement.style.setProperty(name, value);
                if (document.body) {
                    document.body.style.setProperty(name, value);
                }
            };

            let browserState = null;
            const rawPrefs = localStorage.getItem(browserPrefsKey);
            if (rawPrefs) {
                try {
                    const parsed = JSON.parse(rawPrefs);
                    browserState = {
                        isDark: Boolean(parsed?.isDarkMode ?? parsed?.IsDarkMode),
                        preset: normalizePreset(parsed?.themePreset ?? parsed?.ThemePreset),
                        intensity: normalizeIntensity(parsed?.visualIntensity ?? parsed?.VisualIntensity)
                    };
                } catch {
                    browserState = null;
                }
            }

            const storedValue = localStorage.getItem(storageKey) ?? localStorage.getItem(legacyStorageKey);
            const isDark = browserState ? browserState.isDark : parseDark(storedValue);
            const preset = browserState ? browserState.preset : "nrw";
            const intensity = browserState ? browserState.intensity : "ausgewogen";
            const normalized = isDark ? "dark" : "light";
            const palette = themeMap[preset] ?? themeMap.nrw;

            setAttributeOnRoots("data-bs-theme", normalized);
            setAttributeOnRoots("data-theme-preset", preset);
            setAttributeOnRoots("data-intensity", intensity);

            setStyleOnRoots("--theme-primary", palette.primary);
            setStyleOnRoots("--theme-secondary", palette.secondary);
            setStyleOnRoots("--primary-color", palette.primary);
            setStyleOnRoots("--secondary-color", palette.secondary);

            if (storedValue === null) {
                localStorage.setItem(storageKey, normalized);
            }
        })();
    </script>
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
