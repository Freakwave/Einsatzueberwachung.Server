@using System.Text.Json
@using Einsatzueberwachung.Domain.Interfaces
@using Einsatzueberwachung.Domain.Models
@inject ISettingsService SettingsService

<!DOCTYPE html>
<html lang="de" data-bs-theme="light">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <script>
        (function () {
            const storageKey = "einsatz.theme";
            const legacyStorageKey = "theme";
            const serverThemeMode = @((MarkupString)_serverThemeModeJson);
            const serverThemeDark = @(_serverThemeDark ? "true" : "false");
            const serverThemePreset = @((MarkupString)_serverThemePresetJson);
            const serverVisualIntensity = @((MarkupString)_serverVisualIntensityJson);
            const serverCustomThemes = @((MarkupString)_serverCustomThemesJson);
            window.__einsatzServerCustomThemes = Array.isArray(serverCustomThemes) ? serverCustomThemes : [];
            const themeMap = {
                nrw: { primary: "#A72920", secondary: "#404040" },
                ruhr: { primary: "#005D9E", secondary: "#FFED00" }
            };

            const normalizePreset = (value) => {
                const normalizedValue = (value ?? "").toString().trim().toLowerCase();
                if (!normalizedValue) {
                    return "nrw";
                }

                if (normalizedValue === "ruhr") {
                    return "ruhr";
                }

                if (normalizedValue === "nrw") {
                    return "nrw";
                }

                return (value ?? "").toString().trim();
            };

            const normalizeIntensity = (value) => {
                const normalizedValue = (value ?? "").toString().trim().toLowerCase();
                if (normalizedValue === "dezent") {
                    return "dezent";
                }

                if (normalizedValue === "lebhaft") {
                    return "lebhaft";
                }

                return "ausgewogen";
            };

            const setAttributeOnRoots = (name, value) => {
                document.documentElement.setAttribute(name, value);
                if (document.body) {
                    document.body.setAttribute(name, value);
                }
            };

            const setStyleOnRoots = (name, value) => {
                document.documentElement.style.setProperty(name, value);
                if (document.body) {
                    document.body.style.setProperty(name, value);
                }
            };

            const storedValue = localStorage.getItem(storageKey) ?? localStorage.getItem(legacyStorageKey);
            const isDark = serverThemeDark;
            const preset = normalizePreset(serverThemePreset);
            const intensity = normalizeIntensity(serverVisualIntensity);
            const customTheme = Array.isArray(serverCustomThemes)
                ? serverCustomThemes.find(t => t && ((t.id ?? t.Id) === preset))
                : null;
            const normalized = isDark ? "dark" : "light";
            const palette = customTheme
                ? {
                    primary: customTheme.primaryColor ?? customTheme.PrimaryColor,
                    secondary: customTheme.secondaryColor ?? customTheme.SecondaryColor
                }
                : (themeMap[preset] ?? themeMap.nrw);

            setAttributeOnRoots("data-bs-theme", normalized);
            setAttributeOnRoots("data-theme-preset", preset);
            setAttributeOnRoots("data-intensity", intensity);
            setAttributeOnRoots("data-theme-mode", serverThemeMode);

            setStyleOnRoots("--theme-primary", palette.primary);
            setStyleOnRoots("--theme-secondary", palette.secondary);
            setStyleOnRoots("--primary-color", palette.primary);
            setStyleOnRoots("--secondary-color", palette.secondary);

            localStorage.setItem(storageKey, normalized);
        })();
    </script>
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    @* JetBrains Mono — Funktisch-Typo für die EL-Seite (Daten, Labels, Funkstammbuch) *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["Einsatzueberwachung.Server.styles.css"]" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.css" />
    <link rel="stylesheet" href="@Assets["leaflet-custom.css"]" />
    <link rel="stylesheet" href="@Assets["print-map.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body>
    <CascadingAuthenticationState>
        <Routes />
    </CascadingAuthenticationState>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/proj4js/2.9.2/proj4.js"></script>
    <script src="js/leaflet-grid.js"></script>
    <script src="js/leaflet-grid-control.js"></script>
    <script src="leaflet-interop.js"></script>
    <script src="_framework/blazor.web.js"></script>
    <script src="js/einsatz-map.js"></script>
    <script src="js/keyboard-shortcuts.js"></script>
    <script src="js/clock.js"></script>
    <script src="js/layout-tools.js"></script>
    <script src="js/theme-sync.js"></script>
    <script src="js/collar-tracking.js"></script>
    <script src="js/phone-tracking.js"></script>
    <script src="js/team-mobile-map.js"></script>
    <script src="js/mention-textarea.js"></script>
    <script src="js/drone-stream.js"></script>
    <script src="js/truemmer-map.js"></script>
    <script src="js/hilfe-drawer.js"></script>
</body>

</html>

@code {
    private string _serverThemeModeJson = "\"Manual\"";
    private bool _serverThemeDark;
    private string _serverThemePresetJson = "\"nrw\"";
    private string _serverVisualIntensityJson = "\"ausgewogen\"";
    private string _serverCustomThemesJson = "[]";

    protected override async Task OnInitializedAsync()
    {
        var app = await SettingsService.GetAppSettingsAsync();
        _serverThemeModeJson = JsonSerializer.Serialize(string.IsNullOrWhiteSpace(app.ThemeMode) ? "Manual" : app.ThemeMode);
        _serverThemeDark = app.IsDarkMode;
        _serverThemePresetJson = JsonSerializer.Serialize(NormalizeThemePreset(app.ThemePreset));
        _serverVisualIntensityJson = JsonSerializer.Serialize(NormalizeVisualIntensity(app.VisualIntensity));
        _serverCustomThemesJson = JsonSerializer.Serialize(app.CustomThemes ?? new List<CustomTheme>());
    }

    private static string NormalizeThemePreset(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "nrw";
        }

        if (value.Equals(ThemePresets.Ruhr, StringComparison.OrdinalIgnoreCase))
        {
            return "ruhr";
        }

        if (value.Equals(ThemePresets.Nrw, StringComparison.OrdinalIgnoreCase))
        {
            return "nrw";
        }

        return value.Trim();
    }

    private static string NormalizeVisualIntensity(string? value)
    {
        if (string.Equals(value, VisualIntensityLevels.Dezent, StringComparison.OrdinalIgnoreCase))
        {
            return "dezent";
        }

        if (string.Equals(value, VisualIntensityLevels.Lebhaft, StringComparison.OrdinalIgnoreCase))
        {
            return "lebhaft";
        }

        return "ausgewogen";
    }
}
