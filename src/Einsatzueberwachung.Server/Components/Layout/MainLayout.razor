@inherits LayoutComponentBase
@using Einsatzueberwachung.Domain.Models
@using Einsatzueberwachung.Domain.Models.Enums

<div class="page @(_sidebarCollapsed ? "sidebar-collapsed" : string.Empty)">
    <div class="sidebar">
        <NavMenu IsCollapsed="_sidebarCollapsed" OnToggleSidebar="ToggleSidebarAsync" />
    </div>

    <main>
        <div class="mission-topbar @(HasActiveEinsatz ? "mission-active" : "")">
            <div class="mission-status-strip" aria-live="polite">
                @if (HasActiveEinsatz)
                {
                    <span class="badge text-bg-success">Laufend: @RunningTeamsCount</span>
                    @if (PausingTeamsCount > 0)
                    {
                        <span class="badge text-bg-warning">In Pause: @PausingTeamsCount</span>
                    }
                    <span class="badge text-bg-secondary">Bereit: @ReadyTeamsCount</span>

                    <div class="monitor-szenario-wrap">
                        <button class="badge monitor-szenario-btn"
                                type="button"
                                style="--monitor-szenario-color:@EinsatzService.CurrentEinsatz.Szenario.GetColorHex();"
                                title="Szenario wechseln (auf Anweisung der EL)"
                                @onclick="() => _szenarioMenuOpen = !_szenarioMenuOpen">
                            <i class="bi bi-diagram-3 me-1"></i>@EinsatzService.CurrentEinsatz.Szenario.GetDisplayName()
                            <i class="bi bi-caret-down-fill ms-1"></i>
                        </button>

                        @if (_szenarioMenuOpen)
                        {
                            <button type="button"
                                    class="monitor-szenario-backdrop"
                                    @onclick="() => _szenarioMenuOpen = false"
                                    aria-label="Szenario-Menü schließen"></button>
                            <ul class="monitor-szenario-menu">
                                @foreach (var sz in new[] { EinsatzSzenarioType.Mantrailer, EinsatzSzenarioType.Flaeche, EinsatzSzenarioType.Truemmer, EinsatzSzenarioType.Sonstige })
                                {
                                    <li>
                                        <button class="monitor-szenario-item @(EinsatzService.CurrentEinsatz.Szenario == sz ? "active" : "")"
                                                type="button"
                                                @onclick="() => SetSzenarioAsync(sz)">
                                            <span class="monitor-szenario-dot" style="background:@sz.GetColorHex();"></span>
                                            <span>@sz.GetDisplayName()</span>
                                        </button>
                                    </li>
                                }
                            </ul>
                        }
                    </div>

                    


                    <span class="mission-status-location">@EinsatzService.CurrentEinsatz.Einsatzort</span>
                }
                else
                {
                    <span class="badge text-bg-secondary">Kein aktiver Einsatz</span>
                }
                @if (_lastWarning != null)
                {
                    <a class="badge @LastWarningBadgeClass mission-last-warning text-decoration-none"
                       href="@(_lastWarning.NavigationUrl ?? "#")"
                       title="@_lastWarning.Message">
                        <i class="bi bi-bell-fill me-1"></i>@_lastWarning.Title
                    </a>
                }
            </div>

            <div class="mission-topbar-page-slot @(MissionTopbar.Content is null ? "is-empty" : "")">
                @MissionTopbar.Content
            </div>

            <div class="mission-topbar-clock" aria-live="polite">
                @if (EinsatzService.CurrentEinsatz.AlarmierungsZeit.HasValue)
                    {
                        <span id="live-duration">
                            <i class="bi bi-clock-history"></i>@GetMissionDurationDisplay()
                        </span>
                    }
                <span id="live-time">00:00:00</span>
                <span id="live-date">01.01.2000</span>
            </div>

            <div class="mission-topbar-actions">
                @if (HasActiveEinsatz)
                {
                    <button class="btn btn-sm btn-primary"
                            type="button"
                            title="Einsatz beenden"
                            @onclick="OpenCloseMissionFromTopbar">
                        <i class="bi bi-stop-circle me-1"></i>Beenden
                    </button>
                }

                <button class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
                        type="button"
                        title="@(BrowserPrefs.Preferences.ThemeMode == "Auto" ? "Theme: Automatisch (Systemmodus) — in Einstellungen ändern" : BrowserPrefs.Preferences.ThemeMode == "Scheduled" ? "Theme: Zeitsteuerung aktiv — in Einstellungen ändern" : (_isDarkMode ? "Dark Mode deaktivieren" : "Dark Mode aktivieren"))"
                        disabled="@(BrowserPrefs.Preferences.ThemeMode != "Manual")"
                        @onclick="ToggleThemeAsync">
                    <i class="bi @(_isDarkMode ? "bi-sun" : "bi-moon-stars")"></i>
                    @if (BrowserPrefs.Preferences.ThemeMode != "Manual")
                    {
                        <span class="topbar-theme-mode-label">@(BrowserPrefs.Preferences.ThemeMode == "Auto" ? "Auto" : "Plan")</span>
                    }
                </button>

                <button class="btn btn-sm btn-outline-secondary"
                        type="button"
                        title="Vollbild umschalten"
                        @onclick="ToggleFullscreenAsync">
                    <i class="bi bi-arrows-fullscreen"></i>
                </button>

                <button class="btn btn-sm btn-outline-secondary"
                        type="button"
                        title="Hilfe anzeigen"
                        @onclick="() => _hilfeOpen = true">
                    <i class="bi bi-question-circle"></i>
                </button>
            </div>
        </div>

        <article class="content app-content">
            @Body
        </article>
    </main>
</div>

@if (_showCriticalWarningPopup)
{
    <div class="global-warning-overlay">
        <button type="button"
                class="global-warning-overlay-dismiss"
                @onclick="DismissCriticalWarningAsync"
                aria-label="Warnung schließen"></button>
        <div class="global-warning-popup" @onclick:stopPropagation="true">
            <div class="global-warning-header">
                <h4 class="mb-0"><i class="bi bi-exclamation-triangle-fill me-2"></i>Kritische Teamwarnung</h4>
            </div>
            <div class="global-warning-body">
                <p class="mb-2"><strong>@_criticalWarningTitle</strong></p>
                <p class="mb-2">@_criticalWarningMessage</p>
                @if (_audioEnableHintVisible)
                {
                    <div class="alert alert-warning py-2 mb-0">
                        Audio konnte nicht automatisch gestartet werden. Bitte einmal auf die Seite klicken, dann wird Audio aktiviert.
                    </div>
                }
            </div>
            <div class="global-warning-footer">
                <button class="btn btn-danger" @onclick="DismissCriticalWarningAsync">Warnung quittieren</button>
            </div>
        </div>
    </div>
}

@if (_showExerciseEndedPopup)
{
    <div class="global-warning-overlay">
        <button type="button"
                class="global-warning-overlay-dismiss"
                @onclick="DismissExerciseEndedPopup"
                aria-label="Hinweis schließen"></button>
        <div class="global-warning-popup" @onclick:stopPropagation="true">
            <div class="global-warning-header global-warning-header--success">
                <h4 class="mb-0"><i class="bi bi-flag-fill me-2"></i>Übung beendet</h4>
            </div>
            <div class="global-warning-body">
                <p class="mb-2"><strong>@_exerciseEndedName</strong></p>
                @if (!string.IsNullOrWhiteSpace(_exerciseEndedSummary))
                {
                    <p class="mb-0">@_exerciseEndedSummary</p>
                }
            </div>
            <div class="global-warning-footer">
                <button class="btn btn-success" @onclick="DismissExerciseEndedPopup">OK</button>
            </div>
        </div>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    Es ist ein Fehler aufgetreten.
    <a href="." class="reload">Neu laden</a>
    <span class="dismiss">X</span>
</div>

<WarnToast />

<HilfeDrawer IsOpen="_hilfeOpen" OnClose="() => _hilfeOpen = false" />