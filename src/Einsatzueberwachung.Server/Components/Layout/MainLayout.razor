@inherits LayoutComponentBase
@implements IAsyncDisposable
@inject Einsatzueberwachung.Domain.Interfaces.ISettingsService SettingsService
@inject IJSRuntime JS
@inject NavigationManager Navigation

<div class="page @(_sidebarCollapsed ? "sidebar-collapsed" : string.Empty)">
    <div class="sidebar">
        <NavMenu IsCollapsed="_sidebarCollapsed" OnToggleSidebar="ToggleSidebar" />
    </div>

    <main>
        <div class="mission-topbar">
            <button class="mission-topbar-close"
                    type="button"
                    title="Zur Startseite"
                    @onclick="GoHome">
                <i class="bi bi-x-lg"></i>
            </button>

            <div class="mission-topbar-clock" aria-live="polite">
                <span id="live-time">00:00:00</span>
                <span id="live-date">01.01.2000</span>
            </div>

            <div class="mission-topbar-actions">
                <button class="btn btn-sm btn-outline-secondary"
                        type="button"
                        title="Dark Mode umschalten"
                        @onclick="ToggleThemeAsync">
                    <i class="bi @( _isDarkMode ? "bi-sun" : "bi-moon-stars")"></i>
                </button>

                <button class="btn btn-sm btn-outline-secondary"
                        type="button"
                        title="Vollbild umschalten"
                        @onclick="ToggleFullscreenAsync">
                    <i class="bi bi-arrows-fullscreen"></i>
                </button>
            </div>
        </div>

        <article class="content app-content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Es ist ein Fehler aufgetreten.
    <a href="." class="reload">Neu laden</a>
    <span class="dismiss">X</span>
</div>

@code {
    private bool _isDarkMode;
    private bool _sidebarCollapsed;
    private DotNetObjectReference<MainLayout>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _isDarkMode = await SettingsService.GetIsDarkModeAsync();
        _dotNetRef = DotNetObjectReference.Create(this);

        await JS.InvokeVoidAsync("themeSync.init", _dotNetRef, _isDarkMode);
        await JS.InvokeVoidAsync("initializeClock");
        StateHasChanged();
    }

    private void ToggleSidebar()
    {
        _sidebarCollapsed = !_sidebarCollapsed;
    }

    private void GoHome()
    {
        Navigation.NavigateTo("/");
    }

    private async Task ToggleThemeAsync()
    {
        _isDarkMode = !_isDarkMode;
        await SettingsService.SetIsDarkModeAsync(_isDarkMode);
        await JS.InvokeVoidAsync("themeSync.setTheme", _isDarkMode);
    }

    private async Task ToggleFullscreenAsync()
    {
        await JS.InvokeVoidAsync("layoutTools.toggleFullscreen");
    }

    [JSInvokable]
    public async Task OnThemeChangedFromStorage(bool isDark)
    {
        _isDarkMode = isDark;
        await SettingsService.SetIsDarkModeAsync(isDark);
        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("themeSync.dispose");
        }
        catch
        {
            // Ignore disposal errors during disconnect/shutdown.
        }

        _dotNetRef?.Dispose();
    }
}
