@inject ISettingsService SettingsService

<div class="top-row navbar navbar-dark">
    <div class="container-fluid nav-brand-row">
        <a class="navbar-brand" href="/" title="Startseite">
            @if (!string.IsNullOrWhiteSpace(_staffelLogoUrl))
            {
                <img class="brand-logo" src="@_staffelLogoUrl" alt="Staffel-Logo" />
            }
            else
            {
                <i class="bi bi-radar brand-icon"></i>
            }
            <span class="brand-text">Einsatzüberwachung</span>
        </a>
        <button class="btn-sidebar-toggle"
                type="button"
                title="@(IsCollapsed ? "Navigation ausklappen" : "Navigation einklappen")"
                aria-label="@(IsCollapsed ? "Navigation ausklappen" : "Navigation einklappen")"
                aria-expanded="@(!IsCollapsed)"
                @onclick="() => OnToggleSidebar.InvokeAsync()">
            <i class="bi @(IsCollapsed ? "bi-chevron-right" : "bi-chevron-left") toggle-icon"></i>
        </button>
    </div>
</div>

<div class="nav-scrollable">
    <nav class="nav flex-column nav-wrapper">
        <div class="nav-item px-2">
            <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                <span class="nav-icon"><i class="bi bi-house-door-fill"></i></span>
                <span class="nav-text">Home</span>
            </NavLink>
        </div>

        <div class="nav-section-header">EINSATZ</div>

        <div class="nav-item px-2">
            <NavLink class="nav-link" href="/einsatz-start">
                <span class="nav-icon"><i class="bi bi-alarm"></i></span>
                <span class="nav-text">Neuer Einsatz</span>
            </NavLink>
        </div>
        <div class="nav-item px-2">
            <NavLink class="nav-link" href="/einsatz-monitor">
                <span class="nav-icon"><i class="bi bi-bar-chart-fill"></i></span>
                <span class="nav-text">Monitor</span>
            </NavLink>
        </div>
        <div class="nav-item px-2">
            <NavLink class="nav-link" href="/einsatz-karte">
                <span class="nav-icon"><i class="bi bi-map-fill"></i></span>
                <span class="nav-text">Karte</span>
            </NavLink>
        </div>
        @* Bericht vorübergehend deaktiviert – wird in einer späteren Version fertiggestellt
        <div class="nav-item px-2">
            <NavLink class="nav-link" href="/einsatz-bericht">
                <span class="nav-icon"><i class="bi bi-file-earmark-text-fill"></i></span>
                <span class="nav-text">Bericht</span>
            </NavLink>
        </div>
        *@
        <div class="nav-item px-2">
            <NavLink class="nav-link" href="/einsatz-archiv">
                <span class="nav-icon"><i class="bi bi-archive-fill"></i></span>
                <span class="nav-text">Archiv</span>
            </NavLink>
        </div>
        <div class="nav-item px-2">
            <NavLink class="nav-link" href="/wetter">
                <span class="nav-icon"><i class="bi bi-cloud-sun-fill"></i></span>
                <span class="nav-text">Wetter</span>
            </NavLink>
        </div>

        <div class="nav-section-header">VERWALTUNG</div>

        <div class="nav-item px-2">
            <NavLink class="nav-link" href="/stammdaten">
                <span class="nav-icon"><i class="bi bi-journal-medical"></i></span>
                <span class="nav-text">Stammdaten</span>
            </NavLink>
        </div>
        <div class="nav-item px-2">
            <NavLink class="nav-link" href="/einstellungen">
                <span class="nav-icon"><i class="bi bi-gear-fill"></i></span>
                <span class="nav-text">Einstellungen</span>
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private string _staffelLogoUrl = string.Empty;

    [Parameter]
    public bool IsCollapsed { get; set; }

    [Parameter]
    public EventCallback OnToggleSidebar { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var settings = await SettingsService.GetStaffelSettingsAsync();
        if (string.IsNullOrWhiteSpace(settings.StaffelLogoPfad))
        {
            return;
        }

        _staffelLogoUrl = $"/downloads/staffel-logo?v={DateTimeOffset.UtcNow.ToUnixTimeSeconds()}";
    }
}

