@inherits LayoutComponentBase
<div class="trainer-shell">
    <header class="trainer-header">
        <div>
            <p class="trainer-kicker mb-1">Geschuetzter Bereich</p>
            <h1 class="h3 mb-0">Trainer-Modul</h1>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-warning btn-lg" href="/api/trainer-auth/logout?returnUrl=/einstellungen">
                <i class="bi bi-box-arrow-right me-1"></i>Trainer abmelden
            </a>
        </div>
    </header>

    <main class="trainer-main">
        @Body
    </main>
</div>
