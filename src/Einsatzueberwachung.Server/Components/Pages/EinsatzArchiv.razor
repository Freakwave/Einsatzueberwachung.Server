@page "/einsatz-archiv"
@rendermode InteractiveServer

@inject IArchivService ArchivService
@inject IJSRuntime JSRuntime
@inject ISubgroupMergeService MergeService
@inject NavigationManager Navigation

<PageTitle>Einsatz-Archiv</PageTitle>

<div class="container py-4 archive-page">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4 page-headline-row">
        <div>
            <h1 class="mb-1"><i class="bi bi-archive me-2"></i>Einsatz-Archiv</h1>
            <p class="text-muted mb-0">Vergangene Einsaetze und Uebungen</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="LoadAsync">Neu laden</button>
            <a class="btn btn-outline-success" href="/downloads/einsatz-archiv.json" target="_blank" rel="noopener">Archiv als JSON exportieren</a>
        </div>
    </div>

    <div class="card archive-filter-card mb-3">
        <div class="card-header fw-semibold">
            <i class="bi bi-funnel me-2"></i>Filter
        </div>
        <div class="card-body">
            <div class="row g-2">
                <div class="col-12 col-md-4">
                    <InputText class="form-control" @bind-Value="_search" placeholder="Suche nach Ort, Leiter, Ergebnis" />
                </div>
                <div class="col-6 col-md-3">
                    <InputDate class="form-control" @bind-Value="_fromDate" />
                </div>
                <div class="col-6 col-md-3">
                    <InputDate class="form-control" @bind-Value="_toDate" />
                </div>
                <div class="col-12 col-md-2 d-grid">
                    <button class="btn btn-outline-primary" @onclick="SearchAsync">Filtern</button>
                </div>
            </div>
        </div>
    </div>

    @if (_stats is not null)
    {
        <div class="row g-3 mb-3">
            <div class="col-6 col-md-3">
                <div class="card archive-stat-card"><div class="card-body"><div class="text-muted small">Gesamt</div><div class="archive-stat-value">@_stats.GesamtAnzahl</div></div></div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card archive-stat-card"><div class="card-body"><div class="text-muted small">Einsaetze</div><div class="archive-stat-value">@_stats.AnzahlEinsaetze</div></div></div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card archive-stat-card"><div class="card-body"><div class="text-muted small">Uebungen</div><div class="archive-stat-value">@_stats.AnzahlUebungen</div></div></div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card archive-stat-card"><div class="card-body"><div class="text-muted small">Dauer (avg)</div><div class="archive-stat-value">@_stats.DurchschnittlicheDauer.ToString(@"hh\:mm")</div></div></div>
            </div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_status))
    {
        <div class="alert alert-secondary">@_status</div>
    }

    @if (_loading)
    {
        <p>Lade Archiv...</p>
    }
    else if (_entries.Count == 0)
    {
        <p class="text-muted">Keine archivierten Einsaetze vorhanden.</p>
    }
    else
    {
        <div class="table-responsive archive-table-wrap">
            <table class="table table-striped archive-table">
                <thead>
                    <tr>
                        <th>Datum</th>
                        <th>Typ</th>
                        <th>Ort</th>
                        <th>Einsatzleiter</th>
                        <th>Ergebnis</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _entries)
                    {
                        <tr>
                            <td>@item.EinsatzDatum.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@item.EinsatzTyp</td>
                            <td>@item.Einsatzort</td>
                            <td>@item.Einsatzleiter</td>
                            <td>@item.Ergebnis</td>
                            <td class="d-flex flex-wrap gap-2">
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => ShowDetailsAsync(item.Id)">Details</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => PromptDelete(item)">Loeschen</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (_selected is not null)
        {
            <div class="card mt-3 archive-details-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>Archivdetails: @_selected.EinsatzNummer</strong>
                    <div class="d-flex gap-2 flex-wrap">
                        <button class="btn btn-sm btn-outline-success"
                                @onclick="() => NavigateToMerge(_selected.Id)"
                                title="Teilgruppe in diesen archivierten Einsatz integrieren">
                            <i class="bi bi-diagram-2 me-1"></i>Teilgruppe integrieren
                        </button>
                        <a class="btn btn-sm btn-outline-primary" href="@GetArchivedPdfDownloadUrl(_selected.Id)" target="_blank" rel="noopener">PDF</a>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="CloseDetails">Schliessen</button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row g-2 mb-3">
                        <div class="col-12 col-md-4"><strong>Datum:</strong> @_selected.EinsatzDatum.ToString("dd.MM.yyyy HH:mm")</div>
                        <div class="col-12 col-md-4"><strong>Typ:</strong> @_selected.EinsatzTyp</div>
                        <div class="col-12 col-md-4"><strong>Dauer:</strong> @_selected.DauerFormatiert</div>
                        <div class="col-12 col-md-6"><strong>Ort:</strong> @_selected.Einsatzort</div>
                        <div class="col-12 col-md-6"><strong>Ergebnis:</strong> @_selected.Ergebnis</div>
                        <div class="col-12"><strong>Bemerkungen:</strong> @(!string.IsNullOrWhiteSpace(_selected.Bemerkungen) ? _selected.Bemerkungen : "-")</div>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-6 col-md-3"><strong>Teams:</strong> @_selected.AnzahlTeams</div>
                        <div class="col-6 col-md-3"><strong>Personal:</strong> @_selected.AnzahlPersonal</div>
                        <div class="col-6 col-md-3"><strong>Hunde:</strong> @_selected.AnzahlHunde</div>
                        <div class="col-6 col-md-3"><strong>Drohnen:</strong> @_selected.AnzahlDrohnen</div>
                    </div>

                    @if (_selected.Teams.Count > 0)
                    {
                        <h5>Teams</h5>
                        <ul class="mb-3">
                            @foreach (var team in _selected.Teams)
                            {
                                <li>@team.TeamName (@team.Status)</li>
                            }
                        </ul>
                    }

                    @if (_selected.GlobalNotesEntries.Count > 0)
                    {
                        <h5>Letzte Notizen/Funksprueche</h5>
                        <ul class="mb-0">
                            @foreach (var note in _selected.GlobalNotesEntries.OrderByDescending(n => n.Timestamp).Take(10))
                            {
                                <li>
                                    @note.FormattedTimestamp - @note.Text
                                </li>
                            }
                        </ul>
                    }

                    @if (_selected.SearchAreas.Count > 0)
                    {
                        <h5 class="mt-3">Suchgebiete</h5>
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th></th>
                                        <th>Name</th>
                                        <th>Fläche</th>
                                        <th>Team</th>
                                        <th>Status</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var area in _selected.SearchAreas)
                                    {
                                        <tr>
                                            <td><span style="background-color: @area.Color; width: 12px; height: 12px; border-radius: 3px; display: inline-block;"></span></td>
                                            <td>@area.Name</td>
                                            <td>@area.FormattedArea</td>
                                            <td>@(string.IsNullOrEmpty(area.AssignedTeamName) ? "–" : area.AssignedTeamName)</td>
                                            <td>
                                                @if (area.IsCompleted)
                                                {
                                                    <span class="badge bg-success">Abgeschlossen</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning text-dark">In Bearbeitung</span>
                                                }
                                            </td>
                                            <td>
                                                @if (area.Coordinates?.Count >= 2)
                                                {
                                                    <button class="btn btn-xs btn-outline-success" @onclick="() => DownloadAreaGpxAsync(area)" title="GPX herunterladen">
                                                        <i class="bi bi-download me-1"></i>GPX
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    @if (_selected.TrackSnapshots.Count > 0)
                    {
                        <h5 class="mt-3">GPS-Tracks</h5>
                        <div class="list-group mb-0">
                            @foreach (var snap in _selected.TrackSnapshots)
                            {
                                <button class="list-group-item list-group-item-action d-flex align-items-center gap-2 py-2 px-3"
                                        @onclick="() => _archiveTrackPopup = snap">
                                    <span style="background: @snap.Color; width: 6px; min-height: 34px; border-radius: 3px; flex-shrink: 0;"></span>
                                    <div class="flex-grow-1" style="min-width:0;">
                                        <div class="fw-semibold text-truncate">@snap.TeamName</div>
                                        <div class="small text-muted text-truncate">
                                            @(snap.CollarName ?? snap.CollarId)
                                            @if (!string.IsNullOrEmpty(snap.SearchAreaName))
                                            {
                                                <text> · @snap.SearchAreaName</text>
                                            }
                                            &nbsp;·&nbsp;@snap.FormattedDuration · @snap.FormattedDistance · @snap.Points.Count&thinsp;Pkt.
                                        </div>
                                    </div>
                                    <i class="bi bi-info-circle text-muted small"></i>
                                </button>
                            }
                        </div>
                    }

                    @* Zusammenführungs-Historie *@
                    @if (_selected.MergeHistory?.Any() == true)
                    {
                        <h5 class="mt-3">Zusammenführungs-Historie</h5>
                        <div class="list-group mb-0">
                            @foreach (var merge in _selected.MergeHistory)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center @(merge.IsReverted ? "list-group-item-secondary" : "")">
                                    <div>
                                        <span class="fw-semibold me-2">@merge.SubgroupName</span>
                                        <span class="text-muted small">@merge.FormattedMergedAt</span>
                                        <br />
                                        <small class="text-muted">@merge.Summary</small>
                                        @if (merge.IsReverted)
                                        {
                                            <span class="badge bg-secondary ms-2">Rückgängig gemacht</span>
                                        }
                                    </div>
                                    @if (!merge.IsReverted)
                                    {
                                        <button class="btn btn-outline-danger btn-sm"
                                                @onclick="() => RevertArchivedMergeAsync(_selected.Id, merge.MergeId)"
                                                disabled="@_revertingMergeId.Contains(merge.MergeId)">
                                            @if (_revertingMergeId.Contains(merge.MergeId))
                                            {
                                                <span class="spinner-border spinner-border-sm"></span>
                                            }
                                            else
                                            {
                                                <i class="bi bi-arrow-counterclockwise me-1"></i>
                                                <span>Rückgängig</span>
                                            }
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    }

@* Track-Detail-Popup *@
@if (_archiveTrackPopup != null)
{
    <div class="modal-backdrop show" style="z-index: 2000;" @onclick='() => _archiveTrackPopup = null'></div>
    <div class="modal show d-block" style="z-index: 2001;" tabindex="-1">
        <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <div class="d-flex align-items-center gap-2">
                        <span style="background:@_archiveTrackPopup.Color; width:10px; height:20px; border-radius:3px; display:inline-block; flex-shrink:0;"></span>
                        <h6 class="modal-title mb-0">@_archiveTrackPopup.TeamName</h6>
                    </div>
                    <button type="button" class="btn-close" @onclick='() => _archiveTrackPopup = null'></button>
                </div>
                <div class="modal-body py-2">
                    <table class="table table-sm table-borderless mb-2">
                        <tbody>
                            <tr><td class="text-muted">Team</td><td><strong>@_archiveTrackPopup.TeamName</strong></td></tr>
                            <tr><td class="text-muted">Halsband</td><td>@(_archiveTrackPopup.CollarName ?? _archiveTrackPopup.CollarId)</td></tr>
                            <tr><td class="text-muted">Suchgebiet</td><td>@(string.IsNullOrEmpty(_archiveTrackPopup.SearchAreaName) ? "–" : _archiveTrackPopup.SearchAreaName)</td></tr>
                            <tr><td class="text-muted">Beginn</td><td>@(_archiveTrackPopup.Points.FirstOrDefault()?.Timestamp.ToLocalTime().ToString("HH:mm:ss") ?? "–")</td></tr>
                            <tr><td class="text-muted">Ende</td><td>@(_archiveTrackPopup.Points.LastOrDefault()?.Timestamp.ToLocalTime().ToString("HH:mm:ss") ?? "–")</td></tr>
                            <tr><td class="text-muted">Dauer</td><td>@_archiveTrackPopup.FormattedDuration</td></tr>
                            <tr><td class="text-muted">Strecke</td><td>@_archiveTrackPopup.FormattedDistance</td></tr>
                            <tr><td class="text-muted">Punkte</td><td>@_archiveTrackPopup.Points.Count</td></tr>
                        </tbody>
                    </table>
                    @if (_archiveTrackPopup.Points.Count > 0)
                    {
                        <div style="max-height: 200px; overflow-y: auto; border: 1px solid var(--bs-border-color); border-radius: 4px;">
                            <table class="table table-sm mb-0" style="font-size: 0.72rem;">
                                <thead>
                                    <tr><th>#</th><th>Zeit</th><th>Lat</th><th>Lng</th></tr>
                                </thead>
                                <tbody>
                                    @for (var pi = 0; pi < _archiveTrackPopup.Points.Count; pi++)
                                    {
                                        var pt = _archiveTrackPopup.Points[pi];
                                        <tr>
                                            <td class="text-muted">@(pi + 1)</td>
                                            <td>@pt.Timestamp.ToLocalTime().ToString("HH:mm:ss")</td>
                                            <td class="font-monospace">@pt.Latitude.ToString("F5", System.Globalization.CultureInfo.InvariantCulture)</td>
                                            <td class="font-monospace">@pt.Longitude.ToString("F5", System.Globalization.CultureInfo.InvariantCulture)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
                <div class="modal-footer py-2">
                    <button class="btn btn-sm btn-outline-success" @onclick="DownloadArchiveTrackGpxAsync">
                        <i class="bi bi-download me-1"></i>GPX herunterladen
                    </button>
                    <button type="button" class="btn btn-sm btn-secondary" @onclick='() => _archiveTrackPopup = null'>Schlie&#xDF;en</button>
                </div>
            </div>
        </div>
    </div>
}

    @if (_deleteCandidate is not null)
    {
        <div class="modal-overlay" @onclick="CancelDelete">
            <div class="modal-modern" @onclick:stopPropagation="true">
                <div class="modal-modern-header">
                    <h3 class="mb-0">Archiv-Eintrag loeschen</h3>
                </div>
                <div class="modal-modern-body">
                    <p class="mb-2">
                        Soll der archivierte Einsatz <strong>@_deleteCandidate.EinsatzNummer</strong>
                        vom <strong>@_deleteCandidate.EinsatzDatum.ToString("dd.MM.yyyy HH:mm")</strong> wirklich geloescht werden?
                    </p>
                    <p class="text-muted mb-0">Diese Aktion kann nicht rueckgaengig gemacht werden.</p>
                </div>
                <div class="modal-modern-footer">
                    <button class="btn btn-outline-secondary" @onclick="CancelDelete">Abbrechen</button>
                    <button class="btn btn-danger" @onclick="ConfirmDeleteAsync">Endgueltig loeschen</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private List<ArchivedEinsatz> _entries = new();
    private ArchivStatistics? _stats;
    private string _search = string.Empty;
    private DateTime? _fromDate;
    private DateTime? _toDate;
    private string _status = string.Empty;
    private ArchivedEinsatz? _selected;
    private ArchivedEinsatz? _deleteCandidate;
    private TeamTrackSnapshot? _archiveTrackPopup;
    private readonly HashSet<string> _revertingMergeId = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _entries = await ArchivService.GetAllArchivedAsync();
        _stats = await ArchivService.GetStatisticsAsync();
        _loading = false;
    }

    private async Task SearchAsync()
    {
        _loading = true;
        var criteria = new ArchivSearchCriteria
        {
            Suchtext = string.IsNullOrWhiteSpace(_search) ? null : _search.Trim(),
            VonDatum = _fromDate,
            BisDatum = _toDate
        };

        _entries = await ArchivService.SearchAsync(criteria);
        _loading = false;
    }

    private async Task ShowDetailsAsync(string id)
    {
        _selected = await ArchivService.GetByIdAsync(id);
    }

    private void CloseDetails()
    {
        _selected = null;
    }

    private void PromptDelete(ArchivedEinsatz item)
    {
        _deleteCandidate = item;
        _status = string.Empty;
    }

    private void CancelDelete()
    {
        _deleteCandidate = null;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteCandidate is null)
        {
            return;
        }

        var success = await ArchivService.DeleteAsync(_deleteCandidate.Id);
        if (!success)
        {
            _status = "Der Archiv-Eintrag konnte nicht geloescht werden.";
            _deleteCandidate = null;
            return;
        }

        if (_selected?.Id == _deleteCandidate.Id)
        {
            _selected = null;
        }

        _status = $"Archiv-Eintrag {_deleteCandidate.EinsatzNummer} wurde geloescht.";
        _deleteCandidate = null;
        await LoadAsync();
    }

    private static string GetArchivedPdfDownloadUrl(string id)
    {
        return $"/downloads/einsatz-archiv/{id}.pdf";
    }

    private void NavigateToMerge(string archivedEinsatzId)
    {
        Navigation.NavigateTo($"/teilgruppe-zusammenfuehren/{archivedEinsatzId}");
    }

    private async Task RevertArchivedMergeAsync(string archivedEinsatzId, string mergeId)
    {
        _revertingMergeId.Add(mergeId);
        StateHasChanged();
        try
        {
            await MergeService.RevertMergeAsync(mergeId, archivedEinsatzId);
            // Detailansicht neu laden
            _selected = await ArchivService.GetByIdAsync(archivedEinsatzId);
            _status = "Zusammenführung erfolgreich rückgängig gemacht.";
        }
        catch (Exception ex)
        {
            _status = $"Fehler beim Rückgängigmachen: {ex.Message}";
        }
        finally
        {
            _revertingMergeId.Remove(mergeId);
            StateHasChanged();
        }
    }

    private async Task DownloadArchiveTrackGpxAsync()
    {
        if (_archiveTrackPopup == null || _archiveTrackPopup.Points.Count == 0) return;
        await JSRuntime.InvokeVoidAsync("downloadFile",
            GpxBuilder.TrackSnapshotFileName(_archiveTrackPopup),
            GpxBuilder.BuildTrackSnapshotGpx(_archiveTrackPopup),
            "application/gpx+xml");
    }

    private async Task DownloadAreaGpxAsync(SearchArea area)
    {
        if (area.Coordinates == null || area.Coordinates.Count < 2) return;
        await JSRuntime.InvokeVoidAsync("downloadFile",
            GpxBuilder.SearchAreaFileName(area),
            GpxBuilder.BuildSearchAreaGpx(area),
            "application/gpx+xml");
    }
}
