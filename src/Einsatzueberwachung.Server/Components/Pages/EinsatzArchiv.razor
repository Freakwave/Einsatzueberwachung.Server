@page "/einsatz-archiv"
@rendermode InteractiveServer

@inject IArchivService ArchivService

<PageTitle>Einsatz-Archiv</PageTitle>

<div class="container py-4 archive-page">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4 page-headline-row">
        <div>
            <h1 class="mb-1"><i class="bi bi-archive me-2"></i>Einsatz-Archiv</h1>
            <p class="text-muted mb-0">Vergangene Einsaetze und Uebungen</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="LoadAsync">Neu laden</button>
            <a class="btn btn-outline-success" href="/downloads/einsatz-archiv.json" target="_blank" rel="noopener">Archiv als JSON exportieren</a>
        </div>
    </div>

    <div class="card archive-filter-card mb-3">
        <div class="card-header fw-semibold">
            <i class="bi bi-funnel me-2"></i>Filter
        </div>
        <div class="card-body">
            <div class="row g-2">
                <div class="col-12 col-md-4">
                    <InputText class="form-control" @bind-Value="_search" placeholder="Suche nach Ort, Leiter, Ergebnis" />
                </div>
                <div class="col-6 col-md-3">
                    <InputDate class="form-control" @bind-Value="_fromDate" />
                </div>
                <div class="col-6 col-md-3">
                    <InputDate class="form-control" @bind-Value="_toDate" />
                </div>
                <div class="col-12 col-md-2 d-grid">
                    <button class="btn btn-outline-primary" @onclick="SearchAsync">Filtern</button>
                </div>
            </div>
        </div>
    </div>

    @if (_stats is not null)
    {
        <div class="row g-3 mb-3">
            <div class="col-6 col-md-3">
                <div class="card archive-stat-card"><div class="card-body"><div class="text-muted small">Gesamt</div><div class="archive-stat-value">@_stats.GesamtAnzahl</div></div></div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card archive-stat-card"><div class="card-body"><div class="text-muted small">Einsaetze</div><div class="archive-stat-value">@_stats.AnzahlEinsaetze</div></div></div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card archive-stat-card"><div class="card-body"><div class="text-muted small">Uebungen</div><div class="archive-stat-value">@_stats.AnzahlUebungen</div></div></div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card archive-stat-card"><div class="card-body"><div class="text-muted small">Dauer (avg)</div><div class="archive-stat-value">@_stats.DurchschnittlicheDauer.ToString(@"hh\:mm")</div></div></div>
            </div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_status))
    {
        <div class="alert alert-secondary">@_status</div>
    }

    @if (_loading)
    {
        <p>Lade Archiv...</p>
    }
    else if (_entries.Count == 0)
    {
        <p class="text-muted">Keine archivierten Einsaetze vorhanden.</p>
    }
    else
    {
        <div class="table-responsive archive-table-wrap">
            <table class="table table-striped archive-table">
                <thead>
                    <tr>
                        <th>Datum</th>
                        <th>Typ</th>
                        <th>Ort</th>
                        <th>Einsatzleiter</th>
                        <th>Ergebnis</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _entries)
                    {
                        <tr>
                            <td>@item.EinsatzDatum.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@item.EinsatzTyp</td>
                            <td>@item.Einsatzort</td>
                            <td>@item.Einsatzleiter</td>
                            <td>@item.Ergebnis</td>
                            <td class="d-flex flex-wrap gap-2">
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => ShowDetailsAsync(item.Id)">Details</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => PromptDelete(item)">Loeschen</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (_selected is not null)
        {
            <div class="card mt-3 archive-details-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>Archivdetails: @_selected.EinsatzNummer</strong>
                    <div class="d-flex gap-2">
                        <a class="btn btn-sm btn-outline-primary" href="@GetArchivedPdfDownloadUrl(_selected.Id)" target="_blank" rel="noopener">PDF</a>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="CloseDetails">Schliessen</button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row g-2 mb-3">
                        <div class="col-12 col-md-4"><strong>Datum:</strong> @_selected.EinsatzDatum.ToString("dd.MM.yyyy HH:mm")</div>
                        <div class="col-12 col-md-4"><strong>Typ:</strong> @_selected.EinsatzTyp</div>
                        <div class="col-12 col-md-4"><strong>Dauer:</strong> @_selected.DauerFormatiert</div>
                        <div class="col-12 col-md-6"><strong>Ort:</strong> @_selected.Einsatzort</div>
                        <div class="col-12 col-md-6"><strong>Ergebnis:</strong> @_selected.Ergebnis</div>
                        <div class="col-12"><strong>Bemerkungen:</strong> @(!string.IsNullOrWhiteSpace(_selected.Bemerkungen) ? _selected.Bemerkungen : "-")</div>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-6 col-md-3"><strong>Teams:</strong> @_selected.AnzahlTeams</div>
                        <div class="col-6 col-md-3"><strong>Personal:</strong> @_selected.AnzahlPersonal</div>
                        <div class="col-6 col-md-3"><strong>Hunde:</strong> @_selected.AnzahlHunde</div>
                        <div class="col-6 col-md-3"><strong>Drohnen:</strong> @_selected.AnzahlDrohnen</div>
                    </div>

                    @if (_selected.Teams.Count > 0)
                    {
                        <h5>Teams</h5>
                        <ul class="mb-3">
                            @foreach (var team in _selected.Teams)
                            {
                                <li>@team.TeamName (@team.Status)</li>
                            }
                        </ul>
                    }

                    @if (_selected.GlobalNotesEntries.Count > 0)
                    {
                        <h5>Letzte Notizen/Funksprueche</h5>
                        <ul class="mb-0">
                            @foreach (var note in _selected.GlobalNotesEntries.OrderByDescending(n => n.Timestamp).Take(10))
                            {
                                <li>
                                    @note.FormattedTimestamp - @note.Text
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        }
    }

    @if (_deleteCandidate is not null)
    {
        <div class="modal-overlay" @onclick="CancelDelete">
            <div class="modal-modern" @onclick:stopPropagation="true">
                <div class="modal-modern-header">
                    <h3 class="mb-0">Archiv-Eintrag loeschen</h3>
                </div>
                <div class="modal-modern-body">
                    <p class="mb-2">
                        Soll der archivierte Einsatz <strong>@_deleteCandidate.EinsatzNummer</strong>
                        vom <strong>@_deleteCandidate.EinsatzDatum.ToString("dd.MM.yyyy HH:mm")</strong> wirklich geloescht werden?
                    </p>
                    <p class="text-muted mb-0">Diese Aktion kann nicht rueckgaengig gemacht werden.</p>
                </div>
                <div class="modal-modern-footer">
                    <button class="btn btn-outline-secondary" @onclick="CancelDelete">Abbrechen</button>
                    <button class="btn btn-danger" @onclick="ConfirmDeleteAsync">Endgueltig loeschen</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private List<ArchivedEinsatz> _entries = new();
    private ArchivStatistics? _stats;
    private string _search = string.Empty;
    private DateTime? _fromDate;
    private DateTime? _toDate;
    private string _status = string.Empty;
    private ArchivedEinsatz? _selected;
    private ArchivedEinsatz? _deleteCandidate;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _entries = await ArchivService.GetAllArchivedAsync();
        _stats = await ArchivService.GetStatisticsAsync();
        _loading = false;
    }

    private async Task SearchAsync()
    {
        _loading = true;
        var criteria = new ArchivSearchCriteria
        {
            Suchtext = string.IsNullOrWhiteSpace(_search) ? null : _search.Trim(),
            VonDatum = _fromDate,
            BisDatum = _toDate
        };

        _entries = await ArchivService.SearchAsync(criteria);
        _loading = false;
    }

    private async Task ShowDetailsAsync(string id)
    {
        _selected = await ArchivService.GetByIdAsync(id);
    }

    private void CloseDetails()
    {
        _selected = null;
    }

    private void PromptDelete(ArchivedEinsatz item)
    {
        _deleteCandidate = item;
        _status = string.Empty;
    }

    private void CancelDelete()
    {
        _deleteCandidate = null;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteCandidate is null)
        {
            return;
        }

        var success = await ArchivService.DeleteAsync(_deleteCandidate.Id);
        if (!success)
        {
            _status = "Der Archiv-Eintrag konnte nicht geloescht werden.";
            _deleteCandidate = null;
            return;
        }

        if (_selected?.Id == _deleteCandidate.Id)
        {
            _selected = null;
        }

        _status = $"Archiv-Eintrag {_deleteCandidate.EinsatzNummer} wurde geloescht.";
        _deleteCandidate = null;
        await LoadAsync();
    }

    private static string GetArchivedPdfDownloadUrl(string id)
    {
        return $"/downloads/einsatz-archiv/{id}.pdf";
    }
}
