@page "/einsatz-bericht"
@rendermode InteractiveServer

@inject IEinsatzService EinsatzService
@inject IPdfExportService PdfExportService
@inject IArchivService ArchivService

<PageTitle>Einsatzbericht</PageTitle>

<div class="container py-4 report-page">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <h1 class="mb-1"><i class="bi bi-file-earmark-text me-2"></i>Einsatzbericht</h1>
            <p class="text-muted mb-0">Zusammenfassung und Export</p>
        </div>
        <a class="btn btn-success" href="/downloads/einsatz-bericht.pdf" target="_blank" rel="noopener">
            <i class="bi bi-file-earmark-pdf-fill me-1"></i>Als PDF exportieren
        </a>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-12 col-md-4">
            <div class="card report-stat-card"><div class="card-body"><div class="small text-muted">Einsatzort</div><div class="fw-semibold">@EinsatzService.CurrentEinsatz.Einsatzort</div></div></div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card report-stat-card"><div class="card-body"><div class="small text-muted">Teams</div><div class="fw-semibold">@EinsatzService.Teams.Count</div></div></div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card report-stat-card"><div class="card-body"><div class="small text-muted">Notizen/Funk</div><div class="fw-semibold">@EinsatzService.GlobalNotes.Count</div></div></div>
        </div>
    </div>

    <div class="card mb-3 report-form-card">
        <div class="card-header fw-semibold">
            <i class="bi bi-journal-check me-2"></i>Abschlussdaten
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <label class="form-label">Ergebnis</label>
                    <InputText class="form-control" @bind-Value="_ergebnis" placeholder="z.B. Person gefunden" />
                </div>
                <div class="col-12 col-md-8">
                    <label class="form-label">Bemerkungen</label>
                    <InputTextArea class="form-control" @bind-Value="_bemerkungen" rows="3" />
                </div>
            </div>
            <div class="row g-3 mt-1">
                <div class="col-12">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="includeTracks" @bind="_includeTracks" />
                        <label class="form-check-label" for="includeTracks">
                            <i class="bi bi-geo-alt me-1"></i>GPS-Tracks in PDF einschließen
                            @if (_trackCount > 0)
                            {
                                <span class="badge bg-info ms-1">@_trackCount Track(s)</span>
                            }
                            else
                            {
                                <span class="text-muted ms-1">(keine Tracks vorhanden)</span>
                            }
                        </label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 flex-wrap report-actions">
        <button class="btn btn-primary" @onclick="ExportAsync">PDF erzeugen</button>
        <button class="btn btn-outline-success" @onclick="ArchiveAndEndAsync">Einsatz beenden und archivieren</button>
        <button class="btn btn-outline-warning" @onclick="ArchiveAndResetAsync">Archivieren und neuen Einsatz vorbereiten</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_status))
    {
        <div class="alert alert-secondary mt-3">@_status</div>
    }
</div>

@code {
    private string _status = string.Empty;
    private string _ergebnis = "";
    private string _bemerkungen = "";
    private bool _includeTracks;
    private int _trackCount => EinsatzService.CurrentEinsatz.TrackSnapshots?.Count ?? 0;

    private bool _isExporting;

    private async Task ExportAsync()
    {
        if (_isExporting) return;
        _isExporting = true;
        _status = "PDF wird erstellt...";
        StateHasChanged();

        try
        {
            var result = await PdfExportService.ExportEinsatzToPdfAsync(
                EinsatzService.CurrentEinsatz,
                EinsatzService.Teams,
                EinsatzService.GlobalNotes,
                _includeTracks);

            _status = result.Success
                ? $"PDF gespeichert: {result.FilePath}"
                : $"Export fehlgeschlagen: {result.ErrorMessage}";
        }
        finally
        {
            _isExporting = false;
        }
    }

    private async Task ArchiveAndEndAsync()
    {
        var archived = await ArchivService.ArchiveEinsatzAsync(
            EinsatzService.CurrentEinsatz,
            string.IsNullOrWhiteSpace(_ergebnis) ? "Offen" : _ergebnis.Trim(),
            _bemerkungen.Trim());

        await EinsatzService.EndEinsatzAsync();

        _status = $"Einsatz archiviert: {archived.EinsatzNummer} ({archived.EinsatzDatum:dd.MM.yyyy HH:mm})";
    }

    private async Task ArchiveAndResetAsync()
    {
        var archived = await ArchivService.ArchiveEinsatzAsync(
            EinsatzService.CurrentEinsatz,
            string.IsNullOrWhiteSpace(_ergebnis) ? "Offen" : _ergebnis.Trim(),
            _bemerkungen.Trim());

        await EinsatzService.EndEinsatzAsync();
        EinsatzService.ResetEinsatz();

        _ergebnis = string.Empty;
        _bemerkungen = string.Empty;
        _status = $"Einsatz archiviert und System zurueckgesetzt: {archived.EinsatzNummer}";
    }
}
