@page "/einsatz-bericht"
@rendermode InteractiveServer

@inject IEinsatzService EinsatzService
@inject IPdfExportService PdfExportService
@inject IArchivService ArchivService

<PageTitle>Einsatzbericht</PageTitle>

<div class="container py-4 report-page">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <h1 class="mb-1"><i class="bi bi-file-earmark-text me-2"></i>Einsatzbericht</h1>
            <p class="text-muted mb-0">Zusammenfassung und Export</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-success" href="/downloads/einsatz-bericht.pdf" target="_blank" rel="noopener">
                <i class="bi bi-file-earmark-pdf-fill me-1"></i>Als PDF exportieren
            </a>
            <a class="btn btn-outline-success" href="/downloads/einsatz-bericht.xlsx" target="_blank" rel="noopener">
                <i class="bi bi-file-earmark-excel me-1"></i>Als Excel exportieren
            </a>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-12 col-md-4">
            <div class="card report-stat-card"><div class="card-body"><div class="small text-muted">Einsatzort</div><div class="fw-semibold">@EinsatzService.CurrentEinsatz.Einsatzort</div></div></div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card report-stat-card"><div class="card-body"><div class="small text-muted">Teams</div><div class="fw-semibold">@EinsatzService.Teams.Count</div></div></div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card report-stat-card"><div class="card-body"><div class="small text-muted">Notizen/Funk</div><div class="fw-semibold">@EinsatzService.GlobalNotes.Count</div></div></div>
        </div>
    </div>

    <div class="card mb-3 report-form-card">
        <div class="card-header fw-semibold">
            <i class="bi bi-journal-check me-2"></i>Abschlussdaten
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <label class="form-label">Ergebnis</label>
                    <InputText class="form-control" @bind-Value="_ergebnis" placeholder="z.B. Person gefunden" />
                </div>
                <div class="col-12 col-md-8">
                    <label class="form-label">Bemerkungen</label>
                    <InputTextArea class="form-control" @bind-Value="_bemerkungen" rows="3" />
                </div>
            </div>
            <div class="row g-3 mt-1">
                <div class="col-12">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="includeTracks" @bind="_includeTracks" />
                        <label class="form-check-label" for="includeTracks">
                            <i class="bi bi-geo-alt me-1"></i>GPS-Tracks in PDF einschließen
                            @if (_trackCount > 0)
                            {
                                <span class="badge bg-info ms-1">@_trackCount Track(s)</span>
                            }
                            else
                            {
                                <span class="text-muted ms-1">(keine Tracks vorhanden)</span>
                            }
                        </label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 flex-wrap report-actions">
        <button class="btn btn-primary" @onclick="ExportAsync" disabled="@_isExporting">
            @if (_isExporting)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                <span>PDF wird erstellt...</span>
            }
            else
            {
                <span>PDF erzeugen</span>
            }
        </button>
        <button class="btn btn-outline-success" @onclick="() => ShowConfirm(ConfirmMode.End)">Einsatz beenden und archivieren</button>
        <button class="btn btn-outline-warning" @onclick="() => ShowConfirm(ConfirmMode.Reset)">Archivieren und neuen Einsatz vorbereiten</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_status))
    {
        <div class="alert alert-secondary mt-3">@_status</div>
    }
</div>

@if (_showConfirm)
{
    <div class="modal-backdrop show"></div>
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @if (_confirmMode == ConfirmMode.Reset)
                        {
                            <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>
                        }
                        else
                        {
                            <i class="bi bi-check-circle me-2"></i>
                        }
                        @_confirmTitle
                    </h5>
                    <button type="button" class="btn-close" @onclick="CancelConfirm"></button>
                </div>
                <div class="modal-body">
                    <p>@_confirmMessage</p>
                    @if (_confirmMode == ConfirmMode.Reset)
                    {
                        <div class="alert alert-warning py-2 mb-0">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            Alle aktiven Einsatzdaten (Teams, Notizen, Suchgebiete) werden gelöscht und können nicht wiederhergestellt werden.
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelConfirm">Abbrechen</button>
                    <button class="btn @(_confirmMode == ConfirmMode.Reset ? "btn-warning" : "btn-success")" @onclick="ExecuteConfirmedActionAsync">
                        @(_confirmMode == ConfirmMode.Reset ? "Archivieren & Zurücksetzen" : "Beenden & Archivieren")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private enum ConfirmMode { End, Reset }

    private string _status = string.Empty;
    private string _ergebnis = "";
    private string _bemerkungen = "";
    private bool _includeTracks;
    private int _trackCount => EinsatzService.CurrentEinsatz.TrackSnapshots?.Count ?? 0;

    private bool _isExporting;
    private bool _showConfirm;
    private ConfirmMode _confirmMode;
    private string _confirmTitle = string.Empty;
    private string _confirmMessage = string.Empty;

    private void ShowConfirm(ConfirmMode mode)
    {
        _confirmMode = mode;
        if (mode == ConfirmMode.End)
        {
            _confirmTitle = "Einsatz beenden und archivieren";
            _confirmMessage = $"Soll der Einsatz \"{EinsatzService.CurrentEinsatz.Einsatzort}\" jetzt abgeschlossen und archiviert werden?";
        }
        else
        {
            _confirmTitle = "Archivieren und Einsatz zurücksetzen";
            _confirmMessage = $"Soll der Einsatz \"{EinsatzService.CurrentEinsatz.Einsatzort}\" archiviert und das System für einen neuen Einsatz vorbereitet werden?";
        }
        _showConfirm = true;
    }

    private void CancelConfirm() => _showConfirm = false;

    private async Task ExecuteConfirmedActionAsync()
    {
        _showConfirm = false;
        if (_confirmMode == ConfirmMode.End)
            await ArchiveAndEndAsync();
        else
            await ArchiveAndResetAsync();
    }

    private async Task ExportAsync()
    {
        if (_isExporting) return;
        _isExporting = true;
        _status = "PDF wird erstellt...";
        StateHasChanged();

        try
        {
            var result = await PdfExportService.ExportEinsatzToPdfAsync(
                EinsatzService.CurrentEinsatz,
                EinsatzService.Teams,
                EinsatzService.GlobalNotes,
                _includeTracks);

            _status = result.Success
                ? $"PDF gespeichert: {result.FilePath}"
                : $"Export fehlgeschlagen: {result.ErrorMessage}";
        }
        finally
        {
            _isExporting = false;
        }
    }

    private async Task ArchiveAndEndAsync()
    {
        var archived = await ArchivService.ArchiveEinsatzAsync(
            EinsatzService.CurrentEinsatz,
            string.IsNullOrWhiteSpace(_ergebnis) ? "Offen" : _ergebnis.Trim(),
            _bemerkungen.Trim());

        await EinsatzService.EndEinsatzAsync();

        _status = $"Einsatz archiviert: {archived.EinsatzNummer} ({archived.EinsatzDatum:dd.MM.yyyy HH:mm})";
    }

    private async Task ArchiveAndResetAsync()
    {
        var archived = await ArchivService.ArchiveEinsatzAsync(
            EinsatzService.CurrentEinsatz,
            string.IsNullOrWhiteSpace(_ergebnis) ? "Offen" : _ergebnis.Trim(),
            _bemerkungen.Trim());

        await EinsatzService.EndEinsatzAsync();
        EinsatzService.ResetEinsatz();

        _ergebnis = string.Empty;
        _bemerkungen = string.Empty;
        _status = $"Einsatz archiviert und System zurueckgesetzt: {archived.EinsatzNummer}";
    }
}
