        font-size: 0.9rem;
        background: var(--bs-secondary-bg);
        border: 2px solid var(--bs-border-color);
        color: var(--bs-secondary-color);
        transition: all 0.2s;
    }

    .merge-step-label {
        font-size: 0.7rem;
        color: var(--bs-secondary-color);
        margin-top: 4px;
        text-align: center;
        max-width: 80px;
    }

    .merge-step.active .merge-step-circle {
        background: var(--bs-primary);
        border-color: var(--bs-primary);
        color: white;
    }

    .merge-step.active .merge-step-label {
        color: var(--bs-primary);
        font-weight: 600;
    }

    .merge-step.completed .merge-step-circle {
        background: var(--bs-success);
        border-color: var(--bs-success);
        color: white;
    }

    .merge-step-connector {
        flex: 1;
        height: 2px;
        background: var(--bs-border-color);
        margin: 0 4px;
        align-self: flex-start;
        margin-top: 16px;
    }

    .merge-step-connector.completed {
        background: var(--bs-success);
    }

    .merge-item-card {
        border-left: 4px solid var(--bs-border-color);
        transition: border-color 0.15s;
    }

    .merge-item-card.resolved-link { border-left-color: var(--bs-success); }
    .merge-item-card.resolved-create { border-left-color: var(--bs-primary); }
    .merge-item-card.resolved-skip { border-left-color: var(--bs-secondary); }

    .candidate-option {
        cursor: pointer;
        transition: background 0.1s;
    }

    .candidate-option:hover {
        background: var(--bs-tertiary-bg);
    }

    .candidate-option.selected {
        background: var(--bs-primary-bg-subtle);
        border-color: var(--bs-primary) !important;
    }
</style>
