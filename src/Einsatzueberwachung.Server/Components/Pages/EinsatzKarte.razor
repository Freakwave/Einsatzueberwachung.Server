    private string GetCollarColor(string collarId)
    {
        // Halsband → Team → Suchgebiet → Suchgebiet-Farbe
        var collar = _collars.FirstOrDefault(c => c.Id == collarId);
        if (collar is { IsAssigned: true, AssignedTeamId: not null })
        {
            var area = _searchAreas.FirstOrDefault(a => a.AssignedTeamId == collar.AssignedTeamId);
            if (area != null)
                return area.Color;
        }

        // 10 klar unterscheidbare Farben (maximaler Hue-Abstand, gut sichtbar auf Karten)
        var palette = new[]
        {
            "#E63946", // Rot
            "#0077B6", // Dunkelblau
            "#2DC653", // Grün
            "#FF851B", // Orange
            "#9B5DE5", // Violett
            "#00B4D8", // Cyan
            "#F72585", // Pink
            "#FFD166", // Gelb
            "#06D6A0", // Mint
            "#FF6B35"  // Tiefes Orange
        };

        // Ersten 10: feste Farbe nach Listenposition (deterministisch, keine Kollisionen)
        var idx = _collars.FindIndex(c => c.Id == collarId);
        if (idx >= 0 && idx < palette.Length)
            return palette[idx];

        // Mehr als 10 Halsbänder: Hash-Fallback auf die gleiche Palette
        return palette[Math.Abs(collarId.GetHashCode()) % palette.Length];
    }

