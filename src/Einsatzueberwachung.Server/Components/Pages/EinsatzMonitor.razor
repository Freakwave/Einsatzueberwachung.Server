        if (team.IsPausing)
        {
            classes.Add("team-pausing");
        }

        if (team.IsSecondWarning)
        {
            classes.Add("team-critical");
        }
        else if (team.IsFirstWarning)
        {
            classes.Add("team-warning");
        }

        return string.Join(" ", classes);
