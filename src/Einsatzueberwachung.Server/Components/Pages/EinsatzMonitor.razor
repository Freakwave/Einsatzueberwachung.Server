                        Team <strong>@(collarSelectTeam?.TeamName ?? "?")</strong> hat noch kein Halsband.
                        Bitte jetzt zuweisen oder ohne Halsband starten.
                    </p>
                    <label class="form-label">GPS-Halsband</label>
                    <select class="form-select mb-0" @bind="_collarSelectCollarId">
                        <option value="">-- Kein Halsband (ohne Tracking starten) --</option>
                        @foreach (var collar in CollarTrackingService.GetAvailableCollars().OrderBy(c => c.CollarName))
