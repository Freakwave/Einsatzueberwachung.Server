@page "/einsatz-monitor"
@rendermode InteractiveServer
@implements IDisposable

@using Einsatzueberwachung.Domain.Models
@using Einsatzueberwachung.Domain.Models.Enums

@inject IEinsatzService EinsatzService
@inject IMasterDataService MasterDataService
@inject IWeatherService WeatherService
@inject IArchivService ArchivService
@inject IPdfExportService PdfExportService
@inject ISettingsService SettingsService
@inject ITimeService TimeService
@inject ICollarTrackingService CollarTrackingService
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Einsatz-Monitor</PageTitle>

<div class="monitor-container-classic">
    <div class="page-header">
        <div>
            <h1>Einsatzmonitor - Live</h1>
            <p class="text-muted">
                @EinsatzService.CurrentEinsatz.EinsatzTyp: @EinsatzService.CurrentEinsatz.Einsatzort
                <br />
                Datum: @EinsatzService.CurrentEinsatz.EinsatzDatum.ToString("dd.MM.yyyy HH:mm")
                @if (_einsatzdauerFromHeader.HasValue)
                {
                    <br /><small><i class="bi bi-clock-history me-1"></i>Einsatzzeit: @GetEinsatzdauerDisplay()</small>
                }
            </p>
            <button class="btn btn-outline-secondary btn-sm mt-1" @onclick="OpenEditEinsatzModal">
                <i class="bi bi-pencil me-1"></i>Einsatz bearbeiten
            </button>
        </div>
        <div class="d-flex align-items-start gap-3">
            @if (_monitorWeather is not null)
            {
                <div class="wetter-container" style="min-width: 200px; text-align: right;">
                    <div class="fs-4 fw-bold">@_monitorWeather.Temperatur.ToString("0.0")°C</div>
                    @if (_monitorWeather.HatWarnung)
                    {
                        <div class="small"><span class="badge @_monitorWeather.GetWarnungBadgeClass()">DWD: @_monitorWeather.WarnungsStufe</span></div>
                    }
                    else
                    {
                        <div class="small text-muted">Kein DWD-Warnung</div>
                    }
                    <div class="small text-muted">
                        <i class="bi bi-wind me-1"></i>@_monitorWeather.Windgeschwindigkeit.ToString("0") km/h
                        <i class="bi bi-droplet ms-2 me-1"></i>@_monitorWeather.Niederschlag.ToString("0.0") mm/h
                    </div>
                    <div class="small text-muted">DWD &bull; @_monitorWeatherLoadedAtLocal.ToString("HH:mm") Uhr</div>
                </div>
            }
            else
            {
                <div class="text-muted small" style="min-width: 200px;">
                    <i class="bi bi-cloud me-1"></i>Wetter: ELW-Position auf Karte setzen
                </div>
            }
            <div class="btn-group-vertical">
                <a class="btn btn-info btn-lg" href="/einsatz-karte">
                    <i class="bi bi-map me-1"></i>Karte
                </a>
                <a class="btn btn-primary btn-lg" href="/einsatz-bericht">
                    <i class="bi bi-file-earmark-text me-1"></i>Bericht
                </a>
                <button class="btn btn-danger btn-lg" type="button" @onclick="OpenCloseMissionModal">
                    <i class="bi bi-stop-circle me-1"></i>Beenden
                </button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_closeMissionStatus))
    {
        <div class="alert @(_closeMissionStatusIsError ? "alert-warning" : "alert-success") mb-3">@_closeMissionStatus</div>
    }

    <div class="row">
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <h4 class="mb-0">Teams (@EinsatzService.Teams.Count)</h4>
                        <a class="btn btn-sm btn-outline-secondary"
                           href="/popout-teams"
                           target="_blank"
                           rel="noopener noreferrer"
                           title="In neuem Fenster oeffnen (Multi-Monitor)">
                            <i class="bi bi-box-arrow-up-right"></i>
                        </a>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-sm btn-primary" @onclick="OpenNewTeamModal">
                            <i class="bi bi-plus-circle me-1"></i>Team anlegen
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    @if (EinsatzService.Teams.Count == 0)
                    {
                        <div class="alert alert-info mb-0">
                            Noch keine Teams vorhanden. Klicken Sie auf "Team anlegen".
                        </div>
                    }
                    else
                    {
                        <div class="teams-monitor-list">
                            @foreach (var team in EinsatzService.Teams.OrderBy(team => team.TeamName))
                            {
                                <div class="monitor-team-card @GetTeamCardClass(team)">
                                    <div class="team-info" style="border-left: 5px solid @GetTeamColor(team); padding-left: 1rem;">
                                        <div class="team-name-section">
                                            <h5>@team.TeamName</h5>
                                            @if (!string.IsNullOrWhiteSpace(team.DogName))
                                            {
                                                <span class="team-dog">Hund: @team.DogName</span>
                                            }
                                            @if (team.IsDroneTeam && !string.IsNullOrWhiteSpace(team.DroneType))
                                            {
                                                <span class="team-dog">Drohne: @team.DroneType</span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(team.HundefuehrerName))
                                            {
                                                <span class="team-dog">@team.HundefuehrerName</span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(team.HelferName))
                                            {
                                                <span class="team-dog">@team.HelferName (Helfer)</span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(team.SearchAreaName))
                                            {
                                                <span class="team-area">Gebiet: @team.SearchAreaName</span>
                                            }
                                        </div>

                                        <div class="team-timer">
                                            @if (!team.IsDroneTeam && !team.IsSupportTeam)
                                            {
                                                @if (team.IsPausing)
                                                {
                                                    <div class="timer-display timer-pausing">
                                                        @if (team.IsPauseComplete)
                                                        {
                                                            <i class="bi bi-check-circle-fill text-success me-1"></i>
                                                        }
                                                        @FormatPauseRemaining(team)
                                                    </div>
                                                    <span class="warning-badge badge @(team.IsPauseComplete ? "bg-success" : "bg-warning text-dark")">
                                                        @(team.IsPauseComplete ? "PAUSE OK" : "IN PAUSE")
                                                    </span>
                                                    <div class="pause-info-line small text-muted mt-1">
                                                        Gelaufen: @((int)team.RunTimeBeforePause.TotalMinutes) Min. &bull;
                                                        Pflichtpause: @team.RequiredPauseMinutes Min.
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="timer-display @GetTimerDisplayClass(team)">@team.ElapsedTime.ToString(@"hh\:mm\:ss")</div>
                                                    @if (team.IsSecondWarning)
                                                    {
                                                        <span class="warning-badge badge bg-danger">KRITISCH</span>
                                                    }
                                                    else if (team.IsFirstWarning)
                                                    {
                                                        <span class="warning-badge badge bg-warning text-dark">Warnung</span>
                                                    }
                                                }
                                            }
                                            else
                                            {
                                                <small class="text-muted">Kein Timer erforderlich</small>
                                            }
                                        </div>

                                        <div class="team-controls flex-wrap">
                                            @if (!team.IsDroneTeam && !team.IsSupportTeam)
                                            {
                                                @if (team.IsRunning)
                                                {
                                                    <button class="btn btn-warning" @onclick="() => StopTeamAsync(team.TeamId)">Stopp</button>
                                                }
                                                else if (!team.IsPausing)
                                                {
                                                    <button class="btn btn-success" @onclick="() => StartTeamAsync(team.TeamId)">Start</button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-success" @onclick="() => StartTeamAsync(team.TeamId)" title="Neuen Einsatz starten (Pause beendet)">Start</button>
                                                }
                                                <button class="btn btn-secondary" @onclick="() => RequestResetTeamAsync(team.TeamId)">Reset</button>
                                            }
                                            <button class="btn btn-sm btn-primary" @onclick="() => EditTeam(team.TeamId)">Bearbeiten</button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <h4 class="mb-0"><i class="bi bi-chat-left-text-fill"></i> Notizen &amp; Funksprüche</h4>
                        <a class="btn btn-sm btn-outline-secondary"
                           href="/popout-notes"
                           target="_blank"
                           rel="noopener noreferrer"
                           title="In neuem Fenster oeffnen (Multi-Monitor)">
                            <i class="bi bi-box-arrow-up-right"></i>
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    <div class="note-input-section mb-3">
                        <div class="mb-2">
                            <label class="form-label fw-bold">Team/Quelle *</label>
                            <select class="form-select" @bind="_newNoteSourceId">
                                <option value="">-- Team wählen (Pflicht) --</option>
                                @foreach (var team in EinsatzService.Teams.OrderBy(team => team.TeamName))
                                {
                                    <option value="@team.TeamId">@team.TeamName</option>
                                }
                                <option value="einsatzleitung">Einsatzleitung</option>
                            </select>
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Typ</label>
                            <select class="form-select" @bind="_newNoteType">
                                <option value="Notiz">Notiz</option>
                                <option value="Funk">Funk</option>
                            </select>
                        </div>
                        <textarea class="form-control mb-2"
                                  rows="3"
                                  @bind="_newNoteText"
                                  placeholder="Neuer Funkspruch oder Notiz..."></textarea>
                        <button class="btn btn-primary w-100"
                                @onclick="AddGlobalNoteAsync"
                                disabled="@(string.IsNullOrWhiteSpace(_newNoteText) || string.IsNullOrWhiteSpace(_newNoteSourceId))">
                            <i class="bi bi-send-fill"></i> Hinzufügen
                        </button>
                    </div>

                    @if (_quickNoteTemplates.Count > 0)
                    {
                        <div class="mb-3">
                            <div class="small text-muted mb-2">Schnell-Notiz (mit Zeitstempel)</div>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var quickTemplate in _quickNoteTemplates)
                                {
                                    <button class="btn btn-sm btn-outline-success" @onclick="() => AddQuickNoteAsync(quickTemplate)">@quickTemplate</button>
                                }
                            </div>
                        </div>
                    }

                    <div class="notes-list" style="max-height: 600px; overflow-y: auto;">
                        @if (EinsatzService.GlobalNotes.Count == 0)
                        {
                            <p class="text-muted mb-0">Noch keine Eintraege.</p>
                        }
                        else
                        {
                            @foreach (var note in EinsatzService.GlobalNotes.OrderByDescending(n => n.Timestamp).Take(10))
                            {
                                <div class="note-card @GetNoteCssClass(note) @(note.Replies.Count > 0 ? "has-replies" : string.Empty)">
                                    <div class="d-flex justify-content-between">
                                        <strong>@(string.IsNullOrWhiteSpace(note.SourceTeamName) ? "System" : note.SourceTeamName)</strong>
                                        <span class="text-muted">@note.FormattedTimestamp</span>
                                    </div>
                                    <div class="mb-2">@note.Text</div>

                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        @if (note.IsEdited)
                                        {
                                            <span class="badge bg-info">Bearbeitet</span>
                                        }
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleHistoryAsync(note.Id)">Historie</button>
                                    </div>

                                    @if (IsHistoryVisible(note.Id))
                                    {
                                        var historyEntries = GetHistoryEntries(note.Id);
                                        if (historyEntries.Count == 0)
                                        {
                                            <div class="small text-muted mb-2">Keine Historie vorhanden.</div>
                                        }
                                        else
                                        {
                                            <div class="small border rounded p-2 mb-2 bg-light-subtle">
                                                @foreach (var history in historyEntries)
                                                {
                                                    <div class="mb-1">
                                                        <div class="text-muted">@history.FormattedChangedAt · @history.ChangedBy</div>
                                                        <div><strong>Alt:</strong> @history.OldText</div>
                                                        <div><strong>Neu:</strong> @history.NewText</div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    }

                                    <div class="d-flex gap-2 mb-2">
                                        <select class="form-select form-select-sm" style="max-width: 12rem;"
                                                value="@GetReplySourceId(note.Id)"
                                                @onchange="e => SetReplySourceId(note.Id, e.Value?.ToString())">
                                            <option value="einsatzleitung">Einsatzleitung</option>
                                            @foreach (var team in EinsatzService.Teams.OrderBy(team => team.TeamName))
                                            {
                                                <option value="@team.TeamId">@team.TeamName</option>
                                            }
                                        </select>
                                        <input class="form-control form-control-sm"
                                               placeholder="Antwort"
                                               value="@GetReplyText(note.Id)"
                                               @oninput="e => SetReplyText(note.Id, e.Value?.ToString())" />
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => AddReplyAsync(note.Id)">Antworten</button>
                                    </div>

                                    @if (note.Replies.Count > 0)
                                    {
                                        <div class="small">
                                            @foreach (var reply in note.Replies.OrderBy(r => r.Timestamp))
                                            {
                                                <div class="border-start ps-2 py-1 mb-1">
                                                    <div class="text-muted">@reply.SourceTeamName · @reply.FormattedTimestamp</div>
                                                    <div>@reply.Text</div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (_showCloseMissionModal)
    {
        <div class="modal-overlay" @onclick="CloseCloseMissionModal">
            <div class="modal-modern modal-close-mission" @onclick:stopPropagation="true">
                <div class="modal-modern-header modal-close-mission-header">
                    <h3 class="mb-0"><i class="bi bi-exclamation-octagon me-1"></i>Einsatz beenden und archivieren</h3>
                    <button class="btn btn-sm btn-outline-light" @onclick="CloseCloseMissionModal" disabled="@_closingMission">X</button>
                </div>
                <div class="modal-modern-body">
                    <div class="alert alert-warning py-2 mb-3">
                        Nach dem Beenden wird der Einsatz archiviert, ein PDF erzeugt und das System fuer den naechsten Einsatz vorbereitet.
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_closeMissionModalError))
                    {
                        <div class="alert alert-danger py-2">@_closeMissionModalError</div>
                    }

                    <div class="row g-3 mb-3">
                        <div class="col-12 col-md-8">
                            <label class="form-label">Ergebnis</label>
                            <select class="form-select" @bind="_closeMissionResult">
                                <option value="">-- Bitte waehlen --</option>
                                @foreach (var option in _closeMissionResultOptions)
                                {
                                    <option value="@option">@option</option>
                                }
                            </select>
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">Ende-Zeit</label>
                            <input type="time" class="form-control" @bind="_closeMissionEndTime" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Bemerkungen</label>
                            <textarea class="form-control" rows="2" @bind="_closeMissionRemarks" placeholder="Zusatzinformationen zum Abschluss..."></textarea>
                        </div>
                    </div>

                    <div class="border rounded p-2 mb-3">
                        <div class="small fw-semibold mb-2">Einsatz-Zusammenfassung</div>
                        <div class="row g-2 small text-muted">
                            <div class="col-6 col-md-3">Teams: @EinsatzService.Teams.Count</div>
                            <div class="col-6 col-md-3">Personal: @SelectedPersonnelNames.Count</div>
                            <div class="col-6 col-md-3">Hunde: @SelectedDogNames.Count</div>
                            <div class="col-6 col-md-3">Notizen/Funk: @EinsatzService.GlobalNotes.Count</div>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-lg-6">
                            <div class="border rounded p-2 h-100">
                                <div class="small fw-semibold mb-2">Welches Personal war vor Ort?</div>
                                <div class="monitor-checklist-scroll">
                                    @if (!ActivePersonnel.Any())
                                    {
                                        <div class="small text-muted">Kein aktives Personal vorhanden.</div>
                                    }
                                    else
                                    {
                                        @foreach (var person in ActivePersonnel)
                                        {
                                            <label class="form-check d-block mb-1">
                                                <input class="form-check-input" type="checkbox" checked="@_selectedPersonnelIds.Contains(person.Id)" @onchange="args => TogglePersonnelSelection(person.Id, args)" />
                                                <span class="form-check-label">@person.FullName</span>
                                            </label>
                                        }
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <div class="border rounded p-2 h-100">
                                <div class="small fw-semibold mb-2">Welche Hunde waren im Einsatz?</div>
                                <div class="monitor-checklist-scroll">
                                    @if (!ActiveDogs.Any())
                                    {
                                        <div class="small text-muted">Keine aktiven Hunde vorhanden.</div>
                                    }
                                    else
                                    {
                                        @foreach (var dog in ActiveDogs)
                                        {
                                            <label class="form-check d-block mb-1">
                                                <input class="form-check-input" type="checkbox" checked="@_selectedDogIds.Contains(dog.Id)" @onchange="args => ToggleDogSelection(dog.Id, args)" />
                                                <span class="form-check-label">@dog.Name</span>
                                            </label>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <label class="form-check mt-3">
                        <input class="form-check-input" type="checkbox" @bind="_closeMissionChecklistConfirmed" />
                        <span class="form-check-label">Ich habe die eingesetzten Ressourcen und Beteiligten geprueft.</span>
                    </label>
                </div>
                <div class="modal-modern-footer">
                    <button class="btn btn-outline-secondary" @onclick="CloseCloseMissionModal" disabled="@_closingMission">Abbrechen</button>
                    <button class="btn btn-danger" @onclick="ConfirmCloseMissionAsync" disabled="@_closingMission">
                        @(_closingMission ? "Wird abgeschlossen..." : "Einsatz beenden & archivieren")
                    </button>
                </div>
            </div>
        </div>
    }

    @if (_showPauseResetModal)
    {
        var pauseTeam = EinsatzService.Teams.FirstOrDefault(t => t.TeamId == _pauseResetTeamId);
        @if (pauseTeam is not null)
        {
            <div class="modal-overlay" @onclick="ClosePauseResetModal">
                <div class="modal-modern" style="max-width:480px" @onclick:stopPropagation="true">
                    <div class="modal-modern-header" style="background:var(--bs-warning);color:#212529;">
                        <h4 class="mb-0"><i class="bi bi-pause-circle-fill me-2"></i>Pflichtpause nicht abgeschlossen</h4>
                        <button class="btn btn-sm btn-outline-dark" @onclick="ClosePauseResetModal">X</button>
                    </div>
                    <div class="modal-modern-body">
                        <div class="alert alert-warning py-2 mb-3">
                            <strong>@pauseTeam.DogName</strong> hat noch nicht die volle Pflichtpause erreicht.
                        </div>
                        <table class="table table-sm mb-3">
                            <tbody>
                                <tr>
                                    <td>Gelaufene Zeit</td>
                                    <td><strong>@((int)pauseTeam.RunTimeBeforePause.TotalMinutes) Minuten</strong></td>
                                </tr>
                                <tr>
                                    <td>Pflichtpause</td>
                                    <td><strong>@pauseTeam.RequiredPauseMinutes Minuten</strong>
                                        @if (pauseTeam.RunTimeBeforePause.TotalMinutes <= 20)
                                        {
                                            <span class="text-muted"> (≤ 20 Min. gelaufen → 60 Min. Pause)</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted"> (> 20 Min. gelaufen → 3 Std. Pause)</span>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td>Bisherige Pause</td>
                                    <td><strong>@((int)pauseTeam.PausedDuration.TotalMinutes) Minuten</strong></td>
                                </tr>
                                <tr class="table-danger">
                                    <td>Noch erforderlich</td>
                                    <td><strong>@pauseTeam.RemainingPauseMinutes Minuten</strong></td>
                                </tr>
                            </tbody>
                        </table>
                        <p class="small text-muted mb-0">
                            Wenn Sie den Timer trotzdem zurücksetzen, übernehmen Sie die Verantwortung
                            für die Gesundheit des Hundes. Bitte nur im absoluten Ausnahmefall fortfahren.
                        </p>
                    </div>
                    <div class="modal-modern-footer">
                        <button class="btn btn-outline-secondary" @onclick="ClosePauseResetModal">Abbrechen</button>
                        <button class="btn btn-danger" @onclick="ConfirmResetTeamAsync">
                            <i class="bi bi-exclamation-triangle-fill me-1"></i>Trotzdem zurücksetzen
                        </button>
                    </div>
                </div>
            </div>
        }
    }

    @if (_showEditEinsatzModal)
    {
        <div class="modal-overlay" @onclick="CloseEditEinsatzModal">
            <div class="modal-modern" style="max-width:640px" @onclick:stopPropagation="true">
                <div class="modal-modern-header">
                    <h3><i class="bi bi-pencil-square me-2"></i>Einsatz bearbeiten</h3>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CloseEditEinsatzModal">Schliessen</button>
                </div>
                <div class="modal-modern-body">
                    @if (!string.IsNullOrWhiteSpace(_editEinsatzMessage))
                    {
                        <div class="alert @(_editEinsatzIsError ? "alert-danger" : "alert-success") py-2">@_editEinsatzMessage</div>
                    }

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Typ</label>
                            <select class="form-select" @bind="_editEinsatzForm.IstEinsatz">
                                <option value="true">Einsatz</option>
                                <option value="false">Uebung</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Einsatznummer</label>
                            <input class="form-control" @bind="_editEinsatzForm.EinsatzNummer" placeholder="z. B. EVD-2026-001" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Alarmierungszeit</label>
                            <input class="form-control" type="time" step="60"
                                   value="@_editEinsatzForm.AlarmierungsZeit"
                                   @onchange="e => _editEinsatzForm.AlarmierungsZeit = e.Value?.ToString() ?? _editEinsatzForm.AlarmierungsZeit" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Einsatzort <span class="text-danger">*</span></label>
                            <input class="form-control" @bind="_editEinsatzForm.Einsatzort" placeholder="Strasse, Ort" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Karten-Adresse</label>
                            <input class="form-control" @bind="_editEinsatzForm.MapAddress" placeholder="Adresse fuer Kartensuche" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Alarmiert durch (Melder)</label>
                            <input class="form-control" @bind="_editEinsatzForm.Alarmiert" placeholder="z. B. Leitstelle" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Anzahl Teams (geplant)</label>
                            <input class="form-control" type="number" min="0" @bind="_editEinsatzForm.AnzahlTeams" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Einsatzleiter</label>
                            <div class="input-group">
