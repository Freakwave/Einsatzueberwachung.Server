    private static string GetPrimaryMemberLabel(Team team)
    {
        if (team.IsDroneTeam)
        {
            return string.IsNullOrWhiteSpace(team.HundefuehrerName)
                ? team.DroneType
                : $"{team.HundefuehrerName} · {team.DroneType}";
        }

        if (team.IsSupportTeam)
        {
            return team.HundefuehrerName;
        }

