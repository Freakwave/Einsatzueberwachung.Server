                </div>
                <div class="modal-modern-footer">
                    <button class="btn btn-outline-secondary" @onclick="CollarSelectCancel">Abbrechen</button>
                    @if (string.IsNullOrEmpty(_collarSelectCollarId))
                    {
                        <button class="btn btn-warning" @onclick="CollarSelectStartWithoutAsync">
                            <i class="bi bi-play-fill me-1"></i>Ohne Halsband starten
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-success" @onclick="CollarSelectConfirmAsync">
                            <i class="bi bi-broadcast me-1"></i>Zuweisen &amp; starten
