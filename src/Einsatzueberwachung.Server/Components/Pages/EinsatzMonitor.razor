                    }
                </div>
            </div>
        </div>
    }

@* ===== Modals ===== *@

@if (_showCloseMissionModal)
{
    <div class="modal-overlay" @onclick="CloseCloseMissionModal">
        <div class="modal-modern modal-close-mission" @onclick:stopPropagation="true">
            <div class="modal-modern-header modal-close-mission-header">
                <h3 class="mb-0"><i class="bi bi-exclamation-octagon me-1"></i>Einsatz beenden und archivieren</h3>
                <button class="btn btn-sm btn-outline-light" @onclick="CloseCloseMissionModal" disabled="@_closingMission">X</button>
            </div>
            <div class="modal-modern-body">
                <div class="alert alert-warning py-2 mb-3">
                    Nach dem Beenden wird der Einsatz archiviert, ein PDF erzeugt und das System fuer den naechsten Einsatz vorbereitet.
                </div>

                @if (!string.IsNullOrWhiteSpace(_closeMissionModalError))
                {
                    <div class="alert alert-danger py-2">@_closeMissionModalError</div>
                }

                <div class="row g-3 mb-3">
                    <div class="col-12 col-md-8">
                        <label class="form-label">Ergebnis</label>
                        <select class="form-select" @bind="_closeMissionResult">
                            <option value="">-- Bitte waehlen --</option>
                            @foreach (var option in _closeMissionResultOptions)
                            {
                                <option value="@option">@option</option>
                            }
                        </select>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label">Ende-Zeit</label>
                        <input type="time" class="form-control" @bind="_closeMissionEndTime" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Bemerkungen</label>
                        <textarea class="form-control" rows="2" @bind="_closeMissionRemarks" placeholder="Zusatzinformationen zum Abschluss..."></textarea>
                    </div>
                    <div class="col-12">
                        <label class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" @bind="_closeMissionIncludeTracks" />
                            <span class="form-check-label">
                                <i class="bi bi-geo-alt me-1"></i>GPS-Livetracking der PDF hinzufuegen
                                @if (_closeMissionTrackCount > 0)
                                {
                                    <span class="badge bg-info ms-1">@_closeMissionTrackCount Track(s)</span>
                                }
                                else
                                {
                                    <span class="text-muted ms-1">(keine Tracks vorhanden)</span>
                                }
                            </span>
                        </label>
                    </div>
                </div>

                <div class="border rounded p-2 mb-3">
                    <div class="small fw-semibold mb-2">Einsatz-Zusammenfassung</div>
                    <div class="row g-2 small text-muted">
                        <div class="col-6 col-md-3">Teams: @EinsatzService.Teams.Count</div>
                        <div class="col-6 col-md-3">Personal: @SelectedPersonnelNames.Count</div>
                        <div class="col-6 col-md-3">Hunde: @SelectedDogNames.Count</div>
                        <div class="col-6 col-md-3">Notizen/Funk: @EinsatzService.GlobalNotes.Count</div>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-12 col-lg-6">
                        <div class="border rounded p-2 h-100">
                            <div class="small fw-semibold mb-2">Welches Personal war vor Ort?</div>
                            <div class="monitor-checklist-scroll">
                                @if (!ActivePersonnel.Any())
                                {
                                    <div class="small text-muted">Kein aktives Personal vorhanden.</div>
                                }
                                else
                                {
                                    @foreach (var person in ActivePersonnel)
                                    {
                                        <label class="form-check d-block mb-1">
                                            <input class="form-check-input" type="checkbox" checked="@_selectedPersonnelIds.Contains(person.Id)" @onchange="args => TogglePersonnelSelection(person.Id, args)" />
                                            <span class="form-check-label">@person.FullName</span>
                                        </label>
                                    }
                                }
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-lg-6">
                        <div class="border rounded p-2 h-100">
                            <div class="small fw-semibold mb-2">Welche Hunde waren im Einsatz?</div>
                            <div class="monitor-checklist-scroll">
                                @if (!ActiveDogs.Any())
                                {
                                    <div class="small text-muted">Keine aktiven Hunde vorhanden.</div>
                                }
                                else
                                {
                                    @foreach (var dog in ActiveDogs)
                                    {
                                        <label class="form-check d-block mb-1">
                                            <input class="form-check-input" type="checkbox" checked="@_selectedDogIds.Contains(dog.Id)" @onchange="args => ToggleDogSelection(dog.Id, args)" />
                                            <span class="form-check-label">@dog.Name</span>
                                        </label>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <label class="form-check mt-3">
                    <input class="form-check-input" type="checkbox" @bind="_closeMissionChecklistConfirmed" />
                    <span class="form-check-label">Ich habe die eingesetzten Ressourcen und Beteiligten geprueft.</span>
                </label>
            </div>
            <div class="modal-modern-footer">
                <button class="btn btn-outline-secondary" @onclick="CloseCloseMissionModal" disabled="@_closingMission">Abbrechen</button>
                <button class="btn btn-danger" @onclick="ConfirmCloseMissionAsync" disabled="@_closingMission">
                    @(_closingMission ? "Wird abgeschlossen..." : "Einsatz beenden & archivieren")
                </button>
            </div>
        </div>
    </div>
}

@if (_showPauseResetModal)
{
    var pauseTeam = EinsatzService.Teams.FirstOrDefault(t => t.TeamId == _pauseResetTeamId);
    @if (pauseTeam is not null)
    {
        <div class="modal-overlay" @onclick="ClosePauseResetModal">
            <div class="modal-modern" style="max-width:480px" @onclick:stopPropagation="true">
                <div class="modal-modern-header" style="background:var(--bs-warning);color:#212529;">
                    <h4 class="mb-0"><i class="bi bi-pause-circle-fill me-2"></i>Pflichtpause nicht abgeschlossen</h4>
                    <button class="btn btn-sm btn-outline-dark" @onclick="ClosePauseResetModal">X</button>
                </div>
                <div class="modal-modern-body">
                    <div class="alert alert-warning py-2 mb-3">
                        <strong>@pauseTeam.DogName</strong> hat noch nicht die volle Pflichtpause erreicht.
                    </div>
                    <table class="table table-sm mb-3">
                        <tbody>
                            <tr>
                                <td>Gelaufene Zeit</td>
                                <td><strong>@((int)pauseTeam.RunTimeBeforePause.TotalMinutes) Minuten</strong></td>
                            </tr>
                            <tr>
                                <td>Pflichtpause</td>
                                <td><strong>@pauseTeam.RequiredPauseMinutes Minuten</strong>
                                    @if (pauseTeam.RunTimeBeforePause.TotalMinutes <= 20)
                                    {
                                        <span class="text-muted"> (≤ 20 Min. gelaufen → 60 Min. Pause)</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted"> (> 20 Min. gelaufen → 3 Std. Pause)</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <td>Bisherige Pause</td>
                                <td><strong>@((int)pauseTeam.PausedDuration.TotalMinutes) Minuten</strong></td>
                            </tr>
                            <tr class="table-danger">
                                <td>Noch erforderlich</td>
                                <td><strong>@pauseTeam.RemainingPauseMinutes Minuten</strong></td>
                            </tr>
                        </tbody>
                    </table>
                    <p class="small text-muted mb-0">
                        Wenn Sie den Timer trotzdem zurücksetzen, übernehmen Sie die Verantwortung
                        für die Gesundheit des Hundes. Bitte nur im absoluten Ausnahmefall fortfahren.
                    </p>
                </div>
                <div class="modal-modern-footer">
                    <button class="btn btn-outline-secondary" @onclick="ClosePauseResetModal">Abbrechen</button>
                    <button class="btn btn-danger" @onclick="ConfirmResetTeamAsync">
                        <i class="bi bi-exclamation-triangle-fill me-1"></i>Trotzdem zurücksetzen
                    </button>
                </div>
            </div>
        </div>
    }
}

@if (_showEditEinsatzModal)
{
    <div class="modal-overlay" @onclick="CloseEditEinsatzModal">
        <div class="modal-modern" style="max-width:640px" @onclick:stopPropagation="true">
            <div class="modal-modern-header">
                <h3><i class="bi bi-pencil-square me-2"></i>Einsatz bearbeiten</h3>
                <button class="btn btn-sm btn-outline-secondary" @onclick="CloseEditEinsatzModal">Schliessen</button>
            </div>
            <div class="modal-modern-body">
                @if (!string.IsNullOrWhiteSpace(_editEinsatzMessage))
                {
                    <div class="alert @(_editEinsatzIsError ? "alert-danger" : "alert-success") py-2">@_editEinsatzMessage</div>
                }

                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Typ</label>
                        <select class="form-select" @bind="_editEinsatzForm.IstEinsatz">
                            <option value="true">Einsatz</option>
                            <option value="false">Uebung</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Einsatznummer</label>
                        <input class="form-control" @bind="_editEinsatzForm.EinsatzNummer" placeholder="z. B. EVD-2026-001" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Alarmierungszeit</label>
                        <input class="form-control" type="time" step="60"
                               value="@_editEinsatzForm.AlarmierungsZeit"
                               @onchange="e => _editEinsatzForm.AlarmierungsZeit = e.Value?.ToString() ?? _editEinsatzForm.AlarmierungsZeit" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Einsatzort <span class="text-danger">*</span></label>
                        <input class="form-control" @bind="_editEinsatzForm.Einsatzort" placeholder="Strasse, Ort" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Karten-Adresse</label>
                        <input class="form-control" @bind="_editEinsatzForm.MapAddress" placeholder="Adresse fuer Kartensuche" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Alarmiert durch (Melder)</label>
                        <input class="form-control" @bind="_editEinsatzForm.Alarmiert" placeholder="z. B. Leitstelle" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Anzahl Teams (geplant)</label>
                        <input class="form-control" type="number" min="0" @bind="_editEinsatzForm.AnzahlTeams" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Einsatzleiter</label>
                        <div class="input-group">
                            <select class="form-select" @onchange="e => _editEinsatzForm.Einsatzleiter = e.Value?.ToString() ?? _editEinsatzForm.Einsatzleiter">
                                <option value="">- aus Stammdaten -</option>
                                @foreach (var p in _personalList.Where(x => x.IsActive && x.Skills.HasFlag(PersonalSkills.Einsatzleiter)).OrderBy(x => x.Nachname))
                                {
                                    <option value="@p.FullName">@p.FullName</option>
                                }
                            </select>
                            <input class="form-control" @bind="_editEinsatzForm.Einsatzleiter" placeholder="oder Freitext" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Fuerungsassistent</label>
                        <div class="input-group">
                            <select class="form-select" @onchange="e => _editEinsatzForm.Fuehrungsassistent = e.Value?.ToString() ?? _editEinsatzForm.Fuehrungsassistent">
                                <option value="">- aus Stammdaten -</option>
                                @foreach (var p in _personalList.Where(x => x.IsActive && x.Skills.HasFlag(PersonalSkills.Fuehrungsassistent)).OrderBy(x => x.Nachname))
                                {
                                    <option value="@p.FullName">@p.FullName</option>
                                }
                            </select>
                            <input class="form-control" @bind="_editEinsatzForm.Fuehrungsassistent" placeholder="oder Freitext" />
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Bemerkungen</label>
                        <textarea class="form-control" rows="3" @bind="_editEinsatzForm.Bemerkungen" placeholder="Weitere Informationen zum Einsatz"></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-modern-footer">
                <button class="btn btn-outline-secondary" @onclick="CloseEditEinsatzModal">Abbrechen</button>
                <button class="btn btn-primary" @onclick="SaveEditEinsatzAsync">
                    <i class="bi bi-check-lg me-1"></i>Speichern
                </button>
            </div>
        </div>
    </div>
}

@if (_showVermisstenModal)
{
    <div class="modal-overlay" @onclick="CloseVermisstenModal">
        <div class="modal-modern" style="max-width:700px;max-height:90vh;overflow-y:auto;" @onclick:stopPropagation="true">
            <div class="modal-modern-header">
                <h3><i class="bi bi-person-exclamation me-2"></i>Vermissteninfo</h3>
                <button class="btn btn-sm btn-outline-secondary" @onclick="CloseVermisstenModal">Schliessen</button>
            </div>
            <div class="modal-modern-body">

                @if (!string.IsNullOrWhiteSpace(_vermisstenMessage))
                {
                    <div class="alert @(_vermisstenIsError ? "alert-danger" : "alert-success") py-2">@_vermisstenMessage</div>
