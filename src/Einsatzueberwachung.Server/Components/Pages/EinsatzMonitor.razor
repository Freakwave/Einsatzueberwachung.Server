                    <h4 class="mb-0"><i class="bi bi-broadcast me-2"></i>GPS-Halsband zuweisen</h4>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CollarSelectCancel">×</button>
                </div>
                <div class="modal-modern-body">
