                        <input class="form-control form-control-sm" @bind="_vForm.Besonderheiten" placeholder="z.B. ca. 175 cm, Brille" />
                    </div>
                </div>

                <h6 class="text-muted text-uppercase small fw-bold mb-2">Letzter bekannter Aufenthalt</h6>
                <div class="row g-2 mb-3">
                    <div class="col-md-6">
                        <label class="form-label form-label-sm">Ort</label>
                        <input class="form-control form-control-sm" @bind="_vForm.ZuletztGesehenOrt" placeholder="z.B. Parkplatz Waldstraße 12" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label form-label-sm">Uhrzeit</label>
                        <input class="form-control form-control-sm" @bind="_vForm.ZuletztGesehenZeit" placeholder="z.B. 14:30" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label form-label-sm">Gesehen von</label>
                        <input class="form-control form-control-sm" @bind="_vForm.ZuletztGesehenVon" placeholder="z.B. Tochter" />
                    </div>
                </div>

                <h6 class="text-muted text-uppercase small fw-bold mb-2">Medizin &amp; Verhalten</h6>
                <div class="row g-2 mb-3">
                    <div class="col-md-4">
                        <label class="form-label form-label-sm">Orientierung</label>
                        <select class="form-select form-select-sm" @bind="_vForm.Orientierung">
                            @foreach (var v in Enum.GetValues<Einsatzueberwachung.Domain.Models.OrientierungsStatus>())
                            {
                                <option value="@v">@v</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label form-label-sm">Mobilität</label>
                        <select class="form-select form-select-sm" @bind="_vForm.Mobilitaet">
                            @foreach (var v in Enum.GetValues<Einsatzueberwachung.Domain.Models.MobilitaetsStatus>())
                            {
                                <option value="@v">@v</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label form-label-sm">Suizidrisiko</label>
                        <select class="form-select form-select-sm @(_vForm.Suizidrisiko == Einsatzueberwachung.Domain.Models.RisikoStatus.Ja ? "border-danger" : "")" @bind="_vForm.Suizidrisiko">
                            @foreach (var v in Enum.GetValues<Einsatzueberwachung.Domain.Models.RisikoStatus>())
                            {
                                <option value="@v">@v</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label form-label-sm">Bewaffnet</label>
                        <select class="form-select form-select-sm @(_vForm.Bewaffnet == Einsatzueberwachung.Domain.Models.RisikoStatus.Ja ? "border-danger" : "")" @bind="_vForm.Bewaffnet">
                            @foreach (var v in Enum.GetValues<Einsatzueberwachung.Domain.Models.RisikoStatus>())
                            {
                                <option value="@v">@v</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label form-label-sm">Vorerkrankungen</label>
                        <input class="form-control form-control-sm" @bind="_vForm.Vorerkrankungen" placeholder="z.B. Demenz, Diabetes" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label form-label-sm">Medikamente</label>
                        <input class="form-control form-control-sm" @bind="_vForm.Medikamente" placeholder="z.B. Metformin, Blutverdünner" />
                    </div>
                </div>

                <h6 class="text-muted text-uppercase small fw-bold mb-2"><i class="bi bi-shield me-1"></i>Polizei-Kontakt</h6>
                <div class="row g-2 mb-2">
                    <div class="col-md-4">
                        <label class="form-label form-label-sm">Name Kontaktbeamter</label>
                        <input class="form-control form-control-sm" @bind="_vForm.PolizeiKontaktName" placeholder="PHK Müller" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label form-label-sm">Dienstnummer / Rufname</label>
                        <input class="form-control form-control-sm" @bind="_vForm.PolizeiDienstnummer" placeholder="z.B. 1234 oder Florian 5" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label form-label-sm">Telefon</label>
                        <input class="form-control form-control-sm" @bind="_vForm.PolizeiTelefon" placeholder="+49 ..." />
                    </div>
                </div>
                <div class="row g-1 mb-3">
                    @foreach (var (label, getter, setter) in GetPolizeiChecklist())
                    {
                        <div class="col-md-6">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" checked="@getter()" @onchange="e => setter((bool)(e.Value ?? false))" />
                                <label class="form-check-label small">@label</label>
                            </div>
                        </div>
                    }
                </div>

                <h6 class="text-muted text-uppercase small fw-bold mb-2"><i class="bi bi-truck me-1"></i>Weitere BOS / Feuerwehr</h6>
                <div class="row g-2 mb-2">
                    <div class="col-md-4">
                        <label class="form-label form-label-sm">Einheit</label>
                        <input class="form-control form-control-sm" @bind="_vForm.BosEinheit" placeholder="z.B. FF Musterstadt" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label form-label-sm">Zugführer</label>
                        <input class="form-control form-control-sm" @bind="_vForm.BosZugfuehrer" placeholder="Name" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label form-label-sm">Funkrufname</label>
                        <input class="form-control form-control-sm" @bind="_vForm.BosFunkrufname" placeholder="z.B. Florian 1/20" />
                    </div>
                    <div class="col-12">
                        <label class="form-label form-label-sm">Aufgabenteilung</label>
                        <input class="form-control form-control-sm" @bind="_vForm.BosAufgabenteilung" placeholder="z.B. Feuerwehr übernimmt Wassersuche" />
                    </div>
                </div>
                <div class="row g-1 mb-1">
                    <div class="col-md-6">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" @bind="_vForm.BosAbschnittAbgestimmt" />
                            <label class="form-check-label small">Einsatzabschnitt abgestimmt</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" @bind="_vForm.BosRessourcenBesprochen" />
                            <label class="form-check-label small">Ressourcen besprochen (Wärmebild, etc.)</label>
                        </div>
                    </div>
                </div>

            </div>
            <div class="modal-modern-footer">
                <button class="btn btn-outline-secondary" @onclick="CloseVermisstenModal">Abbrechen</button>
                <button class="btn btn-primary" @onclick="SaveVermisstenAsync">
                    <i class="bi bi-check-lg me-1"></i>Speichern
                </button>
            </div>
        </div>
    </div>
}

@if (_showTeamModal)
{
    <div class="modal-overlay" @onclick="CloseTeamModal">
        <div class="modal-modern" @onclick:stopPropagation="true">
            <div class="modal-modern-header">
                <h3>@(_editingTeamId is null ? "Team anlegen" : "Team bearbeiten")</h3>
                <button class="btn btn-sm btn-outline-secondary" @onclick="CloseTeamModal">Schliessen</button>
            </div>
            <div class="modal-modern-body">
                @if (!string.IsNullOrWhiteSpace(_teamFormMessage))
                {
                    <div class="alert @(_teamFormIsError ? "alert-danger" : "alert-success") py-2">@_teamFormMessage</div>
                }

                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Teamtyp</label>
                        <select class="form-select" @bind="_teamForm.TeamType" @bind:after="OnTeamTypeChangedAsync">
                            <option value="dog">Hundeteam</option>
                            <option value="drone">Drohnenteam</option>
                            <option value="support">Support-Team</option>
                        </select>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Teamname</label>
                        <input class="form-control" @bind="_teamForm.TeamName" placeholder="z. B. Team Alpha" />
                    </div>

                    @if (_teamForm.TeamType == "dog")
                    {
                        <div class="col-12">
                            <label class="form-label">Hund</label>
                            <select class="form-select" @bind="_teamForm.DogId" @bind:after="OnDogChangedAsync">
                                <option value="">Hund auswaehlen</option>
                                @foreach (var dog in AvailableDogs)
                                {
                                    <option value="@dog.Id">@dog.Name (@dog.SpecializationsShortDisplay)</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Hundefuehrer</label>
                            <select class="form-select" @bind="_teamForm.HundefuehrerId" @bind:after="OnHandlerChangedAsync">
                                <option value="">Hundefuehrer auswaehlen</option>
                                @foreach (var person in HundefuehrerOptions)
                                {
                                    <option value="@person.Id">@person.FullName</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Helfer 1</label>
                            <select class="form-select" @bind="_teamForm.HelferId">
                                <option value="">Helfer auswaehlen</option>
                                @foreach (var person in HelferOptions)
                                {
                                    <option value="@person.Id">@person.FullName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Helfer 2 <span class="text-muted small">(optional)</span></label>
                            <select class="form-select" @bind="_teamForm.HelferId2">
                                <option value="">— kein zweiter Helfer —</option>
                                @foreach (var person in HelferOptions)
                                {
                                    <option value="@person.Id">@person.FullName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Helfer 3 <span class="text-muted small">(optional)</span></label>
                            <select class="form-select" @bind="_teamForm.HelferId3">
                                <option value="">— kein dritter Helfer —</option>
                                @foreach (var person in HelferOptions)
                                {
                                    <option value="@person.Id">@person.FullName</option>
                                }
                            </select>
                        </div>
                    }
                    else if (_teamForm.TeamType == "drone")
                    {
                        <div class="col-12">
                            <label class="form-label">Drohne</label>
                            <select class="form-select" @bind="_teamForm.DroneId" @bind:after="OnDroneChangedAsync">
                                <option value="">Drohne auswaehlen</option>
                                @foreach (var drone in AvailableDrones)
                                {
                                    <option value="@drone.Id">@drone.DisplayName (@drone.FullDescription)</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Pilot</label>
                            <select class="form-select" @bind="_teamForm.HundefuehrerId">
                                <option value="">Pilot auswaehlen</option>
                                @foreach (var person in DrohnenpilotOptions)
                                {
                                    <option value="@person.Id">@person.FullName</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Unterstuetzung</label>
                            <select class="form-select" @bind="_teamForm.HelferId">
                                <option value="">Person auswaehlen</option>
                                @foreach (var person in ActivePersonnel)
                                {
                                    <option value="@person.Id">@person.FullName</option>
                                }
                            </select>
                        </div>
                    }
                    else
                    {
                        <div class="col-md-6">
                            <label class="form-label">Leitung / Fuehrung</label>
                            <select class="form-select" @bind="_teamForm.HundefuehrerId">
                                <option value="">Person auswaehlen</option>
                                @foreach (var person in ActivePersonnel)
                                {
                                    <option value="@person.Id">@person.FullName</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Zweite Person</label>
                            <select class="form-select" @bind="_teamForm.HelferId">
                                <option value="">Person auswaehlen</option>
                                @foreach (var person in ActivePersonnel)
                                {
                                    <option value="@person.Id">@person.FullName</option>
                                }
                            </select>
                        </div>
                    }

                    <div class="col-12">
                        <label class="form-label">Suchgebiet</label>
                        <select class="form-select" @bind="_teamForm.SearchAreaId">
                            <option value="">Kein Gebiet</option>
                            @foreach (var area in EinsatzService.CurrentEinsatz.SearchAreas.OrderBy(area => area.Name))
                            {
                                <option value="@area.Id">@area.Name</option>
                            }
                        </select>
                    </div>

                    @if (_teamForm.TeamType == "dog")
                    {
                        <div class="col-12">
                            <label class="form-label"><i class="bi bi-broadcast me-1"></i>GPS-Halsband</label>
                            <select class="form-select" @bind="_teamForm.CollarId">
                                <option value="">-- Kein Halsband --</option>
                                @foreach (var collar in CollarTrackingService.Collars
                                    .Where(c => !c.IsAssigned || c.Id == _teamForm.CollarId)
                                    .OrderBy(c => c.CollarName))
                                {
                                    <option value="@collar.Id">@collar.CollarName [@collar.Id]</option>
                                }
                            </select>
                        </div>
                    }

                    <div class="col-md-6">
                        <label class="form-label">Warnung 1 (Minuten)</label>
                        <input class="form-control" type="number" min="1" @bind="_teamForm.FirstWarningMinutes" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Warnung 2 (Minuten)</label>
                        <input class="form-control" type="number" min="1" @bind="_teamForm.SecondWarningMinutes" />
                    </div>

                    <div class="col-12">
                        <label class="form-label">Notizen</label>
                        <textarea class="form-control" rows="3" @bind="_teamForm.Notes"></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-modern-footer">
                <button class="btn btn-primary" @onclick="SaveTeamAsync">@(_editingTeamId is null ? "Team speichern" : "Aenderungen speichern")</button>
                <button class="btn btn-outline-secondary" @onclick="ResetTeamForm">Formular leeren</button>
            </div>
        </div>
    </div>
}

@if (_showTeamMessageModal)
{
    <div class="modal-overlay" @onclick="CloseTeamMessageModal">
        <div class="modal-modern" style="max-width:520px;" @onclick:stopPropagation="true">
            <div class="modal-modern-header bg-warning text-dark">
                <h3 class="mb-0"><i class="bi bi-megaphone me-1"></i>Nachricht an Team</h3>
                <button class="btn btn-sm btn-outline-dark" @onclick="CloseTeamMessageModal">X</button>
            </div>
            <div class="modal-modern-body">
                @if (EinsatzService.Teams.Count == 0)
                {
                    <div class="alert alert-info">Keine Teams im Einsatz.</div>
                }
                else
                {
                    <div class="mb-3">
                        <label class="form-label">Empfaenger</label>
                        <select class="form-select" @bind="_teamMessageTargetId">
                            @foreach (var t in EinsatzService.Teams.OrderBy(t => t.TeamName))
                            {
                                <option value="@t.TeamId">@t.TeamName @(string.IsNullOrWhiteSpace(t.DogName) ? "" : " / " + t.DogName)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nachricht</label>
                        <textarea class="form-control" rows="3" @bind="_teamMessageText" placeholder="kurze Nachricht..."></textarea>
                    </div>
                    @if (!string.IsNullOrEmpty(_teamMessageFeedback))
                    {
                        <div class="alert @(_teamMessageFeedback.StartsWith("Nachricht") ? "alert-success" : "alert-danger") py-2 mb-0">@_teamMessageFeedback</div>
                    }
                    <p class="small text-muted mt-2 mb-0">
                        <i class="bi bi-info-circle me-1"></i>Erscheint sofort am Smartphone des gewaehlten Teams (max. 5 letzte Nachrichten).
                    </p>
                }
            </div>
            <div class="modal-modern-footer">
                <button class="btn btn-warning" @onclick="SendTeamMessage" disabled="@(EinsatzService.Teams.Count == 0)">Senden</button>
                <button class="btn btn-outline-secondary" @onclick="CloseTeamMessageModal">Schliessen</button>
            </div>
        </div>
    </div>
}

@if (_showTeamMobileModal)
{
    <div class="modal-overlay" @onclick="CloseTeamMobileModal">
        <div class="modal-modern" style="max-width:520px;" @onclick:stopPropagation="true">
            <div class="modal-modern-header bg-success text-white">
                <h3 class="mb-0"><i class="bi bi-qr-code me-1"></i>Team-Mobile Anmelde-Code</h3>
                <button class="btn btn-sm btn-outline-light" @onclick="CloseTeamMobileModal">X</button>
            </div>
            <div class="modal-modern-body text-center">
                @if (string.IsNullOrEmpty(_teamMobileFullUrl))
                {
                    <div class="alert alert-warning">
                        Es ist gerade kein Einsatz aktiv. Starte einen Einsatz, um einen Anmelde-Code zu generieren.
                    </div>
                }
                else
                {
                    <p class="text-muted small mb-2">
                        Teams scannen diesen QR-Code mit dem Smartphone, um sich auf <strong>/team/login</strong> anzumelden.
                    </p>
                    <img src="@_teamMobileQrDataUrl" alt="QR-Code" style="max-width:320px;width:100%;height:auto;" />
                    <div class="mt-3">
                        <input type="text" class="form-control text-center" readonly value="@_teamMobileFullUrl" onclick="this.select()" />
                    </div>
                    <p class="small text-muted mt-3 mb-0">
                        <i class="bi bi-info-circle me-1"></i>Der Code wird beim Einsatz-Ende automatisch ungueltig.
                    </p>
                }
            </div>
            <div class="modal-modern-footer">
                <button class="btn btn-outline-secondary" @onclick="CloseTeamMobileModal">Schliessen</button>
            </div>
        </div>
    </div>
}
