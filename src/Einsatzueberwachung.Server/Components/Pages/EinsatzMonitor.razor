@page "/einsatz-monitor"
@rendermode InteractiveServer
@implements IDisposable

@using Einsatzueberwachung.Domain.Models
@using Einsatzueberwachung.Domain.Models.Enums

<PageTitle>Einsatz-Monitor</PageTitle>

<div class="monitor-dashboard-wrapper">
    <header class="monitor-dash-header">
        <div class="monitor-dash-title">
            <span class="badge @(EinsatzService.CurrentEinsatz.IstEinsatz ? "bg-danger" : "bg-warning text-dark") me-2 fs-6">
                @EinsatzService.CurrentEinsatz.EinsatzTyp
            </span>
            <strong>@EinsatzService.CurrentEinsatz.Einsatzort</strong>
            @if (_einsatzdauerFromHeader.HasValue)
            {
                <span class="ms-3 einsatz-dauer-badge">
                    <i class="bi bi-clock-history"></i>@GetEinsatzdauerDisplay()
                </span>
            }
        </div>
        <div class="monitor-dash-actions">
            @if (_editMode)
            {
                <span class="text-muted small me-2"><i class="bi bi-grid me-1"></i>Layout bearbeiten</span>
                <button class="btn btn-success btn-sm" @onclick="SaveLayoutAsync">
                    <i class="bi bi-check-lg me-1"></i>Speichern
                </button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="CancelEditAsync">
                    <i class="bi bi-x-lg me-1"></i>Verwerfen
                </button>
            }
            else
            {
                <button class="btn btn-outline-primary btn-sm" @onclick="EnterEditModeAsync">
                    <i class="bi bi-grid me-1"></i>Layout bearbeiten
                </button>
                <a class="btn btn-info btn-sm" href="/einsatz-karte">
                    <i class="bi bi-map me-1"></i>Karte
                </a>
                <button class="btn btn-outline-success btn-sm" type="button" @onclick="OpenTeamMobileModal" title="QR-Code fuer Team-Smartphones">
                    <i class="bi bi-qr-code me-1"></i>Team-Mobile
                </button>
                <button class="btn btn-outline-warning btn-sm" type="button" @onclick="OpenTeamMessageModal" title="Nachricht an ein Team-Smartphone">
                    <i class="bi bi-megaphone me-1"></i>Push
                </button>
                <button class="btn btn-danger btn-sm" type="button" @onclick="OpenCloseMissionModal">
                    <i class="bi bi-stop-circle me-1"></i>Beenden
                </button>
            }
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(_closeMissionStatus))
    {
        <div class="alert @(_closeMissionStatusIsError ? "alert-warning" : "alert-success") mx-2 mb-0 mt-2 py-2">
            @_closeMissionStatus
        </div>
    }

    <div id="monitor-dashboard-grid" class="monitor-dashboard-grid">
        @foreach (var panel in _currentLayout.OrderBy(p => p.Order))
        {
            @if (panel.IsVisible || _editMode)
            {
                <div @key="panel.PanelId"
                     class="dashboard-panel-wrapper @ColSpanClass(panel.ColSpan) @(!panel.IsVisible ? "panel-invisible" : "")"
                     data-panel-id="@panel.PanelId">
                    <div class="dashboard-panel">
                        <div class="dashboard-panel-header">
                            @if (_editMode)
                            {
                                <i class="bi bi-grip-vertical dashboard-panel-drag-handle me-1"></i>
                            }
                            <span class="dashboard-panel-title">@PanelLabel(panel.PanelId)</span>

                            @if (_editMode)
                            {
                                <div class="dashboard-panel-edit-controls ms-auto">
                                    <div class="btn-group btn-group-sm me-1" title="Breite">
                                        @foreach (var cs in new[] { 3, 4, 6, 8, 12 })
                                        {
                                            <button class="btn btn-sm @(panel.ColSpan == cs ? "btn-primary" : "btn-outline-secondary")"
                                                    @onclick="() => SetPanelColSpan(panel.PanelId, cs)"
                                                    title="Breite: @ColSpanLabel(cs)">
                                                @ColSpanLabel(cs)
                                            </button>
                                        }
                                    </div>
                                    <div class="btn-group btn-group-sm me-1" title="Höhe">
                                        @foreach (var h in new[] { 0, 250, 400, 600, 800 })
                                        {
                                            <button class="btn btn-sm @(panel.PanelHeight == h ? "btn-info" : "btn-outline-secondary")"
                                                    @onclick="() => SetPanelHeight(panel.PanelId, h)"
                                                    title="Höhe: @PanelHeightLabel(h)">
                                                @PanelHeightLabel(h)
                                            </button>
                                        }
                                    </div>
                                    <button class="btn btn-sm @(panel.IsVisible ? "btn-outline-secondary" : "btn-outline-warning")"
                                            @onclick="() => TogglePanelVisible(panel.PanelId)"
                                            title="@(panel.IsVisible ? "Panel ausblenden" : "Panel einblenden")">
                                        <i class="bi @(panel.IsVisible ? "bi-eye" : "bi-eye-slash")"></i>
                                    </button>
                                </div>
                            }
                            else
                            {
                                @if (panel.PanelId == KnownPanels.Teams)
                                {
                                    <div class="ms-auto d-flex align-items-center gap-2">
                                        <a class="btn btn-sm btn-outline-secondary"
                                           href="/popout-teams"
                                           target="_blank"
                                           rel="noopener noreferrer"
                                           title="In neuem Fenster öffnen (Multi-Monitor)">
                                            <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i>
                                        </a>
                                        <button class="btn btn-sm btn-primary" @onclick="OpenNewTeamModal">
                                            <i class="bi bi-plus-circle me-1"></i>Team anlegen
                                        </button>
                                    </div>
                                }
                                else if (panel.PanelId == KnownPanels.Notizen)
                                {
                                    <div class="ms-auto">
                                        <a class="btn btn-sm btn-outline-secondary"
                                           href="/popout-notes"
                                           target="_blank"
                                           rel="noopener noreferrer"
                                           title="In neuem Fenster öffnen (Multi-Monitor)">
                                            <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i>
                                        </a>
                                    </div>
                                }
                                else if (panel.PanelId == KnownPanels.EinsatzInfo)
                                {
                                    <div class="ms-auto">
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="OpenEditEinsatzModal">
                                            <i class="bi bi-pencil me-1"></i>Bearbeiten
                                        </button>
                                    </div>
                                }
                                else if (panel.PanelId == KnownPanels.Vermissten)
                                {
                                    <div class="ms-auto">
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="OpenVermisstenModal">
                                            <i class="bi bi-pencil me-1"></i>Bearbeiten
                                        </button>
                                    </div>
                                }
                            }
                        </div>

                        <div class="dashboard-panel-body" style="@PanelBodyStyle(panel)">
                            @switch (panel.PanelId)
                            {
                                case KnownPanels.EinsatzInfo:
                                    <dl class="row mb-0 small">
                                        <dt class="col-5">Typ</dt>
                                        <dd class="col-7 mb-1">@EinsatzService.CurrentEinsatz.EinsatzTyp</dd>
                                        @if (!string.IsNullOrWhiteSpace(EinsatzService.CurrentEinsatz.EinsatzNummer))
                                        {
                                            <dt class="col-5">Einsatznummer</dt>
                                            <dd class="col-7 mb-1">@EinsatzService.CurrentEinsatz.EinsatzNummer</dd>
                                        }
                                        <dt class="col-5">Einsatzort</dt>
                                        <dd class="col-7 mb-1">@EinsatzService.CurrentEinsatz.Einsatzort</dd>
                                        <dt class="col-5">Datum</dt>
                                        <dd class="col-7 mb-1">@EinsatzService.CurrentEinsatz.EinsatzDatum.ToString("dd.MM.yyyy HH:mm")</dd>
                                        @if (EinsatzService.CurrentEinsatz.AlarmierungsZeit.HasValue)
                                        {
                                            <dt class="col-5">Alarmierung</dt>
                                            <dd class="col-7 mb-1">@EinsatzService.CurrentEinsatz.AlarmierungsZeit.Value.ToString("HH:mm") Uhr</dd>
                                            <dt class="col-5">Einsatzzeit</dt>
                                            <dd class="col-7 mb-1"><i class="bi bi-clock-history me-1"></i>@GetEinsatzdauerDisplay()</dd>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(EinsatzService.CurrentEinsatz.Einsatzleiter))
                                        {
                                            <dt class="col-5">Einsatzleiter</dt>
                                            <dd class="col-7 mb-1">@EinsatzService.CurrentEinsatz.Einsatzleiter</dd>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(EinsatzService.CurrentEinsatz.Fuehrungsassistent))
                                        {
                                            <dt class="col-5">FA</dt>
                                            <dd class="col-7 mb-1">@EinsatzService.CurrentEinsatz.Fuehrungsassistent</dd>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(EinsatzService.CurrentEinsatz.Alarmiert))
                                        {
                                            <dt class="col-5">Alarmiert durch</dt>
                                            <dd class="col-7 mb-1">@EinsatzService.CurrentEinsatz.Alarmiert</dd>
                                        }
                                        <dt class="col-5">Teams</dt>
                                        <dd class="col-7 mb-1">@EinsatzService.Teams.Count / @EinsatzService.CurrentEinsatz.AnzahlTeams geplant</dd>
                                    </dl>
                                    break;

                                case KnownPanels.Teams:
                                    @if (!string.IsNullOrWhiteSpace(_teamStatusMessage))
                                    {
                                        <div class="alert @(_teamStatusIsError ? "alert-warning" : "alert-success") alert-dismissible py-2 mb-3" role="alert">
                                            @_teamStatusMessage
                                            <button type="button" class="btn-close" @onclick="() => _teamStatusMessage = string.Empty"></button>
                                        </div>
                                    }
                                    @if (EinsatzService.Teams.Count == 0)
                                    {
                                        <div class="alert alert-info mb-0">
                                            Noch keine Teams vorhanden. Klicken Sie auf "Team anlegen".
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="teams-monitor-list">
                                            @foreach (var team in EinsatzService.Teams
                                                .OrderBy(team => team.IsPausing ? 2 : team.IsRunning ? 0 : 1)
                                                .ThenBy(team => team.TeamName))
                                            {
                                                var isDogConflict = !team.IsRunning && !team.IsPausing
                                                    && !string.IsNullOrWhiteSpace(team.DogId)
                                                    && EinsatzService.IsDogRunning(team.DogId);
                                                var conflictingTeam = isDogConflict
                                                    ? EinsatzService.Teams.FirstOrDefault(t => t.TeamId != team.TeamId && t.IsRunning && t.DogId == team.DogId)
                                                    : null;
                                                <div id="team-@team.TeamId"
                                                     class="monitor-team-card @GetTeamCardClass(team) @(isDogConflict ? "team-dog-blocked" : "")">
                                                    @if (isDogConflict)
                                                    {
                                                        <div class="team-dog-conflict-banner">
                                                            <i class="bi bi-exclamation-triangle-fill me-2"></i>Hund läuft in anderem Team
                                                            @if (conflictingTeam != null)
                                                            {
                                                                <span class="ms-1">— aktiv in <strong>@conflictingTeam.TeamName</strong></span>
                                                            }
                                                        </div>
                                                    }
                                                    <div class="team-card-body" style="border-left: 5px solid @GetTeamColor(team); padding-left: 1rem;">
                                                        <div class="team-card-top">
                                                            <div class="team-name-section">
                                                                <h5>@team.TeamName</h5>
                                                                @if (!string.IsNullOrWhiteSpace(team.DogName))
                                                                {
                                                                    <span class="team-detail">🐕 @team.DogName</span>
                                                                }
                                                                @if (team.IsDroneTeam && !string.IsNullOrWhiteSpace(team.DroneType))
                                                                {
                                                                    <span class="team-detail">
                                                                        <i class="bi bi-airplane me-1"></i>@team.DroneType
                                                                        @{ var _droneEntry = _droneList.FirstOrDefault(d => d.Id == team.DroneId); }
                                                                        @if (_droneEntry is not null && !string.IsNullOrWhiteSpace(_droneEntry.LivestreamUrl))
                                                                        {
                                                                            <a href="@_droneEntry.LivestreamUrl" target="_blank" rel="noopener noreferrer" class="ms-2 text-info" title="Drohne112 Livestream öffnen">
                                                                                <i class="bi bi-camera-video-fill"></i>
                                                                            </a>
                                                                        }
                                                                    </span>
                                                                }
                                                                @if (!string.IsNullOrWhiteSpace(team.HundefuehrerName))
                                                                {
                                                                    <span class="team-detail"><i class="bi bi-person-fill me-1"></i>@team.HundefuehrerName</span>
                                                                }
                                                                @if (team.HelferNames.Count > 0)
                                                                {
                                                                    var helferLabel = team.HelferNames.Count == 1 ? "Helfer" : $"Helfer ({team.HelferNames.Count})";
                                                                    <span class="team-detail"><i class="bi bi-person me-1"></i>@team.HelferNamesJoined (@helferLabel)</span>
                                                                }
                                                                @if (!string.IsNullOrWhiteSpace(team.SearchAreaName))
                                                                {
                                                                    <span class="team-detail"><i class="bi bi-geo-alt me-1"></i>Gebiet: @team.SearchAreaName</span>
                                                                }
                                                            </div>

                                                            <div class="team-timer">
                                                                @if (!team.IsDroneTeam && !team.IsSupportTeam)
                                                                {
                                                                    @if (team.IsPausing)
                                                                    {
                                                                        <div class="timer-display timer-pausing">
                                                                            @if (team.IsPauseComplete)
                                                                            {
                                                                                <i class="bi bi-check-circle-fill text-success me-1"></i>
                                                                            }
                                                                            @FormatPauseRemaining(team)
                                                                        </div>
                                                                        <span class="warning-badge badge @(team.IsPauseComplete ? "bg-success" : "bg-warning text-dark")">
                                                                            @(team.IsPauseComplete ? "PAUSE OK" : "IN PAUSE")
                                                                        </span>
                                                                        <div class="pause-info-line small text-muted mt-1">
                                                                            Gelaufen: @((int)team.RunTimeBeforePause.TotalMinutes) Min. &bull;
                                                                            Pflichtpause: @team.RequiredPauseMinutes Min.
                                                                        </div>
                                                                    }
                                                                    else
                                                                    {
                                                                        <div class="timer-display @GetTimerDisplayClass(team)">@team.ElapsedTime.ToString(@"hh\:mm\:ss")</div>
                                                                        @if (team.IsSecondWarning)
                                                                        {
                                                                            <span class="warning-badge badge bg-danger">KRITISCH</span>
                                                                        }
                                                                        else if (team.IsFirstWarning)
                                                                        {
                                                                            <span class="warning-badge badge bg-warning text-dark">Warnung</span>
                                                                        }
                                                                    }
                                                                }
                                                                else
                                                                {
                                                                    <small class="text-muted">Kein Timer erforderlich</small>
                                                                }
                                                            </div>
                                                        </div>

                                                        <div class="team-card-bottom">
                                                            <div class="team-controls">
                                                                @if (!team.IsDroneTeam && !team.IsSupportTeam)
                                                                {
                                                                    @if (team.IsRunning)
                                                                    {
                                                                        <button class="btn btn-warning" @onclick="() => StopTeamAsync(team.TeamId)">Stopp</button>
                                                                    }
                                                                    else if (!team.IsPausing)
                                                                    {
                                                                        <button class="btn btn-success" disabled="@isDogConflict"
                                                                                @onclick="() => StartTeamAsync(team.TeamId)"
                                                                                title="@(isDogConflict ? "Hund läuft bereits in einem anderen Team" : "Timer starten")">Start</button>
                                                                    }
                                                                    else
                                                                    {
                                                                        <button class="btn btn-success" @onclick="() => StartTeamAsync(team.TeamId)" title="Neuen Einsatz starten (Pause beendet)">Start</button>
                                                                    }
                                                                    <button class="btn btn-secondary btn-team-reset ms-3" disabled="@isDogConflict" @onclick="() => RequestResetTeamAsync(team.TeamId)" title="Timer zurücksetzen"><i class="bi bi-arrow-counterclockwise me-1"></i>Reset</button>
                                                                }
                                                                <button class="btn btn-primary" @onclick="() => EditTeam(team.TeamId)">Bearbeiten</button>
                                                            </div>
                                                            @if (!string.IsNullOrWhiteSpace(team.Notes))
                                                            {
                                                                <div class="team-notes-badge mt-1">
                                                                    <i class="bi bi-sticky-fill me-1 text-warning"></i><span class="small text-muted">@team.Notes</span>
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    break;

                                case KnownPanels.Notizen:
                                    <div class="note-input-section mb-3">
                                        <div class="mb-2">
                                            <label class="form-label fw-bold">Team/Quelle *</label>
                                            <div class="note-source-chips">
                                                @foreach (var team in EinsatzService.Teams.OrderBy(t => t.TeamName))
                                                {
                                                    <button type="button"
                                                            class="btn btn-sm note-source-chip @(_newNoteSourceId == team.TeamId ? "active" : "")"
                                                            @onclick="() => _newNoteSourceId = team.TeamId">
                                                        @team.TeamName
                                                    </button>
                                                }
                                                <button type="button"
                                                        class="btn btn-sm note-source-chip @(_newNoteSourceId == "einsatzleitung" ? "active" : "")"
                                                        @onclick='() => _newNoteSourceId = "einsatzleitung"'>
                                                    <i class="bi bi-shield-fill me-1"></i>EL
                                                </button>
                                            </div>
                                        </div>
                                        <div class="mb-2">
                                            <label class="form-label">Typ</label>
                                            <select class="form-select" @bind="_newNoteType">
                                                <option value="Notiz">Notiz</option>
                                                <option value="Funk">Funk</option>
                                            </select>
                                        </div>
                                        <textarea class="form-control mb-2"
                                                  rows="3"
                                                  @bind="_newNoteText"
                                                  placeholder="Neuer Funkspruch oder Notiz..."></textarea>
                                        <button class="btn btn-primary w-100"
                                                @onclick="AddGlobalNoteAsync"
                                                disabled="@(string.IsNullOrWhiteSpace(_newNoteText) || string.IsNullOrWhiteSpace(_newNoteSourceId))">
                                            <i class="bi bi-send-fill"></i> Hinzufügen
                                        </button>
                                    </div>

                                    @if (_quickNoteTemplates.Count > 0)
                                    {
                                        <div class="mb-3">
                                            <div class="small text-muted mb-2">Schnell-Notiz (mit Zeitstempel)</div>
                                            <div class="d-flex flex-wrap gap-2">
                                                @foreach (var quickTemplate in _quickNoteTemplates)
                                                {
                                                    <button class="btn btn-sm btn-outline-success" @onclick="() => AddQuickNoteAsync(quickTemplate)">@quickTemplate</button>
                                                }
                                            </div>
                                        </div>
                                    }

                                    <div class="notes-list" style="max-height: 500px; overflow-y: auto;">
                                        @if (EinsatzService.GlobalNotes.Count == 0)
                                        {
                                            <p class="text-muted mb-0">Noch keine Eintraege.</p>
                                        }
                                        else
                                        {
                                            @foreach (var note in EinsatzService.GlobalNotes.OrderByDescending(n => n.Timestamp).Take(10))
                                            {
                                                <div class="note-card @GetNoteCssClass(note) @(note.Replies.Count > 0 ? "has-replies" : string.Empty)">
                                                    <div class="d-flex justify-content-between">
                                                        <strong>@(string.IsNullOrWhiteSpace(note.SourceTeamName) ? "System" : note.SourceTeamName)</strong>
                                                        <span class="text-muted">@note.FormattedTimestamp</span>
                                                    </div>
                                                    <div class="mb-2">@note.Text</div>

                                                    <div class="d-flex align-items-center gap-2 mb-2">
                                                        @if (note.IsEdited)
                                                        {
                                                            <span class="badge bg-info">Bearbeitet</span>
                                                        }
                                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleHistoryAsync(note.Id)">Historie</button>
                                                    </div>

                                                    @if (IsHistoryVisible(note.Id))
                                                    {
                                                        var historyEntries = GetHistoryEntries(note.Id);
                                                        if (historyEntries.Count == 0)
                                                        {
                                                            <div class="small text-muted mb-2">Keine Historie vorhanden.</div>
                                                        }
                                                        else
                                                        {
                                                            <div class="small border rounded p-2 mb-2 bg-light-subtle">
                                                                @foreach (var history in historyEntries)
                                                                {
                                                                    <div class="mb-1">
                                                                        <div class="text-muted">@history.FormattedChangedAt · @history.ChangedBy</div>
                                                                        <div><strong>Alt:</strong> @history.OldText</div>
                                                                        <div><strong>Neu:</strong> @history.NewText</div>
                                                                    </div>
                                                                }
                                                            </div>
                                                        }
                                                    }

                                                    <div class="d-flex gap-2 mb-2">
                                                        <select class="form-select form-select-sm" style="max-width: 12rem;"
                                                                value="@GetReplySourceId(note.Id)"
                                                                @onchange="e => SetReplySourceId(note.Id, e.Value?.ToString())">
                                                            <option value="einsatzleitung">Einsatzleitung</option>
                                                            @foreach (var team in EinsatzService.Teams.OrderBy(team => team.TeamName))
                                                            {
                                                                <option value="@team.TeamId">@team.TeamName</option>
                                                            }
                                                        </select>
                                                        <input class="form-control form-control-sm"
                                                               placeholder="Antwort"
                                                               value="@GetReplyText(note.Id)"
                                                               @oninput="e => SetReplyText(note.Id, e.Value?.ToString())" />
                                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => AddReplyAsync(note.Id)">Antworten</button>
                                                    </div>

                                                    @if (note.Replies.Count > 0)
                                                    {
                                                        <div class="small">
                                                            @foreach (var reply in note.Replies.OrderBy(r => r.Timestamp))
                                                            {
                                                                <div class="border-start ps-2 py-1 mb-1">
                                                                    <div class="text-muted">@reply.SourceTeamName · @reply.FormattedTimestamp</div>
                                                                    <div>@reply.Text</div>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        }
                                    </div>
                                    break;

                                case KnownPanels.Wetter:
                                    @if (!string.IsNullOrWhiteSpace(_monitorWeatherError))
                                    {
                                        <div class="alert alert-warning py-2 mb-2 small">@_monitorWeatherError</div>
                                    }
                                    @if (_monitorWeather is not null)
                                    {
                                        <div class="wetter-panel-content">
                                            <div class="d-flex align-items-start gap-3 mb-2">
                                                <div class="fs-2 fw-bold">@_monitorWeather.Temperatur.ToString("0.0")°C</div>
                                                <div>
                                                    @if (_monitorWeather.HatWarnung)
                                                    {
                                                        <div class="mb-1"><span class="badge @_monitorWeather.GetWarnungBadgeClass()">DWD: @_monitorWeather.WarnungsStufe</span></div>
                                                    }
                                                    <div class="small text-muted">
                                                        <i class="bi bi-wind me-1"></i>@_monitorWeather.Windgeschwindigkeit.ToString("0") km/h
                                                        <i class="bi bi-droplet ms-2 me-1"></i>@_monitorWeather.Niederschlag.ToString("0.0") mm/h
                                                    </div>
                                                    @if (_monitorWeather.Windboeen > 0)
                                                    {
                                                        <div class="small text-muted"><i class="bi bi-wind me-1"></i>Böen: @_monitorWeather.Windboeen.ToString("0") km/h</div>
                                                    }
                                                    <div class="small mt-1">
                                                        <span class="badge @GetWeatherRiskBadgeClass(_monitorWeather)">@GetWeatherRiskLabel(_monitorWeather)</span>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="small text-muted mb-2">
                                                DWD &bull; @_monitorWeatherLoadedAtLocal.ToString("HH:mm") Uhr
                                                @if (_monitorWeatherUsingFallback)
                                                {
                                                    <span class="text-warning ms-1">(Fallback)</span>
                                                }
                                            </div>
                                            @{
                                                var forecastItems = GetMonitorForecastItems().ToList();
                                            }
                                            @if (forecastItems.Count > 0)
                                            {
                                                <div class="forecast-strip">
                                                    @foreach (var item in forecastItems)
                                                    {
                                                        <div class="forecast-item @GetForecastRiskClass(item)">
                                                            <div class="small fw-bold">@item.Zeitpunkt.ToLocalTime().ToString("HH:mm")</div>
                                                            <div class="small">@item.Temperatur.ToString("0")°</div>
                                                            <div class="small text-muted">@item.Niederschlag.ToString("0.0") mm</div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                    else if (_monitorWeatherLoading)
                                    {
                                        <div class="text-muted small"><i class="bi bi-cloud me-1"></i>Wetterdaten werden geladen...</div>
                                    }
                                    else
                                    {
                                        <div class="text-muted small"><i class="bi bi-cloud me-1"></i>Wetter: ELW-Position auf Karte setzen</div>
                                    }
                                    break;

                                case KnownPanels.Suchgebiete:
                                    @if (EinsatzService.CurrentEinsatz.SearchAreas.Count == 0)
                                    {
                                        <div class="text-muted small"><i class="bi bi-map me-1"></i>Noch keine Suchgebiete auf der Karte angelegt.</div>
                                    }
                                    else
                                    {
                                        <div class="suchgebiete-list">
                                            @foreach (var area in EinsatzService.CurrentEinsatz.SearchAreas.OrderBy(a => a.Name))
                                            {
                                                var areaTeam = EinsatzService.Teams.FirstOrDefault(t => t.SearchAreaId == area.Id);
                                                <div class="suchgebiet-row @(area.IsCompleted ? "suchgebiet-done" : "")">
                                                    <span class="suchgebiet-color-dot" style="background:@area.Color"></span>
                                                    <div class="suchgebiet-info">
                                                        <div class="fw-semibold small">@area.Name</div>
                                                        <div class="small text-muted">@area.FormattedArea</div>
                                                    </div>
                                                    <div class="suchgebiet-team ms-auto">
                                                        @if (areaTeam is not null)
                                                        {
                                                            <span class="badge" style="background:@GetTeamColor(areaTeam)">@areaTeam.TeamName</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-secondary">Unbesetzt</span>
                                                        }
                                                        @if (area.IsCompleted)
                                                        {
                                                            <span class="badge bg-success ms-1"><i class="bi bi-check-lg"></i></span>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    break;

                                case KnownPanels.Minimap:
                                    <div id="minimap-panel-map"
                                         style="height:@(panel.PanelHeight > 0 ? $"{panel.PanelHeight - 10}px" : "320px");width:100%;border-radius:0.25rem;overflow:hidden;">
                                    </div>
                                    break;

                                case KnownPanels.Vermissten:
                                    @if (EinsatzService.CurrentEinsatz.VermisstenInfo is null)
                                    {
                                        <div class="text-center py-3">
                                            <p class="text-muted small mb-2"><i class="bi bi-person-exclamation me-1"></i>Noch keine Vermissteninfo erfasst.</p>
                                            <button class="btn btn-sm btn-primary" @onclick="OpenVermisstenModal">
                                                <i class="bi bi-plus-circle me-1"></i>Jetzt erfassen
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        var _vi = EinsatzService.CurrentEinsatz.VermisstenInfo!;
                                        <div class="vermissten-panel-view">
                                            <div class="row g-2 small">
                                                <div class="col-6">
                                                    <div class="vermissten-field-label">Name</div>
                                                    <div class="vermissten-field-value fw-semibold">@_vi.VollerName</div>
                                                </div>
                                                <div class="col-3">
                                                    <div class="vermissten-field-label">Alter</div>
                                                    <div class="vermissten-field-value">@(string.IsNullOrWhiteSpace(_vi.Alter) ? "—" : _vi.Alter)</div>
                                                </div>
                                                <div class="col-3">
                                                    <div class="vermissten-field-label">Mobilität</div>
                                                    <div class="vermissten-field-value">@_vi.Mobilitaet</div>
                                                </div>
                                                @if (!string.IsNullOrWhiteSpace(_vi.Kleidung))
                                                {
                                                    <div class="col-12">
                                                        <div class="vermissten-field-label">Kleidung</div>
                                                        <div class="vermissten-field-value">@_vi.Kleidung</div>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(_vi.ZuletztGesehenOrt))
                                                {
                                                    <div class="col-8">
                                                        <div class="vermissten-field-label">Zuletzt gesehen (Ort)</div>
                                                        <div class="vermissten-field-value">@_vi.ZuletztGesehenOrt</div>
                                                    </div>
                                                    <div class="col-4">
                                                        <div class="vermissten-field-label">Uhrzeit</div>
                                                        <div class="vermissten-field-value">@_vi.ZuletztGesehenZeit</div>
                                                    </div>
                                                }
                                                @if (_vi.Suizidrisiko == Einsatzueberwachung.Domain.Models.RisikoStatus.Ja)
                                                {
                                                    <div class="col-12">
                                                        <div class="alert alert-danger py-1 mb-0 small">
                                                            <i class="bi bi-exclamation-triangle-fill me-1"></i><strong>Suizidrisiko</strong>
                                                        </div>
                                                    </div>
                                                }
                                                @if (_vi.Bewaffnet == Einsatzueberwachung.Domain.Models.RisikoStatus.Ja)
                                                {
                                                    <div class="col-12">
                                                        <div class="alert alert-danger py-1 mb-0 small">
                                                            <i class="bi bi-exclamation-triangle-fill me-1"></i><strong>Bewaffnet</strong>
                                                        </div>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(_vi.Vorerkrankungen))
                                                {
                                                    <div class="col-12">
                                                        <div class="vermissten-field-label">Vorerkrankungen</div>
                                                        <div class="vermissten-field-value">@_vi.Vorerkrankungen</div>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(_vi.PolizeiKontaktName))
                                                {
                                                    <div class="col-12 mt-1">
                                                        <div class="vermissten-field-label text-primary"><i class="bi bi-shield me-1"></i>Polizei-Kontakt</div>
                                                        <div class="vermissten-field-value">@_vi.PolizeiKontaktName @(string.IsNullOrWhiteSpace(_vi.PolizeiTelefon) ? "" : $"· {_vi.PolizeiTelefon}")</div>
                                                    </div>
                                                }
                                                @if (_vi.ZuletztAktualisiert.HasValue)
                                                {
                                                    <div class="col-12">
                                                        <div class="text-muted" style="font-size:.7rem;">Stand: @_vi.ZuletztAktualisiert.Value.ToString("dd.MM. HH:mm")</div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                    break;
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

    @if (_showCollarSelectModal)
    {
        var collarSelectTeam = _collarSelectTeamId != null
            ? EinsatzService.Teams.FirstOrDefault(t => t.TeamId == _collarSelectTeamId)
            : null;
        <div class="modal-overlay" @onclick="CollarSelectCancel">
            <div class="modal-modern" style="max-width:460px" @onclick:stopPropagation="true">
