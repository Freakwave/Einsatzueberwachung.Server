@page "/einsatz-start"
@rendermode InteractiveServer

@using Einsatzueberwachung.Domain.Models.Enums
@using Einsatzueberwachung.Domain.Models.Divera

@inject IEinsatzService EinsatzService
@inject IMasterDataService MasterDataService
@inject ISettingsService SettingsService
@inject IDiveraService DiveraService
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Einsatz anlegen</PageTitle>

<div class="container py-4 start-page" style="max-width:1150px;">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4 page-headline-row">
        <div>
            <h1 class="mb-1"><i class="bi bi-alarm me-2"></i>Neuen Einsatz starten</h1>
            <p class="text-muted mb-0">Bitte alle wichtigen Einsatzinformationen eingeben.</p>
        </div>
        <a class="btn btn-outline-secondary" href="/">
            <i class="bi bi-arrow-left me-1"></i>Zurueck
        </a>
    </div>

    @if (_einsatzBereitsAktiv)
    {
        <div class="alert alert-warning d-flex align-items-start gap-3 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill fs-4 mt-1"></i>
            <div>
                <h5 class="alert-heading mb-1">Einsatz bereits aktiv</h5>
                <p class="mb-2">Es läuft bereits ein Einsatz. Bitte beende den aktuellen Einsatz, bevor du einen neuen anlegen kannst.</p>
                <a class="btn btn-warning btn-sm" href="/einsatz-monitor">
                    <i class="bi bi-speedometer2 me-1"></i>Zum aktiven Einsatz
                </a>
            </div>
        </div>
    }
    else
    {
    @* Divera-Alarm-Hinweis — wird oberhalb des Formulars angezeigt wenn Alarm(e) vorliegen *@
    @if (DiveraService.IsConfigured && _diveraAlarms.Any())
    {
        <div class="alert alert-danger d-flex align-items-start gap-3 mb-4 shadow-sm" role="alert" style="border-left: 4px solid var(--bs-danger);">
            <i class="bi bi-broadcast-pin fs-3 flex-shrink-0 mt-1"></i>
            <div class="flex-grow-1">
                <h5 class="alert-heading mb-1">@_diveraAlarms.Count Divera-Alarm@(_diveraAlarms.Count > 1 ? "e" : "") — bitte Felder unten ausfüllen</h5>
                @foreach (var alarm in _diveraAlarms.Take(2))
                {
                    <div class="small mb-1">
                        <strong>@alarm.Title</strong>
                        @if (!string.IsNullOrWhiteSpace(alarm.Address))
                        {
                            <span class="ms-2"><i class="bi bi-geo-alt me-1"></i>@alarm.Address</span>
                        }
                        <span class="ms-2 text-danger-emphasis"><i class="bi bi-clock me-1"></i>@alarm.DateFormatted</span>
                    </div>
                }
                <p class="mb-0 mt-1 small">
                    <i class="bi bi-arrow-down-circle me-1"></i>Alarm unten anklicken um das Formular automatisch zu befüllen.
                </p>
            </div>
        </div>
    }

    <EditForm Model="_model" OnValidSubmit="StartAsync" class="row g-3">
        <DataAnnotationsValidator />

        <div class="col-12 col-lg-7">
            <div class="card h-100 start-section-card">
                <div class="card-header fw-semibold">
                    <i class="bi bi-info-circle me-2"></i>Einsatzinformationen
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-4">
                            <label class="form-label fw-semibold">Typ</label>
                            <InputSelect class="form-select" @bind-Value="_model.IstEinsatz">
                                <option value="true">Einsatz</option>
                                <option value="false">Uebung</option>
                            </InputSelect>
                        </div>

                        <div class="col-12 col-md-4">
                            <label class="form-label fw-semibold">Timer-Start (Alarmierung)</label>
                            <input class="form-control"
                                   type="time"
                                   step="60"
                                   value="@_alarmStartTime"
                                   @onchange="e => _alarmStartTime = e.Value?.ToString() ?? string.Empty" />
                            <div class="form-text">Datum wird automatisch gesetzt.</div>
                        </div>

                        <div class="col-12 col-md-4">
                            <label class="form-label fw-semibold">Einsatznummer</label>
                            <InputText class="form-control" @bind-Value="_model.EinsatzNummer" placeholder="optional" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold">Einsatzort <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="_model.Einsatzort" placeholder="Strasse, Ort oder Koordinate" />
                            <ValidationMessage For="() => _model.Einsatzort" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold">Stichwort</label>
                            <InputText class="form-control" @bind-Value="_model.Stichwort" placeholder="z.B. Vermisstensuche, Personensuche" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold">Karten-Adresse</label>
                            <InputText class="form-control" @bind-Value="_model.MapAddress" placeholder="fuer Leaflet-Suche (optional)" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold">Alarmiert durch (Melder)</label>
                            <InputText class="form-control" @bind-Value="_model.Alarmiert" placeholder="z.B. Polizei, Leitstelle, Angeh&ouml;rige" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold">Staffel-Name</label>
                            <InputText class="form-control" @bind-Value="_model.StaffelName" placeholder="z.B. RHS Musterstadt" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold">Anzahl Teams (geplant)</label>
                            <InputNumber class="form-control" @bind-Value="_model.AnzahlTeams" min="1" max="50" />
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold">Bemerkungen</label>
                            <InputTextArea class="form-control" @bind-Value="_model.ExportPfad" rows="2" placeholder="Lagebeschreibung, Anfahrt, sonstige Hinweise..." />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-5">
            <div class="card start-section-card mb-3">
                <div class="card-header fw-semibold">
                    <i class="bi bi-people me-2"></i>Fuehrungspersonal
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Einsatzleiter</label>
                        <div class="input-group">
                            <select class="form-select" @onchange="e => SetEinsatzleiter(e.Value?.ToString())">
                                <option value="">- aus Stammdaten waehlen -</option>
                                @foreach (var p in EinsatzleiterOptions)
                                {
                                    <option value="@p.Id">@p.FullName</option>
                                }
                            </select>
                            <InputText class="form-control" @bind-Value="_model.Einsatzleiter" placeholder="oder Freitext" />
                        </div>
                    </div>

                    <div>
                        <label class="form-label fw-semibold">Fuehrungsassistent</label>
                        <div class="input-group">
                            <select class="form-select" @onchange="e => SetFuehrungsassistent(e.Value?.ToString())">
                                <option value="">- aus Stammdaten waehlen -</option>
                                @foreach (var p in FuehrungsassistentOptions)
                                {
                                    <option value="@p.Id">@p.FullName</option>
                                }
                            </select>
                            <InputText class="form-control" @bind-Value="_model.Fuehrungsassistent" placeholder="oder Freitext" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card start-section-card">
                <div class="card-header fw-semibold">
                    <i class="bi bi-play-circle me-2"></i>Aktionen
                </div>
                <div class="card-body d-grid gap-2">
                    <button class="btn btn-primary" type="submit" disabled="@_busy">
                        @if (_busy) { <span class="spinner-border spinner-border-sm me-2"></span> }
                        <i class="bi bi-play-fill me-1"></i>Einsatz starten
                    </button>
                    <a class="btn btn-outline-secondary" href="/">Abbrechen</a>
                </div>
            </div>
        </div>

    </EditForm>

    @if (DiveraService.IsConfigured)
    {
        <div class="col-12 mt-3">
            <div class="card start-section-card">
                <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-broadcast-pin me-2"></i>Aus Divera 24/7 importieren</span>
                    @if (_diveraAlarms.Any())
                    {
                        <span class="badge bg-danger">@_diveraAlarms.Count aktiv</span>
                    }
                </div>
                <div class="card-body">
                    @if (_diveraLoading)
                    {
                        <div class="text-center py-3">
                            <span class="spinner-border spinner-border-sm me-2"></span>Lade Divera-Alarme...
                        </div>
                    }
                    else if (_diveraAlarms.Any())
                    {
                        <p class="text-muted small mb-2">Alarm anklicken, um die Felder automatisch zu befüllen:</p>
                        <div class="list-group">
                            @foreach (var alarm in _diveraAlarms)
                            {
                                <button class="list-group-item list-group-item-action"
                                        type="button"
                                        @onclick="() => ImportFromDivera(alarm)">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="flex-grow-1">
                                            <div class="d-flex align-items-center gap-2 mb-1">
                                                @if (alarm.Priority)
                                                {
                                                    <span class="badge bg-danger"><i class="bi bi-exclamation-circle"></i> PRIO</span>
                                                }
                                                <strong>@alarm.Title</strong>
                                            </div>
                                            @if (!string.IsNullOrWhiteSpace(alarm.Text))
                                            {
                                                <div class="small mb-1">@alarm.Text</div>
                                            }
                                            <div class="d-flex flex-wrap gap-2 small text-muted">
                                                @if (!string.IsNullOrWhiteSpace(alarm.Address))
                                                {
                                                    <span><i class="bi bi-geo-alt me-1"></i>@alarm.Address</span>
                                                }
                                                <span><i class="bi bi-clock me-1"></i>@alarm.DateFormatted</span>
                                                @if (alarm.Lat.HasValue && alarm.Lng.HasValue)
                                                {
                                                    <span class="text-success"><i class="bi bi-crosshair me-1"></i>GPS vorhanden</span>
                                                }
                                            </div>
                                        </div>
                                        <div class="text-end ms-3 flex-shrink-0">
                                            <span class="badge bg-success d-block mb-1">@alarm.CountKomme kommen</span>
                                            @if (alarm.CountSpaeter > 0)
                                            {
                                                <span class="badge bg-warning text-dark d-block mb-1">@alarm.CountSpaeter später</span>
                                            }
                                            @if (alarm.CountKommeNicht > 0)
                                            {
                                                <span class="badge bg-danger d-block">@alarm.CountKommeNicht kommen nicht</span>
                                            }
                                        </div>
                                    </div>
                                </button>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-2"><i class="bi bi-check-circle me-1"></i>Keine aktiven Alarme in Divera.</p>
                    }
                    <button class="btn btn-outline-primary btn-sm mt-2" @onclick="LoadDiveraAlarmsAsync" disabled="@_diveraLoading">
                        <i class="bi bi-arrow-clockwise me-1"></i>Alarme aktualisieren
                    </button>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_status))
    {
        <div class="alert @(_error ? "alert-danger" : "alert-success") mt-3" role="alert">
            @_status
        </div>
    }
    } @* end else *@
</div>

@code {
    private static readonly string[] AlarmTimeFormats =
    {
        "H:mm",
        "HH:mm",
        "H:mm:ss",
        "HH:mm:ss"
    };

    private EinsatzData _model = new()
    {
        EinsatzDatum = DateTime.Now,
        AnzahlTeams = 1
    };

    private List<PersonalEntry> _personal = new();
    private string _alarmStartTime = DateTime.Now.ToString("HH:mm");
    private DateTime? _clientNow;
    private string _status = string.Empty;
    private bool _error;
    private bool _busy;
    private bool _einsatzBereitsAktiv;

    // Divera 24/7 Import-Felder
    private List<DiveraAlarm> _diveraAlarms = new();
    private bool _diveraLoading;

    private sealed class ClientLocalNowDto
    {
        public int Year { get; set; }
        public int Month { get; set; }
        public int Day { get; set; }
        public int Hour { get; set; }
        public int Minute { get; set; }
        public int Second { get; set; }
    }

    private IEnumerable<PersonalEntry> ActivePersonnel => _personal
        .Where(person => person.IsActive)
        .OrderBy(person => person.Nachname)
        .ThenBy(person => person.Vorname);

    private IEnumerable<PersonalEntry> EinsatzleiterOptions => ActivePersonnel
        .Where(person => person.Skills.HasFlag(PersonalSkills.Einsatzleiter));

    private IEnumerable<PersonalEntry> FuehrungsassistentOptions => ActivePersonnel
        .Where(person => person.Skills.HasFlag(PersonalSkills.Fuehrungsassistent));

    protected override async Task OnInitializedAsync()
    {
        var einsatz = EinsatzService.CurrentEinsatz;
        _einsatzBereitsAktiv = !string.IsNullOrWhiteSpace(einsatz.Einsatzort)
            && einsatz.EinsatzEnde is null;

        if (_einsatzBereitsAktiv)
        {
            return;
        }

        var personalTask = MasterDataService.GetPersonalListAsync();
        var settingsTask = SettingsService.GetStaffelSettingsAsync();

        await Task.WhenAll(personalTask, settingsTask);

        _personal = personalTask.Result;
        var staffelSettings = settingsTask.Result;

        if (!string.IsNullOrWhiteSpace(staffelSettings.StaffelName))
        {
            _model.StaffelName = staffelSettings.StaffelName;
        }

        _model.StaffelAdresse = staffelSettings.StaffelAdresse;
        _model.StaffelTelefon = staffelSettings.StaffelTelefon;
        _model.StaffelEmail = staffelSettings.StaffelEmail;
        _model.StaffelLogoPfad = staffelSettings.StaffelLogoPfad;

        var alarmBase = _model.AlarmierungsZeit ?? DateTime.Now;
        _alarmStartTime = alarmBase.ToString("HH:mm");

        // Divera-Alarme laden wenn konfiguriert
        if (DiveraService.IsConfigured)
        {
            await LoadDiveraAlarmsAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await RefreshClientNowAsync();

        if (_clientNow.HasValue)
        {
            var now = _clientNow.Value;
            _alarmStartTime = now.ToString("HH:mm");
            _model.AlarmierungsZeit = now;
            _model.EinsatzDatum = now;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshClientNowAsync()
    {
        try
        {
            var dto = await JS.InvokeAsync<ClientLocalNowDto>("layoutTools.getClientLocalNow");
            _clientNow = new DateTime(dto.Year, dto.Month, dto.Day, dto.Hour, dto.Minute, dto.Second, DateTimeKind.Unspecified);
        }
        catch
        {
            _clientNow = null;
        }
    }

    private void SetEinsatzleiter(string? id)
    {
        if (string.IsNullOrWhiteSpace(id)) return;
        var p = _personal.FirstOrDefault(x => x.Id == id);
        if (p is not null) _model.Einsatzleiter = p.FullName;
    }

    private void SetFuehrungsassistent(string? id)
    {
        if (string.IsNullOrWhiteSpace(id)) return;
        var p = _personal.FirstOrDefault(x => x.Id == id);
        if (p is not null) _model.Fuehrungsassistent = p.FullName;
    }

    private async Task StartAsync()
    {
        await RefreshClientNowAsync();

        if (string.IsNullOrWhiteSpace(_model.Einsatzort))
        {
            _status = "Bitte Einsatzort ausfüllen.";
            _error = true;
            return;
        }

        if (!TryPrepareAlarmTime())
        {
            _status = "Alarmzeit ungueltig. Bitte Format HH:mm verwenden.";
            _error = true;
            return;
        }

        _busy = true;
        _status = string.Empty;
        try
        {
            _model.EinsatzDatum = _clientNow ?? DateTime.Now;
            await EinsatzService.StartEinsatzAsync(_model);
            _status = "Einsatz wurde gestartet.";
            _error = false;
            await Task.Delay(800);
            Navigation.NavigateTo("/einsatz-monitor");
        }
        catch (Exception ex)
        {
            _status = $"Fehler: {ex.Message}";
            _error = true;
        }
        finally
        {
            _busy = false;
        }
    }

    private bool TryPrepareAlarmTime()
    {
        var now = _clientNow ?? DateTime.Now;

        if (string.IsNullOrWhiteSpace(_alarmStartTime))
        {
            _model.AlarmierungsZeit = now;
            return true;
        }

        if (DateTime.TryParseExact(_alarmStartTime.Trim(), AlarmTimeFormats, System.Globalization.CultureInfo.GetCultureInfo("de-DE"), System.Globalization.DateTimeStyles.None, out var parsed)
            || DateTime.TryParse(_alarmStartTime.Trim(), System.Globalization.CultureInfo.GetCultureInfo("de-DE"), System.Globalization.DateTimeStyles.None, out parsed))
        {
            parsed = new DateTime(now.Year, now.Month, now.Day, parsed.Hour, parsed.Minute, 0);

            if (parsed > now.AddMinutes(1))
            {
                parsed = parsed.AddDays(-1);
            }

            _model.AlarmierungsZeit = parsed;
            return true;
        }

        return false;
    }

    private async Task LoadDiveraAlarmsAsync()
    {
        _diveraLoading = true;
        try
        {
            _diveraAlarms = await DiveraService.GetActiveAlarmsAsync();
        }
        catch
        {
            _diveraAlarms = new();
        }
        finally
        {
            _diveraLoading = false;
        }
    }

    private void ImportFromDivera(DiveraAlarm alarm)
    {
        // Einsatzort immer aus der Adresse
        _model.Einsatzort = alarm.Address;

        // Karten-Adresse: GPS-Koordinaten bevorzugen (direkter Leaflet-Zoom), sonst Adresse
        if (alarm.Lat.HasValue && alarm.Lng.HasValue)
        {
            _model.MapAddress = string.Format(
                System.Globalization.CultureInfo.InvariantCulture,
                "{0:F6},{1:F6}", alarm.Lat.Value, alarm.Lng.Value);
            // GPS-Position auch als ELW-Position setzen
            _model.ElwPosition = (alarm.Lat.Value, alarm.Lng.Value);
        }
        else
        {
            _model.MapAddress = alarm.Address;
        }

        // Stichwort = Alarm-Titel aus Divera (z.B. "Vermisstensuche")
        _model.Stichwort = alarm.Title;

        // Alarmiert bleibt leer — muss manuell eingetragen werden (Leitstelle, Polizei etc.)
        _model.Alarmiert = string.Empty;

        _model.EinsatzNummer = $"D-{alarm.Id}";
        _model.IstEinsatz = true;

        // Lagetext als Bemerkungen
        _model.ExportPfad = string.IsNullOrWhiteSpace(alarm.Text)
            ? alarm.Title
            : $"{alarm.Title}: {alarm.Text}";

        if (alarm.Date != default)
        {
            _model.AlarmierungsZeit = alarm.Date;
            _alarmStartTime = alarm.Date.ToString("HH:mm");
        }

        StateHasChanged();
    }
}

