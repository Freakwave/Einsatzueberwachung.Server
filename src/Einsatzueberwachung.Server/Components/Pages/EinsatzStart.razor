@page "/einsatz-start"
@rendermode InteractiveServer

@using Einsatzueberwachung.Domain.Models.Enums
@using Einsatzueberwachung.Domain.Models.Divera
@using Einsatzueberwachung.Server.Training

<PageTitle>Einsatz anlegen</PageTitle>

<div class="es-page">

    @if (_einsatzBereitsAktiv)
    {
        <div class="es-active-warning">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div class="flex-grow-1">
                <h5 class="mb-1">Einsatz bereits aktiv</h5>
                <p class="mb-2 small">Es läuft bereits ein Einsatz. Bitte beende den aktuellen Einsatz, bevor du einen neuen anlegen kannst.</p>
                <a class="btn btn-warning btn-sm" href="/einsatz-monitor">
                    <i class="bi bi-speedometer2 me-1"></i>Zum aktiven Einsatz
                </a>
            </div>
            <a class="btn btn-outline-secondary btn-sm" href="/"><i class="bi bi-arrow-left me-1"></i>Zurück</a>
        </div>
    }
    else
    {
    <div class="es-headline">
        <div class="es-headline-title">
            <i class="bi bi-alarm"></i>
            <span>Neuen Einsatz starten</span>
        </div>
        <a class="es-back" href="/"><i class="bi bi-arrow-left me-1"></i>Zurück</a>
    </div>

    <EditForm Model="_model" OnValidSubmit="StartAsync" class="es-form">
        <DataAnnotationsValidator />

        <!-- 1) SZENARIO HERO -->
        <section class="es-szenario-hero @(_szenarioMissing ? "is-missing" : "")"
                 role="radiogroup"
                 aria-label="Einsatz-Szenario wählen">
            <header class="es-section-header">
                <i class="bi bi-diagram-3"></i>
                <span>Szenario</span>
                <span class="es-required">Pflicht</span>
                @if (_model.Szenario != EinsatzSzenarioType.Unbestimmt)
                {
                    <span class="es-section-meta">@_model.Szenario.GetDescription()</span>
                }
            </header>
            <div class="es-tile-grid">
                @foreach (var sz in new[] { EinsatzSzenarioType.Mantrailer, EinsatzSzenarioType.Flaeche, EinsatzSzenarioType.Truemmer, EinsatzSzenarioType.Sonstige })
                {
                    var selected = _model.Szenario == sz;
                    <button type="button"
                            class="es-tile @(selected ? "is-selected" : "")"
                            role="radio"
                            aria-checked="@selected.ToString().ToLowerInvariant()"
                            style="--tile-accent:@sz.GetColorHex();"
                            @onclick="() => SelectSzenario(sz)">
                        <i class="bi @sz.GetIconClass()"></i>
                        <span class="es-tile-name">@sz.GetDisplayName()</span>
                        <span class="es-tile-desc">@sz.GetDescription()</span>
                    </button>
                }
            </div>
        </section>

        <!-- 2) EINSATZORT HERO -->
        <section class="es-einsatzort">
            <label class="es-label" for="es-einsatzort-input">
                Einsatzort <span class="es-required-mark">*</span>
            </label>
            <input id="es-einsatzort-input"
                   type="text"
                   class="es-input es-input-hero @(_einsatzortMissing ? "is-invalid" : "")"
                   value="@_model.Einsatzort"
                   placeholder="Straße, Ort oder Koordinate — wird auch als Karten-Adresse übernommen"
                   @oninput="OnEinsatzortInput" />
        </section>

        <!-- 3) HAUPT-GRID: Lagedaten | Führung -->
        <div class="es-main-grid">

            <!-- LAGEDATEN -->
            <section class="es-block es-block-lage">
                <header class="es-section-header">
                    <i class="bi bi-clipboard-data"></i>
                    <span>Lagedaten</span>

                    @if (_trainerStartPreset is not null)
                    {
                        <button type="button" class="es-trainer-chip" @onclick="ToggleTrainerDetails"
                                title="Trainer-Lage geladen"
                                aria-expanded="@_trainerDetailsOpen">
                            <i class="bi bi-mortarboard-fill"></i>
                            <span>Trainer-Lage</span>
                            <i class="bi @(_trainerDetailsOpen ? "bi-chevron-up" : "bi-chevron-down")"></i>
                        </button>
                    }
                </header>

                @if (_trainerStartPreset is not null && _trainerDetailsOpen)
                {
                    <div class="es-trainer-details">
                        <div class="small">
                            <strong>@_trainerStartPreset.ExerciseName</strong> · @_trainerStartPreset.ScenarioCategory
                        </div>
                        <div class="small text-muted mt-1">@_trainerStartPreset.BriefingText</div>
                        <div class="d-flex gap-2 mt-2">
                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="ApplyTrainerPreset">
                                <i class="bi bi-arrow-repeat me-1"></i>Erneut anwenden
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ClearTrainerPresetAsync">
                                <i class="bi bi-x-circle me-1"></i>Entfernen
                            </button>
                        </div>
                    </div>
                }

                <div class="es-grid-row es-grid-3">
                    <div class="es-field">
                        <label class="es-label">Typ</label>
                        <div class="es-pill-toggle" role="radiogroup" aria-label="Einsatztyp">
                            <button type="button"
                                    class="es-pill @(_model.IstEinsatz ? "is-active is-active-danger" : "")"
                                    role="radio"
                                    aria-checked="@_model.IstEinsatz.ToString().ToLowerInvariant()"
                                    @onclick="() => _model.IstEinsatz = true">
                                <i class="bi bi-exclamation-triangle"></i> Einsatz
                            </button>
                            <button type="button"
                                    class="es-pill @(!_model.IstEinsatz ? "is-active" : "")"
                                    role="radio"
                                    aria-checked="@((!_model.IstEinsatz).ToString().ToLowerInvariant())"
                                    @onclick="() => _model.IstEinsatz = false">
                                <i class="bi bi-mortarboard"></i> Übung
                            </button>
                        </div>
                    </div>

                    <div class="es-field">
                        <label class="es-label" for="es-alarm-input">Alarmiert um</label>
                        <input id="es-alarm-input"
                               class="es-input"
                               type="time"
                               step="60"
                               value="@_alarmStartTime"
                               @onchange="e => _alarmStartTime = e.Value?.ToString() ?? string.Empty" />
                    </div>

                    <div class="es-field">
                        <label class="es-label">Anzahl Teams</label>
                        <div class="es-stepper" @onkeydown="OnStepperKeyDown">
                            <button type="button" class="es-stepper-btn"
                                    @onclick="() => _model.AnzahlTeams = Math.Max(1, _model.AnzahlTeams - 1)"
                                    disabled="@(_model.AnzahlTeams <= 1)"
                                    aria-label="Weniger">−</button>
                            <input class="es-stepper-input"
                                   type="number" min="1" max="50"
                                   value="@_model.AnzahlTeams"
                                   @onchange="e => _model.AnzahlTeams = Math.Clamp(
                                       int.TryParse(e.Value?.ToString(), out var v) ? v : 1, 1, 50)"
                                   @onkeydown:preventDefault="true" />
                            <button type="button" class="es-stepper-btn"
                                    @onclick="() => _model.AnzahlTeams = Math.Min(50, _model.AnzahlTeams + 1)"
                                    disabled="@(_model.AnzahlTeams >= 50)"
                                    aria-label="Mehr">+</button>
                        </div>
                    </div>
                </div>

                <div class="es-grid-row es-grid-2">
                    <div class="es-field">
                        <label class="es-label">Stichwort</label>
                        <InputText class="es-input" @bind-Value="_model.Stichwort" placeholder="z.B. Vermisstensuche" />
                    </div>
                    <div class="es-field">
                        <label class="es-label">Einsatznummer</label>
                        <InputText class="es-input" @bind-Value="_model.EinsatzNummer" placeholder="optional" />
                    </div>
                </div>

                <div class="es-grid-row es-grid-2">
                    <div class="es-field">
                        <label class="es-label">
                            Karten-Adresse
                            @if (!_mapAddressUserDirty)
                            {
                                <i class="bi bi-link-45deg es-sync-icon"
                                   title="Wird automatisch aus Einsatzort übernommen — beim Tippen losgelöst"></i>
                            }
                        </label>
                        <input type="text"
                               class="es-input"
                               value="@_model.MapAddress"
                               placeholder="für Leaflet-Suche (optional)"
                               @oninput="OnMapAddressInput" />
                    </div>
                    <div class="es-field">
                        <label class="es-label">Alarmiert durch (Melder)</label>
                        <InputText class="es-input" @bind-Value="_model.Alarmiert" placeholder="Polizei, Leitstelle, …" />
                    </div>
                </div>

                <div class="es-grid-row es-grid-1">
                    <div class="es-field">
                        <label class="es-label">Bemerkungen</label>
                        <InputTextArea class="es-input es-textarea"
                                       @bind-Value="_model.ExportPfad"
                                       rows="2"
                                       placeholder="Lagebeschreibung, Anfahrt, sonstige Hinweise…" />
                    </div>
                </div>
            </section>

            <!-- FÜHRUNG + START -->
            <aside class="es-block es-block-fuehrung">
                <header class="es-section-header">
                    <i class="bi bi-people"></i>
                    <span>Führung</span>
                </header>

                <div class="es-field">
                    <label class="es-label">Einsatzleiter</label>
                    <div class="es-input-group">
                        <select class="es-input es-input-select" @onchange="e => SetEinsatzleiter(e.Value?.ToString())">
                            <option value="">— aus Stammdaten —</option>
                            @foreach (var p in EinsatzleiterOptions)
                            {
                                <option value="@p.Id">@p.FullName</option>
                            }
                        </select>
                        <InputText class="es-input es-input-text" @bind-Value="_model.Einsatzleiter" placeholder="oder Freitext" />
                    </div>
                </div>

                <div class="es-field">
                    <label class="es-label">Führungsassistent</label>
                    <div class="es-input-group">
                        <select class="es-input es-input-select" @onchange="e => SetFuehrungsassistent(e.Value?.ToString())">
                            <option value="">— aus Stammdaten —</option>
                            @foreach (var p in FuehrungsassistentOptions)
                            {
                                <option value="@p.Id">@p.FullName</option>
                            }
                        </select>
                        <InputText class="es-input es-input-text" @bind-Value="_model.Fuehrungsassistent" placeholder="oder Freitext" />
                    </div>
                </div>

                <div class="es-field es-staffel">
                    <label class="es-label">Staffel</label>
                    <InputText class="es-input es-input-staffel" @bind-Value="_model.StaffelName" placeholder="Staffel-Name" />
                </div>

                <div class="es-cta">
                    @if (!string.IsNullOrWhiteSpace(_status) && _error)
                    {
                        <div class="es-cta-error" role="alert">
                            <i class="bi bi-exclamation-circle"></i> @_status
                        </div>
                    }
                    <button class="es-start-btn" type="submit" disabled="@_busy">
                        @if (_busy)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        else
                        {
                            <i class="bi bi-play-fill"></i>
                        }
                        Einsatz starten
                    </button>
                    <a class="es-cancel-link" href="/">Abbrechen</a>
                </div>
            </aside>
        </div>

        @if (!string.IsNullOrWhiteSpace(_status) && !_error)
        {
            <div class="es-success-toast" role="status">
                <i class="bi bi-check-circle me-1"></i>@_status
            </div>
        }

    </EditForm>

    <!-- DIVERA FOOTER-STRIP -->
    @if (DiveraService.IsConfigured && _diveraAlarms.Any() && !_diveraDrawerOpen)
    {
        <button type="button" class="es-divera-strip" @onclick="ToggleDiveraDrawer">
            <i class="bi bi-broadcast-pin"></i>
            <strong>@_diveraAlarms.Count Divera-Alarm@(_diveraAlarms.Count > 1 ? "e" : "")</strong>
            <span class="es-divera-strip-hint">verfügbar — anklicken zum Übernehmen</span>
            <i class="bi bi-chevron-up es-divera-strip-arrow"></i>
        </button>
    }

    <!-- DIVERA SIDE-SHEET -->
    @if (_diveraDrawerOpen)
    {
        <div class="es-drawer-backdrop" @onclick="ToggleDiveraDrawer"></div>
        <aside class="es-drawer" aria-label="Divera-Alarme">
            <header class="es-drawer-header">
                <i class="bi bi-broadcast-pin"></i>
                <strong>Divera 24/7 — aktive Alarme</strong>
                <button type="button" class="es-drawer-close" @onclick="ToggleDiveraDrawer" aria-label="Schließen">
                    <i class="bi bi-x-lg"></i>
                </button>
            </header>
            <div class="es-drawer-body">
                @if (_diveraLoading)
                {
                    <div class="text-center py-3">
                        <span class="spinner-border spinner-border-sm me-2"></span>Lade Alarme…
                    </div>
                }
                else if (_diveraAlarms.Any())
                {
                    <p class="text-muted small mb-2">Alarm anklicken, um die Felder automatisch zu befüllen:</p>
                    <div class="es-drawer-list">
                        @foreach (var alarm in _diveraAlarms)
                        {
                            <button class="es-drawer-item" type="button" @onclick="() => ImportFromDivera(alarm)">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    @if (alarm.Priority)
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-exclamation-circle"></i> PRIO</span>
                                    }
                                    <strong>@alarm.Title</strong>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(alarm.Text))
                                {
                                    <div class="small mb-1 text-muted">@alarm.Text</div>
                                }
                                <div class="d-flex flex-wrap gap-2 small text-muted">
                                    @if (!string.IsNullOrWhiteSpace(alarm.Address))
                                    {
                                        <span><i class="bi bi-geo-alt me-1"></i>@alarm.Address</span>
                                    }
                                    <span><i class="bi bi-clock me-1"></i>@alarm.DateFormatted</span>
                                    @if (alarm.Lat.HasValue && alarm.Lng.HasValue)
                                    {
                                        <span class="text-success"><i class="bi bi-crosshair me-1"></i>GPS</span>
                                    }
                                </div>
                                <div class="d-flex flex-wrap gap-1 mt-2">
                                    <span class="badge bg-secondary">@alarm.CountKomme geantwortet</span>
                                    @if (alarm.Count30Min > 0)
                                    {
                                        <span class="badge bg-success">@alarm.Count30Min · 30 Min</span>
                                    }
                                    @if (alarm.Count1Std > 0)
                                    {
                                        <span class="badge bg-warning text-dark">@alarm.Count1Std · 1 Std</span>
                                    }
                                    @if (alarm.CountNichtEinsatzbereit > 0)
                                    {
                                        <span class="badge bg-danger">@alarm.CountNichtEinsatzbereit · n.e.</span>
                                    }
                                </div>
                            </button>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mb-2"><i class="bi bi-check-circle me-1"></i>Keine aktiven Alarme.</p>
                }
            </div>
            <footer class="es-drawer-footer">
                <button class="btn btn-outline-primary btn-sm" @onclick="LoadDiveraAlarmsAsync" disabled="@_diveraLoading">
                    <i class="bi bi-arrow-clockwise me-1"></i>Aktualisieren
                </button>
            </footer>
        </aside>
    }

    } @* end else (not _einsatzBereitsAktiv) *@
</div>
