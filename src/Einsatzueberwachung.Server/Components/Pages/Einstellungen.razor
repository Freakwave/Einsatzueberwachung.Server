@page "/einstellungen"
@rendermode InteractiveServer
@using System.Text.Json
@using System.IO.Compression
@using System.Text

<PageTitle>Einstellungen</PageTitle>

<div class="cfg-page">

    <!-- STICKY HEADER -->
    <header class="cfg-header">
        <div class="cfg-header-title">
            <i class="bi bi-folder2-open"></i>
            <span>Einstellungen</span>
        </div>
        <button type="button" class="cfg-save-btn" @onclick="SaveAsync">
            <i class="bi bi-floppy-fill"></i>
            <span>Speichern</span>
        </button>
    </header>

    <div class="cfg-body">

        <!-- AKTENREGISTER (links) -->
        <nav class="cfg-register" aria-label="Einstellungen-Bereiche">
            <button type="button"
                    class="cfg-tab @(_activeTab == SettingsTab.Staffel ? "is-active" : "")"
                    @onclick="() => SetActiveTab(SettingsTab.Staffel)">
                <span class="cfg-tab-label"><i class="bi bi-building me-2"></i>Staffel</span>
                @if (StaffelComplete)
                {
                    <span class="cfg-tab-badge ok"><i class="bi bi-check-lg"></i></span>
                }
                else
                {
                    <span class="cfg-tab-badge muted">unvollständig</span>
                }
            </button>

            <button type="button"
                    class="cfg-tab @(_activeTab == SettingsTab.Einsatzbetrieb ? "is-active" : "")"
                    @onclick="() => SetActiveTab(SettingsTab.Einsatzbetrieb)">
                <span class="cfg-tab-label"><i class="bi bi-clipboard-data me-2"></i>Einsatzbetrieb</span>
            </button>

            <button type="button"
                    class="cfg-tab @(_activeTab == SettingsTab.Erscheinungsbild ? "is-active" : "")"
                    @onclick="() => SetActiveTab(SettingsTab.Erscheinungsbild)">
                <span class="cfg-tab-label"><i class="bi bi-palette me-2"></i>Erscheinungsbild</span>
            </button>

            <button type="button"
                    class="cfg-tab @(_activeTab == SettingsTab.Integration ? "is-active" : "")"
                    @onclick="() => SetActiveTab(SettingsTab.Integration)">
                <span class="cfg-tab-label"><i class="bi bi-broadcast-pin me-2"></i>Integration</span>
                <span class="cfg-tab-badge ok">@IntegrationActiveCount aktiv</span>
            </button>

            <button type="button"
                    class="cfg-tab @(_activeTab == SettingsTab.System ? "is-active" : "")"
                    @onclick="() => SetActiveTab(SettingsTab.System)">
                <span class="cfg-tab-label"><i class="bi bi-cpu me-2"></i>System</span>
                @if (UpdateAvailable)
                {
                    <span class="cfg-tab-badge warning"><i class="bi bi-arrow-up-circle"></i> Update</span>
                }
            </button>

            <button type="button"
                    class="cfg-tab @(_activeTab == SettingsTab.Wartung ? "is-active" : "")"
                    @onclick="() => SetActiveTab(SettingsTab.Wartung)">
                <span class="cfg-tab-label"><i class="bi bi-database-gear me-2"></i>Wartung</span>
                <span class="cfg-tab-badge @BackupAgeSeverity">Backup @BackupAgeLabel</span>
            </button>

            <a class="cfg-tab cfg-tab-link" href="/trainer">
                <span class="cfg-tab-label"><i class="bi bi-mortarboard-fill me-2"></i>Trainerbereich</span>
                <i class="bi bi-arrow-right cfg-tab-arrow"></i>
            </a>
        </nav>

        <!-- AKTIVER PANE (rechts) -->
        <main class="cfg-pane">

            @if (_activeTab == SettingsTab.Staffel)
            {
                <h2 class="cfg-pane-title"><i class="bi bi-building me-2"></i>Staffel</h2>
                <p class="cfg-pane-subtitle">Stammdaten der Staffel und Logos für Berichte.</p>

                <div class="cfg-section">
                    <h3 class="cfg-sub-header">Kontaktdaten</h3>
                    <div class="cfg-grid cfg-grid-2">
                        <div class="cfg-field">
                            <label class="cfg-label">Staffel-Name</label>
                            <InputText class="cfg-input" placeholder="z.B. RHS Speyer" @bind-Value="_staffelSettings.StaffelName" />
                        </div>
                        <div class="cfg-field">
                            <label class="cfg-label">Adresse</label>
                            <InputText class="cfg-input" placeholder="Straße, PLZ Ort" @bind-Value="_staffelSettings.StaffelAdresse" />
                        </div>
                        <div class="cfg-field">
                            <label class="cfg-label">Telefon</label>
                            <InputText class="cfg-input" placeholder="+49 …" @bind-Value="_staffelSettings.StaffelTelefon" />
                        </div>
                        <div class="cfg-field">
                            <label class="cfg-label">E-Mail</label>
                            <InputText class="cfg-input" placeholder="kontakt@staffel.de" @bind-Value="_staffelSettings.StaffelEmail" />
                        </div>
                    </div>
                </div>

                <div class="cfg-section">
                    <h3 class="cfg-sub-header">Logos</h3>
                    <div class="cfg-grid cfg-grid-2">
                        <div class="cfg-logo-card">
                            <div class="cfg-logo-meta">
                                <span class="cfg-label">Staffel-Logo</span>
                                <span class="cfg-help">PDF + Anzeige im Header</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(_staffelSettings.StaffelLogoPfad))
                            {
                                <code class="cfg-logo-path">@_staffelSettings.StaffelLogoPfad</code>
                            }
                            <div class="cfg-logo-actions">
                                <InputFile OnChange="UploadStaffelLogoAsync" accept=".png,.jpg,.jpeg,.webp,.svg,image/*" />
                                @if (!string.IsNullOrWhiteSpace(_staffelSettings.StaffelLogoPfad))
                                {
                                    <button class="cfg-btn cfg-btn-ghost-danger" @onclick="ClearStaffelLogoAsync" type="button">
                                        <i class="bi bi-trash"></i> Entfernen
                                    </button>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(_logoStatus))
                            {
                                <div class="cfg-inline-status @(_logoStatusIsError ? "is-error" : "is-ok")">@_logoStatus</div>
                            }
                        </div>

                        <div class="cfg-logo-card">
                            <div class="cfg-logo-meta">
                                <span class="cfg-label">PDF-Logo</span>
                                <span class="cfg-help">überschreibt Staffel-Logo im Bericht</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(_staffelSettings.PdfLogoPfad))
                            {
                                <code class="cfg-logo-path">@_staffelSettings.PdfLogoPfad</code>
                            }
                            <div class="cfg-logo-actions">
                                <InputFile OnChange="UploadPdfLogoAsync" accept=".png,.jpg,.jpeg,.webp,image/*" />
                                @if (!string.IsNullOrWhiteSpace(_staffelSettings.PdfLogoPfad))
                                {
                                    <button class="cfg-btn cfg-btn-ghost-danger" @onclick="ClearPdfLogoAsync" type="button">
                                        <i class="bi bi-trash"></i> Entfernen
                                    </button>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(_pdfLogoStatus))
                            {
                                <div class="cfg-inline-status @(_pdfLogoStatusIsError ? "is-error" : "is-ok")">@_pdfLogoStatus</div>
                            }
                        </div>
                    </div>
                </div>
            }

            else if (_activeTab == SettingsTab.Einsatzbetrieb)
            {
                <h2 class="cfg-pane-title"><i class="bi bi-clipboard-data me-2"></i>Einsatzbetrieb</h2>
                <p class="cfg-pane-subtitle">Operative Defaults: Timer, Pausen, Karte, Akustik, Notizvorlagen.</p>

                <div class="cfg-section">
                    <h3 class="cfg-sub-header"><i class="bi bi-alarm me-1"></i>Default-Warnungen</h3>
                    <div class="cfg-grid cfg-grid-2">
                        <div class="cfg-field">
                            <label class="cfg-label">1. Warnung (Min)</label>
                            <InputNumber class="cfg-input" @bind-Value="_appSettings.DefaultFirstWarningMinutes" />
                            <span class="cfg-help">Standard 45</span>
                        </div>
                        <div class="cfg-field">
                            <label class="cfg-label">2. Warnung (Min)</label>
                            <InputNumber class="cfg-input" @bind-Value="_appSettings.DefaultSecondWarningMinutes" />
                            <span class="cfg-help">Standard 60</span>
                        </div>
                    </div>
                </div>

                <div class="cfg-section">
                    <h3 class="cfg-sub-header"><i class="bi bi-hourglass-split me-1"></i>Hundepausen</h3>
                    <div class="cfg-grid cfg-grid-3">
                        <div class="cfg-field">
                            <label class="cfg-label">Schwelle (Min)</label>
                            <InputNumber class="cfg-input" @bind-Value="_appSettings.PauseThresholdMinutes" />
                            <span class="cfg-help">Std. 20</span>
                        </div>
                        <div class="cfg-field">
                            <label class="cfg-label">Kurze Pause (Min)</label>
                            <InputNumber class="cfg-input" @bind-Value="_appSettings.PauseMinutesShortRun" />
                            <span class="cfg-help">Std. 60</span>
                        </div>
                        <div class="cfg-field">
                            <label class="cfg-label">Lange Pause (Min)</label>
                            <InputNumber class="cfg-input" @bind-Value="_appSettings.PauseMinutesLongRun" />
                            <span class="cfg-help">Std. 180</span>
                        </div>
                    </div>
                </div>

                <div class="cfg-section">
                    <h3 class="cfg-sub-header"><i class="bi bi-broadcast me-1"></i>GPS-Halsband</h3>
                    <div class="cfg-grid cfg-grid-2">
                        <div class="cfg-field">
                            <label class="cfg-label">Kein-Signal-Timeout</label>
                            <InputSelect class="cfg-input" @bind-Value="_appSettings.CollarNoSignalTimeoutSeconds">
                                <option value="30">30 Sekunden</option>
                                <option value="45">45 Sekunden</option>
                                <option value="60">60 Sekunden</option>
                                <option value="90">90 Sekunden</option>
                            </InputSelect>
                            <span class="cfg-help">Gilt bei aktiven Suchen mit zugewiesenem Halsband.</span>
                        </div>
                    </div>
                </div>

                <div class="cfg-section">
                    <h3 class="cfg-sub-header"><i class="bi bi-map me-1"></i>Karten-Standard</h3>
                    <div class="cfg-grid cfg-grid-3">
                        <div class="cfg-field">
                            <label class="cfg-label">Breitengrad (Lat)</label>
                            <InputNumber class="cfg-input" @bind-Value="_appSettings.MapDefaultLat" />
                        </div>
                        <div class="cfg-field">
                            <label class="cfg-label">Längengrad (Lng)</label>
                            <InputNumber class="cfg-input" @bind-Value="_appSettings.MapDefaultLng" />
                        </div>
                        <div class="cfg-field">
                            <label class="cfg-label">Zoom (5–18)</label>
                            <InputNumber class="cfg-input" @bind-Value="_appSettings.MapDefaultZoom" />
                        </div>
                    </div>
                </div>

                <div class="cfg-section">
                    <h3 class="cfg-sub-header"><i class="bi bi-volume-up me-1"></i>Akustik</h3>
                    <div class="cfg-grid cfg-grid-2">
                        <div class="cfg-field">
                            <label class="cfg-label">Akustische Warnungen</label>
                            <label class="cfg-toggle">
                                <InputCheckbox @bind-Value="BrowserPrefs.Preferences.SoundAlertsEnabled" />
                                <span>aktiviert</span>
                            </label>
                        </div>
                        <div class="cfg-field">
                            <label class="cfg-label">Lautstärke @BrowserPrefs.Preferences.SoundVolume %</label>
                            <input class="cfg-range" type="range" min="0" max="100" @bind="BrowserPrefs.Preferences.SoundVolume" />
                        </div>
                    </div>
                    <div class="cfg-grid cfg-grid-2 mt-2">
                        <div class="cfg-field">
                            <label class="cfg-label">1. Warnung — Sound</label>
                            <InputSelect class="cfg-input" @bind-Value="BrowserPrefs.Preferences.FirstWarningSound">
                                <option value="beep">Signalton</option>
                                <option value="bell">Glocke</option>
                                <option value="alarm">Alarm</option>
                                <option value="double">Doppelton</option>
                                <option value="chime">Chime</option>
                                <option value="pulse">Puls</option>
                                <option value="siren">Sirene</option>
                                <option value="triple">Dreifachton</option>
                                <option value="klaxon">Klaxon</option>
                                <option value="rising">Ansteigend</option>
                                <option value="file_funk">Funk-Ping (Datei)</option>
                                <option value="file_glocke">Glocke (Datei)</option>
                                <option value="file_kritisch">Kritischer Alarm (Datei)</option>
                            </InputSelect>
                        </div>
                        <div class="cfg-field">
                            <label class="cfg-label">Frequenz (Hz)</label>
                            <InputNumber class="cfg-input" @bind-Value="BrowserPrefs.Preferences.FirstWarningFrequency" />
                        </div>
                        <div class="cfg-field">
                            <label class="cfg-label">2. (kritische) Warnung — Sound</label>
                            <InputSelect class="cfg-input" @bind-Value="BrowserPrefs.Preferences.SecondWarningSound">
                                <option value="beep">Signalton</option>
                                <option value="bell">Glocke</option>
                                <option value="alarm">Alarm</option>
                                <option value="double">Doppelton</option>
                                <option value="chime">Chime</option>
                                <option value="pulse">Puls</option>
                                <option value="siren">Sirene</option>
                                <option value="triple">Dreifachton</option>
                                <option value="klaxon">Klaxon</option>
                                <option value="rising">Ansteigend</option>
                                <option value="file_funk">Funk-Ping (Datei)</option>
                                <option value="file_glocke">Glocke (Datei)</option>
                                <option value="file_kritisch">Kritischer Alarm (Datei)</option>
                            </InputSelect>
                        </div>
                        <div class="cfg-field">
                            <label class="cfg-label">Frequenz (Hz)</label>
                            <InputNumber class="cfg-input" @bind-Value="BrowserPrefs.Preferences.SecondWarningFrequency" />
                        </div>
                    </div>
                    <div class="cfg-grid cfg-grid-2 mt-2">
                        <div class="cfg-field">
                            <label class="cfg-label">Kritische Warnung wiederholen</label>
                            <label class="cfg-toggle">
                                <InputCheckbox @bind-Value="BrowserPrefs.Preferences.RepeatSecondWarning" />
                                <span>aktiviert</span>
                            </label>
                        </div>
                        <div class="cfg-field">
                            <label class="cfg-label">Wiederholungs-Intervall (Sek)</label>
                            <InputNumber class="cfg-input" @bind-Value="BrowserPrefs.Preferences.RepeatWarningIntervalSeconds" />
                        </div>
                    </div>
                    <div class="cfg-actions mt-2">
                        <button type="button" class="cfg-btn cfg-btn-ghost" @onclick="PlayFirstWarningTestAsync">
                            <i class="bi bi-play"></i> 1. Warnung testen
                        </button>
                        <button type="button" class="cfg-btn cfg-btn-ghost-danger" @onclick="PlayCriticalWarningTestAsync">
                            <i class="bi bi-exclamation-triangle"></i> Kritisch testen
                        </button>
                        <button type="button" class="cfg-btn cfg-btn-ghost" @onclick="StopWarningTestAsync">
                            <i class="bi bi-stop"></i> Stoppen
                        </button>
                        @if (!string.IsNullOrWhiteSpace(_audioTestStatus))
                        {
                            <span class="cfg-inline-status @(_audioTestError ? "is-error" : "is-ok")">@_audioTestStatus</span>
                        }
                    </div>
                </div>

                <div class="cfg-section">
                    <h3 class="cfg-sub-header"><i class="bi bi-journal-text me-1"></i>Schnell-Notizen (Vorlagen)</h3>
                    <div class="cfg-quicknotes">
                        @for (int i = 0; i < _quickNoteList.Count; i++)
                        {
                            var idx = i;
                            <div class="cfg-quicknote-row">
                                <input class="cfg-input" value="@_quickNoteList[idx]"
                                       @onchange="e => _quickNoteList[idx] = e.Value?.ToString() ?? string.Empty" />
                                <button type="button" class="cfg-icon-btn" @onclick="() => _quickNoteList.RemoveAt(idx)" title="Entfernen">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                        }
                        <button type="button" class="cfg-btn cfg-btn-ghost cfg-btn-add"
                                @onclick="() => _quickNoteList.Add(string.Empty)">
                            <i class="bi bi-plus-lg"></i> Vorlage hinzufügen
                        </button>
                    </div>
                </div>

                <div class="cfg-section">
                    <h3 class="cfg-sub-header"><i class="bi bi-clock-history me-1"></i>Zeitzone</h3>
                    <div class="cfg-grid cfg-grid-2">
                        <div class="cfg-field">
                            <label class="cfg-label">Server-Zeitzone</label>
                            <InputSelect class="cfg-input" @bind-Value="_appSettings.TimeZoneId">
                                <option value="Europe/Berlin">Europa/Berlin (Deutschland, Österreich)</option>
                                <option value="Europe/Vienna">Europa/Wien</option>
                                <option value="Europe/Zurich">Europa/Zürich</option>
                                <option value="Europe/Paris">Europa/Paris</option>
                                <option value="Europe/London">Europa/London</option>
                                <option value="Europe/Amsterdam">Europa/Amsterdam</option>
                                <option value="Europe/Brussels">Europa/Brüssel</option>
                                <option value="Europe/Warsaw">Europa/Warschau</option>
                                <option value="Europe/Prague">Europa/Prag</option>
                                <option value="Europe/Budapest">Europa/Budapest</option>
                                <option value="UTC">UTC</option>
                            </InputSelect>
                            <span class="cfg-help">Aktuelle Server-Zeit: <strong>@_currentServerTime</strong></span>
                        </div>
                    </div>
                </div>
            }

            else if (_activeTab == SettingsTab.Erscheinungsbild)
            {
                <h2 class="cfg-pane-title"><i class="bi bi-palette me-2"></i>Erscheinungsbild</h2>
                <p class="cfg-pane-subtitle">Theme-Modus und Zeitfenster für den Dunkel-Modus.</p>

                <div class="cfg-section">
                    <h3 class="cfg-sub-header">Theme</h3>
                    <div class="cfg-grid cfg-grid-2">
                        <div class="cfg-field">
                            <label class="cfg-label">Modus</label>
                            <InputSelect class="cfg-input" @bind-Value="BrowserPrefs.Preferences.ThemeMode">
                                <option value="Manual">Manuell (per Button umschalten)</option>
                                <option value="Auto">Automatisch (Systemmodus)</option>
                                <option value="Scheduled">Geplant (Zeitfenster)</option>
                            </InputSelect>
                            @if (BrowserPrefs.Preferences.ThemeMode == "Auto")
                            {
                                <span class="cfg-help"><i class="bi bi-info-circle me-1"></i>Folgt dem OS-Theme.</span>
                            }
                        </div>

                        @if (BrowserPrefs.Preferences.ThemeMode == "Manual")
                        {
                            <div class="cfg-field">
                                <label class="cfg-label">Aktuelles Theme</label>
                                <div class="cfg-pill-toggle">
                                    <button type="button"
                                            class="cfg-pill @(!BrowserPrefs.Preferences.IsDarkMode ? "is-active" : "")"
                                            @onclick="() => SetDesignModeAsync(false)">
                                        <i class="bi bi-brightness-high"></i> Hell
                                    </button>
                                    <button type="button"
                                            class="cfg-pill @(BrowserPrefs.Preferences.IsDarkMode ? "is-active" : "")"
                                            @onclick="() => SetDesignModeAsync(true)">
                                        <i class="bi bi-moon-stars"></i> Dunkel
                                    </button>
                                </div>
                            </div>
                        }
                    </div>

                    @if (BrowserPrefs.Preferences.ThemeMode == "Scheduled")
                    {
                        <div class="cfg-grid cfg-grid-2 mt-2">
                            <div class="cfg-field">
                                <label class="cfg-label">Dunkel ab</label>
                                <input type="time" class="cfg-input"
                                       value="@BrowserPrefs.Preferences.DarkModeStartTime"
                                       @onchange="e => BrowserPrefs.Preferences.DarkModeStartTime = e.Value?.ToString() ?? BrowserPrefs.Preferences.DarkModeStartTime" />
                            </div>
                            <div class="cfg-field">
                                <label class="cfg-label">Hell ab</label>
                                <input type="time" class="cfg-input"
                                       value="@BrowserPrefs.Preferences.DarkModeEndTime"
                                       @onchange="e => BrowserPrefs.Preferences.DarkModeEndTime = e.Value?.ToString() ?? BrowserPrefs.Preferences.DarkModeEndTime" />
                            </div>
                            <div class="cfg-help">Z.B. Dunkel ab 20:00, Hell ab 06:00 (über Mitternacht möglich).</div>
                        </div>
                    }
                </div>
            }

            else if (_activeTab == SettingsTab.Integration)
            {
                <h2 class="cfg-pane-title"><i class="bi bi-broadcast-pin me-2"></i>Integration</h2>
                <p class="cfg-pane-subtitle">Externe Schnittstellen — Divera 24/7 und GPS-Livetracking.</p>

                <div class="cfg-section">
                    <div class="cfg-section-title-row">
                        <h3 class="cfg-sub-header"><i class="bi bi-broadcast-pin me-1"></i>Divera 24/7</h3>
                        @if (_appSettings.DiveraEnabled && !string.IsNullOrWhiteSpace(_appSettings.DiveraAccessKey))
                        {
                            <span class="cfg-inline-badge ok">aktiv</span>
                        }
                        else
                        {
                            <span class="cfg-inline-badge muted">inaktiv</span>
                        }
                    </div>
                    <div class="cfg-field">
                        <label class="cfg-toggle">
                            <InputCheckbox @bind-Value="_appSettings.DiveraEnabled" />
                            <span>Integration aktivieren</span>
                        </label>
                    </div>

                    @if (_appSettings.DiveraEnabled)
                    {
                        <div class="cfg-grid cfg-grid-2 mt-2">
                            <div class="cfg-field">
                                <label class="cfg-label">API Access-Key</label>
                                <div class="cfg-input-with-action">
                                    <input type="@(_showDiveraKey ? "text" : "password")"
                                           class="cfg-input"
                                           placeholder="Divera API-Key"
                                           @bind="_appSettings.DiveraAccessKey" />
                                    <button type="button" class="cfg-icon-btn"
                                            @onclick="() => _showDiveraKey = !_showDiveraKey"
                                            title="Zeigen/Verbergen">
                                        <i class="bi @(_showDiveraKey ? "bi-eye-slash" : "bi-eye")"></i>
                                    </button>
                                </div>
                                <span class="cfg-help">Verwaltung → Schnittstellen → API-Access-Key</span>
                            </div>
                            <div class="cfg-field">
                                <label class="cfg-label">API Base-URL</label>
                                <InputText class="cfg-input" @bind-Value="_appSettings.DiveraBaseUrl" placeholder="https://app.divera247.com/api/v2" />
                            </div>
                            <div class="cfg-field">
                                <label class="cfg-label">Poll Idle (Sek)</label>
                                <InputNumber class="cfg-input" @bind-Value="_appSettings.DiveraPollIntervalIdleSeconds" />
                                <span class="cfg-help">Standard 600 (= 10 Min)</span>
                            </div>
                            <div class="cfg-field">
                                <label class="cfg-label">Poll bei Alarm (Sek)</label>
                                <InputNumber class="cfg-input" @bind-Value="_appSettings.DiveraPollIntervalActiveSeconds" />
                                <span class="cfg-help">Standard 60 (= 1 Min)</span>
                            </div>
                        </div>

                        <div class="cfg-actions mt-2">
                            <button type="button" class="cfg-btn cfg-btn-ghost" @onclick="TestDiveraConnectionAsync" disabled="@_diveraTestBusy">
                                @if (_diveraTestBusy)
                                {
                                    <span class="spinner-border spinner-border-sm"></span>
                                }
                                else
                                {
                                    <i class="bi bi-plug"></i>
                                }
                                Verbindung testen
                            </button>
                            @if (!string.IsNullOrWhiteSpace(_diveraTestStatus))
                            {
                                <span class="cfg-inline-status @(_diveraTestError ? "is-error" : "is-ok")">
                                    <i class="bi @(_diveraTestError ? "bi-x-circle" : "bi-check-circle")"></i>
                                    @_diveraTestStatus
                                </span>
                            }
                        </div>
                    }
                </div>

                <div class="cfg-section">
                    <div class="cfg-section-title-row">
                        <h3 class="cfg-sub-header"><i class="bi bi-geo-alt me-1"></i>GPS-Livetracking (Windows-Tool)</h3>
                        <span class="cfg-inline-badge muted">extern</span>
                    </div>
                    <p class="cfg-help">
                        Der Server empfängt GPS-Daten nicht direkt vom Halsband. Starte die Anwendung
                        <code>Einsatzueberwachung.LiveTracking</code> auf einem Windows-Rechner.
                    </p>
                    <div class="cfg-actions">
                        <a class="cfg-btn cfg-btn-ghost" href="@GetDownloadUrl("/downloads/livetracking.zip")">
                            <i class="bi bi-download"></i> Herunterladen
                        </a>
                    </div>
                    <ol class="cfg-steps">
                        <li>ZIP herunterladen und entpacken.</li>
                        <li><code>Einsatzueberwachung.LiveTracking.exe</code> auf dem Windows-Rechner starten.</li>
                        <li>Verbindung zur Einsatzüberwachung im Tool konfigurieren.</li>
                    </ol>
                </div>
            }

            else if (_activeTab == SettingsTab.System)
            {
                <h2 class="cfg-pane-title"><i class="bi bi-cpu me-2"></i>System</h2>
                <p class="cfg-pane-subtitle">Versionsstand, Pfade und Update-Verwaltung.</p>

                <div class="cfg-section">
                    <h3 class="cfg-sub-header">Stand</h3>
                    <dl class="cfg-info-grid">
                        <dt>Version</dt><dd>@_appVersion</dd>
                        <dt>Framework</dt><dd>.NET 9 / Blazor Server</dd>
                        <dt>Datenpfad</dt><dd><code class="cfg-path">@_dataDirectory</code></dd>
                        <dt>Berichte</dt><dd><code class="cfg-path">@_reportDirectory</code></dd>
                        <dt>Mobile-URL</dt><dd><a href="@_mobileUrl" target="_blank">@_mobileUrl</a></dd>
                    </dl>
                </div>

                <div class="cfg-section">
                    <div class="cfg-section-title-row">
                        <h3 class="cfg-sub-header"><i class="bi bi-arrow-repeat me-1"></i>Updates</h3>
                        @if (_updateStatus.UpdateAvailable)
                        {
                            <span class="cfg-inline-badge warning">verfügbar</span>
                        }
                        else
                        {
                            <span class="cfg-inline-badge ok">aktuell</span>
                        }
                    </div>
                    <dl class="cfg-info-grid cfg-info-grid-compact">
                        <dt>Installiert</dt><dd>@_updateStatus.CurrentVersion</dd>
                        <dt>Neueste</dt><dd>@DisplayLatestVersion()</dd>
                        <dt>Letzter Check</dt><dd>@DisplayDateTime(_updateStatus.LastCheckedAt)</dd>
                        <dt>Letzte Installation</dt><dd>@DisplayDateTime(_updateStatus.LastInstalledAt)</dd>
                    </dl>

                    <div class="cfg-grid cfg-grid-2 mt-2">
                        <div class="cfg-field">
                            <label class="cfg-label">Update-URL</label>
                            <InputText class="cfg-input" placeholder="https://…" @bind-Value="_appSettings.UpdateUrl" />
                        </div>
                        <div class="cfg-field">
                            <label class="cfg-label">GitHub-Token (optional)</label>
                            <input type="password" class="cfg-input" placeholder="ghp_…" @bind="_appSettings.GitHubToken" />
                            <span class="cfg-help">Nur bei privaten Repositories nötig. Env-Variable hat Vorrang.</span>
                        </div>
                        <div class="cfg-field">
                            <label class="cfg-toggle">
                                <InputCheckbox @bind-Value="_appSettings.AutoCheckUpdates" />
                                <span>Automatisch nach Updates suchen</span>
                            </label>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_updateStatus.LastError))
                    {
                        <div class="cfg-inline-status is-error mt-2">@_updateStatus.LastError</div>
                    }

                    <div class="cfg-actions mt-2">
                        <button type="button" class="cfg-btn cfg-btn-ghost"
                                @onclick="CheckForUpdatesAsync"
                                disabled="@(_updateStatus.IsChecking || _updateStatus.IsInstalling)">
                            <i class="bi bi-arrow-clockwise"></i> Jetzt prüfen
                        </button>
                        <button type="button" class="cfg-btn cfg-btn-primary"
                                @onclick="InstallUpdateAsync"
                                disabled="@(!_updateStatus.UpdateAvailable || _updateStatus.IsChecking || _updateStatus.IsInstalling)">
                            <i class="bi bi-download"></i> Update installieren
                        </button>
                        @if (!string.IsNullOrWhiteSpace(_updateStatus.LastMessage))
                        {
                            <span class="cfg-help">@_updateStatus.LastMessage</span>
                        }
                    </div>
                </div>

                <div class="cfg-section">
                    <h3 class="cfg-sub-header">Datei-Exporte</h3>
                    <div class="cfg-actions cfg-actions-wrap">
                        <a class="cfg-btn cfg-btn-ghost" href="@GetDownloadUrl("/downloads/app-settings.json")"><i class="bi bi-filetype-json"></i> AppSettings</a>
                        <a class="cfg-btn cfg-btn-ghost" href="@GetDownloadUrl("/downloads/staffel-settings.json")"><i class="bi bi-filetype-json"></i> Staffel</a>
                        <a class="cfg-btn cfg-btn-ghost" href="@GetDownloadUrl("/downloads/session-data.json")"><i class="bi bi-filetype-json"></i> Session</a>
                        <a class="cfg-btn cfg-btn-ghost" href="@GetDownloadUrl("/downloads/stammdaten.xlsx")"><i class="bi bi-filetype-xlsx"></i> Excel</a>
                    </div>
                </div>
            }

            else if (_activeTab == SettingsTab.Wartung)
            {
                <h2 class="cfg-pane-title"><i class="bi bi-database-gear me-2"></i>Wartung</h2>
                <p class="cfg-pane-subtitle">Backup erstellen / wiederherstellen und Datenimporte.</p>

                <div class="cfg-section">
                    <div class="cfg-section-title-row">
                        <h3 class="cfg-sub-header"><i class="bi bi-archive me-1"></i>Backup</h3>
                        <span class="cfg-inline-badge @BackupAgeSeverity">@BackupAgeLabel</span>
                    </div>
                    <p class="cfg-help">
                        Letztes Backup:
                        @if (_appSettings.LastBackupAt is null)
                        {
                            <strong>noch nie erstellt</strong>
                        }
                        else
                        {
                            <strong>@_appSettings.LastBackupAt.Value.ToString("dd.MM.yyyy HH:mm")</strong>
                        }
                    </p>
                    <div class="cfg-actions">
                        <a class="cfg-btn cfg-btn-primary"
                           href="@GetDownloadUrl("/downloads/data-backup.zip")"
                           @onclick="MarkBackupCreatedAsync">
                            <i class="bi bi-download"></i> Daten-Backup ZIP
                        </a>
                    </div>

                    <div class="cfg-field mt-3">
                        <label class="cfg-label">Backup wiederherstellen (ZIP)</label>
                        <span class="cfg-help">Importiert SessionData, AppSettings, StaffelSettings und Archivdaten aus einer Backup-ZIP.</span>
                        <InputFile OnChange="ConfirmRestoreBackupZipAsync" accept=".zip,application/zip" />
                    </div>
                </div>

                <div class="cfg-section">
                    <h3 class="cfg-sub-header"><i class="bi bi-upload me-1"></i>Daten-Imports</h3>
                    <div class="cfg-field">
                        <label class="cfg-label">SessionData (JSON)</label>
                        <textarea class="cfg-input cfg-textarea"
                                  rows="6"
                                  placeholder="JSON-Inhalt von SessionData hier einfügen"
                                  @bind="_sessionImportJson"></textarea>
                        <div class="cfg-actions">
                            <button type="button" class="cfg-btn cfg-btn-ghost" @onclick="ImportSessionJsonAsync">
                                <i class="bi bi-clipboard-check"></i> Aus Textfeld importieren
                            </button>
                            <InputFile OnChange="ImportSessionFileAsync" accept=".json,application/json" />
                        </div>
                    </div>
                    <div class="cfg-grid cfg-grid-2 mt-2">
                        <div class="cfg-field">
                            <label class="cfg-label">AppSettings (JSON)</label>
                            <InputFile OnChange="ImportAppSettingsFileAsync" accept=".json,application/json" />
                        </div>
                        <div class="cfg-field">
                            <label class="cfg-label">StaffelSettings (JSON)</label>
                            <InputFile OnChange="ImportStaffelSettingsFileAsync" accept=".json,application/json" />
                        </div>
                    </div>
                </div>

                <div class="cfg-section">
                    <h3 class="cfg-sub-header"><i class="bi bi-exclamation-triangle me-1"></i>Daten zurücksetzen</h3>
                    <p class="cfg-help">Setzt SessionData, AppSettings und StaffelSettings auf die Standardwerte zurück. Nicht rückgängig machbar.</p>
                    <div class="cfg-actions">
                        <button type="button" class="cfg-btn cfg-btn-ghost-danger" @onclick="ConfirmResetDataAsync">
                            <i class="bi bi-trash"></i> Auf Standard zurücksetzen
                        </button>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(_maintenanceStatus))
                {
                    <div class="cfg-inline-status @(_maintenanceError ? "is-error" : "is-ok")">@_maintenanceStatus</div>
                }
            }

        </main>
    </div>

    <!-- TOAST -->
    @if (_showSavedToast)
    {
        <div class="cfg-toast" role="status">
            <i class="bi bi-check-circle"></i>
            <span>@_status</span>
        </div>
    }
</div>
