@page "/einstellungen"
@rendermode InteractiveServer
@using System.Text.Json
@using System.IO.Compression
@using System.Text

<PageTitle>Einstellungen</PageTitle>

<div class="container py-4 settings-page">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <h1 class="mb-1"><i class="bi bi-gear-fill me-2"></i>Einstellungen</h1>
            <p class="text-muted mb-0">Staffel-Daten und App-Konfiguration</p>
        </div>
    </div>

    <div class="card border-primary-subtle mb-4 trainer-access-card">
        <div class="card-body">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                <div>
                    <h2 class="h5 mb-1"><i class="bi bi-shield-lock-fill me-2"></i>Trainerbereich</h2>
                    <p class="text-muted mb-0">Zugang zum eigenstaendigen Trainer-Modul. Die Passwortabfrage erfolgt direkt auf der Trainer-Seite.</p>
                </div>
                <button type="button" class="btn btn-primary btn-lg" @onclick="OpenTrainerDashboardAsync">
                    <i class="bi bi-mortarboard-fill me-1"></i>Trainerbereich oeffnen
                </button>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-xl-6">
            <div class="card h-100">
                <div class="card-header">
                    <h2 class="h4 mb-0"><i class="bi bi-building me-2"></i>Staffel-Informationen</h2>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Staffel-Name</label>
                        <InputText class="form-control" placeholder="z.B. RHS Speyer" @bind-Value="_staffelSettings.StaffelName" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Adresse</label>
                        <InputText class="form-control" placeholder="Straße, PLZ Ort" @bind-Value="_staffelSettings.StaffelAdresse" />
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label">Telefon</label>
                            <InputText class="form-control" placeholder="+49 123 456789" @bind-Value="_staffelSettings.StaffelTelefon" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label">E-Mail</label>
                            <InputText class="form-control" placeholder="kontakt@staffel.de" @bind-Value="_staffelSettings.StaffelEmail" />
                        </div>
                    </div>

                    <div class="mt-3">
                        <label class="form-label">Logo-Pfad</label>
                        <InputText class="form-control" placeholder="Pfad zum Logo" @bind-Value="_staffelSettings.StaffelLogoPfad" />
                        <div class="form-text">Pfad zu einer Bilddatei für den PDF-Export</div>

                        <div class="d-flex flex-wrap gap-2 mt-2 align-items-center">
                            <InputFile OnChange="UploadStaffelLogoAsync" accept=".png,.jpg,.jpeg,.webp,.svg,image/*" />
                            @if (!string.IsNullOrWhiteSpace(_staffelSettings.StaffelLogoPfad))
                            {
                                <button class="btn btn-sm btn-outline-danger" @onclick="ClearStaffelLogoAsync">
                                    <i class="bi bi-trash me-1"></i>Logo entfernen
                                </button>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_logoStatus))
                        {
                            <div class="alert @(_logoStatusIsError ? "alert-danger" : "alert-success") py-2 mt-2 mb-0">@_logoStatus</div>
                        }
                    </div>

                    <div class="mt-4">
                        <button class="btn btn-success w-100" @onclick="SaveAsync">
                            <i class="bi bi-floppy-fill me-1"></i>Speichern
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-6">
            <div class="card h-100">
                <div class="card-header">
                    <h2 class="h4 mb-0"><i class="bi bi-palette-fill me-2"></i>Darstellung</h2>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Theme-Modus</label>
                        <InputSelect class="form-select" @bind-Value="BrowserPrefs.Preferences.ThemeMode">
                            <option value="Manual">Manuell (per Button umschalten)</option>
                            <option value="Auto">Automatisch (Systemmodus)</option>
                            <option value="Scheduled">Geplant (Zeitfenster)</option>
                        </InputSelect>
                        @if (BrowserPrefs.Preferences.ThemeMode == "Auto")
                        {
                            <div class="form-text"><i class="bi bi-info-circle me-1"></i>Das Theme folgt automatisch dem Betriebssystemmodus des Browsers.</div>
                        }
                    </div>

                    @if (BrowserPrefs.Preferences.ThemeMode == "Scheduled")
                    {
                        <div class="mb-3">
                            <label class="form-label"><i class="bi bi-clock me-1"></i>Zeitfenster für Dunkel-Modus</label>
                            <div class="row g-2">
                                <div class="col-6">
                                    <label class="form-label small text-muted mb-1">Dunkel ab</label>
                                    <input type="time" class="form-control"
                                           value="@BrowserPrefs.Preferences.DarkModeStartTime"
                                           @onchange="e => BrowserPrefs.Preferences.DarkModeStartTime = e.Value?.ToString() ?? BrowserPrefs.Preferences.DarkModeStartTime" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label small text-muted mb-1">Hell ab</label>
                                    <input type="time" class="form-control"
                                           value="@BrowserPrefs.Preferences.DarkModeEndTime"
                                           @onchange="e => BrowserPrefs.Preferences.DarkModeEndTime = e.Value?.ToString() ?? BrowserPrefs.Preferences.DarkModeEndTime" />
                                </div>
                            </div>
                            <div class="form-text">Z.B. Dunkel ab 20:00, Hell ab 06:00 (über Mitternacht möglich).</div>
                        </div>
                    }

                    @if (BrowserPrefs.Preferences.ThemeMode == "Manual")
                    {
                        <div class="mb-3">
                            <label class="form-label">Design-Modus</label>
                            <div class="settings-segmented">
                                <button type="button"
                                        class="btn @(BrowserPrefs.Preferences.IsDarkMode ? "btn-outline-light" : "btn-light")"
                                        @onclick="() => SetDesignModeAsync(false)">
                                    <i class="bi bi-brightness-high me-1"></i>Hell
                                </button>
                                <button type="button"
                                        class="btn @(BrowserPrefs.Preferences.IsDarkMode ? "btn-secondary" : "btn-outline-secondary")"
                                        @onclick="() => SetDesignModeAsync(true)">
                                    <i class="bi bi-moon-stars me-1"></i>Dunkel
                                </button>
                            </div>
                        </div>
                    }

                    <hr />

                    <h3 class="h5 mb-3"><i class="bi bi-journal-text me-1"></i>Schnell-Notizen</h3>
                    <div class="mb-3">
                        <label class="form-label">Vorlagen</label>
                        <div class="list-group mb-2">
                            @for (int i = 0; i < _quickNoteList.Count; i++)
                            {
                                var idx = i;
                                <div class="list-group-item d-flex align-items-center gap-2 py-1 px-2">
                                    <input class="form-control form-control-sm" value="@_quickNoteList[idx]"
                                           @onchange="e => _quickNoteList[idx] = e.Value?.ToString() ?? string.Empty" />
                                    <button class="btn btn-sm btn-outline-danger flex-shrink-0" type="button"
                                            @onclick="() => _quickNoteList.RemoveAt(idx)" title="Entfernen">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            }
                        </div>
                        <button class="btn btn-sm btn-outline-success" type="button"
                                @onclick="() => _quickNoteList.Add(string.Empty)">
                            <i class="bi bi-plus-circle me-1"></i>Vorlage hinzufügen
                        </button>
                        <div class="form-text">Diese Buttons erscheinen im Einsatzmonitor als Schnell-Notiz-Schaltflächen.</div>
                    </div>

                    <hr />

                    <h3 class="h5 mb-3"><i class="bi bi-clock-history me-1"></i>Datum &amp; Uhrzeit</h3>
                    <div class="mb-3">
                        <label class="form-label">Server-Zeitzone</label>
                        <InputSelect class="form-select" @bind-Value="_appSettings.TimeZoneId">
                            <option value="Europe/Berlin">Europa/Berlin (Deutschland, Österreich)</option>
                            <option value="Europe/Vienna">Europa/Wien (Österreich)</option>
                            <option value="Europe/Zurich">Europa/Zürich (Schweiz)</option>
                            <option value="Europe/Paris">Europa/Paris (Frankreich)</option>
                            <option value="Europe/London">Europa/London (Vereinigtes Königreich)</option>
                            <option value="Europe/Amsterdam">Europa/Amsterdam (Niederlande)</option>
                            <option value="Europe/Brussels">Europa/Brüssel (Belgien)</option>
                            <option value="Europe/Warsaw">Europa/Warschau (Polen)</option>
                            <option value="Europe/Prague">Europa/Prag (Tschechien)</option>
                            <option value="Europe/Budapest">Europa/Budapest (Ungarn)</option>
                            <option value="UTC">UTC (Koordinierte Weltzeit)</option>
                        </InputSelect>
                        <div class="form-text">
                            Bestimmt die Zeitzone für alle Zeitstempel (Notizen, Funksprüche, Team-Erstellung).
                            Muss mit der Uhr im Header übereinstimmen. Aktuelle Serverzeit in gewählter Zeitzone:
                            <strong>@_currentServerTime</strong>
                        </div>
                    </div>

                    <hr />

                    <h3 class="h5 mb-3"><i class="bi bi-alarm me-1"></i>Timer-Warnungen (Standard)</h3>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Erste Warnung (Minuten)</label>
                            <InputNumber class="form-control" @bind-Value="_appSettings.DefaultFirstWarningMinutes" />
                            <div class="form-text">Standard: 45 Minuten</div>
                        </div>

                        <div class="col-12">
                            <label class="form-label">Zweite Warnung (Minuten)</label>
                            <InputNumber class="form-control" @bind-Value="_appSettings.DefaultSecondWarningMinutes" />
                            <div class="form-text">Standard: 60 Minuten</div>
                        </div>
                    </div>

                    <hr />

                    <h3 class="h5 mb-3"><i class="bi bi-map me-1"></i>Karten-Standardposition</h3>
                    <div class="row g-3 mb-3">
                        <div class="col-12 col-md-4">
                            <label class="form-label">Breitengrad (Lat)</label>
                            <InputNumber class="form-control" @bind-Value="_appSettings.MapDefaultLat" />
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">Längengrad (Lng)</label>
                            <InputNumber class="form-control" @bind-Value="_appSettings.MapDefaultLng" />
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">Zoom-Stufe</label>
                            <InputNumber class="form-control" @bind-Value="_appSettings.MapDefaultZoom" />
                            <div class="form-text">5–18, Standard: 13</div>
                        </div>
                    </div>

                    <hr />

                    <h3 class="h5 mb-3"><i class="bi bi-hourglass-split me-1"></i>Hundepausen</h3>
                    <div class="row g-3 mb-3">
                        <div class="col-12 col-md-4">
                            <label class="form-label">Schwellwert (Min.)</label>
                            <InputNumber class="form-control" @bind-Value="_appSettings.PauseThresholdMinutes" />
                            <div class="form-text">Laufzeit bis zur kurzen Pause. Standard: 20</div>
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">Kurze Pause (Min.)</label>
                            <InputNumber class="form-control" @bind-Value="_appSettings.PauseMinutesShortRun" />
                            <div class="form-text">Pausenpflicht bei kurzer Laufzeit. Standard: 60</div>
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">Lange Pause (Min.)</label>
                            <InputNumber class="form-control" @bind-Value="_appSettings.PauseMinutesLongRun" />
                            <div class="form-text">Pausenpflicht bei langer Laufzeit. Standard: 180</div>
                        </div>
                    </div>

                    <hr />

                    <h3 class="h5 mb-3"><i class="bi bi-volume-up me-1"></i>Sound-Warnungen</h3>
                    <div class="form-check form-switch mb-2">
                        <InputCheckbox class="form-check-input" id="soundAlerts" @bind-Value="BrowserPrefs.Preferences.SoundAlertsEnabled" />
                        <label class="form-check-label" for="soundAlerts">Akustische Warnungen aktiviert</label>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Lautstärke: @BrowserPrefs.Preferences.SoundVolume%</label>
                        <input class="form-range" type="range" min="0" max="100" @bind="BrowserPrefs.Preferences.SoundVolume" />
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label">Erste Warnung - Sound</label>
                            <InputSelect class="form-select" @bind-Value="BrowserPrefs.Preferences.FirstWarningSound">
                                <option value="beep">Signalton</option>
                                <option value="bell">Glocke</option>
                                <option value="alarm">Alarm</option>
                                <option value="double">Doppelton</option>
                                <option value="chime">Chime</option>
                                <option value="pulse">Puls</option>
                                <option value="siren">Sirene</option>
                                <option value="triple">Dreifachton</option>
                                <option value="klaxon">Klaxon</option>
                                <option value="rising">Ansteigend</option>
                                <option value="file_funk">Funk-Ping (Datei)</option>
                                <option value="file_glocke">Glocke (Datei)</option>
                                <option value="file_kritisch">Kritischer Alarm (Datei)</option>
                            </InputSelect>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Frequenz (Hz)</label>
                            <InputNumber class="form-control" @bind-Value="BrowserPrefs.Preferences.FirstWarningFrequency" />
                            <div class="form-text">Standard: 800 Hz</div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Kritische Warnung - Sound</label>
                            <InputSelect class="form-select" @bind-Value="BrowserPrefs.Preferences.SecondWarningSound">
                                <option value="beep">Signalton</option>
                                <option value="bell">Glocke</option>
                                <option value="alarm">Alarm (Standard)</option>
                                <option value="double">Doppelton</option>
                                <option value="chime">Chime</option>
                                <option value="pulse">Puls</option>
                                <option value="siren">Sirene</option>
                                <option value="triple">Dreifachton</option>
                                <option value="klaxon">Klaxon</option>
                                <option value="rising">Ansteigend</option>
                                <option value="file_funk">Funk-Ping (Datei)</option>
                                <option value="file_glocke">Glocke (Datei)</option>
                                <option value="file_kritisch">Kritischer Alarm (Datei)</option>
                            </InputSelect>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Frequenz (Hz)</label>
                            <InputNumber class="form-control" @bind-Value="BrowserPrefs.Preferences.SecondWarningFrequency" />
                            <div class="form-text">Standard: 1200 Hz</div>
                        </div>
                    </div>

                    <div class="form-check form-switch mt-3">
                        <InputCheckbox class="form-check-input" id="repeatSecondWarning" @bind-Value="BrowserPrefs.Preferences.RepeatSecondWarning" />
                        <label class="form-check-label" for="repeatSecondWarning">Kritische Warnung wiederholen</label>
                    </div>

                    <div class="mt-2">
                        <label class="form-label">Wiederholungs-Intervall (Sekunden)</label>
                        <InputNumber class="form-control" @bind-Value="BrowserPrefs.Preferences.RepeatWarningIntervalSeconds" />
                        <div class="form-text">Standard: 30 Sekunden</div>
                    </div>

                    <div class="mt-3">
                        <label class="form-label">Akustik-Test</label>
                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-outline-primary" type="button" @onclick="PlayFirstWarningTestAsync">
                                Erste Warnung testen
                            </button>
                            <button class="btn btn-outline-danger" type="button" @onclick="PlayCriticalWarningTestAsync">
                                Kritische Warnung testen
                            </button>
                            <button class="btn btn-outline-secondary" type="button" @onclick="StopWarningTestAsync">
                                Test stoppen
                            </button>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_audioTestStatus))
                        {
                            <div class="alert @(_audioTestError ? "alert-warning" : "alert-success") py-2 mt-2 mb-0">@_audioTestStatus</div>
                        }
                    </div>

                    <hr />

                    <h3 class="h5 mb-3"><i class="bi bi-arrow-repeat me-1"></i>Updates</h3>
                    <div class="mb-2">
                        <label class="form-label">Update-URL</label>
                        <InputText class="form-control" placeholder="https://..." @bind-Value="_appSettings.UpdateUrl" />
                    </div>

                    <div class="mb-2">
                        <label class="form-label">GitHub Token (optional)</label>
                        <input type="password" class="form-control" placeholder="ghp_..." @bind="_appSettings.GitHubToken" />
                        <div class="form-text">Nur noetig bei privaten Repositories. Umgebungsvariable hat Vorrang.</div>
                    </div>

                    <div class="form-check mb-3">
                        <InputCheckbox class="form-check-input" id="autoUpdates" @bind-Value="_appSettings.AutoCheckUpdates" />
                        <label class="form-check-label" for="autoUpdates">Automatisch nach Updates suchen</label>
                    </div>

                    <div class="card border-0 shadow-sm home-update-card mt-2">
                        <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div class="fw-semibold">
                                <i class="bi bi-cloud-arrow-down me-2 text-primary"></i>Server-Updates
                            </div>
                            <span class="badge @( _updateStatus.UpdateAvailable ? "bg-warning text-dark" : "bg-success")">
                                @(_updateStatus.UpdateAvailable ? "Update verfuegbar" : "Aktuell")
                            </span>
                        </div>
                        <div class="card-body">
                            <div class="row g-2 small mb-3">
                                <div class="col-md-3"><span class="text-muted">Installiert:</span> @_updateStatus.CurrentVersion</div>
                                <div class="col-md-3"><span class="text-muted">Neueste:</span> @DisplayLatestVersion()</div>
                                <div class="col-md-3"><span class="text-muted">Letzter Check:</span> @DisplayDateTime(_updateStatus.LastCheckedAt)</div>
                                <div class="col-md-3"><span class="text-muted">Letzte Installation:</span> @DisplayDateTime(_updateStatus.LastInstalledAt)</div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(_updateStatus.LastError))
                            {
                                <div class="alert alert-danger py-2 mb-3">@_updateStatus.LastError</div>
                            }

                            <div class="d-flex flex-wrap gap-2 align-items-center">
                                <button class="btn btn-outline-primary btn-sm" @onclick="CheckForUpdatesAsync" disabled="@(_updateStatus.IsChecking || _updateStatus.IsInstalling)">
                                    <i class="bi bi-arrow-clockwise me-1"></i>Jetzt pruefen
                                </button>
                                <button class="btn btn-primary btn-sm" @onclick="InstallUpdateAsync" disabled="@(!_updateStatus.UpdateAvailable || _updateStatus.IsChecking || _updateStatus.IsInstalling)">
                                    <i class="bi bi-download me-1"></i>Update installieren
                                </button>
                                <span class="text-muted small">@_updateStatus.LastMessage</span>
                            </div>
                        </div>
                    </div>

                    <button class="btn btn-success w-100" @onclick="SaveAsync">
                        <i class="bi bi-floppy-fill me-1"></i>Speichern
                    </button>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-6">
            <div class="card h-100">
                <div class="card-header">
                    <h2 class="h4 mb-0"><i class="bi bi-geo-alt-fill me-2"></i>GPS-Livetracking</h2>
                </div>
                <div class="card-body">
                    <div class="alert alert-info mb-3">
                        <div class="fw-semibold mb-1">LiveTracking-Anwendung erforderlich</div>
                        <div>
                            Fuer das GPS-Livetracking muss die Anwendung
                            <strong>Einsatzueberwachung.LiveTracking</strong>
                            heruntergeladen und auf dem Windows-Rechner gestartet werden.
                        </div>
                    </div>

                    <p class="text-muted mb-2">
                        Die Server-Anwendung empf&auml;ngt die GPS-Daten nicht direkt vom Halsband. Starte deshalb zuerst die Anwendung aus
                        <code>src/Einsatzueberwachung.LiveTracking</code>
                        auf dem entsprechenden Windows-Rechner.
                    </p>

                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <a class="btn btn-outline-primary" href="@GetDownloadUrl("/downloads/livetracking.zip")">
                            <i class="bi bi-download me-1"></i>LiveTracking herunterladen
                        </a>
                    </div>

                    <ol class="mb-0 ps-3">
                        <li>Einsatzueberwachung.LiveTracking herunterladen bzw. bereitstellen.</li>
                        <li>ZIP entpacken und <code>Einsatzueberwachung.LiveTracking.exe</code> auf dem Windows-Rechner starten.</li>
                        <li>Danach die Verbindung zur Einsatz&uuml;berwachung konfigurieren.</li>
                    </ol>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-6">
            <div class="card h-100">
                <div class="card-header">
                    <h2 class="h4 mb-0"><i class="bi bi-broadcast-pin me-2"></i>Divera 24/7</h2>
                </div>
                <div class="card-body">
                    <div class="form-check form-switch mb-3">
                        <InputCheckbox class="form-check-input" id="diveraEnabled" @bind-Value="_appSettings.DiveraEnabled" />
                        <label class="form-check-label" for="diveraEnabled">Divera 24/7 Integration aktivieren</label>
                    </div>

                    @if (_appSettings.DiveraEnabled)
                    {
                        <div class="mb-3">
                            <label class="form-label">API Access-Key <span class="badge bg-secondary">Staffel / Einheit</span></label>
                            <div class="input-group">
                                <input type="@(_showDiveraKey ? "text" : "password")"
                                       class="form-control"
                                       placeholder="Divera API-Key eingeben"
                                       @bind="_appSettings.DiveraAccessKey" />
                                <button class="btn btn-outline-secondary" type="button"
                                        @onclick="() => _showDiveraKey = !_showDiveraKey">
                                    <i class="bi @(_showDiveraKey ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                            </div>
                            <div class="form-text">
                                Den API-Key findest du in Divera unter Verwaltung &rarr; Schnittstellen &rarr; API-Access-Key.
                                Wird f&uuml;r Alarmabfragen verwendet.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">API Base-URL</label>
                            <InputText class="form-control" @bind-Value="_appSettings.DiveraBaseUrl" placeholder="https://app.divera247.com/api/v2" />
                            <div class="form-text">Standard: https://app.divera247.com/api/v2 &mdash; nur &auml;ndern wenn abweichend.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Poll-Intervall &mdash; kein Alarm aktiv (Sekunden)</label>
                            <InputNumber class="form-control" @bind-Value="_appSettings.DiveraPollIntervalIdleSeconds" />
                            <div class="form-text">Abfrageintervall wenn kein Alarm vorliegt. Standard: 600 (= 10 Minuten).</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Poll-Intervall &mdash; Alarm aktiv (Sekunden)</label>
                            <InputNumber class="form-control" @bind-Value="_appSettings.DiveraPollIntervalActiveSeconds" />
                            <div class="form-text">Abfrageintervall sobald ein Alarm anliegt. Standard: 60 (= 1 Minute).</div>
                        </div>

                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-outline-primary" type="button" @onclick="TestDiveraConnectionAsync" disabled="@_diveraTestBusy">
                                @if (_diveraTestBusy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                <i class="bi bi-plug me-1"></i>Verbindung testen
                            </button>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_diveraTestStatus))
                        {
                            <div class="alert @(_diveraTestError ? "alert-danger" : "alert-success") py-2 mt-2 mb-0">
                                <i class="bi @(_diveraTestError ? "bi-x-circle" : "bi-check-circle") me-1"></i>@_diveraTestStatus
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted">Aktiviere die Integration, um den API-Key einzugeben und Divera zu nutzen.</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-6">
            <div class="card h-100">
                <div class="card-header">
                    <h2 class="h4 mb-0"><i class="bi bi-info-circle me-2"></i>System-Information</h2>
                </div>
                <div class="card-body">
                    <div class="mb-2"><strong>Version:</strong> 1.6.4</div>
                    <div class="mb-2"><strong>Framework:</strong> .NET 8 / Blazor Server</div>
                    <div class="mb-3"><strong>Plattform:</strong> Web-basiert</div>
                    <div class="mb-3"><strong>Integration:</strong> Divera 24/7 und Live-Tracking (aktive Alarme, Verfuegbarkeiten, Alarm-Import, GPS-Halsband-Ortung)</div>

                    <dl class="row mb-0">
                        <dt class="col-sm-4">Datenpfad</dt>
                        <dd class="col-sm-8"><code>@_dataDirectory</code></dd>

                        <dt class="col-sm-4">Berichte</dt>
                        <dd class="col-sm-8"><code>@_reportDirectory</code></dd>

                        <dt class="col-sm-4">Mobile URL</dt>
                        <dd class="col-sm-8"><a href="@_mobileUrl" target="_blank">@_mobileUrl</a></dd>
                    </dl>

                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a class="btn btn-outline-secondary" href="@GetDownloadUrl("/downloads/app-settings.json")">App-Settings JSON</a>
                        <a class="btn btn-outline-secondary" href="@GetDownloadUrl("/downloads/staffel-settings.json")">Staffel JSON</a>
                        <a class="btn btn-outline-secondary" href="@GetDownloadUrl("/downloads/session-data.json")">Session JSON</a>
                        <a class="btn btn-outline-secondary" href="@GetDownloadUrl("/downloads/stammdaten.xlsx")">Excel Export</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h2 class="h4 mb-0"><i class="bi bi-database-gear me-2"></i>Wartung und Datenverwaltung</h2>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <a class="btn btn-outline-success" href="@GetDownloadUrl("/downloads/data-backup.zip")">Daten-Backup herunterladen (ZIP)</a>
                        <button class="btn btn-outline-danger" @onclick="ConfirmResetDataAsync">Daten auf Standard zuruecksetzen</button>
                    </div>

                    <label class="form-label">SessionData Import (JSON)</label>
                    <textarea class="form-control"
                              rows="8"
                              placeholder="JSON-Inhalt von SessionData hier einfuegen"
                              @bind="_sessionImportJson"></textarea>
                    <div class="mt-2 d-flex flex-wrap gap-2">
                        <button class="btn btn-outline-secondary" @onclick="ImportSessionJsonAsync">SessionData importieren</button>
                        <InputFile OnChange="ImportSessionFileAsync" accept=".json,application/json" />
                    </div>

                    <hr />

                    <label class="form-label">AppSettings / StaffelSettings Import (JSON)</label>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="d-inline-flex align-items-center gap-2">
                            <span class="small text-muted">AppSettings</span>
                            <InputFile OnChange="ImportAppSettingsFileAsync" accept=".json,application/json" />
                        </span>
                        <span class="d-inline-flex align-items-center gap-2">
                            <span class="small text-muted">StaffelSettings</span>
                            <InputFile OnChange="ImportStaffelSettingsFileAsync" accept=".json,application/json" />
                        </span>
                    </div>

                    <hr />

                    <label class="form-label">Backup wiederherstellen (ZIP)</label>
                    <p class="text-muted mb-2">Importiert SessionData, AppSettings, StaffelSettings und Archivdaten aus einer zuvor erzeugten Daten-Backup-ZIP.</p>
                    <div>
                        <InputFile OnChange="ConfirmRestoreBackupZipAsync" accept=".zip,application/zip" />
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_maintenanceStatus))
                    {
                        <div class="alert @(_maintenanceError ? "alert-danger" : "alert-success") mt-3 mb-0">@_maintenanceStatus</div>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_status))
    {
        <div class="alert alert-success mt-4">@_status</div>
    }
</div>
