@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<div class="container py-4">
    <div class="card error-page-card">
        <div class="card-header">
            <h1 class="h4 mb-0 text-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>Fehler</h1>
        </div>
        <div class="card-body">
            <p class="mb-3">Bei der Verarbeitung ist ein Fehler aufgetreten.</p>

            @if (ShowRequestId)
            {
                <p>
                    <strong>Request-ID:</strong> <code>@RequestId</code>
                </p>
            }

            <h2 class="h5">Hinweis zum Entwicklungsmodus</h2>
            <p class="mb-0">
                Im Modus <strong>Development</strong> werden detaillierte Fehlerinformationen angezeigt.
                Im produktiven Betrieb sollte Development nicht aktiv sein, um sensible Informationen zu schuetzen.
            </p>
        </div>
    </div>
</div>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
