@page "/"
@rendermode InteractiveServer
@inject IEinsatzService EinsatzService
@inject IArchivService ArchivService
@inject IHttpClientFactory HttpClientFactory
@inject IDiveraService DiveraService
@inject IWeatherService WeatherService
@using Einsatzueberwachung.Domain.Models.Divera
@implements IDisposable

<PageTitle>Startseite — Einsatzüberwachung</PageTitle>

@{
    var e = EinsatzService.CurrentEinsatz;
    var teams = EinsatzService.Teams;
    var notes = EinsatzService.GlobalNotes;
    var laufend = teams.Where(t => t.IsRunning).ToList();
    var warnung = teams.Where(t => t.IsSecondWarning).ToList();
    var orange = teams.Where(t => t.IsFirstWarning && !t.IsSecondWarning).ToList();
    var letzteFunk = notes.Where(n => n.SourceType == "Funk")
                          .OrderByDescending(n => n.Timestamp).Take(3).ToList();
    var letzteNotizen = notes.Where(n => n.SourceType != "Funk")
                             .OrderByDescending(n => n.Timestamp).Take(3).ToList();
    bool aktiv = !string.IsNullOrWhiteSpace(e.Einsatzort);
}

<div class="container-fluid py-4 dashboard-page">
    @* Divera-Alarm-Banner — _diveraAlarms wird nur befuellt wenn konfiguriert und Alarm aktiv *@
    @if (_diveraAlarms.Any())
    {
        <div class="alert alert-danger d-flex align-items-start gap-3 mb-4 shadow-sm" role="alert" style="border-left: 4px solid var(--bs-danger);">
            <i class="bi bi-broadcast-pin fs-3 flex-shrink-0 mt-1"></i>
            <div class="flex-grow-1">
                <h5 class="alert-heading mb-1">@_diveraAlarms.Count Divera-Alarm@(_diveraAlarms.Count > 1 ? "e" : "") aktiv</h5>
                @foreach (var alarm in _diveraAlarms.Take(3))
                {
                    <div class="mb-1">
                        <strong>@alarm.Title</strong>
                        @if (!string.IsNullOrWhiteSpace(alarm.Address))
                        {
                            <span class="text-danger-emphasis ms-2 small"><i class="bi bi-geo-alt me-1"></i>@alarm.Address</span>
                        }
                        <span class="text-danger-emphasis ms-2 small"><i class="bi bi-clock me-1"></i>@alarm.DateFormatted</span>
                    </div>
                }
            </div>
            <div class="d-flex flex-column gap-2 flex-shrink-0">
                <a class="btn btn-danger btn-sm" href="/einsatz-start">
                    <i class="bi bi-plus-circle me-1"></i>Einsatz anlegen
                </a>
                <a class="btn btn-outline-danger btn-sm" href="/divera">
                    <i class="bi bi-broadcast-pin me-1"></i>Divera-Details
                </a>
            </div>
        </div>
    }

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4 page-headline-row">
        <div>
            <h1 class="h3 mb-1">
                <i class="bi bi-speedometer2 me-2 text-primary"></i>Dashboard
            </h1>
            <p class="text-muted mb-0">Lageübersicht für @DateTime.Now.ToString("dddd, dd. MMMM yyyy")</p>
        </div>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            @if (aktiv)
            {
                <span class="badge bg-success fs-6 align-self-center px-3 py-2">
                    <i class="bi bi-record-circle me-1"></i>Einsatz aktiv
                </span>
            }
            else
            {
                <span class="badge bg-secondary fs-6 align-self-center px-3 py-2">
                    <i class="bi bi-pause-circle me-1"></i>Kein Einsatz
                </span>
            }
        </div>
    </div>

    <!-- Kennzahlen -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card h-100 border-0 shadow-sm home-stat-card stat-teams">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="stat-icon-badge stat-icon-primary">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <div>
                        <div class="stat-number text-primary">@teams.Count</div>
                        <div class="stat-label text-muted">Teams gesamt</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card h-100 border-0 shadow-sm home-stat-card stat-active">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="stat-icon-badge stat-icon-success">
                        <i class="bi bi-play-circle-fill"></i>
                    </div>
                    <div>
                        <div class="stat-number text-success">@laufend.Count</div>
                        <div class="stat-label text-muted">Im Einsatz</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card h-100 border-0 shadow-sm home-stat-card stat-critical">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="stat-icon-badge @(warnung.Count > 0 ? "stat-icon-danger" : "stat-icon-primary")">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </div>
                    <div>
                        <div class="stat-number @(warnung.Count > 0 ? "text-danger" : "text-muted")">@warnung.Count</div>
                        <div class="stat-label text-muted">Kritische Teams</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card h-100 border-0 shadow-sm home-stat-card stat-notes">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <div class="stat-icon-badge stat-icon-info">
                        <i class="bi bi-journal-text"></i>
                    </div>
                    <div>
                        <div class="stat-number text-info">@notes.Count</div>
                        <div class="stat-label text-muted">Einträge gesamt</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <!-- Einsatz-Info -->
        <div class="col-md-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-transparent border-0 fw-semibold">
                    <i class="bi bi-info-circle me-2 text-primary"></i>Aktueller Einsatz
                </div>
                <div class="card-body">
                    @if (aktiv)
                    {
                        <dl class="row mb-0 small">
                            <dt class="col-5 text-muted">Typ</dt>
                            <dd class="col-7">@(e.IstEinsatz ? "Einsatz" : "Übung")</dd>
                            <dt class="col-5 text-muted">Einsatzort</dt>
                            <dd class="col-7">@e.Einsatzort</dd>
                            <dt class="col-5 text-muted">Alarmiert</dt>
                            <dd class="col-7">@e.Alarmiert</dd>
                            <dt class="col-5 text-muted">Einsatzleiter</dt>
                            <dd class="col-7">@(string.IsNullOrWhiteSpace(e.Einsatzleiter) ? "—" : e.Einsatzleiter)</dd>
                            @if (!string.IsNullOrWhiteSpace(e.Fuehrungsassistent))
                            {
                                <dt class="col-5 text-muted">Führungsass.</dt>
                                <dd class="col-7">@e.Fuehrungsassistent</dd>
                            }
                        </dl>
                    }
                    else
                    {
                        <p class="text-muted mb-3">Kein Einsatz aktiv.</p>
                    }
                    <div class="d-flex gap-2 mt-3 flex-wrap">
                        @if (!aktiv)
                        {
                            <a class="btn btn-primary btn-sm" href="/einsatz-start"><i class="bi bi-plus-circle me-1"></i>Einsatz anlegen</a>
                        }
                        <a class="btn btn-outline-primary btn-sm" href="/einsatz-monitor"><i class="bi bi-display me-1"></i>Monitor</a>
                        <a class="btn btn-outline-secondary btn-sm" href="/einsatz-karte"><i class="bi bi-map me-1"></i>Karte</a>
                        <a class="btn btn-outline-secondary btn-sm" href="/einsatz-archiv"><i class="bi bi-archive me-1"></i>Archiv</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Teams Status -->
        <div class="col-md-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-transparent border-0 fw-semibold">
                    <i class="bi bi-people me-2 text-primary"></i>Team-Status
                </div>
                <div class="card-body p-0">
                    @if (teams.Count == 0)
                    {
                        <p class="text-muted p-3 mb-0">Keine Teams aktiv.</p>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var team in teams.Take(8))
                            {
                                var elapsed = team.ElapsedTime;
                                string timerCss = team.IsSecondWarning ? "text-danger fw-bold" : team.IsFirstWarning ? "text-warning fw-bold" : "text-success";
                                string statusBadge = team.IsSecondWarning ? "bg-danger" : team.IsFirstWarning ? "bg-warning text-dark" : team.IsRunning ? "bg-success" : "bg-secondary";
                                <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center border-0 py-2">
                                    <div>
                                        <div class="fw-semibold small">@team.TeamName</div>
                                        <div class="text-muted small">
                                            @(string.IsNullOrWhiteSpace(team.SearchAreaName) ? "Kein Suchgebiet" : team.SearchAreaName)
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="@timerCss" style="font-family:monospace;font-size:.85rem;">
                                            @elapsed.ToString(@"hh\:mm\:ss")
                                        </span>
                                        <span class="badge @statusBadge">@(team.IsRunning ? "Läuft" : "Stop")</span>
                                    </div>
                                </div>
                            }
                            @if (teams.Count > 8)
                            {
                                <div class="list-group-item text-muted small text-center border-0">
                                    +@(teams.Count - 8) weitere → <a href="/einsatz-monitor">Monitor öffnen</a>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Letzte Einträge -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent border-0 fw-semibold">
                    <i class="bi bi-chat-left-text me-2 text-primary"></i>Letzte Notizen
                </div>
                <div class="card-body p-0">
                    @if (letzteNotizen.Count == 0)
                    {
                        <p class="text-muted p-3 mb-0">Keine Notizen vorhanden.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var n in letzteNotizen)
                            {
                                <li class="list-group-item border-0 py-2">
                                    <div class="small">@n.Text</div>
                                    <div class="text-muted small">@n.Timestamp.ToString("HH:mm")</div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>

        <!-- Letzte Funksprüche -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent border-0 fw-semibold">
                    <i class="bi bi-broadcast me-2 text-primary"></i>Letzte Funksprüche
                </div>
                <div class="card-body p-0">
                    @if (letzteFunk.Count == 0)
                    {
                        <p class="text-muted p-3 mb-0">Keine Funksprüche vorhanden.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var f in letzteFunk)
                            {
                                <li class="list-group-item border-0 py-2">
                                    <div class="small">@f.Text</div>
                                    <div class="text-muted small">@f.Timestamp.ToString("HH:mm")</div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (aktiv && !string.IsNullOrWhiteSpace(e.Einsatzort))
    {
        <div class="card border-0 shadow-sm mt-4">
            <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div class="fw-semibold">
                    <i class="bi bi-cloud-sun me-2 text-info"></i>Wetter am Einsatzort
                    <span class="text-muted small ms-2">@e.Einsatzort</span>
                </div>
                <button class="btn btn-outline-secondary btn-sm" @onclick="RefreshWeatherAsync" disabled="@_weatherLoading">
                    <i class="bi bi-arrow-clockwise me-1"></i>Aktualisieren
                </button>
            </div>
            <div class="card-body">
                @if (_weatherLoading)
                {
                    <span class="text-muted small"><span class="spinner-border spinner-border-sm me-1"></span>Wetterdaten werden geladen...</span>
                }
                else if (_weather != null)
                {
                    <div class="row g-3">
                        <div class="col-6 col-md-2 text-center">
                            <i class="bi @_weather.GetBootstrapIcon() fs-2 text-info"></i>
                            <div class="fw-semibold fs-5">@_weather.TemperaturFormatiert</div>
                            <div class="text-muted small">@_weather.Wetterlage</div>
                        </div>
                        <div class="col-6 col-md-2">
                            <div class="small text-muted">Wind</div>
                            <div class="fw-semibold">@_weather.WindFormatiert</div>
                            @if (_weather.Windboeen > 0)
                            {
                                <div class="small text-muted">Böen @((int)_weather.Windboeen) km/h</div>
                            }
                        </div>
                        <div class="col-6 col-md-2">
                            <div class="small text-muted">Luftfeuchte</div>
                            <div class="fw-semibold">@_weather.LuftfeuchtigkeitFormatiert</div>
                            <div class="small text-muted">Bewölkung @_weather.Bewoelkung%</div>
                        </div>
                        <div class="col-6 col-md-2">
                            <div class="small text-muted">Sicht</div>
                            <div class="fw-semibold">@(_weather.Sichtweite >= 1 ? $"{_weather.Sichtweite:0.0} km" : $"{(int)(_weather.Sichtweite * 1000)} m")</div>
                        </div>
                        @if (_flugwetter != null)
                        {
                            <div class="col-6 col-md-2">
                                <div class="small text-muted">Drohnenflug</div>
                                <span class="badge @_flugwetter.GetKategorieBadgeClass()">@_flugwetter.Kategorie</span>
                                <div class="small @(_flugwetter.IstDrohnenflugMoeglich ? "text-success" : "text-danger") mt-1">
                                    @(_flugwetter.IstDrohnenflugMoeglich ? "Möglich" : "Nicht empfohlen")
                                </div>
                            </div>
                        }
                        @if (_weather.HatWarnung)
                        {
                            <div class="col-12">
                                <div class="alert @_weather.GetWarnungBadgeClass() py-2 mb-0">
                                    <i class="bi bi-exclamation-triangle me-1"></i>@_weather.Warnung
                                </div>
                            </div>
                        }
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(_weatherError))
                {
                    <span class="text-muted small"><i class="bi bi-cloud-slash me-1"></i>@_weatherError</span>
                }
            </div>
        </div>
    }

    <div class="card border-0 shadow-sm mt-4 home-update-card home-server-status-card">
        <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div class="fw-semibold">
                <i class="bi bi-hdd-network me-2 text-primary"></i>Server-Status
            </div>
            <span class="badge @(_serverHealthy ? "bg-success" : "bg-warning text-dark")">
                @(_serverHealthy ? "Online" : "Pruefen")
            </span>
        </div>
        <div class="card-body">
            <div class="home-server-meta-grid mb-3">
                <div class="home-server-meta-item">
                    <div class="home-server-meta-label">Health</div>
                    <div class="home-server-meta-value">@_serverHealthText</div>
                </div>
                <div class="home-server-meta-item">
                    <div class="home-server-meta-label">Letzter Check</div>
                    <div class="home-server-meta-value">@DisplayDateTime(_serverLastCheckedAt)</div>
                </div>
                <div class="home-server-meta-item">
                    <div class="home-server-meta-label">Updates</div>
                    <div class="home-server-meta-value"><a href="/einstellungen">In Einstellungen verwalten</a></div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_serverStatusError))
            {
                <div class="alert alert-warning py-2 mb-2">@_serverStatusError</div>
            }

            <div class="d-flex flex-wrap gap-2 align-items-center justify-content-between">
                <span class="text-muted small">
                    <i class="bi bi-shield-check me-1"></i>Basis-Healthcheck über /health
                </span>
                <button class="btn btn-outline-primary btn-sm" @onclick="RefreshServerStatusAsync" disabled="@_serverStatusLoading">
                    <i class="bi bi-arrow-clockwise me-1"></i>Status aktualisieren
                </button>
                @if (_serverStatusLoading)
                {
                    <span class="text-muted small">Prüfe Serverstatus...</span>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private Action<Team>? _teamAddedHandler;
    private Action<Team>? _teamRemovedHandler;
    private Action<Team>? _teamUpdatedHandler;
    private Action<GlobalNotesEntry>? _noteAddedHandler;
    private bool _serverHealthy;
    private bool _serverStatusLoading;
    private string _serverHealthText = "Unbekannt";
    private string _serverStatusError = string.Empty;
    private DateTime? _serverLastCheckedAt;

    // Divera-Polling
    private List<DiveraAlarm> _diveraAlarms = new();
    private System.Threading.Timer? _diveraTimer;

    // Wetter-Widget
    private WeatherData? _weather;
    private FlugwetterData? _flugwetter;
    private bool _weatherLoading;
    private string _weatherError = string.Empty;

    protected override void OnInitialized()
    {
        _teamAddedHandler = _ => Refresh();
        _teamRemovedHandler = _ => Refresh();
        _teamUpdatedHandler = _ => Refresh();
        _noteAddedHandler = _ => Refresh();

        EinsatzService.EinsatzChanged += Refresh;
        EinsatzService.TeamAdded += _teamAddedHandler;
        EinsatzService.TeamRemoved += _teamRemovedHandler;
        EinsatzService.TeamUpdated += _teamUpdatedHandler;
        EinsatzService.NoteAdded += _noteAddedHandler;

        _ = RefreshServerStatusAsync();
    }

    protected override async Task OnInitializedAsync()
    {
        // IsConfigured-Guard NICHT verwenden — DiveraService ist frisch (transient),
        // Konfiguration wird erst in GetActiveAlarmsAsync lazy geladen
        await PollDiveraAsync();

        var e = EinsatzService.CurrentEinsatz;
        if (!string.IsNullOrWhiteSpace(e.Einsatzort))
            await RefreshWeatherAsync();
    }

    private void ScheduleDiveraTimer()
    {
        _diveraTimer?.Dispose();
        // Naechstes Intervall je nach aktuellem Alarm-Status bestimmen
        var intervalMs = _diveraAlarms.Any()
            ? DiveraService.PollIntervalActiveSeconds * 1000
            : DiveraService.PollIntervalIdleSeconds * 1000;

        _diveraTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await PollDiveraAsync();
                StateHasChanged();
            });
        }, null, intervalMs, System.Threading.Timeout.Infinite);
    }

    private async Task PollDiveraAsync()
    {
        try
        {
            _diveraAlarms = await DiveraService.GetActiveAlarmsAsync();
        }
        catch
        {
            _diveraAlarms = new();
        }
        // Timer neu planen damit Intervall auf aktuellem Status basiert
        ScheduleDiveraTimer();
    }

    private void Refresh() => InvokeAsync(StateHasChanged);

    private async Task RefreshServerStatusAsync()
    {
        _serverStatusLoading = true;
        _serverStatusError = string.Empty;

        try
        {
            var client = HttpClientFactory.CreateClient();
            var response = await client.GetAsync("/health");

            _serverHealthy = response.IsSuccessStatusCode;
            _serverHealthText = _serverHealthy ? "OK" : $"Fehler ({(int)response.StatusCode})";
        }
        catch (Exception ex)
        {
            _serverHealthy = false;
            _serverHealthText = "Nicht erreichbar";
            _serverStatusError = ex.Message;
        }
        finally
        {
            _serverLastCheckedAt = DateTime.Now;
            _serverStatusLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshWeatherAsync()
    {
        var einsatzort = EinsatzService.CurrentEinsatz.Einsatzort;
        if (string.IsNullOrWhiteSpace(einsatzort)) return;

        _weatherLoading = true;
        _weatherError = string.Empty;
        StateHasChanged();

        try
        {
            _weather = await WeatherService.GetCurrentWeatherByAddressAsync(einsatzort);
            if (_weather == null)
            {
                _weatherError = "Keine Wetterdaten verfügbar.";
            }
            else
            {
                // Flugwetter nur laden wenn Koordinaten bekannt (ELW-Position oder Geocoding)
                var elw = EinsatzService.CurrentEinsatz.ElwPosition;
                if (elw.HasValue)
                {
                    _flugwetter = await WeatherService.GetFlugwetterAsync(elw.Value.Latitude, elw.Value.Longitude);
                }
                else
                {
                    var coords = await WeatherService.GeocodeAddressAsync(einsatzort);
                    if (coords.HasValue)
                        _flugwetter = await WeatherService.GetFlugwetterAsync(coords.Value.Latitude, coords.Value.Longitude);
                }
            }
        }
        catch (Exception ex)
        {
            _weatherError = $"Wetter konnte nicht geladen werden: {ex.Message}";
        }
        finally
        {
            _weatherLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string DisplayDateTime(DateTime? value)
    {
        return value.HasValue ? value.Value.ToString("dd.MM.yyyy HH:mm") : "-";
    }

    public void Dispose()
    {
        EinsatzService.EinsatzChanged -= Refresh;
        if (_teamAddedHandler is not null) EinsatzService.TeamAdded -= _teamAddedHandler;
        if (_teamRemovedHandler is not null) EinsatzService.TeamRemoved -= _teamRemovedHandler;
        if (_teamUpdatedHandler is not null) EinsatzService.TeamUpdated -= _teamUpdatedHandler;
        if (_noteAddedHandler is not null) EinsatzService.NoteAdded -= _noteAddedHandler;
        _diveraTimer?.Dispose();
    }
}
