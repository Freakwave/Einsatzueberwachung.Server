@page "/"
@rendermode InteractiveServer

<PageTitle>Startseite — Einsatzüberwachung</PageTitle>

<div class="home-lobby-wrapper">

    <div class="row g-4 home-lobby-row">

        <!-- Linke Spalte: Notizblock -->
        <div class="col-12 col-md-3 order-2 order-md-1 d-flex flex-column">
            <div class="card border-0 shadow-sm home-fill-card">
                <div class="card-header bg-transparent border-0 fw-semibold">
                    <i class="bi bi-pencil-square me-2 text-primary"></i>Verfügbarkeit / Notizen
                </div>
                <div class="card-body d-flex flex-column gap-3 home-fill-body">
                    <div class="input-group input-group-sm">
                        <input class="form-control" placeholder="Notiz hinzufügen…" @bind="_newNoteText" @onkeydown="OnNoteKeyDown" maxlength="200" />
                        <button class="btn btn-primary" @onclick="AddNoteAsync" disabled="@string.IsNullOrWhiteSpace(_newNoteText)">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                    </div>
                    <div class="home-note-list">
                        @if (_notes.Count == 0)
                        {
                            <p class="text-muted small mb-0">Keine Einträge.</p>
                        }
                        else
                        {
                            @foreach (var note in _notes)
                            {
                                <div class="home-note-item d-flex justify-content-between align-items-start gap-2">
                                    <div class="flex-grow-1">
                                        <div class="small">@note.Text</div>
                                        <div class="text-muted" style="font-size:.7rem;">@note.CreatedAt.ToString("HH:mm dd.MM")</div>
                                    </div>
                                    <button class="btn btn-link btn-sm text-danger p-0 flex-shrink-0" @onclick="() => DeleteNoteAsync(note.Id)" title="Löschen">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Mittlere Spalte: Staffel-Identität -->
        <div class="col-12 col-md-6 order-1 order-md-2 d-flex flex-column">
            <div class="card border-0 shadow-sm home-fill-card">
                <div class="card-body home-fill-body d-flex flex-column align-items-center justify-content-center text-center gap-3">
                    @if (_logoVisible)
                    {
                        <img src="/downloads/staffel-logo"
                             class="home-logo"
                             alt="Staffel-Logo"
                             @onerror="OnLogoError" />
                    }
                    @if (!string.IsNullOrWhiteSpace(_staffelName))
                    {
                        <h2 class="fw-bold mb-0">@_staffelName</h2>
                    }
                    <div class="home-clock">@_now.ToString("HH:mm:ss")</div>
                    <div class="text-muted fs-5">@_now.ToString("dddd, dd. MMMM yyyy", new System.Globalization.CultureInfo("de-DE"))</div>
                    <div class="mt-2">
                        @if (_diveraAlarms.Any())
                        {
                            <a class="btn btn-danger btn-lg px-5 py-3 home-alarm-btn shadow" href="/einsatz-start">
                                <i class="bi bi-broadcast-pin me-2 fs-5"></i>
                                <strong>@_diveraAlarms.Count Divera-Alarm@(_diveraAlarms.Count > 1 ? "e" : "") aktiv</strong>
                                <span class="d-block small fw-normal mt-1">Jetzt Einsatz anlegen →</span>
                            </a>
                        }
                        else if (_einsatzAktiv)
                        {
                            <a class="btn btn-success btn-lg px-5 py-3 shadow" href="/einsatz-monitor">
                                <i class="bi bi-display me-2 fs-5"></i>
                                <strong>Einsatz aktiv — @_einsatzOrt</strong>
                                <span class="d-block small fw-normal mt-1">Zum Einsatz-Monitor →</span>
                            </a>
                        }
                        else
                        {
                            <a class="btn btn-outline-primary" href="/einsatz-start">
                                <i class="bi bi-plus-circle me-1"></i>Neuen Einsatz anlegen
                            </a>
                        }
                    </div>
                    <div class="text-muted mt-auto" style="font-size:.75rem;">
                        v@(_appVersion)
                    </div>
                </div>
            </div>
        </div>

        <!-- Rechte Spalte: Statistik + Letzte Einsätze -->
        <div class="col-12 col-md-3 order-3 d-flex flex-column gap-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent border-0 fw-semibold">
                    <i class="bi bi-bar-chart-line me-2 text-primary"></i>Archiv-Statistik
                </div>
                <div class="card-body p-3">
                    <div class="home-stat-grid">
                        <div class="home-stat-cell">
                            <div class="home-stat-value">@(_stats?.GesamtAnzahl ?? 0)</div>
                            <div class="home-stat-label">Einsätze gesamt</div>
                        </div>
                        <div class="home-stat-cell">
                            <div class="home-stat-value">@(_stats?.AnzahlDiesesJahr ?? 0)</div>
                            <div class="home-stat-label">Dieses Jahr</div>
                        </div>
                        <div class="home-stat-cell">
                            <div class="home-stat-value">@AvgPersonal</div>
                            <div class="home-stat-label">Ø Kräfte/Einsatz</div>
                        </div>
                        <div class="home-stat-cell">
                            <div class="home-stat-value">@AvgDuration</div>
                            <div class="home-stat-label">Ø Dauer</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm flex-grow-1">
                <div class="card-header bg-transparent border-0 fw-semibold d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-archive me-2 text-primary"></i>Letzte Einsätze</span>
                    <a class="btn btn-link btn-sm p-0 text-muted" href="/einsatz-archiv">Alle →</a>
                </div>
                <div class="card-body p-0">
                    @if (_recentEinsaetze.Count == 0)
                    {
                        <p class="text-muted small p-3 mb-0">Noch keine archivierten Einsätze.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var e in _recentEinsaetze)
                            {
                                <li class="list-group-item border-0 py-2 px-3">
                                    <div class="d-flex justify-content-between align-items-center gap-2">
                                        <div class="small fw-semibold text-truncate">@e.Einsatzort</div>
                                        <span class="badge @(e.IstEinsatz ? "bg-danger" : "bg-secondary") flex-shrink-0">
                                            @(e.IstEinsatz ? "Einsatz" : "Übung")
                                        </span>
                                    </div>
                                    <div class="text-muted" style="font-size:.75rem;">@e.ArchivedAt.ToString("dd.MM.yyyy")</div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>

    </div>
</div>
