@page "/"
@rendermode InteractiveServer

<PageTitle>Startseite — Einsatzüberwachung</PageTitle>

<div class="home-lobby-wrapper">

    <div class="row g-3 home-lobby-row">

        <!-- Bereitschaft (links) -->
        <div class="col-12 col-md-3 order-2 order-md-1 d-flex flex-column">
            <section class="home-card home-fill-card">
                <header class="home-card-head">
                    <span class="home-card-eyebrow">Bereitschaft</span>
                </header>
                <div class="home-card-body home-fill-body">
                    <div class="home-bereitschaft-add">
                        <input class="home-bereitschaft-input"
                               placeholder="Notiz hinzufügen …"
                               @bind="_newNoteText"
                               @onkeydown="OnNoteKeyDown"
                               maxlength="200" />
                        <button class="home-bereitschaft-add-btn"
                                @onclick="AddNoteAsync"
                                disabled="@string.IsNullOrWhiteSpace(_newNoteText)"
                                title="Hinzufügen">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                    </div>

                    @if (_notes.Count == 0)
                    {
                        <p class="home-empty">Keine Einträge.</p>
                    }
                    else
                    {
                        <ul class="home-note-list">
                            @foreach (var note in _notes)
                            {
                                <li class="home-note-item">
                                    <div class="home-note-body">
                                        <span class="home-note-text">@note.Text</span>
                                        <span class="home-note-meta">@note.CreatedAt.ToString("HH:mm · dd.MM")</span>
                                    </div>
                                    <button class="home-note-del" @onclick="() => DeleteNoteAsync(note.Id)" title="Löschen">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </section>
        </div>

        <!-- Lagebild (Mitte) -->
        <div class="col-12 col-md-6 order-1 order-md-2 d-flex flex-column">
            <section class="home-lagebild home-fill-card">
                <div class="home-lagebild-content">
                    @if (_logoVisible)
                    {
                        <img src="/downloads/staffel-logo"
                             class="home-logo"
                             alt="Staffel-Logo"
                             @onerror="OnLogoError" />
                    }
                    @if (!string.IsNullOrWhiteSpace(_staffelName))
                    {
                        <h1 class="home-staffel-name">@_staffelName</h1>
                    }

                    <div class="home-clock">
                        <span class="home-clock-main">@_now.ToString("HH:mm")</span><span class="home-clock-seconds">:@_now.ToString("ss")</span>
                    </div>
                    <div class="home-clock-date">
                        @_now.ToString("dddd, dd. MMMM yyyy", new System.Globalization.CultureInfo("de-DE"))
                    </div>

                    @{
                        var hasAlarm = _diveraAlarms.Any();
                        string statusClass;
                        string statusIcon;
                        string statusText;
                        if (hasAlarm)
                        {
                            statusClass = "is-alarm";
                            statusIcon = "bi-broadcast-pin";
                            statusText = $"ALARM — {_diveraAlarms.Count} Divera-Alarm{(_diveraAlarms.Count > 1 ? "e" : "")} aktiv";
                        }
                        else if (_einsatzAktiv)
                        {
                            statusClass = "is-active";
                            statusIcon = "bi-display";
                            statusText = $"Einsatz läuft — {_einsatzOrt}";
                        }
                        else
                        {
                            statusClass = "is-calm";
                            statusIcon = "bi-shield-check";
                            statusText = "Lage ruhig — keine aktiven Alarme";
                        }
                    }
                    <div class="home-status-band @statusClass">
                        <span class="home-status-pulse"></span>
                        <i class="bi @statusIcon"></i>
                        <span>@statusText</span>
                    </div>

                    <div class="home-action-row">
                        @if (hasAlarm)
                        {
                            <a class="home-action-btn home-action-btn--alarm" href="/einsatz-start">
                                <span>Jetzt Einsatz anlegen</span>
                                <i class="bi bi-arrow-right"></i>
                            </a>
                        }
                        else if (_einsatzAktiv)
                        {
                            <a class="home-action-btn home-action-btn--active" href="/einsatz-monitor">
                                <span>Zum Einsatz-Monitor</span>
                                <i class="bi bi-arrow-right"></i>
                            </a>
                        }
                        else
                        {
                            <a class="home-action-btn home-action-btn--calm" href="/einsatz-start">
                                <i class="bi bi-plus-circle"></i>
                                <span>Neuen Einsatz anlegen</span>
                            </a>
                        }
                    </div>
                </div>

                <div class="home-watchline">
                    <span class="home-watchline-dot"></span>
                    System bereit · v@(_appVersion)
                </div>
            </section>
        </div>

        <!-- Letzte Lagen + Bilanz (rechts) -->
        <div class="col-12 col-md-3 order-3 d-flex flex-column gap-3">
            <section class="home-card home-fill-card">
                <header class="home-card-head home-card-head--split">
                    <span class="home-card-eyebrow">Letzte Lagen</span>
                    <a class="home-card-link" href="/einsatz-archiv">Alle →</a>
                </header>
                <div class="home-card-body home-fill-body">
                    @if (_recentEinsaetze.Count == 0)
                    {
                        <p class="home-empty">Noch keine archivierten Einsätze.</p>
                    }
                    else
                    {
                        <ol class="home-timeline">
                            @foreach (var e in _recentEinsaetze)
                            {
                                <li class="home-timeline-item @(e.IstEinsatz ? "is-einsatz" : "is-uebung")">
                                    <span class="home-timeline-dot"></span>
                                    <div class="home-timeline-title">@e.Einsatzort</div>
                                    <div class="home-timeline-meta">
                                        @e.ArchivedAt.ToString("dd.MM.yyyy") · @(e.IstEinsatz ? "Einsatz" : "Übung")
                                    </div>
                                </li>
                            }
                        </ol>
                    }
                </div>
            </section>

            <section class="home-card">
                <header class="home-card-head">
                    <span class="home-card-eyebrow">Bilanz</span>
                </header>
                <div class="home-card-body home-bilanz-body">
                    <dl class="home-bilanz">
                        <div class="home-bilanz-row">
                            <dt>Einsätze gesamt</dt>
                            <dd>@(_stats?.GesamtAnzahl ?? 0)</dd>
                        </div>
                        <div class="home-bilanz-row">
                            <dt>Dieses Jahr</dt>
                            <dd>@(_stats?.AnzahlDiesesJahr ?? 0)</dd>
                        </div>
                        <div class="home-bilanz-row">
                            <dt>Ø Kräfte / Einsatz</dt>
                            <dd>@AvgPersonal</dd>
                        </div>
                        <div class="home-bilanz-row">
                            <dt>Ø Dauer</dt>
                            <dd>@AvgDuration</dd>
                        </div>
                    </dl>
                </div>
            </section>
        </div>

    </div>
</div>
