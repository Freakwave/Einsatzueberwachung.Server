@page "/mobile-connect"

@using QRCoder

@inject NavigationManager Navigation

<PageTitle>Mobile Verbindung</PageTitle>

<div class="container py-4">
    <h1 class="mb-1"><i class="bi bi-qr-code me-2"></i>Mobile Verbindung</h1>
    <p class="text-muted">QR-Code und Direktlink fuer die mobile Web-App im VPN.</p>

    <div class="row g-4 align-items-start">
        <div class="col-12 col-lg-5">
            <div class="card">
                <div class="card-body text-center">
                    <h2 class="h5 mb-3">QR-Code</h2>
                    <div class="border rounded p-3 bg-white d-inline-block">
                        @((MarkupString)_qrCodeSvg)
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-7">
            <div class="card mb-3">
                <div class="card-body">
                    <h2 class="h5 mb-3">Direktlink</h2>

                    <label class="form-label">Mobile URL</label>
                    <input class="form-control" value="@_mobileUrl" readonly />

                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a class="btn btn-primary" href="@_mobileUrl" target="_blank"><i class="bi bi-phone me-1"></i>Mobile App oeffnen</a>
                        <a class="btn btn-outline-secondary" href="@Navigation.ToAbsoluteUri("/")" target="_blank"><i class="bi bi-display me-1"></i>Hauptanwendung oeffnen</a>
                    </div>
                </div>
            </div>

            <div class="alert alert-info mb-0">
                Die Mobile-App ist nur innerhalb des VPN erreichbar. Der QR-Code verweist auf die konfigurierte Adresse dieses Servers mit dem Pfad <strong>/mobile/</strong>.
            </div>
        </div>
    </div>
</div>

@code {
    private string _mobileUrl = string.Empty;
    private string _qrCodeSvg = string.Empty;

    protected override void OnInitialized()
    {
        _mobileUrl = new Uri(new Uri(Navigation.BaseUri), "mobile/").ToString();

        using var qrGenerator = new QRCodeGenerator();
        using var qrCodeData = qrGenerator.CreateQrCode(_mobileUrl, QRCodeGenerator.ECCLevel.Q);
        var svgQrCode = new SvgQRCode(qrCodeData);
        _qrCodeSvg = svgQrCode.GetGraphic(8);
    }
}
