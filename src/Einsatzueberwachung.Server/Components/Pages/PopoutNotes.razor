@page "/popout-notes"
@rendermode InteractiveServer
@implements IDisposable

@inject IEinsatzService EinsatzService

<PageTitle>Popout Notizen</PageTitle>

<div class="container py-3 popout-page">
    <h1 class="mb-1"><i class="bi bi-chat-left-text me-2"></i>Notizen & Funksprueche</h1>
    <p class="text-muted">Separates Fenster fuer Notizen und Funksprueche.</p>

    <div class="d-flex gap-2 mb-3">
        <select class="form-select" style="max-width: 12rem;" @bind="_filter">
            <option value="alle">Alle</option>
            <option value="notiz">Notizen</option>
            <option value="funk">Funk</option>
        </select>
        <button class="btn btn-outline-secondary" @onclick="RefreshAsync">Aktualisieren</button>
    </div>

    @if (_notes.Count == 0)
    {
        <p class="text-muted">Keine Eintraege vorhanden.</p>
    }
    else
    {
        @foreach (var note in _notes)
        {
            <div class="card mb-2 popout-entry-card">
                <div class="card-body py-2">
                    <div class="d-flex justify-content-between">
                        <strong>@(string.IsNullOrWhiteSpace(note.SourceTeamName) ? "System" : note.SourceTeamName)</strong>
                        <span class="text-muted">@note.FormattedDateTime</span>
                    </div>
                    <div class="mb-2">@MentionTextarea.RenderWithMentions(note.Text)</div>

                    <div class="d-flex align-items-center gap-2 mb-2">
                        @if (note.IsEdited)
                        {
                            <span class="badge bg-info">Bearbeitet</span>
                        }
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleHistoryAsync(note.Id)">Historie</button>
                    </div>

                    @if (IsHistoryVisible(note.Id))
                    {
                        var historyEntries = GetHistoryEntries(note.Id);
                        if (historyEntries.Count == 0)
                        {
                            <div class="small text-muted mb-2">Keine Historie vorhanden.</div>
                        }
                        else
                        {
                            <div class="small border rounded p-2 mb-2 popout-history-box">
                                @foreach (var history in historyEntries)
                                {
                                    <div class="mb-1">
                                        <div class="text-muted">@history.FormattedChangedAt - @history.ChangedBy</div>
                                        <div><strong>Alt:</strong> @history.OldText</div>
                                        <div><strong>Neu:</strong> @history.NewText</div>
                                    </div>
                                }
                            </div>
                        }
                    }

                    @if (note.Replies.Count > 0)
                    {
                        @foreach (var reply in note.Replies.OrderBy(r => r.Timestamp))
                        {
                            <div class="border-start ps-2 mb-1 small">
                                <span class="text-muted">@reply.SourceTeamName - @reply.FormattedTimestamp</span>
                                <div>@MentionTextarea.RenderWithMentions(reply.Text)</div>
                            </div>
                        }
                    }

                    <div class="input-group input-group-sm mt-2">
                        <input class="form-control"
                               placeholder="Antwort"
                               value="@GetReplyText(note.Id)"
                               @oninput="e => SetReplyText(note.Id, e.Value?.ToString())" />
                        <button class="btn btn-outline-primary" @onclick="() => AddReplyAsync(note.Id)">Antworten</button>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private string _filter = "alle";
    private List<GlobalNotesEntry> _notes = new();
    private readonly Dictionary<string, string> _replyTexts = new();
    private readonly Dictionary<string, bool> _historyVisible = new();
    private readonly Dictionary<string, List<GlobalNotesHistory>> _historyCache = new();

    protected override async Task OnInitializedAsync()
    {
        EinsatzService.NoteAdded += OnNoteChanged;
        EinsatzService.EinsatzChanged += OnEinsatzChanged;
        await RefreshAsync();
    }

    public void Dispose()
    {
        EinsatzService.NoteAdded -= OnNoteChanged;
        EinsatzService.EinsatzChanged -= OnEinsatzChanged;
    }

    private void OnNoteChanged(GlobalNotesEntry note)
    {
        _ = InvokeAsync(RefreshAsync);
    }

    private void OnEinsatzChanged()
    {
        _ = InvokeAsync(RefreshAsync);
    }

    private async Task RefreshAsync()
    {
        var notes = await EinsatzService.GetFilteredNotesAsync();
        _notes = _filter switch
        {
            "funk" => notes.Where(n => n.SourceType == "Funk").ToList(),
            "notiz" => notes.Where(n => n.SourceType != "Funk").ToList(),
            _ => notes
        };
        StateHasChanged();
    }

    private async Task AddReplyAsync(string noteId)
    {
        _replyTexts.TryGetValue(noteId, out var text);
        if (string.IsNullOrWhiteSpace(text))
        {
            return;
        }

        await EinsatzService.AddReplyToNoteAsync(
            noteId,
            text.Trim(),
            "einsatzleitung",
            "Einsatzleitung",
            "Einsatzleitung");

        _replyTexts[noteId] = string.Empty;
        await RefreshAsync();
    }

    private async Task ToggleHistoryAsync(string noteId)
    {
        var show = !_historyVisible.TryGetValue(noteId, out var visible) || !visible;
        _historyVisible[noteId] = show;

        if (show)
        {
            _historyCache[noteId] = await EinsatzService.GetNoteHistoryAsync(noteId);
        }
    }

    private bool IsHistoryVisible(string noteId)
    {
        return _historyVisible.TryGetValue(noteId, out var value) && value;
    }

    private List<GlobalNotesHistory> GetHistoryEntries(string noteId)
    {
        return _historyCache.TryGetValue(noteId, out var entries) ? entries : new List<GlobalNotesHistory>();
    }

    private string GetReplyText(string noteId)
    {
        return _replyTexts.TryGetValue(noteId, out var text) ? text : string.Empty;
    }

    private void SetReplyText(string noteId, string? text)
    {
        _replyTexts[noteId] = text ?? string.Empty;
    }
}
