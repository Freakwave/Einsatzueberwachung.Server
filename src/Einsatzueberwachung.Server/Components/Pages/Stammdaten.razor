@page "/stammdaten"
@rendermode InteractiveServer

<PageTitle>Stammdaten</PageTitle>

<div class="container py-4">
    <h1 class="mb-1">Stammdaten-Verwaltung</h1>
    <p class="text-muted mb-4">Personal, Hunde und Drohnen verwalten</p>

    <div class="row g-3 mb-3">
        <div class="col-12 col-md-4">
            <div class="card"><div class="card-body"><strong>Personal:</strong> @_personalCount</div></div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card"><div class="card-body"><strong>Hunde:</strong> @_dogCount</div></div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card"><div class="card-body"><strong>Drohnen:</strong> @_droneCount</div></div>
        </div>
    </div>

    <div class="stammdaten-toolbar d-flex flex-wrap gap-2 mb-4 align-items-center">
        <a class="btn btn-outline-primary" href="@GetDownloadUrl("/downloads/stammdaten.xlsx")">
            <i class="bi bi-file-earmark-excel me-1"></i>Exportieren
        </a>
        <a class="btn btn-outline-secondary" href="@GetDownloadUrl("/downloads/stammdaten-template.xlsx")">
            <i class="bi bi-download me-1"></i>Vorlage
        </a>
        <div class="stammdaten-import-picker">
            <InputFile OnChange="HandleImportAsync" accept=".xlsx" disabled="@_isImporting" />
        </div>
        <button class="btn btn-outline-secondary" @onclick="RefreshAsync" disabled="@_isImporting">
            <i class="bi bi-arrow-clockwise me-1"></i>Neu laden
        </button>
    </div>

    <div class="stammdaten-tabs mb-3">
        <button class="btn @GetTabButtonClass("personal")" @onclick='() => SetActiveTab("personal")'>Personal</button>
        <button class="btn @GetTabButtonClass("dogs")" @onclick='() => SetActiveTab("dogs")'>Hunde</button>
        <button class="btn @GetTabButtonClass("drones")" @onclick='() => SetActiveTab("drones")'>Drohnen</button>
        <button class="btn @GetTabButtonClass("checklists")" @onclick='() => SetActiveTab("checklists")'>Checklisten</button>
    </div>

    <div class="row g-4">
        <div class="col-12 @GetTabPaneClass("personal")">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h4 mb-0">Personal</h2>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="OpenCreatePersonalModal">Neu</button>
                    </div>

                    <div class="row g-4">
                        <div class="col-12 col-xl-4">
                            <div class="mb-3">
                                <label class="form-label">Vorname</label>
                                <InputText class="form-control" @bind-Value="_personalDraft.Vorname" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Nachname</label>
                                <InputText class="form-control" @bind-Value="_personalDraft.Nachname" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Notizen</label>
                                <InputTextArea class="form-control" @bind-Value="_personalDraft.Notizen" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">
                                    Divera Benutzer-ID
                                    <span class="badge bg-info text-dark ms-1" style="font-size:0.7em;">optional</span>
                                </label>
                                <InputNumber class="form-control" @bind-Value="_personalDraft.DiveraUserId" placeholder="z.B. 681743" />
                                <div class="form-text">Die numerische Divera-ID (sichtbar in der App unter Profil oder in Alarm-R&#252;ckmeldungen als #ID).</div>
                            </div>

                            <div class="form-check form-switch mb-3">
                                <InputCheckbox class="form-check-input" id="personalActive" @bind-Value="_personalDraft.IsActive" />
                                <label class="form-check-label" for="personalActive">Aktiv</label>
                            </div>

                            <label class="form-label">Qualifikationen</label>
                            <div class="border rounded p-3 mb-3">
                                @foreach (var skill in _personalSkillOptions)
                                {
                                    var skillId = $"skill-{skill}";
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="@skillId" checked="@_personalDraft.Skills.HasFlag(skill)" @onchange="args => TogglePersonalSkill(skill, args.Value is true)" />
                                        <label class="form-check-label" for="@skillId">@skill.GetDisplayName()</label>
                                    </div>
                                }
                            </div>

                            <div class="d-flex gap-2">
                                <button class="btn btn-primary" @onclick="SavePersonalAsync">@(_editingPersonalId is null ? "Personal anlegen" : "Personal speichern")</button>
                                @if (_editingPersonalId is not null)
                                {
                                    <button class="btn btn-outline-secondary" @onclick="ResetPersonalForm">Abbrechen</button>
                                }
                            </div>
                        </div>

                        <div class="col-12 col-xl-8">
                            <div class="table-responsive">
                                <table class="table table-sm align-middle">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>Qualifikationen</th>
                                            <th>Status</th>
                                            <th class="text-end">Aktionen</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var person in _personal)
                                        {
                                            <tr id="entry-@person.Id" class="@(HighlightId == person.Id ? "mention-highlight-row" : "")">
                                                <td>
                                                    <strong>@person.FullName</strong>
                                                    @if (!string.IsNullOrWhiteSpace(person.Notizen))
                                                    {
                                                        <div class="small text-muted">@person.Notizen</div>
                                                    }
                                                </td>
                                                <td>@person.SkillsDisplay</td>
                                                <td>@(person.IsActive ? "Aktiv" : "Inaktiv")</td>
                                                <td class="text-end">
                                                    <div class="btn-group btn-group-sm">
                                                        <button class="btn btn-outline-primary" @onclick="() => EditPersonal(person.Id)">Bearbeiten</button>
                                                        <button class="btn btn-outline-danger" @onclick="() => DeletePersonalAsync(person.Id)">Loeschen</button>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 @GetTabPaneClass("dogs")">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h4 mb-0">Hunde</h2>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="OpenCreateDogModal">Neu</button>
                    </div>

                    <div class="row g-4">
                        <div class="col-12 col-xl-4">
                            <div class="mb-3">
                                <label class="form-label">Name</label>
                                <InputText class="form-control" @bind-Value="_dogDraft.Name" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Rasse</label>
                                <InputText class="form-control" @bind-Value="_dogDraft.Rasse" />
                            </div>

                            <div class="row g-3 mb-3">
                                <div class="col-12 col-md-6">
                                    <label class="form-label">Alter</label>
                                    <InputNumber class="form-control" @bind-Value="_dogDraft.Alter" />
                                </div>

                                <div class="col-12 col-md-6">
                                    <label class="form-label">Hundeführer</label>
                                    <div class="border rounded p-2" style="max-height:160px;overflow-y:auto">
                                        @if (!_personal.Any())
                                        {
                                            <span class="text-muted small">Kein Personal vorhanden</span>
                                        }
                                        @foreach (var person in _personal)
                                        {
                                            var hfId = $"hf-edit-{person.Id}";
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="@hfId"
                                                       checked="@_dogDraft.HundefuehrerIds.Contains(person.Id)"
                                                       @onchange="args => ToggleHundefuehrer(person.Id, args.Value is true)" />
                                                <label class="form-check-label" for="@hfId">@person.FullName</label>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Notizen</label>
                                <InputTextArea class="form-control" @bind-Value="_dogDraft.Notizen" />
                            </div>

                            <div class="form-check form-switch mb-3">
                                <InputCheckbox class="form-check-input" id="dogActive" @bind-Value="_dogDraft.IsActive" />
                                <label class="form-check-label" for="dogActive">Aktiv</label>
                            </div>

                            <label class="form-label">Spezialisierungen</label>
                            <div class="border rounded p-3 mb-3">
                                @foreach (var specialization in _dogSpecializationOptions)
                                {
                                    var specializationId = $"dog-spec-{specialization}";
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="@specializationId" checked="@_dogDraft.Specializations.HasFlag(specialization)" @onchange="args => ToggleDogSpecialization(specialization, args.Value is true)" />
                                        <label class="form-check-label" for="@specializationId">@specialization.GetDisplayName()</label>
                                    </div>
                                }
                            </div>

                            <div class="d-flex gap-2">
                                <button class="btn btn-primary" @onclick="SaveDogAsync">@(_editingDogId is null ? "Hund anlegen" : "Hund speichern")</button>
                                @if (_editingDogId is not null)
                                {
                                    <button class="btn btn-outline-secondary" @onclick="ResetDogForm">Abbrechen</button>
                                }
                            </div>
                        </div>

                        <div class="col-12 col-xl-8">
                            <div class="table-responsive">
                                <table class="table table-sm align-middle">
                                    <thead>
                                        <tr>
                                            <th>Hund</th>
                                            <th>Hundefuehrer</th>
                                            <th>Spezialisierung</th>
                                            <th>Status</th>
                                            <th class="text-end">Aktionen</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var dog in _dogs)
                                        {
                                            <tr id="entry-@dog.Id" class="@(HighlightId == dog.Id ? "mention-highlight-row" : "")">
                                                <td>
                                                    <strong>@dog.Name</strong>
                                                    <div class="small text-muted">@dog.Rasse, @dog.Alter Jahre</div>
                                                </td>
                                                <td>@GetHundefuehrerNames(dog.HundefuehrerIds)</td>
                                                <td>@dog.SpecializationsDisplay</td>
                                                <td>@(dog.IsActive ? "Aktiv" : "Inaktiv")</td>
                                                <td class="text-end">
                                                    <div class="btn-group btn-group-sm">
                                                        <button class="btn btn-outline-primary" @onclick="() => EditDog(dog.Id)">Bearbeiten</button>
                                                        <button class="btn btn-outline-danger" @onclick="() => DeleteDogAsync(dog.Id)">Loeschen</button>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 @GetTabPaneClass("drones")">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h4 mb-0">Drohnen</h2>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="OpenCreateDroneModal">Neu</button>
                    </div>

                    <div class="row g-4">
                        <div class="col-12 col-xl-4">
                            <div class="mb-3">
                                <label class="form-label">Name</label>
                                <InputText class="form-control" @bind-Value="_droneDraft.Name" />
                            </div>

                            <div class="row g-3 mb-3">
                                <div class="col-12 col-md-6">
                                    <label class="form-label">Hersteller</label>
                                    <InputText class="form-control" @bind-Value="_droneDraft.Hersteller" />
                                </div>

                                <div class="col-12 col-md-6">
                                    <label class="form-label">Modell</label>
                                    <InputText class="form-control" @bind-Value="_droneDraft.Modell" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Seriennummer</label>
                                <InputText class="form-control" @bind-Value="_droneDraft.Seriennummer" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Pilot</label>
                                <InputSelect class="form-select" @bind-Value="_droneDraft.DrohnenpilotId">
                                    <option value="">Nicht zugewiesen</option>
                                    @foreach (var person in _personal)
                                    {
                                        <option value="@person.Id">@person.FullName</option>
                                    }
                                </InputSelect>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Notizen</label>
                                <InputTextArea class="form-control" @bind-Value="_droneDraft.Notizen" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Drohne112 Livestream-URL</label>
                                <InputText class="form-control" @bind-Value="_droneDraft.LivestreamUrl" placeholder="https://..." />
                            </div>

                            <div class="form-check form-switch mb-3">
                                <InputCheckbox class="form-check-input" id="droneActive" @bind-Value="_droneDraft.IsActive" />
                                <label class="form-check-label" for="droneActive">Aktiv</label>
                            </div>

                            <div class="d-flex gap-2">
                                <button class="btn btn-primary" @onclick="SaveDroneAsync">@(_editingDroneId is null ? "Drohne anlegen" : "Drohne speichern")</button>
                                @if (_editingDroneId is not null)
                                {
                                    <button class="btn btn-outline-secondary" @onclick="ResetDroneForm">Abbrechen</button>
                                }
                            </div>
                        </div>

                        <div class="col-12 col-xl-8">
                            <div class="table-responsive">
                                <table class="table table-sm align-middle">
                                    <thead>
                                        <tr>
                                            <th>Drohne</th>
                                            <th>Pilot</th>
                                            <th>Seriennummer</th>
                                            <th>Status</th>
                                            <th class="text-end">Aktionen</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var drone in _drones)
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@drone.DisplayName</strong>
                                                    <div class="small text-muted">@drone.FullDescription</div>
                                                </td>
                                                <td>@GetPersonalName(drone.DrohnenpilotId)</td>
                                                <td>@drone.Seriennummer</td>
                                                <td>@(drone.IsActive ? "Aktiv" : "Inaktiv")</td>
                                                <td class="text-end">
                                                    <div class="btn-group btn-group-sm">
                                                        <button class="btn btn-outline-primary" @onclick="() => EditDrone(drone.Id)">Bearbeiten</button>
                                                        <button class="btn btn-outline-danger" @onclick="() => DeleteDroneAsync(drone.Id)">Loeschen</button>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 @GetTabPaneClass("checklists")">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h2 class="h4 mb-0">Checklisten</h2>
                            <p class="text-muted small mb-0">Szenarioabhängige Checklisten für vermisste Personen.</p>
                        </div>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="OpenCreateChecklistTemplateModal">
                            <i class="bi bi-plus-circle me-1"></i>Neu
                        </button>
                    </div>

                    @if (_checklistTemplates.Count == 0)
                    {
                        <div class="alert alert-secondary mb-0">Keine Checklisten-Templates vorhanden.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Szenario</th>
                                        <th>Items</th>
                                        <th></th>
                                        <th class="text-end"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var tmpl in _checklistTemplates.OrderBy(t => t.Szenario).ThenBy(t => t.Name))
                                    {
                                        <tr>
                                            <td><strong>@tmpl.Name</strong></td>
                                            <td>
                                                <span class="badge" style="background-color:@tmpl.Szenario.GetColorHex(); color:#fff;">
                                                    @tmpl.Szenario.GetDisplayName()
                                                </span>
                                            </td>
                                            <td>@tmpl.Items.Count</td>
                                            <td>
                                                @if (tmpl.IsDefault)
                                                {
                                                    <span class="badge bg-secondary">Default</span>
                                                }
                                            </td>
                                            <td class="text-end">
                                                <div class="btn-group btn-group-sm">
                                                    <button class="btn btn-outline-primary" @onclick="() => EditChecklistTemplate(tmpl.Id)">Bearbeiten</button>
                                                    <button class="btn btn-outline-danger" @onclick="() => DeleteChecklistTemplateAsync(tmpl.Id)">Löschen</button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (_showChecklistTemplateModal)
    {
        <div class="modal-overlay" @onclick="CloseChecklistTemplateModal">
            <div class="modal-modern" style="max-width:900px;" @onclick:stopPropagation="true">
                <div class="modal-modern-header">
                    <h3>@(_editingChecklistTemplateId is null ? "Checkliste anlegen" : "Checkliste bearbeiten")</h3>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CloseChecklistTemplateModal">Schließen</button>
                </div>
                <div class="modal-modern-body">
                    <div class="row g-3 mb-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label">Name</label>
                            <InputText class="form-control" @bind-Value="_checklistTemplateDraft.Name" placeholder="z.B. Trümmer-Standard" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Szenario</label>
                            <InputSelect class="form-select" @bind-Value="_checklistTemplateDraft.Szenario">
                                <option value="@EinsatzSzenarioType.Mantrailer">@EinsatzSzenarioType.Mantrailer.GetDisplayName()</option>
                                <option value="@EinsatzSzenarioType.Flaeche">@EinsatzSzenarioType.Flaeche.GetDisplayName()</option>
                                <option value="@EinsatzSzenarioType.Truemmer">@EinsatzSzenarioType.Truemmer.GetDisplayName()</option>
                                <option value="@EinsatzSzenarioType.Sonstige">@EinsatzSzenarioType.Sonstige.GetDisplayName()</option>
                            </InputSelect>
                        </div>
                    </div>

                    <h5 class="mt-4">Items</h5>
                    @if (_checklistTemplateDraft.Items.Count == 0)
                    {
                        <p class="text-muted small">Noch keine Items angelegt.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead>
                                    <tr>
                                        <th>Label</th>
                                        <th style="width:140px;">Typ</th>
                                        <th>Auswahl (kommasepariert)</th>
                                        <th style="width:90px;">Pflicht</th>
                                        <th style="width:120px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < _checklistTemplateDraft.Items.Count; i++)
                                    {
                                        var idx = i;
                                        var item = _checklistTemplateDraft.Items[idx];
                                        <tr>
                                            <td>
                                                <input class="form-control form-control-sm" @bind="item.Label" placeholder="z.B. Gebäudeteil" />
                                            </td>
                                            <td>
                                                <select class="form-select form-select-sm" @bind="item.Type">
                                                    <option value="@ChecklistItemType.Bool">Häkchen</option>
                                                    <option value="@ChecklistItemType.FreeText">Freitext</option>
                                                    <option value="@ChecklistItemType.Choice">Auswahl</option>
                                                </select>
                                            </td>
                                            <td>
                                                @if (item.Type == ChecklistItemType.Choice)
                                                {
                                                    <input class="form-control form-control-sm"
                                                           value="@string.Join(", ", item.Choices)"
                                                           @onchange="e => SetChoices(item, e.Value?.ToString())"
                                                           placeholder="z.B. Wohnhaus, Hochhaus" />
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">—</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <input type="checkbox" class="form-check-input" @bind="item.Required" />
                                            </td>
                                            <td class="text-end">
                                                <div class="btn-group btn-group-sm">
                                                    <button class="btn btn-outline-secondary" type="button" disabled="@(idx == 0)"
                                                            @onclick="() => MoveChecklistItem(idx, -1)" title="Hoch">
                                                        <i class="bi bi-arrow-up"></i>
                                                    </button>
                                                    <button class="btn btn-outline-secondary" type="button" disabled="@(idx == _checklistTemplateDraft.Items.Count - 1)"
                                                            @onclick="() => MoveChecklistItem(idx, 1)" title="Runter">
                                                        <i class="bi bi-arrow-down"></i>
                                                    </button>
                                                    <button class="btn btn-outline-danger" type="button" @onclick="() => RemoveChecklistItem(idx)" title="Entfernen">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="AddChecklistItem">
                        <i class="bi bi-plus-circle me-1"></i>Item hinzufügen
                    </button>
                </div>
                <div class="modal-modern-footer d-flex justify-content-end gap-2">
                    <button class="btn btn-outline-secondary" @onclick="CloseChecklistTemplateModal">Abbrechen</button>
                    <button class="btn btn-primary" @onclick="SaveChecklistTemplateAsync">
                        @(_editingChecklistTemplateId is null ? "Anlegen" : "Speichern")
                    </button>
                </div>
            </div>
        </div>
    }

    @if (_showCreatePersonalModal)
    {
        <div class="modal-overlay">
            <button type="button" class="modal-overlay-dismiss" @onclick="CloseCreatePersonalModal" aria-label="Dialog schließen"></button>
            <div class="modal-modern" @onclick:stopPropagation="true">
                <div class="modal-modern-header">
                    <h3>Personal anlegen</h3>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CloseCreatePersonalModal">Schliessen</button>
                </div>
                <div class="modal-modern-body">
                    <div class="mb-3">
                        <label class="form-label">Vorname</label>
                        <InputText class="form-control" @bind-Value="_personalDraft.Vorname" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nachname</label>
                        <InputText class="form-control" @bind-Value="_personalDraft.Nachname" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notizen</label>
                        <InputTextArea class="form-control" @bind-Value="_personalDraft.Notizen" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">
                            Divera Benutzer-ID
                            <span class="badge bg-info text-dark ms-1" style="font-size:0.7em;">optional</span>
                        </label>
                        <InputNumber class="form-control" @bind-Value="_personalDraft.DiveraUserId" placeholder="z.B. 681743" />
                        <div class="form-text">Die numerische Divera-ID (sichtbar in der App unter Profil oder in Alarm-R&#252;ckmeldungen als #ID).</div>
                    </div>
                    <div class="form-check form-switch mb-3">
                        <InputCheckbox class="form-check-input" id="personalActiveModal" @bind-Value="_personalDraft.IsActive" />
                        <label class="form-check-label" for="personalActiveModal">Aktiv</label>
                    </div>
                    <label class="form-label">Qualifikationen</label>
                    <div class="border rounded p-3">
                        @foreach (var skill in _personalSkillOptions)
                        {
                            var skillId = $"skill-modal-{skill}";
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="@skillId" checked="@_personalDraft.Skills.HasFlag(skill)" @onchange="args => TogglePersonalSkill(skill, args.Value is true)" />
                                <label class="form-check-label" for="@skillId">@skill.GetDisplayName()</label>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-modern-footer">
                    <button class="btn btn-primary" @onclick="SavePersonalAsync">Personal anlegen</button>
                    <button class="btn btn-outline-secondary" @onclick="CloseCreatePersonalModal">Abbrechen</button>
                </div>
            </div>
        </div>
    }

    @if (_showCreateDogModal)
    {
        <div class="modal-overlay">
            <button type="button" class="modal-overlay-dismiss" @onclick="CloseCreateDogModal" aria-label="Dialog schließen"></button>
            <div class="modal-modern" @onclick:stopPropagation="true">
                <div class="modal-modern-header">
                    <h3>Hund anlegen</h3>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CloseCreateDogModal">Schliessen</button>
                </div>
                <div class="modal-modern-body">
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="_dogDraft.Name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Rasse</label>
                        <InputText class="form-control" @bind-Value="_dogDraft.Rasse" />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label">Alter</label>
                            <InputNumber class="form-control" @bind-Value="_dogDraft.Alter" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Hundeführer</label>
                            <div class="border rounded p-2" style="max-height:160px;overflow-y:auto">
                                @if (!_personal.Any())
                                {
                                    <span class="text-muted small">Kein Personal vorhanden</span>
                                }
                                @foreach (var person in _personal)
                                {
                                    var hfId = $"hf-modal-{person.Id}";
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="@hfId"
                                               checked="@_dogDraft.HundefuehrerIds.Contains(person.Id)"
                                               @onchange="args => ToggleHundefuehrer(person.Id, args.Value is true)" />
                                        <label class="form-check-label" for="@hfId">@person.FullName</label>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    <label class="form-label">Spezialisierungen</label>
                    <div class="border rounded p-3 mb-3">
                        @foreach (var specialization in _dogSpecializationOptions)
                        {
                            var specializationId = $"dog-spec-modal-{specialization}";
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="@specializationId" checked="@_dogDraft.Specializations.HasFlag(specialization)" @onchange="args => ToggleDogSpecialization(specialization, args.Value is true)" />
                                <label class="form-check-label" for="@specializationId">@specialization.GetDisplayName()</label>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-modern-footer">
                    <button class="btn btn-primary" @onclick="SaveDogAsync">Hund anlegen</button>
                    <button class="btn btn-outline-secondary" @onclick="CloseCreateDogModal">Abbrechen</button>
                </div>
            </div>
        </div>
    }

    @if (_showCreateDroneModal)
    {
        <div class="modal-overlay">
            <button type="button" class="modal-overlay-dismiss" @onclick="CloseCreateDroneModal" aria-label="Dialog schließen"></button>
            <div class="modal-modern" @onclick:stopPropagation="true">
                <div class="modal-modern-header">
                    <h3>Drohne anlegen</h3>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CloseCreateDroneModal">Schliessen</button>
                </div>
                <div class="modal-modern-body">
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="_droneDraft.Name" />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label">Hersteller</label>
                            <InputText class="form-control" @bind-Value="_droneDraft.Hersteller" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Modell</label>
                            <InputText class="form-control" @bind-Value="_droneDraft.Modell" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Pilot</label>
                        <InputSelect class="form-select" @bind-Value="_droneDraft.DrohnenpilotId">
                            <option value="">Nicht zugewiesen</option>
                            @foreach (var person in _personal)
                            {
                                <option value="@person.Id">@person.FullName</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Drohne112 Livestream-URL</label>
                        <InputText class="form-control" @bind-Value="_droneDraft.LivestreamUrl" placeholder="https://..." />
                    </div>
                </div>
                <div class="modal-modern-footer">
                    <button class="btn btn-primary" @onclick="SaveDroneAsync">Drohne anlegen</button>
                    <button class="btn btn-outline-secondary" @onclick="CloseCreateDroneModal">Abbrechen</button>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_status))
    {
        <div class="alert alert-secondary mt-3">@_status</div>
    }
</div>

