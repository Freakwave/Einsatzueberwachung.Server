@page "/team"
@rendermode InteractiveServer
@layout Einsatzueberwachung.Server.Components.Layout.TeamMobileLayout
@using System.Net.Http.Json
@using Einsatzueberwachung.Domain.Interfaces
@using Einsatzueberwachung.Domain.Models
@using Einsatzueberwachung.Server.Security
@using Einsatzueberwachung.Server.Services
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Components.Web
@inject IHttpContextAccessor HttpContextAccessor
@inject IEinsatzService EinsatzService
@inject ICollarTrackingService CollarTrackingService
@inject ISettingsService SettingsService
@inject ITeamMobileTokenService TokenService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject PersistentComponentState ApplicationState
@implements IAsyncDisposable

<PageTitle>Team-Ansicht</PageTitle>

@if (!_authChecked)
{
    <div class="d-flex justify-content-center align-items-center" style="height:100vh;">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (_team == null)
{
    <div class="container py-5 text-center">
        <i class="bi bi-exclamation-triangle text-warning display-3"></i>
        <p class="mt-3">Dein Team ist nicht mehr im Einsatz.</p>
        <a href="/team/login" class="btn btn-primary mt-2">Zurueck zur Anmeldung</a>
    </div>
}
else
{
    <div style="display:flex;flex-direction:column;height:100vh;">
        <header style="background:#0d6efd;color:#fff;padding:10px 14px;display:flex;align-items:center;gap:10px;">
            <div style="flex:1;min-width:0;">
                <div style="font-weight:600;font-size:0.95rem;line-height:1.1;">@_team.TeamName</div>
                <div style="font-size:0.75rem;opacity:0.85;line-height:1.1;">
                    @(string.IsNullOrWhiteSpace(_team.DogName) ? "(ohne Hund)" : _team.DogName)
                    @if (_team.IsRunning) { <span class="badge bg-success ms-1">aktiv</span> }
                </div>
            </div>
            <button class="btn btn-sm btn-light" @onclick="ToggleInfoPanel" title="Team-Info">
                <i class="bi bi-info-circle"></i>
            </button>
            <button class="btn btn-sm btn-light" @onclick="CenterOnDogAsync" title="Auf Hund zentrieren">
                <i class="bi bi-geo-alt-fill"></i>
            </button>
            <form method="post" action="/api/team-mobile/logout" style="margin:0;">
                <button class="btn btn-sm btn-outline-light" type="submit" title="Abmelden">
                    <i class="bi bi-box-arrow-right"></i>
                </button>
            </form>
        </header>

        @if (_pushMessages.Count > 0)
        {
            <div style="background:#fff3cd;border-bottom:1px solid #ffe69c;padding:8px 12px;">
                @foreach (var m in _pushMessages.TakeLast(3))
                {
                    <div class="d-flex align-items-start gap-2" style="font-size:0.85rem;">
                        <i class="bi bi-megaphone-fill text-warning"></i>
                        <div class="flex-grow-1">
                            <div class="text-muted small" style="line-height:1;">EL @m.Time.ToString("HH:mm")</div>
                            <div>@m.Text</div>
                        </div>
                        <button class="btn-close btn-close-sm" @onclick="() => DismissMessage(m)" aria-label="OK"></button>
                    </div>
                }
            </div>
        }

        @if (_infoPanelOpen)
        {
            <div style="background:#f8f9fa;border-bottom:1px solid #dee2e6;padding:10px 14px;font-size:0.85rem;">
                <div class="row g-2">
                    <div class="col-12 col-sm-6"><strong>Hundefuehrer:</strong> @(string.IsNullOrWhiteSpace(_team.HundefuehrerName) ? "—" : _team.HundefuehrerName)</div>
                    <div class="col-12 col-sm-6"><strong>Helfer:</strong> @(string.IsNullOrWhiteSpace(_team.HelferNamesJoined) ? "—" : _team.HelferNamesJoined)</div>
                    <div class="col-12 col-sm-6"><strong>Hund:</strong> @(string.IsNullOrWhiteSpace(_team.DogName) ? "—" : _team.DogName)</div>
                    <div class="col-12 col-sm-6"><strong>Suchgebiet:</strong> @(string.IsNullOrWhiteSpace(_team.SearchAreaName) ? "—" : _team.SearchAreaName)</div>
                </div>
            </div>
        }

        @if (_mapInitDone && !_phoneGpsActive && !_einsatzEnded)
        {
            <div class="d-flex align-items-center gap-2 px-3 py-2 @GetGpsBannerCssClass()"
                 style="border-bottom:1px solid var(--bs-border-color);font-size:0.82rem;">
                @if (_requestingGps)
                {
                    <span class="spinner-border spinner-border-sm text-secondary" aria-hidden="true"></span>
                    <span class="flex-grow-1">GPS wird angefragt…</span>
                }
                else if (_phoneGpsErrorCode == 4)
                {
                    <i class="bi bi-lock-fill text-warning flex-shrink-0"></i>
                    <span class="flex-grow-1">Handy-GPS funktioniert nur mit HTTPS oder auf localhost. Bitte öffnen Sie die Seite über HTTPS und versuchen Sie es erneut.</span>
                    <button class="btn btn-sm btn-outline-secondary py-0 px-2" @onclick="RequestGpsPermissionAsync">
                        <i class="bi bi-arrow-clockwise me-1"></i>Erneut
                    </button>
                }
                else if (_phoneGpsErrorCode == 1)
                {
                    <i class="bi bi-shield-exclamation text-warning flex-shrink-0"></i>
                    <span class="flex-grow-1">GPS-Berechtigung fehlt. Bitte erlauben Sie den GPS-Zugriff in den Browser-Einstellungen und versuchen Sie es erneut.</span>
                    <button class="btn btn-sm btn-outline-secondary py-0 px-2" @onclick="RequestGpsPermissionAsync">
                        <i class="bi bi-arrow-clockwise me-1"></i>Erneut
                    </button>
                }
                else if (_phoneGpsErrorCode.HasValue)
                {
                    <i class="bi bi-geo-alt-slash text-danger flex-shrink-0"></i>
                    <span class="flex-grow-1">Handy-GPS: @GetGpsErrorText(_phoneGpsErrorCode.Value)</span>
                    <button class="btn btn-sm btn-outline-secondary py-0 px-2" @onclick="RequestGpsPermissionAsync">
                        <i class="bi bi-arrow-clockwise me-1"></i>Erneut
                    </button>
                }
                else
                {
                    <i class="bi bi-phone text-muted flex-shrink-0"></i>
                    <span class="flex-grow-1">Warte auf Handy-GPS…</span>
                    <button class="btn btn-sm btn-outline-secondary py-0 px-2" @onclick="RequestGpsPermissionAsync">
                        <i class="bi bi-geo-alt me-1"></i>GPS anfordern
                    </button>
                }
            </div>
        }

        <div id="team-mobile-map" style="flex:1;width:100%;min-height:300px;background:#e9ecef;"></div>

        @if (!_einsatzEnded)
        {
            <div style="background:#fff;border-top:1px solid #dee2e6;padding:6px 8px;display:flex;gap:6px;flex-wrap:wrap;">
                <button class="btn btn-sm btn-outline-primary flex-grow-1" disabled="@_statusSending" @onclick='() => SendStatusAsync("im Suchgebiet eingetroffen")'>
                    <i class="bi bi-bounding-box me-1"></i>Im Gebiet
                </button>
                <button class="btn btn-sm btn-outline-warning flex-grow-1" disabled="@_statusSending" @onclick='() => SendStatusAsync("Pause")'>
                    <i class="bi bi-pause-circle me-1"></i>Pause
                </button>
                <button class="btn btn-sm btn-outline-info flex-grow-1" disabled="@_statusSending" @onclick='() => SendStatusAsync("Funkkontakt benoetigt")'>
                    <i class="bi bi-broadcast-pin me-1"></i>Funk
                </button>
                <button class="btn btn-sm btn-outline-success flex-grow-1" disabled="@_statusSending" @onclick='() => SendStatusAsync("Auftrag beendet")'>
                    <i class="bi bi-check-circle me-1"></i>Beendet
                </button>
            </div>
        }

        <footer style="background:#fff;border-top:1px solid #dee2e6;padding:6px 12px;font-size:0.75rem;display:flex;gap:12px;flex-wrap:wrap;">
            <div>
                <i class="bi bi-broadcast @(string.IsNullOrWhiteSpace(_team.CollarId) ? "text-muted" : "text-success")"></i>
                @(string.IsNullOrWhiteSpace(_team.CollarId) ? "kein GPS" : (_lastUpdate.HasValue ? $"GPS: {(_now - _lastUpdate.Value).TotalSeconds:0}s" : "warte auf GPS"))
            </div>
            <div>
                @if (_requestingGps)
                {
                    <span class="spinner-border spinner-border-sm text-secondary" style="width:0.8rem;height:0.8rem;" aria-hidden="true"></span>
                    <span>GPS wird angefragt…</span>
                }
                else if (_phoneGpsActive)
                {
                    <i class="bi bi-phone-fill text-primary"></i>
                    <span>Handy-GPS aktiv</span>
                }
                else if (_phoneGpsErrorCode.HasValue)
                {
                    <i class="bi bi-phone text-danger"></i>
                    <span>GPS @GetGpsErrorText(_phoneGpsErrorCode.Value)</span>
                }
                else
                {
                    <i class="bi bi-phone text-muted"></i>
                    <span>GPS-Verbindung…</span>
                }
            </div>
            <div>
                <i class="bi bi-bounding-box @(_hasArea ? "text-primary" : "text-muted")"></i>
                @(_hasArea ? "Suchgebiet" : "kein Suchgebiet")
            </div>
            @if (_distanceToAreaKm.HasValue)
            {
                <div>
                    <i class="bi bi-arrows-move text-secondary"></i>
                    @($"{_distanceToAreaKm.Value:0.00} km zum Gebiet")
                </div>
            }
            @if (!string.IsNullOrEmpty(_statusFeedback))
            {
                <div class="ms-auto text-success">@_statusFeedback</div>
            }
            @if (_einsatzEnded)
            {
                <div class="ms-auto text-danger fw-bold">Einsatz beendet</div>
            }
        </footer>
    </div>
}

@code {
    public sealed class PushMessageEntry
    {
        public string Text { get; set; } = string.Empty;
        public DateTime Time { get; set; }
    }

    private bool _authChecked;
    private Team? _team;
    private bool _hasArea;
    private double? _areaCentroidLat;
    private double? _areaCentroidLng;
    private double? _distanceToAreaKm;
    private DateTime? _lastUpdate;
    private DateTime _now = DateTime.Now;
    private bool _einsatzEnded;
    private string? _teamId;
    private bool _infoPanelOpen;
    private bool _statusSending;
    private string _statusFeedback = string.Empty;
    private readonly List<PushMessageEntry> _pushMessages = new();

    private System.Timers.Timer? _uiTimer;
    private Action<string, CollarLocation>? _collarHandler;
    private Action? _generationHandler;
    private Action<string, string, DateTime>? _messageHandler;
    private PersistingComponentStateSubscription _persistSubscription;
    private bool _mapInitDone;
    private DotNetObjectReference<TeamMobile>? _selfRef;
    private bool _phoneGpsActive;
    private int? _phoneGpsErrorCode;
    private bool _requestingGps;

    protected override async Task OnInitializedAsync()
    {
        if (ApplicationState.TryTakeFromJson<string>("team-mobile-id", out var persistedId)
            && !string.IsNullOrWhiteSpace(persistedId))
        {
            _teamId = persistedId;
        }
        else
        {
            var ctx = HttpContextAccessor.HttpContext;
            if (ctx != null)
            {
                var auth = await ctx.AuthenticateAsync(TeamMobileAuth.AuthenticationScheme);
                if (auth.Succeeded && auth.Principal != null)
                    _teamId = auth.Principal.FindFirst(TeamMobileAuth.TeamIdClaim)?.Value;
            }
        }

        _persistSubscription = ApplicationState.RegisterOnPersisting(() =>
        {
            if (!string.IsNullOrWhiteSpace(_teamId))
                ApplicationState.PersistAsJson("team-mobile-id", _teamId);
            return Task.CompletedTask;
        });

        if (string.IsNullOrWhiteSpace(_teamId))
        {
            Navigation.NavigateTo("/team/login", false);
            return;
        }

        _team = EinsatzService.Teams.FirstOrDefault(t => t.TeamId == _teamId);
        var einsatz = EinsatzService.CurrentEinsatz;
        _einsatzEnded = einsatz?.EinsatzEnde != null;

        _authChecked = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_mapInitDone || _team == null) return;
        _mapInitDone = true;

        try
        {
            await JS.InvokeVoidAsync("teamMobileMap.init", "team-mobile-map", 51.1657, 10.4515);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"team-mobile map init failed: {ex.Message}");
            return;
        }

        // Karten-Marker Symbole aus Einstellungen laden und anwenden
        // SettingsService ist ein Singleton mit In-Memory-Cache, daher kein try-catch nötig
        var mapSettings = await SettingsService.GetAppSettingsAsync();
        try
        {
            await JS.InvokeVoidAsync("teamMobileMap.setOptions", new
            {
                collarIcon = mapSettings.CollarMarkerIconOrDefault,
                humanIcon  = mapSettings.HumanMarkerIconOrDefault
            });
        }
        catch { /* tolerant — Icons bleiben auf Standard-Wert */ }

        var einsatz = EinsatzService.CurrentEinsatz;
        var area = TeamMobileLookup.FindSearchAreaForTeam(einsatz, _team);
        if (area?.Coordinates is { Count: > 2 })
        {
            _hasArea = true;
            var coords = area.Coordinates.Select(c => new { lat = c.Latitude, lng = c.Longitude }).ToArray();
            try { await JS.InvokeVoidAsync("teamMobileMap.renderSearchArea", coords, area.Color ?? "#3388ff"); }
            catch { /* tolerant */ }

            var lat = area.Coordinates.Average(c => c.Latitude);
            var lng = area.Coordinates.Average(c => c.Longitude);
            _areaCentroidLat = lat;
            _areaCentroidLng = lng;
        }

        // Abgeschlossene Track-Episoden früherer Suchläufe laden (überlebt Server-Neustart via SQLite)
        // Halsband-Track (Hund) und Mensch-Laufweg (Telefon-GPS) der vergangenen Sessions
        var completedSearches = EinsatzService.CurrentEinsatz.CompletedSearches?
            .Where(cs => cs.TeamId == _team.TeamId)
            .ToList() ?? new();
        foreach (var cs in completedSearches)
        {
            foreach (var track in cs.Tracks)
            {
                if (track.Points.Count < 2) continue;
                var pts = track.Points.Select(p => new { lat = p.Latitude, lng = p.Longitude }).ToArray();
                var isHuman = track.TrackType == Einsatzueberwachung.Domain.Models.Enums.TrackType.HumanTrack;
                try { await JS.InvokeVoidAsync("teamMobileMap.addCompletedTrack", pts, track.Color, isHuman); } catch { /* tolerant */ }
            }
        }

        // _lastUpdate für Footer-Anzeige ("GPS: Xs") aus der letzten bekannten Halsband-Position initialisieren.
        // Die eigentliche Track-Darstellung übernimmt reloadCurrentTracks() per HTTP-Fetch, damit auch
        // große Track-Verläufe zuverlässig geladen werden (kein Blazor-Interop-Größenlimit).
        if (!string.IsNullOrWhiteSpace(_team.CollarId))
        {
            var latestLocation = CollarTrackingService.GetLatestLocation(_team.CollarId);
            if (latestLocation != null)
                _lastUpdate = latestLocation.Timestamp;
        }

        // Track-Verlauf per direktem HTTP-Fetch des JS laden (robuster als Blazor-Interop bei großen Daten).
        // Lädt Halsband-Track, Hund-Marker und Telefon-GPS-Track aus /api/team-mobile/state.
        try { await JS.InvokeVoidAsync("teamMobileMap.reloadCurrentTracks"); } catch { /* tolerant */ }

        _selfRef = DotNetObjectReference.Create(this);
        try { await JS.InvokeVoidAsync("teamMobileMap.startWatchingUser", _selfRef); } catch { /* ignore */ }

        // Direkt an Domain-Events andocken
        _collarHandler = OnCollarLocation;
        _generationHandler = OnGenerationChanged;
        _messageHandler = OnTeamMessage;
        CollarTrackingService.CollarLocationReceived += _collarHandler;
        TokenService.GenerationChanged += _generationHandler;
        TokenService.TeamMessageBroadcasted += _messageHandler;

        _uiTimer = new System.Timers.Timer(1000) { AutoReset = true };
        _uiTimer.Elapsed += async (_, _) =>
        {
            try { _now = DateTime.Now; await InvokeAsync(StateHasChanged); }
            catch { /* circuit kann zwischenzeitlich weg sein */ }
        };
        _uiTimer.Start();

        StateHasChanged();
    }

    [JSInvokable]
    public Task OnUserLocation(double lat, double lng)
    {
        _phoneGpsActive = true;
        _phoneGpsErrorCode = null;
        _requestingGps = false;
        if (_areaCentroidLat.HasValue && _areaCentroidLng.HasValue)
        {
            _distanceToAreaKm = HaversineKm(lat, lng, _areaCentroidLat.Value, _areaCentroidLng.Value);
        }
        _ = InvokeAsync(StateHasChanged);
        _ = JS.InvokeVoidAsync("teamMobileMap.postLocation", lat, lng).AsTask();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnUserLocationError(int code)
    {
        _phoneGpsActive = false;
        _phoneGpsErrorCode = code;
        _requestingGps = false;
        _ = InvokeAsync(StateHasChanged);
        return Task.CompletedTask;
    }

    private string GetGpsBannerCssClass()
    {
        if (_phoneGpsErrorCode == 4) return "bg-warning-subtle";
        if (_phoneGpsErrorCode == 1) return "bg-warning-subtle";
        if (_phoneGpsErrorCode.HasValue) return "bg-danger-subtle";
        return "bg-light";
    }

    private static string GetGpsErrorText(int code) => code switch
    {
        4 => "nur mit HTTPS/localhost möglich",
        1 => "verweigert",
        2 => "nicht verfügbar",
        3 => "Zeitüberschreitung",
        _ => $"Fehler ({code})"
    };

    private async Task RequestGpsPermissionAsync()
    {
        if (_requestingGps) return;
        _requestingGps = true;
        _phoneGpsActive = false;
        _phoneGpsErrorCode = null;
        StateHasChanged();
        try
        {
            _selfRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("teamMobileMap.requestGeolocationPermission", _selfRef);
        }
        catch
        {
            // JS-Aufruf fehlgeschlagen — Zustand zurücksetzen damit die UI nicht eingefroren bleibt
            _requestingGps = false;
            StateHasChanged();
        }
    }

    private static double HaversineKm(double lat1, double lng1, double lat2, double lng2)
    {
        const double R = 6371.0;
        double dLat = (lat2 - lat1) * Math.PI / 180.0;
        double dLng = (lng2 - lng1) * Math.PI / 180.0;
        double a = Math.Sin(dLat / 2) * Math.Sin(dLat / 2) +
                   Math.Cos(lat1 * Math.PI / 180.0) * Math.Cos(lat2 * Math.PI / 180.0) *
                   Math.Sin(dLng / 2) * Math.Sin(dLng / 2);
        return R * 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a));
    }

    private void OnCollarLocation(string collarId, CollarLocation location)
    {
        if (_team == null || _team.CollarId != collarId) return;
        _ = InvokeAsync(async () =>
        {
            try
            {
                _lastUpdate = location.Timestamp;
                await JS.InvokeVoidAsync("teamMobileMap.setDogPosition", location.Latitude, location.Longitude, _team.DogName);
                await JS.InvokeVoidAsync("teamMobileMap.appendTrackPoint", location.Latitude, location.Longitude);
                StateHasChanged();
            }
            catch { /* tolerant */ }
        });
    }

    private void OnGenerationChanged()
    {
        _ = InvokeAsync(() =>
        {
            _einsatzEnded = true;
            StateHasChanged();
        });
    }

    private void OnTeamMessage(string targetTeamId, string text, DateTime time)
    {
        if (_teamId != targetTeamId) return;
        _ = InvokeAsync(() =>
        {
            _pushMessages.Add(new PushMessageEntry { Text = text, Time = time });
            // max. 5 behalten
            while (_pushMessages.Count > 5) _pushMessages.RemoveAt(0);
            StateHasChanged();
        });
    }

    private void DismissMessage(PushMessageEntry m)
    {
        _pushMessages.Remove(m);
    }

    private void ToggleInfoPanel() => _infoPanelOpen = !_infoPanelOpen;

    private async Task SendStatusAsync(string status)
    {
        if (_statusSending || _team == null) return;
        _statusSending = true;
        _statusFeedback = string.Empty;
        StateHasChanged();
        try
        {
            using var http = new HttpClient { BaseAddress = new Uri(Navigation.BaseUri) };
            // Cookie wird vom Browser nicht automatisch mitgesendet — wir nutzen JS fetch
            await JS.InvokeVoidAsync("eval",
                $"fetch('/api/team-mobile/status', {{method:'POST',credentials:'same-origin',headers:{{'Content-Type':'application/json'}},body:JSON.stringify({{status:{System.Text.Json.JsonSerializer.Serialize(status)}}})}})");
            _statusFeedback = "gesendet";
        }
        catch
        {
            _statusFeedback = "Fehler";
        }
        finally
        {
            _statusSending = false;
            StateHasChanged();
            // Feedback nach 3s ausblenden
            _ = Task.Delay(3000).ContinueWith(_ =>
            {
                _statusFeedback = string.Empty;
                _ = InvokeAsync(StateHasChanged);
            });
        }
    }

    private async Task CenterOnDogAsync()
    {
        try { await JS.InvokeVoidAsync("teamMobileMap.centerOnDog"); } catch { /* tolerant */ }
    }

    public async ValueTask DisposeAsync()
    {
        _uiTimer?.Stop();
        _uiTimer?.Dispose();
        if (_collarHandler != null) CollarTrackingService.CollarLocationReceived -= _collarHandler;
        if (_generationHandler != null) TokenService.GenerationChanged -= _generationHandler;
        if (_messageHandler != null) TokenService.TeamMessageBroadcasted -= _messageHandler;
        _persistSubscription.Dispose();
        try { await JS.InvokeVoidAsync("teamMobileMap.stopWatchingUser"); } catch { /* ignore */ }
        try { await JS.InvokeVoidAsync("teamMobileMap.destroy"); } catch { /* ignore */ }
        _selfRef?.Dispose();
    }
}
