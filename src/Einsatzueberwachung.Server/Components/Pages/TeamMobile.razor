@page "/team"
@rendermode InteractiveServer
@layout Einsatzueberwachung.Server.Components.Layout.TeamMobileLayout
@using Einsatzueberwachung.Domain.Interfaces
@using Einsatzueberwachung.Domain.Models
@using Einsatzueberwachung.Server.Security
@using Einsatzueberwachung.Server.Services
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Components.Web
@inject IHttpContextAccessor HttpContextAccessor
@inject IEinsatzService EinsatzService
@inject ICollarTrackingService CollarTrackingService
@inject ITeamMobileTokenService TokenService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject PersistentComponentState ApplicationState
@implements IAsyncDisposable

<PageTitle>Team-Ansicht</PageTitle>

@if (!_authChecked)
{
    <div class="d-flex justify-content-center align-items-center" style="height:100vh;">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (_team == null)
{
    <div class="container py-5 text-center">
        <i class="bi bi-exclamation-triangle text-warning display-3"></i>
        <p class="mt-3">Dein Team ist nicht mehr im Einsatz.</p>
        <a href="/team/login" class="btn btn-primary mt-2">Zurueck zur Anmeldung</a>
    </div>
}
else
{
    <div style="display:flex;flex-direction:column;height:100vh;">
        <header style="background:#0d6efd;color:#fff;padding:10px 14px;display:flex;align-items:center;gap:10px;">
            <div style="flex:1;min-width:0;">
                <div style="font-weight:600;font-size:0.95rem;line-height:1.1;">@_team.TeamName</div>
                <div style="font-size:0.75rem;opacity:0.85;line-height:1.1;">
                    @(string.IsNullOrWhiteSpace(_team.DogName) ? "(ohne Hund)" : _team.DogName)
                    @if (_team.IsRunning) { <span class="badge bg-success ms-1">aktiv</span> }
                </div>
            </div>
            <button class="btn btn-sm btn-light" @onclick="CenterOnDogAsync" title="Auf Hund zentrieren">
                <i class="bi bi-geo-alt-fill"></i>
            </button>
            <form method="post" action="/api/team-mobile/logout" style="margin:0;">
                <button class="btn btn-sm btn-outline-light" type="submit" title="Abmelden">
                    <i class="bi bi-box-arrow-right"></i>
                </button>
            </form>
        </header>

        <div id="team-mobile-map" style="flex:1;width:100%;min-height:300px;background:#e9ecef;"></div>

        <footer style="background:#fff;padding:8px 12px;border-top:1px solid #dee2e6;font-size:0.8rem;display:flex;gap:12px;">
            <div>
                <i class="bi bi-broadcast @(string.IsNullOrWhiteSpace(_team.CollarId) ? "text-muted" : "text-success")"></i>
                @(string.IsNullOrWhiteSpace(_team.CollarId) ? "kein GPS" : (_lastUpdate.HasValue ? $"GPS: {(_now - _lastUpdate.Value).TotalSeconds:0}s" : "warte auf GPS"))
            </div>
            <div>
                <i class="bi bi-bounding-box @(_hasArea ? "text-primary" : "text-muted")"></i>
                @(_hasArea ? "Suchgebiet" : "kein Suchgebiet")
            </div>
            @if (_einsatzEnded)
            {
                <div class="ms-auto text-danger fw-bold">Einsatz beendet</div>
            }
        </footer>
    </div>
}

@code {
    private bool _authChecked;
    private Team? _team;
    private bool _hasArea;
    private DateTime? _lastUpdate;
    private DateTime _now = DateTime.Now;
    private bool _einsatzEnded;
    private string? _teamId;

    private System.Timers.Timer? _uiTimer;
    private Action<string, CollarLocation>? _collarHandler;
    private Action? _generationHandler;
    private PersistingComponentStateSubscription _persistSubscription;
    private bool _mapInitDone;

    protected override async Task OnInitializedAsync()
    {
        // 1) Re-use teamId vom Prerender (interaktiver Boot hat keinen HttpContext mehr)
        if (ApplicationState.TryTakeFromJson<string>("team-mobile-id", out var persistedId)
            && !string.IsNullOrWhiteSpace(persistedId))
        {
            _teamId = persistedId;
        }
        else
        {
            // 2) Erste Phase (Prerender): HttpContext-basierte Auth ueber TeamMobile-Cookie-Schema
            var ctx = HttpContextAccessor.HttpContext;
            if (ctx != null)
            {
                var auth = await ctx.AuthenticateAsync(TeamMobileAuth.AuthenticationScheme);
                if (auth.Succeeded && auth.Principal != null)
                    _teamId = auth.Principal.FindFirst(TeamMobileAuth.TeamIdClaim)?.Value;
            }
        }

        // teamId ueber Prerender->Interactive Boundary persistieren
        _persistSubscription = ApplicationState.RegisterOnPersisting(() =>
        {
            if (!string.IsNullOrWhiteSpace(_teamId))
                ApplicationState.PersistAsJson("team-mobile-id", _teamId);
            return Task.CompletedTask;
        });

        if (string.IsNullOrWhiteSpace(_teamId))
        {
            Navigation.NavigateTo("/team/login", false);
            return;
        }

        _team = EinsatzService.Teams.FirstOrDefault(t => t.TeamId == _teamId);
        var einsatz = EinsatzService.CurrentEinsatz;
        _einsatzEnded = einsatz?.EinsatzEnde != null;

        _authChecked = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Wichtig: nicht nur firstRender abfragen — _team kann erst beim 2. Render gesetzt sein
        // (z.B. wenn OnInitializedAsync nach Prerender im interaktiven Boot lief).
        if (_mapInitDone || _team == null) return;
        _mapInitDone = true;

        try
        {
            await JS.InvokeVoidAsync("teamMobileMap.init", "team-mobile-map", 51.1657, 10.4515);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"team-mobile map init failed: {ex.Message}");
            return;
        }

        var einsatz = EinsatzService.CurrentEinsatz;
        var area = TeamMobileLookup.FindSearchAreaForTeam(einsatz, _team);
        if (area?.Coordinates is { Count: > 2 })
        {
            _hasArea = true;
            var coords = area.Coordinates.Select(c => new { lat = c.Latitude, lng = c.Longitude }).ToArray();
            try { await JS.InvokeVoidAsync("teamMobileMap.renderSearchArea", coords, area.Color ?? "#3388ff"); }
            catch { /* tolerant */ }
        }

        if (!string.IsNullOrWhiteSpace(_team.CollarId))
        {
            var history = CollarTrackingService.GetLocationHistory(_team.CollarId);
            if (history.Count > 0)
            {
                var pts = history.Select(p => new { lat = p.Latitude, lng = p.Longitude }).ToArray();
                try
                {
                    await JS.InvokeVoidAsync("teamMobileMap.setTrack", pts);
                    var last = history[^1];
                    await JS.InvokeVoidAsync("teamMobileMap.setDogPosition", last.Latitude, last.Longitude, _team.DogName);
                    _lastUpdate = last.Timestamp;
                }
                catch { /* tolerant */ }
            }
        }

        // Footer-Status (Suchgebiet / GPS) nach OnAfterRender aktualisieren.
        StateHasChanged();

        // Direkt an Domain-Service andocken — kein zusaetzlicher SignalR-Roundtrip noetig.
        _collarHandler = OnCollarLocation;
        _generationHandler = OnGenerationChanged;
        CollarTrackingService.CollarLocationReceived += _collarHandler;
        TokenService.GenerationChanged += _generationHandler;

        _uiTimer = new System.Timers.Timer(1000) { AutoReset = true };
        _uiTimer.Elapsed += async (_, _) =>
        {
            try
            {
                _now = DateTime.Now;
                await InvokeAsync(StateHasChanged);
            }
            catch { /* circuit kann zwischenzeitlich weg sein */ }
        };
        _uiTimer.Start();
    }

    private void OnCollarLocation(string collarId, CollarLocation location)
    {
        if (_team == null || _team.CollarId != collarId) return;
        _ = InvokeAsync(async () =>
        {
            try
            {
                _lastUpdate = location.Timestamp;
                await JS.InvokeVoidAsync("teamMobileMap.setDogPosition", location.Latitude, location.Longitude, _team.DogName);
                await JS.InvokeVoidAsync("teamMobileMap.appendTrackPoint", location.Latitude, location.Longitude);
                StateHasChanged();
            }
            catch { /* tolerant */ }
        });
    }

    private void OnGenerationChanged()
    {
        _ = InvokeAsync(() =>
        {
            _einsatzEnded = true;
            StateHasChanged();
        });
    }

    private async Task CenterOnDogAsync()
    {
        try { await JS.InvokeVoidAsync("teamMobileMap.centerOnDog"); } catch { /* tolerant */ }
    }

    public async ValueTask DisposeAsync()
    {
        _uiTimer?.Stop();
        _uiTimer?.Dispose();
        if (_collarHandler != null) CollarTrackingService.CollarLocationReceived -= _collarHandler;
        if (_generationHandler != null) TokenService.GenerationChanged -= _generationHandler;
        _persistSubscription.Dispose();
        try { await JS.InvokeVoidAsync("teamMobileMap.destroy"); } catch { /* ignore */ }
    }
}
