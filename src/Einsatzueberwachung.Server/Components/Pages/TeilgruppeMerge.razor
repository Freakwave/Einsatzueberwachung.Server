@page "/teilgruppe-zusammenfuehren"
@page "/teilgruppe-zusammenfuehren/{ArchivedEinsatzId}"
@rendermode InteractiveServer

@using Einsatzueberwachung.Domain.Models
@using Einsatzueberwachung.Domain.Models.Merge
@using Einsatzueberwachung.Domain.Interfaces
@using Microsoft.AspNetCore.Components.Forms

@inject ISubgroupMergeService MergeService
@inject IEinsatzService EinsatzService
@inject IArchivService ArchivService
@inject NavigationManager Navigation

<PageTitle>Teilgruppe zusammenführen</PageTitle>

<div class="container py-4">

    <div class="d-flex align-items-center gap-3 mb-4">
        <button class="btn btn-outline-secondary btn-sm" @onclick="NavigateBack">
            <i class="bi bi-arrow-left me-1"></i>Zurück
        </button>
        <div>
            <h1 class="mb-0 h3">
                <i class="bi bi-diagram-2 me-2"></i>Teilgruppe zusammenführen
            </h1>
            @if (!string.IsNullOrEmpty(ArchivedEinsatzId))
            {
                <small class="text-muted">Ziel: Archivierter Einsatz</small>
            }
            else
            {
                <small class="text-muted">Ziel: Laufender Einsatz</small>
            }
        </div>
    </div>

    @* Fortschritts-Stepper *@
    <div class="merge-stepper d-flex gap-0 mb-4 align-items-center">
        @foreach (var step in _steps)
        {
            <div class="merge-step @GetStepClass(step.Number)">
                <div class="merge-step-circle">@step.Number</div>
                <div class="merge-step-label d-none d-md-block">@step.Label</div>
            </div>
            @if (step.Number < _steps.Count)
            {
                <div class="merge-step-connector @GetConnectorClass(step.Number)"></div>
            }
        }
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle me-2"></i>@_errorMessage
        </div>
    }

    @* ═══════════════════════════════════════════════════════════════════════
       SCHRITT 1: Upload
       ═══════════════════════════════════════════════════════════════════════ *@
    @if (_currentStep == MergeWizardStep.Upload)
    {
        <div class="card">
            <div class="card-header fw-semibold">
                <i class="bi bi-upload me-2"></i>Schritt 1 — Export-Datei hochladen
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">
                    Wählen Sie die <code>.einsatz-export.json</code> Datei der Teilgruppe aus.
                </p>

                <div class="mb-3">
                    <InputFile OnChange="HandleFileUploadAsync"
                               accept=".json"
                               class="form-control"
                               disabled="@_isLoading" />
                </div>

                @if (_isLoading)
                {
                    <div class="text-muted"><i class="bi bi-hourglass-split me-1"></i>Wird verarbeitet…</div>
                }

                @if (_session?.Packet != null && _currentStep == MergeWizardStep.Upload)
                {
                    <div class="card bg-body-secondary mt-3">
                        <div class="card-body">
                            <h6 class="card-title mb-2">
                                <i class="bi bi-info-circle me-1"></i>Export-Zusammenfassung
                            </h6>
                            <dl class="row mb-0 small">
                                <dt class="col-sm-4">Teilgruppe</dt>
                                <dd class="col-sm-8">@_session.Packet.SubgroupName</dd>
                                <dt class="col-sm-4">EinsatzNummer</dt>
                                <dd class="col-sm-8">@_session.Packet.EinsatzNummer</dd>
                                <dt class="col-sm-4">Exportiert am</dt>
                                <dd class="col-sm-8">@_session.Packet.ExportedAt.ToString("dd.MM.yyyy HH:mm")</dd>
                                <dt class="col-sm-4">Stammdaten</dt>
                                <dd class="col-sm-8">
                                    @_session.Packet.Personal.Count Personal,
                                    @_session.Packet.Dogs.Count Hunde,
                                    @_session.Packet.Drones.Count Drohnen
                                </dd>
                                <dt class="col-sm-4">Operative Daten</dt>
                                <dd class="col-sm-8">
                                    @_session.Packet.Teams.Count Teams,
                                    @_session.Packet.Notes.Count Notizen,
                                    @_session.Packet.SearchAreas.Count Gebiete
                                </dd>
                            </dl>
                        </div>
                    </div>

                    @if (_einsatzNrMismatch && !_session.EinsatzNrMismatchAcknowledged)
                    {
                        <div class="alert alert-warning mt-3">
                            <strong><i class="bi bi-exclamation-triangle-fill me-1"></i>Abweichende EinsatzNummer!</strong>
                            <p class="mb-2 mt-1">
                                Die importierte EinsatzNummer <strong>„@_session.Packet.EinsatzNummer"</strong>
                                stimmt nicht mit dem aktuellen Einsatz überein.
                                Bitte bestätigen Sie, dass Sie trotzdem fortfahren möchten.
                            </p>
                            <button class="btn btn-warning btn-sm" @onclick="AcknowledgeMismatch">
                                Ich verstehe das Risiko — trotzdem fortfahren
                            </button>
                        </div>
                    }

                    <div class="d-flex justify-content-end mt-3">
                        <button class="btn btn-primary"
                                @onclick="ProceedToMasterData"
                                disabled="@(!CanProceedFromUpload)">
                            Weiter <i class="bi bi-arrow-right ms-1"></i>
                        </button>
                    </div>
                }
            </div>
        </div>
    }

    @* ═══════════════════════════════════════════════════════════════════════
       SCHRITT 2: Stammdaten-Zuordnung
       ═══════════════════════════════════════════════════════════════════════ *@
    @if (_currentStep == MergeWizardStep.MasterDataResolution && _session != null)
    {
        <div class="card">
            <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                <span><i class="bi bi-people me-2"></i>Schritt 2 — Stammdaten zuordnen</span>
                <span class="badge @(_session.AllMasterDataResolved ? "bg-success" : "bg-warning text-dark")">
                    @_session.ResolvedMasterDataCount / @_session.TotalMasterDataCount zugeordnet
                </span>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-3">
                    Jeder importierte Eintrag muss zugeordnet werden, bevor Sie fortfahren können.
                    <strong>Keine Entscheidung wird gespeichert, bis Sie am Ende „Zusammenführen" klicken.</strong>
                </p>

                @* Personal *@
                @if (_session.PersonalItems.Any())
                {
                    <h5 class="mt-3 mb-2"><i class="bi bi-person me-1"></i>Personal (@_session.PersonalItems.Count)</h5>
                    @foreach (var item in _session.PersonalItems)
                    {
                        <MasterDataMergeItemCard Item="item"
                                                 OnDecisionChanged="() => OnMasterDataDecisionChanged()" />
                    }
                }

                @* Hunde *@
                @if (_session.DogItems.Any())
                {
                    <h5 class="mt-4 mb-2"><i class="bi bi-heart me-1"></i>Hunde (@_session.DogItems.Count)</h5>
                    @foreach (var item in _session.DogItems)
                    {
                        <MasterDataMergeItemCard Item="item"
                                                 OnDecisionChanged="() => OnMasterDataDecisionChanged()" />
                    }
                }

                @* Drohnen *@
                @if (_session.DroneItems.Any())
                {
                    <h5 class="mt-4 mb-2"><i class="bi bi-rocket me-1"></i>Drohnen (@_session.DroneItems.Count)</h5>
                    @foreach (var item in _session.DroneItems)
                    {
                        <MasterDataMergeItemCard Item="item"
                                                 OnDecisionChanged="() => OnMasterDataDecisionChanged()" />
                    }
                }

                @if (_session.TotalMasterDataCount == 0)
                {
                    <p class="text-muted fst-italic">Keine Stammdaten im Export-Paket.</p>
                }

                <div class="d-flex justify-content-between mt-4">
                    <button class="btn btn-outline-secondary" @onclick="() => GoToStep(MergeWizardStep.Upload)">
                        <i class="bi bi-arrow-left me-1"></i>Zurück
                    </button>
                    <button class="btn btn-primary"
                            @onclick="ProceedToOperationalData"
                            disabled="@(!_session.AllMasterDataResolved)">
                        Weiter <i class="bi bi-arrow-right ms-1"></i>
                    </button>
                </div>
            </div>
        </div>
    }

    @* ═══════════════════════════════════════════════════════════════════════
       SCHRITT 3: Operative Daten prüfen
       ═══════════════════════════════════════════════════════════════════════ *@
    @if (_currentStep == MergeWizardStep.OperationalDataReview && _session != null)
    {
        <div class="card">
            <div class="card-header fw-semibold">
                <i class="bi bi-clipboard-check me-2"></i>Schritt 3 — Operative Daten prüfen
            </div>
            <div class="card-body">

                @* Zusammenfassungszeile *@
                <div class="alert alert-info mb-3 small">
                    <strong>Vorschau:</strong>
                    @_session.TeamsToImport Teams,
                    @_session.NotesToImport Notizen,
                    @_session.SearchAreasToImport Gebiete,
                    @_session.NewMarkerCount Marker,
                    @_session.NewTrackSnapshotCount GPS-Tracks werden importiert.
                </div>

                @* Teams *@
                @if (_session.TeamItems.Any())
                {
                    <h5 class="mt-2 mb-2"><i class="bi bi-people me-1"></i>Teams</h5>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-3">
                            <thead>
                                <tr>
                                    <th>Importieren?</th>
                                    <th>Team</th>
                                    <th>Mitglieder</th>
                                    <th>Timer</th>
                                    <th>Konflikt</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var teamItem in _session.TeamItems)
                                {
                                    <tr class="@(teamItem.ShouldImport ? "" : "table-secondary text-muted")">
                                        <td>
                                            <div class="form-check form-switch mb-0">
                                                <input class="form-check-input" type="checkbox"
                                                       @bind="teamItem.ShouldImport" />
                                            </div>
                                        </td>
                                        <td>@teamItem.ImportedTeam.TeamName</td>
                                        <td>@string.Join(", ", teamItem.ResolvedMemberNames)</td>
                                        <td>@teamItem.ImportedTeam.ElapsedTime.ToString(@"hh\:mm\:ss")</td>
                                        <td>
                                            @if (teamItem.HasLocalConflict)
                                            {
                                                <span class="badge bg-warning text-dark">
                                                    <i class="bi bi-exclamation-triangle me-1"></i>ID-Konflikt
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @* Notizen *@
                @{
                    var _newNotes = _session?.NoteItems.Where(n => !n.IsAlreadyPresent).ToList() ?? new();
                    var _existingNotes = _session?.NoteItems.Where(n => n.IsAlreadyPresent).ToList() ?? new();
                }
                @if (_session?.NoteItems.Any() == true)
                {
                    <h5 class="mt-3 mb-2">
                        <i class="bi bi-chat-left-text me-1"></i>Notizen / Funksprüche
                    </h5>

                    @if (_newNotes.Any())
                    {
                        <div class="d-flex gap-2 mb-2 align-items-center">
                            <button class="btn btn-sm btn-outline-success"
                                    @onclick="() => BulkSelectNotes(true)">
                                Alle auswählen
                            </button>
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="() => BulkSelectNotes(false)">
                                Alle abwählen
                            </button>
                            <span class="text-muted small">
                                @_newNotes.Count(n => n.ShouldImport) / @_newNotes.Count neue Notizen ausgewählt
                            </span>
                        </div>

                        <div class="note-preview-list" style="max-height: 300px; overflow-y: auto;">
                            @foreach (var noteItem in _newNotes)
                            {
                                <div class="d-flex align-items-start gap-2 mb-2 p-2 border rounded @(noteItem.ShouldImport ? "" : "opacity-50")">
                                    <input type="checkbox" class="form-check-input mt-1"
                                           @bind="noteItem.ShouldImport" />
                                    <div>
                                        <span class="text-muted small me-2">
                                            @noteItem.Note.Timestamp.ToString("dd.MM. HH:mm")
                                        </span>
                                        <span class="badge bg-secondary small me-1">
                                            @noteItem.Note.SourceTeamName
                                        </span>
                                        @noteItem.Note.Text
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    @if (_existingNotes.Any())
                    {
                        <p class="text-muted small mt-2">
                            <i class="bi bi-check-circle me-1"></i>
                            @_existingNotes.Count Notizen bereits vorhanden — werden übersprungen.
                        </p>
                    }
                }

                @* Suchgebiete *@
                @if (_session.SearchAreaItems.Any())
                {
                    <h5 class="mt-3 mb-2"><i class="bi bi-map me-1"></i>Suchgebiete</h5>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-3">
                            <thead>
                                <tr>
                                    <th>Importieren?</th>
                                    <th>Name</th>
                                    <th>Status</th>
                                    <th>Konflikt / Aktion</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var areaItem in _session.SearchAreaItems)
                                {
                                    @if (areaItem.ConflictType == SearchAreaConflict.SameIdExists)
                                    {
                                        <tr class="table-secondary text-muted">
                                            <td><i class="bi bi-skip-forward text-muted"></i></td>
                                            <td>@areaItem.ImportedArea.Name</td>
                                            <td><span class="badge bg-secondary">Vorhanden</span></td>
                                            <td><small>Gleiche ID bereits lokal — übersprungen</small></td>
                                        </tr>
                                    }
                                    else if (areaItem.ConflictType == SearchAreaConflict.SameNameDifferentId)
                                    {
                                        <tr>
                                            <td>
                                                <div class="form-check form-switch mb-0">
                                                    <input class="form-check-input" type="checkbox"
                                                           @bind="areaItem.ShouldImport" />
                                                </div>
                                            </td>
                                            <td>@areaItem.ImportedArea.Name</td>
                                            <td><span class="badge bg-warning text-dark">Namenskonflikt</span></td>
                                            <td>
                                                @if (areaItem.ShouldImport)
                                                {
                                                    <select class="form-select form-select-sm"
                                                            @bind="areaItem.NameConflictResolution">
                                                        <option value="@SearchAreaNameConflictResolution.KeepBoth">Beide behalten</option>
                                                        <option value="@SearchAreaNameConflictResolution.Rename">Import umbenennen</option>
                                                        <option value="@SearchAreaNameConflictResolution.ReplaceLocal">Lokal ersetzen</option>
                                                    </select>
                                                }
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        <tr class="@(areaItem.ShouldImport ? "" : "table-secondary text-muted")">
                                            <td>
                                                <div class="form-check form-switch mb-0">
                                                    <input class="form-check-input" type="checkbox"
                                                           @bind="areaItem.ShouldImport" />
                                                </div>
                                            </td>
                                            <td>@areaItem.ImportedArea.Name</td>
                                            <td><span class="badge bg-success">Neu</span></td>
                                            <td></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @* GPS-Tracks / Marker *@
                @if (_session.NewTrackSnapshotCount > 0 || _session.NewMarkerCount > 0)
                {
                    <div class="alert alert-secondary small">
                        <i class="bi bi-geo-alt me-1"></i>
                        Additiv übernommen:
                        @_session.NewTrackSnapshotCount neue GPS-Tracks,
                        @_session.NewMarkerCount neue Karten-Marker.
                    </div>
                }

                <div class="d-flex justify-content-between mt-4">
                    <button class="btn btn-outline-secondary"
                            @onclick="() => GoToStep(MergeWizardStep.MasterDataResolution)">
                        <i class="bi bi-arrow-left me-1"></i>Zurück
                    </button>
                    <button class="btn btn-primary"
                            @onclick="() => GoToStep(MergeWizardStep.Confirmation)">
                        Weiter <i class="bi bi-arrow-right ms-1"></i>
                    </button>
                </div>
            </div>
        </div>
    }

    @* ═══════════════════════════════════════════════════════════════════════
       SCHRITT 4: Bestätigung
       ═══════════════════════════════════════════════════════════════════════ *@
    @if (_currentStep == MergeWizardStep.Confirmation && _session != null)
    {
        <div class="card">
            <div class="card-header fw-semibold">
                <i class="bi bi-check2-square me-2"></i>Schritt 4 — Zusammenführung bestätigen
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    <strong>Wichtiger Hinweis:</strong>
                    Die folgenden Änderungen werden atomar übernommen. Das Importieren ist jederzeit
                    mit einem einzigen Klick rückgängig machbar.
                </div>

                <h6 class="mt-3">Stammdaten</h6>
                <ul class="list-unstyled ms-3 small">
                    @foreach (var item in _session.PersonalItems.Concat(_session.DogItems).Concat(_session.DroneItems))
                    {
                        <li>
                            <i class="bi @GetDecisionIcon(item.Decision) me-1 @GetDecisionColor(item.Decision)"></i>
                            <strong>@item.DisplayName</strong>
                            <span class="text-muted">(@GetDecisionLabel(item))</span>
                        </li>
                    }
                </ul>

                <h6 class="mt-3">Operative Daten</h6>
                <ul class="list-unstyled ms-3 small">
                    <li>
                        <i class="bi bi-people me-1 text-success"></i>
                        @_session.TeamsToImport Teams werden hinzugefügt
                    </li>
                    <li>
                        <i class="bi bi-chat-left-text me-1 text-success"></i>
                        @_session.NotesToImport Notizen werden importiert
                    </li>
                    <li>
                        <i class="bi bi-map me-1 text-success"></i>
                        @_session.SearchAreasToImport Suchgebiete werden übernommen
                    </li>
                    <li>
                        <i class="bi bi-geo-alt me-1 text-info"></i>
                        @_session.NewMarkerCount Marker, @_session.NewTrackSnapshotCount GPS-Tracks (additiv)
                    </li>
                </ul>

                <div class="d-flex justify-content-between mt-4">
                    <button class="btn btn-outline-secondary"
                            @onclick="() => GoToStep(MergeWizardStep.OperationalDataReview)">
                        <i class="bi bi-arrow-left me-1"></i>Zurück
                    </button>
                    <button class="btn btn-success"
                            @onclick="ExecuteMergeAsync"
                            disabled="@_isLoading">
                        @if (_isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            <span>Wird zusammengeführt…</span>
                        }
                        else
                        {
                            <i class="bi bi-diagram-2 me-1"></i>
                            <span>Zusammenführen</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }

    @* ═══════════════════════════════════════════════════════════════════════
       SCHRITT 5: Ergebnis
       ═══════════════════════════════════════════════════════════════════════ *@
    @if (_currentStep == MergeWizardStep.Result && _session?.AppliedMerge != null)
    {
        var merge = _session.AppliedMerge;

        <div class="card border-success">
            <div class="card-header bg-success text-white fw-semibold">
                <i class="bi bi-check-circle me-2"></i>Zusammenführung abgeschlossen
            </div>
            <div class="card-body">
                <dl class="row small mb-3">
                    <dt class="col-sm-4">Teilgruppe</dt>
                    <dd class="col-sm-8">@merge.SubgroupName</dd>
                    <dt class="col-sm-4">Zeitpunkt</dt>
                    <dd class="col-sm-8">@merge.FormattedMergedAt</dd>
                    <dt class="col-sm-4">Teams importiert</dt>
                    <dd class="col-sm-8">@merge.TeamsAdded</dd>
                    <dt class="col-sm-4">Notizen importiert</dt>
                    <dd class="col-sm-8">@merge.NotesAdded</dd>
                    <dt class="col-sm-4">Gebiete importiert</dt>
                    <dd class="col-sm-8">@merge.SearchAreasAdded</dd>
                    <dt class="col-sm-4">Marker / Tracks</dt>
                    <dd class="col-sm-8">@merge.MarkersAdded Marker, @merge.TracksAdded Tracks</dd>
                    <dt class="col-sm-4">Neu erstellte Stammdaten</dt>
                    <dd class="col-sm-8">
                        @merge.PersonalCreated Personal,
                        @merge.DogsCreated Hunde,
                        @merge.DronesCreated Drohnen
                    </dd>
                </dl>

                @if (_revertSuccess)
                {
                    <div class="alert alert-info">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>
                        Zusammenführung wurde erfolgreich rückgängig gemacht.
                    </div>
                }
                else
                {
                    <div class="alert alert-secondary d-flex justify-content-between align-items-center">
                        <span>
                            <i class="bi bi-info-circle me-1"></i>
                            Diese Zusammenführung kann vollständig rückgängig gemacht werden.
                        </span>
                        <button class="btn btn-outline-danger btn-sm"
                                @onclick="RevertCurrentMergeAsync"
                                disabled="@_isLoading">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>Rückgängig
                        </button>
                    </div>
                }

                <button class="btn btn-primary" @onclick="NavigateBack">
                    <i class="bi bi-arrow-left me-1"></i>Zurück zum Einsatz
                </button>
            </div>
        </div>
    }
</div>

@* ────────────────────────────────────────────────────────────────────────────
   Inline-Komponente: Ein Stammdaten-Merge-Element mit Vorschlags-Radio-Buttons
   ──────────────────────────────────────────────────────────────────────────── *@

@code {
    [Parameter] public string? ArchivedEinsatzId { get; set; }

    // ── State ──
    private SubgroupMergeSession? _session;
    private MergeWizardStep _currentStep = MergeWizardStep.Upload;
    private bool _isLoading = false;
    private bool _einsatzNrMismatch = false;
    private string _errorMessage = string.Empty;
    private bool _revertSuccess = false;

    private readonly List<(int Number, string Label)> _steps = new()
    {
        (1, "Upload"),
        (2, "Stammdaten"),
        (3, "Daten prüfen"),
        (4, "Bestätigen"),
        (5, "Ergebnis")
    };

    // ── Lifecycle ──

    protected override void OnInitialized()
    {
        // ArchivedEinsatzId comes from route parameter; no async init needed
    }

    // ── Step 1: Upload ──

    private async Task HandleFileUploadAsync(InputFileChangeEventArgs e)
    {
        _errorMessage = string.Empty;
        _isLoading = true;
        StateHasChanged();

        try
        {
            using var ms = new System.IO.MemoryStream();
            await e.File.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(ms);
            var bytes = ms.ToArray();

            var packet = MergeService.ParseExportPacket(bytes);
            if (packet == null)
            {
                _errorMessage = "Die Datei konnte nicht gelesen werden. Bitte eine gültige .einsatz-export.json Datei hochladen.";
                return;
            }

            _session = await MergeService.CreateSessionAsync(packet, ArchivedEinsatzId);

            // EinsatzNummer-Prüfung
            var currentNr = ArchivedEinsatzId == null
                ? EinsatzService.CurrentEinsatz.EinsatzNummer
                : (await ArchivService.GetByIdAsync(ArchivedEinsatzId))?.EinsatzNummer ?? string.Empty;

            _einsatzNrMismatch = !string.IsNullOrEmpty(packet.EinsatzNummer) &&
                                  !string.IsNullOrEmpty(currentNr) &&
                                  !string.Equals(packet.EinsatzNummer, currentNr, StringComparison.OrdinalIgnoreCase);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fehler beim Einlesen der Datei: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void AcknowledgeMismatch()
    {
        if (_session != null)
            _session.EinsatzNrMismatchAcknowledged = true;
    }

    private bool CanProceedFromUpload =>
        _session?.Packet != null &&
        (!_einsatzNrMismatch || _session.EinsatzNrMismatchAcknowledged);

    private void ProceedToMasterData()
    {
        if (!CanProceedFromUpload) return;
        GoToStep(MergeWizardStep.MasterDataResolution);
    }

    // ── Step 2: Master Data ──

    private void OnMasterDataDecisionChanged()
    {
        if (_session != null)
            MergeService.RebuildIdRemapping(_session);
        StateHasChanged();
    }

    private void ProceedToOperationalData()
    {
        if (_session?.AllMasterDataResolved != true) return;
        GoToStep(MergeWizardStep.OperationalDataReview);
    }

    // ── Step 3: Operational Data ──

    private void BulkSelectNotes(bool select)
    {
        if (_session == null) return;
        foreach (var n in _session.NoteItems.Where(x => !x.IsAlreadyPresent))
            n.ShouldImport = select;
    }

    // ── Step 4: Confirmation & Execution ──

    private async Task ExecuteMergeAsync()
    {
        if (_session == null) return;
        _isLoading = true;
        _errorMessage = string.Empty;

        try
        {
            var historyEntry = await MergeService.ApplyMergeAsync(_session);
            _currentStep = MergeWizardStep.Result;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Zusammenführung fehlgeschlagen: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ── Step 5: Result / Revert ──

    private async Task RevertCurrentMergeAsync()
    {
        if (_session?.AppliedMerge == null) return;
        _isLoading = true;

        try
        {
            await MergeService.RevertMergeAsync(
                _session.AppliedMerge.MergeId,
                ArchivedEinsatzId);
            _revertSuccess = true;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Rückgängig fehlgeschlagen: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ── Navigation ──

    private void GoToStep(MergeWizardStep step)
    {
        _currentStep = step;
        if (_session != null)
            _session.CurrentStep = step;
    }

    private void NavigateBack()
    {
        if (!string.IsNullOrEmpty(ArchivedEinsatzId))
            Navigation.NavigateTo("/einsatz-archiv");
        else
            Navigation.NavigateTo("/einsatz-monitor");
    }

    // ── UI helpers ──

    private string GetStepClass(int stepNumber)
    {
        var current = (int)_currentStep;
        if (stepNumber == current) return "active";
        if (stepNumber < current) return "completed";
        return "";
    }

    private string GetConnectorClass(int stepNumber)
    {
        var current = (int)_currentStep;
        return stepNumber < current ? "completed" : "";
    }

    private static string SafeId(string? id) =>
        id is { Length: >= 8 } ? $"{id[..8]}…" : (id ?? "?");

    private static string GetDecisionIcon(MergeDecision d) => d switch
    {
        MergeDecision.LinkToExisting => "bi-link-45deg",
        MergeDecision.CreateNew => "bi-plus-circle",
        MergeDecision.Skip => "bi-x-circle",
        _ => "bi-question-circle"
    };

    private static string GetDecisionColor(MergeDecision d) => d switch
    {
        MergeDecision.LinkToExisting => "text-success",
        MergeDecision.CreateNew => "text-primary",
        MergeDecision.Skip => "text-secondary",
        _ => ""
    };

    private static string GetDecisionLabel(MasterDataMergeItem item) => item.Decision switch
    {
        MergeDecision.LinkToExisting => $"Verknüpft mit {SafeId(item.SelectedLocalId)}",
        MergeDecision.CreateNew => "Neu anlegen",
        MergeDecision.Skip => "Überspringen",
        _ => "Offen"
    };
}


