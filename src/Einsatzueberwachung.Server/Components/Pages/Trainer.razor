@page "/trainer"
@layout Layout.TrainerLayout
@rendermode InteractiveServer
@implements IDisposable

@using Einsatzueberwachung.Server.Training
@using Einsatzueberwachung.Domain.Interfaces


<PageTitle>Trainer-Modul</PageTitle>

@if (!_authChecked)
{
    <div class="trainer-dashboard">
        <section class="card trainer-card">
            <div class="card-body">
                <p class="mb-0 text-muted">Trainer-Authentifizierung wird geprueft...</p>
            </div>
        </section>
    </div>
}
else if (!_trainerAuthenticated)
{
    <div class="trainer-dashboard">
        <section class="card trainer-card trainer-login-card">
            <div class="card-body">
                <h2 class="h4 mb-2">Trainer-Login</h2>
                <p class="text-muted mb-3">Bitte Passwort eingeben, um den Trainerbereich zu oeffnen.</p>

                <div class="row g-2 align-items-end">
                    <div class="col-12 col-md-6 col-lg-5">
                        <label class="form-label">Trainer-Passwort</label>
                        <input class="form-control form-control-lg"
                               type="password"
                               autocomplete="current-password"
                               @bind="_trainerPassword"
                               @bind:event="oninput"
                               @onkeydown="HandleLoginKeyDown"
                               placeholder="Passwort eingeben" />
                    </div>
                    <div class="col-12 col-md-auto">
                        <button type="button"
                                class="btn btn-primary btn-lg"
                                disabled="@_trainerLoginBusy"
                                @onclick="LoginTrainerAsync">
                            <i class="bi bi-unlock-fill me-1"></i>Anmelden
                        </button>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(_trainerAccessStatus))
                {
                    <div class="alert @(_trainerAccessError ? "alert-danger" : "alert-success") mt-3 mb-0">@_trainerAccessStatus</div>
                }
            </div>
        </section>
    </div>
}
else
{
<div class="trainer-dashboard">

    @* ── Tab-Navigation ──────────────────────────────────────────────── *@
    <nav class="trainer-tabs mb-3">
        <button class="trainer-tab @(_activeTab == "start" ? "active" : string.Empty)"
                type="button" @onclick='() => _activeTab = "start"'>
            <i class="bi bi-play-circle me-1"></i>Uebungsstart
        </button>
        <button class="trainer-tab @(_activeTab == "aktuell" ? "active" : string.Empty)"
                type="button" @onclick='() => _activeTab = "aktuell"'
                disabled="@(_selectedExercise is null)">
            <i class="bi bi-activity me-1"></i>Aktuell
            @if (_selectedExercise is not null && _selectedExercise.Status == "open")
            {
                <span class="trainer-tab-badge">●</span>
            }
        </button>
        <button class="trainer-tab @(_activeTab == "abschluss" ? "active" : string.Empty)"
                type="button" @onclick='() => _activeTab = "abschluss"'
                disabled="@(_selectedExercise is null)">
            <i class="bi bi-flag me-1"></i>Abschluss
        </button>
    </nav>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="alert @(_statusError ? "alert-danger" : "alert-success") alert-dismissible mb-3">
            @_statusMessage
            <button type="button" class="btn-close" @onclick='() => _statusMessage = string.Empty'></button>
        </div>
    }

    @* ══════════════════════════════════════════════════════════════════════
         TAB 1 — ÜBUNGSSTART
    ══════════════════════════════════════════════════════════════════════════ *@
    @if (_activeTab == "start")
    {
    <section class="trainer-grid">
        <article class="card trainer-card">
            <div class="card-body">
                <h2 class="h5 mb-3"><i class="bi bi-collection me-2"></i>Neue Uebung erstellen</h2>

                <div class="row g-2">
                    <div class="col-12 col-lg-4">
                        <label class="form-label">Lagevorlage</label>
                        <select class="form-select" @bind="SelectedScenarioId">
                            @foreach (var template in ScenarioTemplates)
                            {
                                <option value="@template.Id">@template.Title (@template.Category)</option>
                            }
                        </select>
                    </div>
                    <div class="col-12 col-lg-3">
                        <label class="form-label">Uebungsname (optional)</label>
                        <input class="form-control" @bind="_newExerciseName" placeholder="Automatisch wenn leer" />
                    </div>
                    <div class="col-6 col-lg-2">
                        <label class="form-label">Dauer (Min)</label>
                        <input class="form-control" type="number" min="1" max="480" @bind="_newExerciseDurationMinutes" placeholder="z.B. 60" />
                    </div>
                    <div class="col-6 col-lg-3 d-flex align-items-end">
                        <button class="btn btn-success w-100" type="button" @onclick="CreateExerciseAsync" disabled="@_busy">
                            <i class="bi bi-play-fill me-1"></i>Uebung starten
                        </button>
                    </div>
                </div>

                <div class="trainer-briefing mt-3">
                    <h3 class="h6 mb-2"><i class="bi bi-file-text me-1"></i>Lage-Briefing fuer Teilnehmer</h3>
                    <p class="mb-2">@SelectedScenario.Briefing</p>
                    <div class="small fw-semibold mb-1">Entscheidungspunkte:</div>
                    <ul class="mb-0 small">
                        @foreach (var decision in SelectedScenario.DecisionPrompts)
                        {
                            <li>@decision</li>
                        }
                    </ul>
                </div>

                <div class="d-flex flex-wrap gap-2 mt-3">
                    <button class="btn btn-outline-primary" type="button" @onclick="PrepareStartMaskAsync" disabled="@_busy">
                        <i class="bi bi-ui-checks me-1"></i>Maske "Neuer Einsatz" vorfuellen
                    </button>
                    <a class="btn btn-outline-secondary" href="/einsatz-start" target="_blank" rel="noopener noreferrer">
                        <i class="bi bi-box-arrow-up-right me-1"></i>Teilnehmer-Startmaske oeffnen
                    </a>
                </div>
            </div>
        </article>

        <article class="card trainer-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h5 mb-0"><i class="bi bi-clock-history me-2"></i>Uebungsauswahl</h2>
                    <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="ReloadExercisesAsync">
                        <i class="bi bi-arrow-repeat"></i>
                    </button>
                </div>

                <label class="form-label">Laufende / abgeschlossene Uebung</label>
                <select class="form-select" @bind="SelectedExerciseId">
                    <option value="">-- Bitte waehlen --</option>
                    @foreach (var exercise in _exercises)
                    {
                        <option value="@exercise.Id">
                            @exercise.CreatedAtUtc.ToLocalTime().ToString("dd.MM HH:mm") — @exercise.Name
                            (@(exercise.Status == "open" ? "laufend" : "beendet"))
                        </option>
                    }
                </select>

                @if (_selectedExercise is not null)
                {
                    <div class="trainer-briefing mt-3">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <div class="fw-semibold">@_selectedExercise.Name</div>
                                <div class="small text-muted">@_selectedExercise.CreatedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>
                            </div>
                            @if (_selectedExercise.Status == "open")
                            {
                                <span class="badge text-bg-success">Laufend</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Beendet</span>
                            }
                        </div>
                    </div>

                    @if (_selectedExercise.Status == "open")
                    {
                        <button class="btn btn-primary mt-3 w-100" type="button" @onclick='() => _activeTab = "aktuell"'>
                            <i class="bi bi-activity me-1"></i>Zur laufenden Uebung wechseln
                        </button>
                    }
                }
            </div>
        </article>
    </section>
    }

    @* ══════════════════════════════════════════════════════════════════════
         TAB 2 — AKTUELL
    ══════════════════════════════════════════════════════════════════════════ *@
    @if (_activeTab == "aktuell")
    {
    @if (_selectedExercise is null)
    {
        <div class="alert alert-info">Bitte zuerst unter <strong>Uebungsstart</strong> eine Uebung auswaehlen oder starten.</div>
    }
    else
    {
    @* Timer-Leiste *@
    <section class="card trainer-card mb-3">
        <div class="card-body py-2">
            <div class="d-flex flex-wrap align-items-center gap-4">
                <div>
                    <div class="small text-muted">Laufzeit</div>
                    <div class="fs-3 fw-bold font-monospace">@GetElapsedDisplay()</div>
                </div>
                @if (_selectedExercise.PlannedDurationMinutes.HasValue)
                {
                    var remaining = GetRemainingTime();
                    var isWarning = remaining.HasValue && remaining.Value.TotalMinutes <= 5 && remaining.Value.TotalSeconds > 0;
                    var isExpired = remaining.HasValue && remaining.Value.TotalSeconds <= 0;
                    <div>
                        <div class="small text-muted">Verbleibend (@_selectedExercise.PlannedDurationMinutes Min)</div>
                        <div class="fs-3 fw-bold font-monospace @(isExpired ? "text-danger" : isWarning ? "text-warning" : "text-success")">
                            @(isExpired ? "ABGELAUFEN" : remaining?.ToString(@"hh\:mm\:ss") ?? "--:--:--")
                        </div>
                    </div>
                    @if (isWarning && !isExpired)
                    {
                        <div class="alert alert-warning py-1 mb-0 small">
                            <i class="bi bi-hourglass-split me-1"></i><strong>Weniger als 5 Minuten!</strong> Abschluss vorbereiten.
                        </div>
                    }
                    @if (isExpired)
                    {
                        <div class="alert alert-danger py-1 mb-0 small">
                            <i class="bi bi-alarm-fill me-1"></i><strong>Uebungszeit abgelaufen.</strong>
                        </div>
                    }
                }
                @if (_selectedExercise.EscalationLevel > 0)
                {
                    <div class="ms-auto">
                        <span class="badge fs-6 @GetEscalationBadgeClass(_selectedExercise.EscalationLevel)">
                            <i class="bi bi-exclamation-triangle-fill me-1"></i>Eskalation Stufe @_selectedExercise.EscalationLevel
                        </span>
                    </div>
                }
            </div>
        </div>
    </section>

    <div class="row g-3">
        @* Linke Spalte: Live-Teams + Trainer-Update *@
        <div class="col-12 col-md-5 col-xl-5">
            <div class="card trainer-card mb-3 h-auto">
                <div class="card-body">
                    <h2 class="h6 mb-2"><i class="bi bi-people-fill me-1"></i>Live-Teams</h2>
                    @if (LiveTeams.Count == 0)
                    {
                        <p class="text-muted small mb-0">Noch keine Teams angelegt.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead><tr><th>Team</th><th>Status</th><th>Funktion</th><th>Gebiet</th></tr></thead>
                                <tbody>
                                    @foreach (var team in LiveTeams)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@team.TeamName</td>
                                            <td>
                                                @if (team.IsRunning)
                                                { <span class="badge text-bg-success">Laufend</span> }
                                                else if (team.IsPausing)
                                                { <span class="badge text-bg-warning">Pause</span> }
                                                else
                                                { <span class="badge text-bg-secondary">Bereit</span> }
                                            </td>
                                            <td class="small">@(team.IsDroneTeam ? "Drohne" : team.IsSupportTeam ? "Support" : "Hund")</td>
                                            <td class="small">@(string.IsNullOrWhiteSpace(team.SearchAreaName) ? "—" : team.SearchAreaName)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <div class="card trainer-card mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                        <h2 class="h6 mb-0"><i class="bi bi-broadcast-pin me-1"></i>Live-Funk & Notizen</h2>
                        <div class="btn-group btn-group-sm" role="group" aria-label="Kommunikationsfilter">
                            <button type="button" class="btn @(_commFilter == "alle" ? "btn-primary" : "btn-outline-primary")" @onclick='() => SetCommFilter("alle")'>Alle</button>
                            <button type="button" class="btn @(_commFilter == "funk" ? "btn-primary" : "btn-outline-primary")" @onclick='() => SetCommFilter("funk")'>Funk</button>
                            <button type="button" class="btn @(_commFilter == "notiz" ? "btn-primary" : "btn-outline-primary")" @onclick='() => SetCommFilter("notiz")'>Notizen</button>
                        </div>
                    </div>

                    @if (_teamJoinReactions.Count > 0)
                    {
                        <div class="trainer-team-reaction-box mb-2">
                            <div class="small fw-semibold mb-1">Sofortreaktion fuer neue Teams</div>
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var reaction in _teamJoinReactions.Take(3))
                                {
                                    <button class="btn btn-warning btn-sm"
                                            type="button"
                                            @onclick="@(() => SendQuickReactionAsync(reaction))"
                                            disabled="@_busy">
                                        <i class="bi bi-send-fill me-1"></i>@reaction.TeamName: Startsignal senden
                                    </button>
                                }
                            </div>
                        </div>
                    }

                    @if (_liveComms.Count == 0)
                    {
                        <p class="text-muted small mb-0">Noch keine Funksprueche oder Notizen vorhanden.</p>
                    }
                    else
                    {
                        <ul class="trainer-comm-list mb-0">
                            @foreach (var note in _liveComms.Take(20))
                            {
                                <li>
                                    <div class="d-flex align-items-start justify-content-between gap-2">
                                        <div>
                                            <div class="small text-muted">@note.Timestamp.ToLocalTime().ToString("HH:mm:ss") · @GetSourceLabel(note)</div>
                                            <div class="small fw-semibold">@note.Text</div>
                                        </div>
                                        <div class="d-flex gap-1">
                                            <span class="badge @(IsRadio(note) ? "text-bg-primary" : "text-bg-secondary")">@(IsRadio(note) ? "Funk" : "Notiz")</span>
                                            <button class="btn btn-outline-secondary btn-sm"
                                                    type="button"
                                                    title="Antwort fuer dieses Team vorbereiten"
                                                    @onclick="@(() => PrepareReplyForNote(note))">
                                                <i class="bi bi-reply-fill"></i>
                                            </button>
                                        </div>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>

            <div class="card trainer-card">
                <div class="card-body">
                    <h2 class="h6 mb-2"><i class="bi bi-send me-1"></i>Trainer-Update senden</h2>
                    <div class="row g-2">
                        <div class="col-6">
                            <select class="form-select form-select-sm" @bind="_entryType">
                                <option value="lage">&#128225; Lageupdate (Funk)</option>
                                <option value="funk">&#128225; Funkspruch</option>
                                <option value="feedback">&#128221; Rueckmeldung (Notiz)</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <select class="form-select form-select-sm" @bind="_entryParticipantName">
                                <option value="">-- kein Team --</option>
                                @foreach (var team in LiveTeams)
                                { <option value="@team.TeamName">@team.TeamName</option> }
                                @foreach (var simTeam in SelectedScenario.SimulatedTeams)
                                { <option value="@simTeam">@simTeam</option> }
                            </select>
                        </div>
                        <div class="col-12">
                            <textarea class="form-control form-control-sm" rows="2" @bind="_entryText"
                                      placeholder="Lageupdate / Funkspruch / Rueckmeldung an Teilnehmer..."></textarea>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-2">
                        <button class="btn btn-primary btn-sm" type="button" @onclick="AddTrainerEntryAsync" disabled="@_busy">
                            <i class="bi bi-send-fill me-1"></i>Senden
                        </button>
                    </div>

                    @* Vorschlaege *@
                    <div class="mt-3">
                        <div class="small text-muted mb-2">Schnellauswahl:</div>
                        <div class="d-flex flex-wrap gap-1">
                            @foreach (var suggestion in GetFeedbackSuggestions().Take(8))
                            {
                                <button class="btn btn-outline-secondary btn-sm"
                                        type="button"
                                        @onclick="@(() => ApplyFeedbackSuggestion(suggestion.Text, suggestion.Type, suggestion.TeamName))">
                                    <span class="badge text-bg-light border me-1" style="font-size:0.6rem">@suggestion.TypeLabel</span>@suggestion.Text[..Math.Min(35, suggestion.Text.Length)]@(suggestion.Text.Length > 35 ? "…" : string.Empty)
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Rechte Spalte: Eskalation + Stressoren + Zeitgesteuerte Events *@
        <div class="col-12 col-md-7 col-xl-7">
            <div class="card trainer-card mb-3">
                <div class="card-body">
                    <h2 class="h6 mb-2"><i class="bi bi-exclamation-triangle me-1"></i>Eskalationsstufen</h2>
                    <div class="d-flex flex-wrap gap-2 mb-2">
                        <button class="btn btn-sm @(_selectedExercise.EscalationLevel == 0 ? "btn-secondary" : "btn-outline-secondary")"
                                type="button" @onclick="@(() => SetEscalationLevelAsync(0))" disabled="@_busy">
                            Keine
                        </button>
                        <button class="btn btn-sm @(_selectedExercise.EscalationLevel == 1 ? "btn-warning text-dark" : "btn-outline-warning")"
                                type="button" @onclick="@(() => SetEscalationLevelAsync(1))" disabled="@_busy">
                            <i class="bi bi-exclamation-triangle me-1"></i>Stufe 1 — Erhoehter Bedarf
                        </button>
                        <button class="btn btn-sm @(_selectedExercise.EscalationLevel == 2 ? "btn-danger" : "btn-outline-danger")"
                                type="button" @onclick="@(() => SetEscalationLevelAsync(2))" disabled="@_busy">
                            <i class="bi bi-exclamation-triangle-fill me-1"></i>Stufe 2 — Kritisch
                        </button>
                        <button class="btn btn-sm @(_selectedExercise.EscalationLevel == 3 ? "btn-dark" : "btn-outline-dark")"
                                type="button" @onclick="@(() => SetEscalationLevelAsync(3))" disabled="@_busy">
                            <i class="bi bi-alarm-fill me-1"></i>Stufe 3 — Vollalarm
                        </button>
                    </div>
                    <div class="small text-muted">
                        <strong>1:</strong> Suche ausgeweitet, Ressourcencheck ·
                        <strong>2:</strong> RD alarmieren, 10-Min-Rhythmus ·
                        <strong>3:</strong> Vollalarm, ueberortliche Fuehrung
                    </div>
                </div>
            </div>

            <div class="card trainer-card mb-3">
                <div class="card-body">
                    <h2 class="h6 mb-2"><i class="bi bi-lightning me-1"></i>Stressoren</h2>
                    @foreach (var category in StressorCatalog)
                    {
                        <div class="mb-2">
                            <div class="small text-muted fw-semibold mb-1">@category.Category</div>
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var stressor in category.Items)
                                {
                                    <button class="btn btn-outline-secondary btn-sm"
                                            type="button"
                                            @onclick="@(() => FireStressorAsync(stressor))"
                                            disabled="@_busy">
                                        <i class="bi bi-lightning-fill me-1"></i>@stressor[..Math.Min(40, stressor.Length)]@(stressor.Length > 40 ? "…" : string.Empty)
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="card trainer-card">
                <div class="card-body">
                    <h2 class="h6 mb-2"><i class="bi bi-clock me-1"></i>Zeitgesteuerte Lageupdates</h2>
                    <div class="row g-2 mb-2">
                        <div class="col-4 col-lg-2">
                            <input class="form-control form-control-sm" type="number" min="1" max="480"
                                   @bind="_schedDelay" placeholder="Min" title="Nach X Minuten ausloesen" />
                        </div>
                        <div class="col-4 col-lg-2">
                            <select class="form-select form-select-sm" @bind="_schedType">
                                <option value="funk">Funk</option>
                                <option value="lage">Lage</option>
                            </select>
                        </div>
                        <div class="col-12 col-lg-6">
                            <input class="form-control form-control-sm" @bind="_schedText" placeholder="Text des Ereignisses..." />
                        </div>
                        <div class="col-4 col-lg-2 d-flex align-items-end">
                            <button class="btn btn-primary btn-sm w-100" type="button" @onclick="AddScheduledEventAsync" disabled="@_busy">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </div>
                    </div>
                    @if (_selectedExercise.ScheduledEvents.Count == 0)
                    {
                        <p class="text-muted small mb-0">Noch keine Events geplant.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead><tr><th>Min</th><th>Typ</th><th>Text</th><th>Status</th><th></th></tr></thead>
                                <tbody>
                                    @foreach (var ev in _selectedExercise.ScheduledEvents.OrderBy(e => e.DelayMinutes))
                                    {
                                        <tr class="@(ev.IsFired ? "table-secondary text-muted" : string.Empty)">
                                            <td>@ev.DelayMinutes</td>
                                            <td><span class="badge @(ev.EventType == "lage" ? "text-bg-info" : "text-bg-primary")">@ev.EventType</span></td>
                                            <td class="small">@ev.Text[..Math.Min(50, ev.Text.Length)]@(ev.Text.Length > 50 ? "…" : string.Empty)</td>
                                            <td>
                                                @if (ev.IsFired)
                                                { <span class="badge text-bg-success">@ev.FiredAtUtc!.Value.ToLocalTime().ToString("HH:mm")</span> }
                                                else
                                                {
                                                    var triggerAt = _selectedExercise.CreatedAtUtc.ToLocalTime() + TimeSpan.FromMinutes(ev.DelayMinutes);
                                                    <span class="badge text-bg-secondary">@triggerAt.ToString("HH:mm")</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!ev.IsFired)
                                                {
                                                    <button class="btn btn-sm btn-outline-danger" type="button"
                                                            @onclick="@(() => RemoveScheduledEventAsync(ev.Id))" disabled="@_busy">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    }
    }

    @* ══════════════════════════════════════════════════════════════════════
         TAB 3 — ABSCHLUSS
    ══════════════════════════════════════════════════════════════════════════ *@
    @if (_activeTab == "abschluss")
    {
    @if (_selectedExercise is null)
    {
        <div class="alert alert-info">Bitte zuerst unter <strong>Uebungsstart</strong> eine Uebung auswaehlen.</div>
    }
    else
    {
    <div class="row g-3">
        @* Linke Spalte: Teilnehmer-Entscheidungen + Beenden *@
        <div class="col-12 col-md-5 col-xl-5">
            @if (_selectedExercise.Status == "open")
            {
            <div class="card trainer-card mb-3">
                <div class="card-body">
                    <h2 class="h6 mb-2"><i class="bi bi-diagram-3 me-1"></i>Teilnehmer-Entscheidung protokollieren</h2>
                    <div class="row g-2">
                        <div class="col-12 col-md-6">
                            <input class="form-control form-control-sm" @bind="_decisionParticipantName" placeholder="Teilnehmer / Team" />
                        </div>
                        <div class="col-12 col-md-6">
                            <input class="form-control form-control-sm" @bind="_decisionCategory" placeholder="Kategorie (z.B. Taktik)" />
                        </div>
                        <div class="col-12">
                            <input class="form-control form-control-sm" @bind="_decisionText" placeholder="Entscheidung beschreiben..." />
                        </div>
                        <div class="col-12">
                            <textarea class="form-control form-control-sm" rows="2" @bind="_decisionRationale"
                                      placeholder="Begruendung (optional)..."></textarea>
                        </div>
                    </div>
                    <button class="btn btn-primary btn-sm mt-2" type="button" @onclick="AddParticipantDecisionAsync" disabled="@_busy">
                        <i class="bi bi-check-lg me-1"></i>Entscheidung speichern
                    </button>
                </div>
            </div>
            }

            <div class="card trainer-card border-danger">
                <div class="card-body">
                    <h2 class="h6 mb-2"><i class="bi bi-flag me-1"></i>Uebung abschliessen</h2>
                    @if (_selectedExercise.Status == "open")
                    {
                        <p class="small text-muted mb-3">
                            Nach dem Abschluss wird die Uebung archiviert und alle Teilnehmer erhalten eine Benachrichtigung.
                        </p>
                        <label class="form-label small">Abschluss-Kommentar / Trainer-Feedback</label>
                        <textarea class="form-control form-control-sm mb-2" rows="4" @bind="_endSummary"
                                  placeholder="z.B. Alle Lernziele erreicht. Team Alpha zeigte gute Kommunikation, EL hat Ressourcenplanung optimierungswuerdig..."></textarea>
                        <button class="btn btn-danger w-100" type="button" @onclick="ShowEndExerciseConfirm" disabled="@_busy">
                            <i class="bi bi-flag-fill me-1"></i>Uebung beenden und archivieren
                        </button>
                    }
                    else
                    {
                        <div class="alert alert-secondary mb-0">
                            <i class="bi bi-check-circle me-1"></i>
                            Uebung wurde am @_selectedExercise.CompletedAtUtc?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") beendet.
                        </div>
                    }
                </div>
            </div>
        </div>

        @* Rechte Spalte: Verlauf / Timeline *@
        <div class="col-12 col-md-7 col-xl-7">
            <div class="card trainer-card">
                <div class="card-body">
                    <h2 class="h6 mb-2"><i class="bi bi-list-ul me-1"></i>Verlauf der Simulation</h2>
                    @{
                        var timeline = BuildTimeline(_selectedExercise);
                    }
                    @if (timeline.Count == 0)
                    {
                        <p class="text-muted small mb-0">Noch keine Eintraege vorhanden.</p>
                    }
                    else
                    {
                        <ul class="trainer-log-list mb-0">
                            @foreach (var line in timeline)
                            {
                                <li>
                                    <span class="trainer-log-time">@line.TimeLabel</span>
                                    <span class="trainer-log-text">
                                        <span class="badge @GetTimelineKindBadge(line.Kind) me-1">@line.Kind</span>
                                        @line.Text
                                    </span>
                                    @if (!string.IsNullOrWhiteSpace(line.Source))
                                    {
                                        <span class="badge text-bg-secondary ms-1">@line.Source</span>
                                    }
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>
    }
    }

</div>
}

@if (_showEndExerciseConfirm)
{
    <div class="global-warning-overlay" @onclick="CancelEndExercise">
        <div class="global-warning-popup" @onclick:stopPropagation="true">
            <div class="global-warning-header" style="background: var(--bs-danger, #dc3545);">
                <h4 class="mb-0"><i class="bi bi-flag-fill me-2"></i>Uebung wirklich beenden?</h4>
            </div>
            <div class="global-warning-body">
                <p class="mb-3">Die Uebung <strong>@_selectedExercise?.Name</strong> wird als abgeschlossen markiert und der aktuelle Einsatz wird archiviert.</p>
                <label class="form-label">Abschluss-Kommentar (optional)</label>
                <textarea class="form-control" rows="3" @bind="_endSummary" placeholder="z.B. Uebung erfolgreich, alle Lernziele erreicht..."></textarea>
            </div>
            <div class="global-warning-footer d-flex gap-2">
                <button class="btn btn-danger" type="button" @onclick="ConfirmEndExerciseAsync" disabled="@_busy">
                    <i class="bi bi-flag-fill me-1"></i>Uebung beenden
                </button>
                <button class="btn btn-secondary" type="button" @onclick="CancelEndExercise">Abbrechen</button>
            </div>
        </div>
    </div>
}
