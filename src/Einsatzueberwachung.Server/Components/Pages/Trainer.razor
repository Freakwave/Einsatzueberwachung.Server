    {
        "lage" => "text-bg-info",
        "funk" => "text-bg-primary",
        "feedback" => "text-bg-success",
        "stressor" => "text-bg-danger",
        "eskalation" => "text-bg-warning text-dark",
        _ when kind.StartsWith("entscheidung") => "text-bg-secondary",
        _ => "text-bg-secondary"
    };

