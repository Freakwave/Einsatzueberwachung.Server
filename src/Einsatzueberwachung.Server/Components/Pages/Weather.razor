@page "/wetter"
@rendermode InteractiveServer

@inject IEinsatzService EinsatzService
@inject IWeatherService WeatherService

<PageTitle>Wetter</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <h1 class="mb-1"><i class="bi bi-cloud-sun me-2"></i>Wetter & Flugwetter</h1>
            <p class="text-muted mb-0">Daten vom Deutschen Wetterdienst (DWD)</p>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <div class="input-group">
                <InputText class="form-control" @bind-Value="_address" placeholder="Ort eingeben" />
                <button class="btn btn-success" @onclick="LoadWeatherAsync">Wetter abrufen</button>
                <button class="btn btn-outline-secondary" @onclick="LoadWeatherAsync">
                    <i class="bi bi-arrow-clockwise me-1"></i>Aktualisieren
                </button>
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="card">
            <div class="card-body text-muted">Lade Wetterdaten...</div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="alert alert-warning">@_errorMessage</div>
    }
    else if (_weather is null)
    {
        <p class="text-muted">Keine Wetterdaten verfuegbar.</p>
    }
    else
    {
        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
            <span class="badge text-bg-secondary">Stand: @_lastLoadedLocal.ToString("dd.MM.yyyy HH:mm")</span>
            <span class="badge text-bg-info">Ort: @_address</span>
            @if (_flugwetter is not null)
            {
                <span class="badge @_flugwetter.GetKategorieBadgeClass()">@_flugwetter.Kategorie</span>
            }
        </div>

        <div class="row g-3">
            <div class="col-12 col-xl-5">
                <div class="card h-100">
                    <div class="card-header"><i class="bi bi-thermometer-half me-2"></i>Aktuelles Wetter</div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="weather-metric-tile">
                                    <div class="weather-metric-value">@_weather.TemperaturFormatiert</div>
                                    <div class="weather-metric-label">Temperatur</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="weather-metric-tile">
                                    <div class="weather-metric-value">@_weather.WindFormatiert</div>
                                    <div class="weather-metric-label">Wind</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="weather-metric-tile">
                                    <div class="weather-metric-value">@_weather.LuftfeuchtigkeitFormatiert</div>
                                    <div class="weather-metric-label">Luftfeuchtigkeit</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="weather-metric-tile">
                                    <div class="weather-metric-value">@_weather.Luftdruck.ToString("0") hPa</div>
                                    <div class="weather-metric-label">Luftdruck</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="weather-metric-tile">
                                    <div class="weather-metric-value">@_weather.Sichtweite.ToString("0.0") km</div>
                                    <div class="weather-metric-label">Sichtweite</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="weather-metric-tile">
                                    <div class="weather-metric-value">@_weather.Wetterlage</div>
                                    <div class="weather-metric-label">Wetterlage</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-7">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-airplane-engines me-2"></i>Flugbedingungen im Detail</span>
                        @if (_flugwetter is not null)
                        {
                            <span class="badge @_flugwetter.GetKategorieBadgeClass()">@_flugwetter.GetKategorieText()</span>
                        }
                    </div>
                    <div class="card-body">
                        @if (_flugwetter is null)
                        {
                            <p class="text-muted mb-0">Keine Flugwetterdaten verfuegbar.</p>
                        }
                        else
                        {
                            <div class="weather-detail-list">
                                <div class="weather-detail-row"><span>Windgeschwindigkeit</span><strong>@_flugwetter.Windgeschwindigkeit.ToString("0") km/h</strong></div>
                                <div class="weather-detail-row"><span>Windboeen</span><strong>@_flugwetter.Windboeen.ToString("0") km/h</strong></div>
                                <div class="weather-detail-row"><span>Sichtweite</span><strong>@_flugwetter.Sichtweite.ToString("0.0") km</strong></div>
                                <div class="weather-detail-row"><span>Wolkenuntergrenze</span><strong>@_flugwetter.WolkenuntergrenzeFuss ft</strong></div>
                                <div class="weather-detail-row"><span>QNH</span><strong>@_flugwetter.QNH hPa</strong></div>
                            </div>

                            <div class="alert @(_flugwetter.IstDrohnenflugMoeglich ? "alert-success" : "alert-danger") mt-3 mb-0">
                                <strong>@(_flugwetter.IstDrohnenflugMoeglich ? "Drohnenflug moeglich" : "Drohnenflug kritisch"):</strong>
                                @_flugwetter.DrohnenflugHinweis
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @if (_forecast?.StundenVorhersage?.Length > 0)
        {
            <div class="card mt-4">
                <div class="card-header">
                    <strong>Stundenvorhersage</strong>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm mb-0 align-middle weather-hourly-table">
                        <thead>
                            <tr>
                                <th>Zeit</th>
                                <th>Temp</th>
                                <th>Wind</th>
                                <th>Niederschlag</th>
                                <th>Wetter</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _forecast.StundenVorhersage.Take(12))
                            {
                                <tr>
                                    <td>@item.Zeitpunkt.ToLocalTime().ToString("HH:mm")</td>
                                    <td>@item.Temperatur.ToString("0.0") °C</td>
                                    <td>@item.Windgeschwindigkeit.ToString("0") km/h</td>
                                    <td>@item.Niederschlag.ToString("0.0") mm</td>
                                    <td>@item.Wetterlage</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>

@code {
    private string _address = string.Empty;
    private bool _loading;
    private WeatherData? _weather;
    private WeatherForecast? _forecast;
    private FlugwetterData? _flugwetter;
    private DateTime _lastLoadedLocal;
    private string _errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _address = EinsatzService.CurrentEinsatz.Einsatzort;
        await LoadWeatherAsync();
    }

    private async Task LoadWeatherAsync()
    {
        _errorMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(_address))
        {
            _errorMessage = "Bitte einen Ort angeben.";
            return;
        }

        _loading = true;

        try
        {
            var coordinates = await WeatherService.GeocodeAddressAsync(_address);
            if (coordinates is null)
            {
                _weather = null;
                _forecast = null;
                _flugwetter = null;
                _errorMessage = "Der Ort konnte nicht aufgeloest werden.";
                return;
            }

            _weather = await WeatherService.GetCurrentWeatherAsync(coordinates.Value.Latitude, coordinates.Value.Longitude);
            _forecast = await WeatherService.GetForecastAsync(coordinates.Value.Latitude, coordinates.Value.Longitude);
            _flugwetter = await WeatherService.GetFlugwetterAsync(coordinates.Value.Latitude, coordinates.Value.Longitude);

            if (_weather is null)
            {
                _errorMessage = "Aktuell konnten keine Wetterdaten geladen werden.";
            }
            else
            {
                _lastLoadedLocal = DateTime.Now;
            }
        }
        finally
        {
            _loading = false;
        }
    }
}
